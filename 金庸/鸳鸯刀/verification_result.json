    "dialogues.json": {
      "total": 17,
      "grounded": 9,
      "weak": 8,
      "unverified": 0,
      "sample_issues": [
        {
          "dialogue": {
            "speaker": "char_zhou_wei_xin",
            "speaker_name": "周威信",
            "listener": null,
            "text": "江湖上有言道：'小心天下去得，莽撞寸步难行。'",
            "tone": "陈述",
            "chapter": 1,
            "line_start": 26,
            "line_end": 26
          },
          "status": "weak",
          "reason": "key phrase matched: 莽撞寸步"
        },
        {
          "dialogue": {
            "speaker": "char_gai_yi_ming",
            "speaker_name": "盖一鸣",
            "listener": "char_zhou_wei_xin",
            "text": "我大哥给你改了个匪号，叫作'铁鞭拜八方'！我大哥料事如神，言之有理。",
            "tone": "嘲讽",
            "chapter": 1,
            "line_start": 30,
            "line_end": 30
          },
          "status": "weak",
          "reason": "prefix match only"
        },
        {
          "dialogue": {
            "speaker": "char_xiao_zhong_hui",
            "speaker_name": "萧中慧",
            "listener": "char_gai_yi_ming",
            "text": "你都瞧了我七八眼啦，还说一眼也不多瞧呢？",
            "tone": "调侃",
            "chapter": 1,
            "line_start": 100,
            "line_end": 100
          },
          "status": "weak",
          "reason": "found in wider context of cited lines"
        },
        {
          "dialogue": {
            "speaker": "char_xiao_yao_zi",
            "speaker_name": "逍遥子",
            "listener": "char_xiao_zhong_hui",
            "text": "这是'中渎穴'，点之腿膝麻痹，四肢软瘫，还不给我束手待缚？",
            "tone": "陈述",
            "chapter": 1,
            "line_start": 112,
            "line_end": 112
          },
          "status": "weak",
          "reason": "key phrase matched: 中渎穴"
        },
        {
          "dialogue": {
            "speaker": "char_xiao_zhong_hui",
            "speaker_name": "萧中慧",
            "listener": "char_xiao_yao_zi",
            "text": "痨病鬼，你点的是什么穴？中渎穴不在这里，偏左了两寸。",
            "tone": "嘲讽",
            "chapter": 1,
            "line_start": 112,
            "line_end": 112
          },
          "status": "weak",
          "reason": "prefix match only"
        },
        {
          "dialogue": {
            "speaker": "char_zhang_biao_shi",
            "speaker_name": "张镖师",
            "listener": "char_zhou_wei_xin",
            "text": "每天晚上你睡着了，便尽说梦话，翻来覆去总是说：'鸳鸯刀，鸳鸯刀！这一次送去北京，可不能出半点岔子，得了鸳鸯刀，无敌于天下⋯⋯'",
            "tone": "调侃",
            "chapter": 1,
            "line_start": 138,
            "line_end": 138
          },
          "status": "weak",
          "reason": "prefix match only"
        },
        {
          "dialogue": {
            "speaker": "char_zhuo_tian_xiong",
            "speaker_name": "卓天雄",
            "listener": "char_yuan_guan_nan",
            "text": "姓袁的，这对刀便在这里，有本事不妨来拿去。你装腔作势，瞒得过别人，可乘早别在卓天雄眼前现世。",
            "tone": "冷酷",
            "chapter": 1,
            "line_start": 264,
            "line_end": 266
          },
          "status": "weak",
          "reason": "prefix match only"
        },
        {
          "dialogue": {
            "speaker": "char_yuan_guan_nan",
            "speaker_name": "袁冠南",
            "listener": "char_zhuo_tian_xiong",
            "text": "好啊！小爷有好生之德，不愿用这'腐骨穿心膏'。你既无礼，说不得，只好叫你尝尝滋味。",
            "tone": "冷酷",
            "chapter": 1,
            "line_start": 284,
            "line_end": 284
          },
          "status": "weak",
          "reason": "prefix match only"
        }
      ]
    }
