  "events": [
    {
      "id": "evt_16_01",
      "name": "杨康与欧阳克夜间密谈",
      "participants": ["char_yang_kang", "char_ou_yang_ke", "char_guo_jing", "char_huang_rong"],
      "location": "loc_bao_ying",
      "description": "郭靖黄蓉从程府出来后，见到杨康牵马与欧阳克路旁低语，隐约听到'岳飞''临安府''我爹爹'等词。欧阳克拱手离去后，郭靖出声招呼杨康，黄蓉暗嘱郭靖假装没瞧见。三人回到祠堂歇息。"
    },
    {
      "id": "evt_16_02",
      "name": "金兵追杀蒙古使者，郭靖出手击退追兵",
      "participants": ["char_guo_jing", "char_huang_rong", "char_tuo_lei", "char_zhe_bie", "char_bo_er_hu", "char_qian_qian_jian", "char_shen_qing_gang", "char_wu_qing_lie"],
      "location": "loc_liu_shi_zong_ci",
      "description": "半夜马蹄声起，三骑蒙古马被十六名金兵追赶。哲别、博尔忽、拖雷爬上旗斗居高射箭。郭靖凭哲别硬箭辨识身份，先掷金兵尸身撞倒砍旗杆的追兵，再以神龙摆尾击碎钱青健肩胛骨，抓住吴青烈枪头将其扯倒，踢飞沈青刚长刀，师兄弟互撞昏迷。众金兵四散溃逃，哲别博尔忽从旗斗射死三名金兵。"
    },
    {
      "id": "evt_16_03",
      "name": "白雕到来与拖雷话别",
      "participants": ["char_guo_jing", "char_huang_rong", "char_tuo_lei", "char_zhe_bie", "char_bo_er_hu", "char_hua_zheng"],
      "location": "loc_liu_shi_zong_ci",
      "description": "白雕从空中飞来认出主人，黄蓉欲摸反被啄。拖雷说明奉父命南下联合宋朝夹攻金国，华筝托他带雕给郭靖并捎话要郭靖尽早回蒙古。郭靖闻华筝之名心中茫然但不敢多想。拖雷因有将令不能延搁，与郭靖拥抱作别上马离去。"
    },
    {
      "id": "evt_16_04",
      "name": "杨康暗中救走完颜洪烈",
      "participants": ["char_yang_kang", "char_wan_yan_hong_lie"],
      "location": "loc_liu_shi_zong_ci",
      "description": "郭靖与金兵相斗之际，杨康在黑暗中看出完颜洪烈身形，情急之下纵身而出抱住完颜洪烈，低声说'父王是康儿别作声'，将其抱至祠堂后院西厢房棺材房中藏匿。完颜洪烈感念杨康救命之恩，杨康内心交战但终究不忍下手报仇，许诺辅佐大业，完颜洪烈以李渊李世民比喻二人关系。"
    },
    {
      "id": "evt_16_05",
      "name": "搜寻完颜洪烈，发现金盔与穆念慈",
      "participants": ["char_guo_jing", "char_huang_rong", "char_yang_kang", "char_mu_nian_ci"],
      "location": "loc_liu_shi_zong_ci",
      "description": "黄蓉献计等待完颜洪烈。郭靖在祠堂后院发现金盔，断定完颜洪烈必在祠堂内。搜查时黄蓉察觉杨康故意拖延，西厢房灰尘中的足迹暴露了完颜洪烈藏身处。棺材中传出女人声，开棺后发现被欧阳克点穴囚禁的穆念慈。完颜洪烈此前已趁机逃走。"
    },
    {
      "id": "evt_16_06",
      "name": "穆念慈怒斥杨康，割发明志",
      "participants": ["char_mu_nian_ci", "char_yang_kang", "char_huang_rong", "char_guo_jing"],
      "location": "loc_liu_shi_zong_ci",
      "description": "穆念慈在棺中听到了杨康与完颜洪烈的密谈，醒来后斥责杨康认贼作父、要灭父母之邦。杨康老羞成怒反诬穆念慈失贞，穆念慈急怒攻心口喷鲜血。杨康转身出墙逃走。郭靖将朱聪从梅超风处得来的匕首（外包九阴真经秘要薄革）交给穆念慈。穆念慈以匕首割断青丝抛于风中，头也不回离去。黄蓉初次识得人间愁苦。"
    },
    {
      "id": "evt_16_07",
      "name": "丐帮设宴与南下赴桃花岛",
      "participants": ["char_guo_jing", "char_huang_rong", "char_li_sheng", "char_cheng_daxiaojie"],
      "location": "loc_bao_ying",
      "description": "黎生等丐帮群雄设宴向洪七公及郭黄道贺，程大小姐亲自烧菜备酒。宴会尽欢后，郭黄商议先到嘉兴给六位师父留信，然后雇船赴桃花岛。途经嘉兴留信醉仙楼，到舟山后黄蓉以匕首逼舟子改道驶向桃花岛。"
    },
    {
      "id": "evt_16_08",
      "name": "郭靖桃花岛迷路，夜闻箫声",
      "participants": ["char_guo_jing", "char_huang_yao_shi"],
      "location": "loc_tao_hua_dao",
      "description": "郭靖随黄蓉登岛后在花丛中迷失方向，小红马也走失。独自在花树中迷路至天黑，饥饿疲倦沉沉睡去。中夜被箫声惊醒，循箫声前行，在白花丛中见到冯氏墓碑，恭恭敬敬跪拜四拜。"
    },
    {
      "id": "evt_16_09",
      "name": "黄药师碧海潮生曲试探",
      "participants": ["char_huang_yao_shi", "char_guo_jing", "char_zhou_bo_tong"],
      "location": "loc_tao_hua_dao",
      "description": "箫声调子忽变柔靡万端后急促催舞，郭靖以内功心法抵御后不受影响。暗中发现一长发长须老人（周伯通）盘膝运功抵御箫声，气喘愈急痛苦难当。郭靖抢上按住其大椎穴助其镇定，黄药师在暗中怒骂'小畜生坏我大事'箫声突止。郭靖运用马钰所授内功心法，物我两忘直到天明。"
    },
    {
      "id": "evt_16_10",
      "name": "郭靖结识周伯通并义结金兰",
      "participants": ["char_guo_jing", "char_zhou_bo_tong"],
      "location": "loc_tao_hua_dao",
      "description": "天明后长发老人自报家门为周伯通，王重阳师弟，被困桃花岛十五年。二人交谈甚欢，周伯通试郭靖掌力后惊讶他如何能抵御碧海潮生曲。周伯通主动提议结拜为兄弟，郭靖推辞辈分不合但周伯通执意不拘礼法，二人向天誓盟结为兄弟。黄药师老仆送来酒菜，聋哑仆人的惨状令郭靖震惊。"
    },
    {
      "id": "evt_16_11",
      "name": "周伯通讲述九阴真经来历",
      "participants": ["char_zhou_bo_tong", "char_guo_jing"],
      "location": "loc_tao_hua_dao",
      "description": "周伯通详述黄裳故事：北宋文官黄裳奉旨校阅万寿道藏，由此悟武成为高手；奉旨剿灭明教，杀伤多名高手后被其亲友围攻，全家被杀；黄裳隐居深山四十余年钻研破解各家绝招，出山后仇人尽皆老死；黄裳感慨之余将毕生心血写下两卷《九阴真经》。经书现世后引发百余年争夺，丧命英雄好汉前前后后逾百人。"
    },
    {
      "id": "evt_16_12",
      "name": "周伯通讲述华山论剑往事",
      "participants": ["char_zhou_bo_tong", "char_guo_jing", "char_wang_chong_yang", "char_ou_yang_feng", "char_hong_qi_gong", "char_huang_yao_shi", "char_duan_huang_ye"],
      "location": "loc_tao_hua_dao",
      "description": "周伯通讲述五绝在华山绝顶论剑七天七夜，王重阳夺得天下第一与九阴真经。王重阳将经书压于蒲团下石板下不练其中功夫，武林因此安静一时。王重阳临终安排教中大事，嘱门下不可习练经中武功，欲焚毁经书但终不忍。"
    },
    {
      "id": "evt_16_13",
      "name": "王重阳灵前风波：欧阳锋抢经",
      "participants": ["char_zhou_bo_tong", "char_ou_yang_feng", "char_wang_chong_yang"],
      "location": "loc_tao_hua_dao",
      "description": "周伯通讲述王重阳停灵当晚，全真七子分头迎敌，欧阳锋突然出现在树顶，轻功绝顶，以火烧道观要挟要经书。周伯通与欧阳锋在树顶拆了三四十招，终于技逊一筹被掌击肩头跌下树。欧阳锋冲入灵堂抢经，王重阳突然用掌力震破灵柩从棺中出手击退欧阳锋。"
    },
    {
      "id": "evt_16_14",
      "name": "郭靖悟出王重阳藏经深意",
      "participants": ["char_guo_jing", "char_zhou_bo_tong"],
      "location": "loc_tao_hua_dao",
      "description": "周伯通让郭靖猜王重阳为何将经书藏而不练，郭靖猜出：王重阳武功已天下第一无需再练，华山论剑是为救天下英雄免于互相斫杀，而非为己。周伯通惊叹郭靖心地忠厚胸襟博大，感叹师兄若在必会喜欢传其武功，继而伏石痛哭想念师兄。"
    },
    {
      "id": "evt_16_15",
      "name": "黄药师暗中观察喝彩",
      "participants": ["char_huang_yao_shi", "char_guo_jing"],
      "location": "loc_tao_hua_dao",
      "description": "郭靖评论黄药师为人时，花树外突然有人喝道'小畜生还有眼光'，正是黄药师在暗中观察。周伯通告知郭靖那是黄老邪，其花树依诸葛亮八阵图遗法种植，在其中东窜西钻别人再也找不到。"
    }
  ],
  "dialogues": [
    {
      "speaker": "char_guo_jing",
      "listener": "char_tuo_lei",
      "text": "贤弟，我在这里。",
      "tone": "惊喜",
      "chapter": 16
    },
    {
      "speaker": "char_guo_jing",
      "listener": "char_zhe_bie",
      "text": "上面是哲别师傅、拖雷义弟、博尔忽师傅吗？我是郭靖。",
      "tone": "急切呼唤",
      "chapter": 16
    },
    {
      "speaker": "char_tuo_lei",
      "listener": "char_guo_jing",
      "text": "爹爹命我去见宋朝皇帝，相约南北出兵，夹攻金国。妹子说或许我能和你遇上，要我带了雕儿来给你。她猜得对，这可不是遇上了吗？",
      "tone": "欢喜",
      "chapter": 16
    },
    {
      "speaker": "char_wan_yan_hong_lie",
      "listener": "char_yang_kang",
      "text": "康儿，你怎么叫我'父王'，不叫'爹'了？",
      "tone": "慈爱中带疑惑",
      "chapter": 16
    },
    {
      "speaker": "char_yang_kang",
      "listener": "char_wan_yan_hong_lie",
      "text": "爹，孩儿必当辅你以成大业。",
      "tone": "热血沸腾",
      "chapter": 16
    },
    {
      "speaker": "char_wan_yan_hong_lie",
      "listener": "char_yang_kang",
      "text": "我做李渊，你做李世民罢。",
      "tone": "大喜",
      "chapter": 16
    },
    {
      "speaker": "char_mu_nian_ci",
      "listener": "char_yang_kang",
      "text": "姓杨的，恭喜你日后富贵不可限量啊。",
      "tone": "冷讽",
      "chapter": 16
    },
    {
      "speaker": "char_mu_nian_ci",
      "listener": "char_yang_kang",
      "text": "你认贼作父，还可说是顾念旧情，一时心里转不过来。哪知你竟存非份之想，还要灭了自己的父母之邦，这……这……",
      "tone": "厉声斥责",
      "chapter": 16
    },
    {
      "speaker": "char_mu_nian_ci",
      "listener": "char_yang_kang",
      "text": "谁是你的妹子？别碰我！",
      "tone": "怒喝",
      "chapter": 16
    },
    {
      "speaker": "char_yang_kang",
      "listener": "char_mu_nian_ci",
      "text": "你落入那人手中这许多天，给他搂也搂过了，抱也抱过了，还能是玉洁冰清么？",
      "tone": "恶毒",
      "chapter": 16
    },
    {
      "speaker": "char_huang_rong",
      "listener": "char_yang_kang",
      "text": "杨大哥，你别胡言乱道，穆姊姊要是喜欢他，那坏蛋怎会将她点了穴道，又放在棺材里？",
      "tone": "仗义执言",
      "chapter": 16
    },
    {
      "speaker": "char_huang_rong",
      "listener": "char_mu_nian_ci",
      "text": "靖哥哥的匕首在我这里，杨大哥的现下交给了你。姊姊，这是命中注定的缘份，一时吵闹算不了甚么，你可别伤心，我和爹爹也常吵架呢。",
      "tone": "温柔安慰",
      "chapter": 16
    },
    {
      "speaker": "char_zhou_bo_tong",
      "listener": "char_guo_jing",
      "text": "小朋友，你我结义为兄弟如何？",
      "tone": "兴致勃勃",
      "chapter": 16
    },
    {
      "speaker": "char_zhou_bo_tong",
      "listener": "char_guo_jing",
      "text": "你既不是全真派门下，也不用罗里罗唆的叫我甚么前辈不前辈的，就叫我周伯通好啦。",
      "tone": "爽快不拘",
      "chapter": 16
    },
    {
      "speaker": "char_zhou_bo_tong",
      "listener": "char_guo_jing",
      "text": "兄弟你怎么如此没出息？《九阴真经》中所载的武功，奇幻奥秘，神妙之极。学武之人只要学到了一点半滴，岂能不为之神魂颠倒？纵然因此而招致杀身之祸，那又算得了甚么？",
      "tone": "激动训斥",
      "chapter": 16
    },
    {
      "speaker": "char_zhou_bo_tong",
      "listener": "char_guo_jing",
      "text": "世上聪明人本来是有的，不过这种人你若是遇上了，多半非倒大霉不可。",
      "tone": "感慨",
      "chapter": 16
    },
    {
      "speaker": "char_zhou_bo_tong",
      "listener": "char_guo_jing",
      "text": "他们五人约定在华山论剑，谁的武功天下第一，经书就归谁所有。",
      "tone": "得意叙述",
      "chapter": 16
    },
    {
      "speaker": "char_zhou_bo_tong",
      "listener": "char_guo_jing",
      "text": "前辈毕生心血，岂能毁于我手？水能载舟，亦能覆舟，要看后人如何善用此经了。只是凡我门下，决不可习练经中武功，以免旁人说我夺经是怀有私心。",
      "tone": "庄重转述王重阳遗言",
      "chapter": 16
    },
    {
      "speaker": "char_guo_jing",
      "listener": "char_zhou_bo_tong",
      "text": "王真人的武功既已天下第一，他再练得更强，仍也不过是天下第一。他到华山论剑，倒不是为了争天下第一的名头，而是要得这部《九阴真经》。他要得到经书，也不是为了要练其中的功夫，却是相救普天下的英雄豪杰，教他们免得互相斫杀，大家不得好死。",
      "tone": "沉思后恍然",
      "chapter": 16
    },
    {
      "speaker": "char_huang_yao_shi",
      "listener": "char_guo_jing",
      "text": "小畜生，坏我大事！",
      "tone": "怒骂",
      "chapter": 16
    },
    {
      "speaker": "char_huang_yao_shi",
      "listener": "char_guo_jing",
      "text": "小畜生还有眼光！",
      "tone": "暗中喝彩",
