  "events": [
    {
      "id": "evt_3_01",
      "name": "法华寺赌约",
      "participants": [
        "char_qiu_chu_ji",
        "char_ke_zhen_e",
        "char_zhu_cong",
        "char_han_bao_ju",
        "char_han_xiao_ying",
        "char_quan_jin_fa",
        "char_nan_xi_ren",
        "char_zhang_a_sheng"
      ],
      "location": "loc_fa_hua_si",
      "description": "焦木圆寂后八人在僧房聚集，丘处机深责鲁莽向七怪赔罪，柯镇恶不肯罢休要留其长剑，丘处机以激将法提出十八年赌约：各自教导郭杨遗孤，十八年后醉仙楼让孩子比试武艺。七怪被激应允，丘处机扬长而去。"
    },
    {
      "id": "evt_3_02",
      "name": "韩宝驹追击段天德",
      "participants": [
        "char_han_bao_ju"
      ],
      "location": "loc_fa_hua_si",
      "description": "赌约定下后韩宝驹率先冲出山门，跨上追风黄名驹急去追赶段天德和李萍，但因段天德走水路而韩宝驹尽在旱道上搜寻，始终未能追到。"
    },
    {
      "id": "evt_3_03",
      "name": "段天德挟持李萍北逃",
      "participants": [
        "char_duan_tian_de",
        "char_li_ping",
        "char_han_bao_ju",
        "char_han_xiao_ying",
        "char_ke_zhen_e"
      ],
      "location": "loc_yang_zhou",
      "description": "段天德挟持李萍乘小船沿运河北逃，经扬州时被韩氏兄妹险些发现，又在山东利国驿差点暴露，李萍故意装疯留下形迹引追兵，段天德多次欲杀李萍未果。两人相打相骂一路北上至中都燕京。"
    },
    {
      "id": "evt_3_04",
      "name": "李萍雪地产子",
      "participants": [
        "char_li_ping",
        "char_guo_jing"
      ],
      "location": "loc_da_mo",
      "description": "段天德与李萍在中都燕京被金兵抓为脚夫北上，途中遭遇蒙古败兵冲散。李萍在大雪纷飞的沙漠中腹痛发作，伏倒沙丘后昏迷，半夜醒来发现胎儿已在患难中诞生。她咬断脐带，从死兵身上找到干粮食粮和皮裘，在雪地中挨过十余日后被蒙古牧民收留。"
    },
    {
      "id": "evt_3_05",
      "name": "铁木真大破泰亦赤兀部",
      "participants": [
        "char_tie_mu_zhen",
        "char_wo_kuo_tai",
        "char_cha_he_tai",
        "char_shu_chi",
        "char_tuo_lei",
        "char_hu_du_hu",
        "char_zhe_le_mi",
        "char_mu_hua_li",
        "char_chi_lao_wen",
        "char_hu_bi_lai",
        "char_su_bu_tai"
      ],
      "location": "loc_da_mo",
      "description": "铁木真率部与世仇泰亦赤兀部决战。铁木真登土山指挥，四路将领分头退却诱敌，忽都虎与者勒米率三千精兵死守土山。铁木真左颈中箭仍坚持指挥，者勒米单骑冲入敌阵夺回三杆黑纛。铁木真见敌势已衰举纛吹号，四路伏兵齐回冲杀，歼灭泰亦赤兀部大半。"
    },
    {
      "id": "evt_3_06",
      "name": "郭靖牧羊目睹大战",
      "participants": [
        "char_guo_jing"
      ],
      "location": "loc_da_mo",
