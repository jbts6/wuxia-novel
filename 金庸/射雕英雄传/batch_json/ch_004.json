      "chapter": 4,
      "line_start": 607,
      "line_end": 607
    },
    {
      "speaker": "char_zhang_a_sheng",
      "speaker_name": "张阿生",
      "listener": null,
      "text": "是妖怪呢还是仇敌？",
      "tone": "低语",
      "chapter": 4,
      "line_start": 619,
      "line_end": 619
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "又问：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 629,
      "line_end": 629
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "韩小莹道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 629,
      "line_end": 629
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "柯镇恶低声道：",
      "tone": "低语",
      "chapter": 4,
      "line_start": 631,
      "line_end": 631
    },
    {
      "speaker": "char_ke_zhen_e",
      "speaker_name": "柯镇恶",
      "listener": null,
      "text": "韩小莹道：",
      "tone": "低语",
      "chapter": 4,
      "line_start": 631,
      "line_end": 631
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "柯镇恶道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 633,
      "line_end": 633
    },
    {
      "speaker": "char_ke_zhen_e",
      "speaker_name": "柯镇恶",
      "listener": null,
      "text": "韩小莹飞步奔到西北方，俯身一看，随即奔回，说道：",
      "tone": "焦急",
      "chapter": 4,
      "line_start": 633,
      "line_end": 633
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "柯镇恶低声道：",
      "tone": "低语",
      "chapter": 4,
      "line_start": 635,
      "line_end": 635
    },
    {
      "speaker": "char_ke_zhen_e",
      "speaker_name": "柯镇恶",
      "listener": null,
      "text": "将骷髅头骨交给全金发，道：",
      "tone": "低语",
      "chapter": 4,
      "line_start": 635,
      "line_end": 635
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪吓了一跳，道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 641,
      "line_end": 641
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "柯镇恶道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 643,
      "line_end": 643
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "韩小莹急道：",
      "tone": "焦急",
      "chapter": 4,
      "line_start": 649,
      "line_end": 649
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "柯镇恶连连挥手，道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 651,
      "line_end": 651
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "韩宝驹怒道：",
      "tone": "愤怒",
      "chapter": 4,
      "line_start": 653,
      "line_end": 653
    },
    {
      "speaker": "char_han_bao_ju",
      "speaker_name": "韩宝驹",
      "listener": null,
      "text": "张阿生道：",
      "tone": "愤怒",
      "chapter": 4,
      "line_start": 653,
      "line_end": 653
    },
    {
      "speaker": "char_quan_jin_fa",
      "speaker_name": "全金发",
      "listener": null,
      "text": "那么咱们一起走。",
      "tone": "疑问",
      "chapter": 4,
      "line_start": 661,
      "line_end": 661
    },
    {
      "speaker": "char_nan_xi_ren",
      "speaker_name": "南希仁",
      "listener": null,
      "text": "有福共享，有难同当。",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 665,
      "line_end": 665
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "说到这里，神情严重，又道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 677,
      "line_end": 677
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "韩小莹低声道：",
      "tone": "低语",
      "chapter": 4,
      "line_start": 707,
      "line_end": 707
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 709,
      "line_end": 709
    },
    {
      "speaker": "char_han_xiao_ying",
      "speaker_name": "韩小莹",
      "listener": null,
      "text": "这二人叫什么名字？",
      "tone": "疑问",
      "chapter": 4,
      "line_start": 715,
      "line_end": 715
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "韩小莹道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 719,
      "line_end": 719
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 721,
      "line_end": 721
    },
    {
      "speaker": "char_zhu_cong",
      "speaker_name": "朱聪",
      "listener": null,
      "text": "韩小莹道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 721,
      "line_end": 721
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 723,
      "line_end": 723
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "乌龙取水",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 817,
      "line_end": 817
    },
    {
      "speaker": "char_mei_chao_feng",
      "speaker_name": "铁尸",
      "listener": null,
      "text": "你是谁，到这里干什么？",
      "tone": "厉声",
      "chapter": 4,
      "line_start": 833,
      "line_end": 833
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "曲池穴",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 847,
      "line_end": 847
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "白露横江",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 849,
      "line_end": 849
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "曲池穴",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 853,
      "line_end": 853
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "他纵高窜低，铁扇晃动，连打敌人头顶",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 881,
      "line_end": 881
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "、咽喉",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 881,
      "line_end": 881
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "两穴，接着又点她小腹",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 881,
      "line_end": 881
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "、后心",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 881,
      "line_end": 881
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "两穴，霎时之间，连试了十多个穴道，要查知她对身上那一部门防护特别周密，那便是",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 881,
      "line_end": 881
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "倏的一抓，抓住了他手腕。朱聪大惊，幸而他动念奇速，手法伶俐，不待她爪子入肉，手掌翻动，已将铁扇塞入了她掌心，叫道：",
      "tone": "惊讶",
      "chapter": 4,
      "line_start": 885,
      "line_end": 885
    },
    {
      "speaker": "char_zhu_cong",
      "speaker_name": "朱聪",
      "listener": null,
      "text": "快下来打！",
      "tone": "焦急",
      "chapter": 4,
      "line_start": 905,
      "line_end": 905
    },
    {
      "speaker": "char_zhu_cong",
      "speaker_name": "朱聪",
      "listener": null,
      "text": "七步之前！",
      "tone": "激动",
      "chapter": 4,
      "line_start": 911,
      "line_end": 911
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "梅超风仰天长笑，叫道：",
      "tone": "轻笑",
      "chapter": 4,
      "line_start": 933,
      "line_end": 933
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "柯镇恶道：",
