      "line_start": 515,
      "line_end": 515
    },
    {
      "speaker": "char_tuo_lei",
      "speaker_name": "拖雷",
      "listener": null,
      "text": "叔叔，再教。",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 519,
      "line_end": 519
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "转头问郭靖道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 521,
      "line_end": 521
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 531,
      "line_end": 531
    },
    {
      "speaker": "char_zhu_cong",
      "speaker_name": "朱聪",
      "listener": null,
      "text": "韩宝驹道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 531,
      "line_end": 531
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "七怪用江南土话纷纷议论。韩小莹向两孩子挥挥手道：",
