      "chapter": 4,
      "line_start": 511,
      "line_end": 511
    },
    {
      "speaker": "char_tuo_lei",
      "speaker_name": "拖雷",
      "listener": null,
      "text": "好极啦，你再教。",
      "tone": "陈述",
