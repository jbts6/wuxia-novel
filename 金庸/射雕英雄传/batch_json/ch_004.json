    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 543,
      "line_end": 543
    },
    {
      "speaker": "char_zhu_cong",
      "speaker_name": "朱聪",
      "listener": null,
      "text": "南希仁道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 543,
      "line_end": 543
    },
    {
      "speaker": "char_nan_xi_ren",
      "speaker_name": "南希仁",
      "listener": null,
      "text": "韩小莹急道：",
      "tone": "焦急",
      "chapter": 4,
      "line_start": 543,
      "line_end": 543
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "南希仁微微一笑，道：",
      "tone": "轻笑",
      "chapter": 4,
      "line_start": 545,
      "line_end": 545
    },
    {
      "speaker": "char_zhang_a_sheng",
      "speaker_name": "张阿生",
      "listener": null,
      "text": "对，对！我几时又聪明过了？",
      "tone": "疑问",
      "chapter": 4,
      "line_start": 549,
      "line_end": 549
    },
    {
      "speaker": "char_zhu_cong",
      "speaker_name": "朱聪",
      "listener": null,
      "text": "且瞧他今晚敢不敢一个人上山来。",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 551,
      "line_end": 551
    },
    {
      "speaker": "char_han_bao_ju",
      "speaker_name": "韩宝驹",
      "listener": null,
      "text": "江南七怪威风一世，到头来却败在这臭道士手里！",
      "tone": "激动",
      "chapter": 4,
      "line_start": 557,
      "line_end": 557
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "张阿生道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 573,
      "line_end": 573
    },
    {
      "speaker": "char_zhang_a_sheng",
      "speaker_name": "张阿生",
      "listener": null,
      "text": "柯镇恶道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 573,
      "line_end": 573
    },
    {
      "speaker": "char_zhu_cong",
      "speaker_name": "朱聪",
      "listener": null,
      "text": "你瞧！",
      "tone": "激动",
      "chapter": 4,
      "line_start": 589,
      "line_end": 589
    },
    {
      "speaker": "char_han_xiao_ying",
      "speaker_name": "韩小莹",
      "listener": null,
      "text": "是吃人的山魈妖怪么？",
      "tone": "疑问",
      "chapter": 4,
      "line_start": 597,
      "line_end": 597
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "全金发沉吟道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 599,
      "line_end": 599
    },
    {
      "speaker": null,
      "speaker_name": "问",
      "listener": null,
      "text": "怎么排的？",
      "tone": "疑问",
      "chapter": 4,
      "line_start": 603,
      "line_end": 603
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "柯镇恶惊问：",
      "tone": "惊讶",
      "chapter": 4,
      "line_start": 605,
      "line_end": 605
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "全金发奇道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 607,
      "line_end": 607
    },
    {
      "speaker": "char_quan_jin_fa",
      "speaker_name": "全金发",
      "listener": null,
      "text": "柯镇恶不答他问话，急道：",
