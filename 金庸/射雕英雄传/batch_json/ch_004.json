      "line_start": 489,
      "line_end": 489
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "柯镇恶低沉了声音道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 489,
      "line_end": 489
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖小眼中闪出怒光，道：",
      "tone": "愤怒",
      "chapter": 4,
      "line_start": 491,
      "line_end": 491
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "柯镇恶道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 493,
      "line_end": 493
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖怔怔的发呆，无法回答。韩小莹道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 495,
      "line_end": 495
    },
    {
      "speaker": "char_tuo_lei",
      "speaker_name": "拖雷",
      "listener": null,
      "text": "你教我本事罢。",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 505,
      "line_end": 505
    },
    {
      "speaker": null,
      "speaker_name": "怒",
      "listener": null,
      "text": "你干么打我？",
      "tone": "愤怒",
      "chapter": 4,
      "line_start": 509,
      "line_end": 509
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "拖雷很是聪明，当即领悟，照式学了一遍，说道：",
