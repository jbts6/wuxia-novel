      "speaker_name": "拖雷",
      "listener": null,
      "text": "朱聪道：",
      "tone": "陈述",
      "chapter": 4,
      "line_start": 473,
      "line_end": 473
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "拖雷道：",
      "tone": "陈述",
      "chapter": 4,
