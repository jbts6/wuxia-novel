      "line_start": 330,
      "line_end": 330
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "梁子翁一怔，随即大喜，心想：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 330,
      "line_end": 330
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "又走近几步，道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 332,
      "line_end": 332
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
