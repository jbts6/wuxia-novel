      "chapter": 39,
      "line_start": 330,
      "line_end": 330
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "梁子翁一怔，随即大喜，心想：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 330,
      "line_end": 330
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "又走近几步，道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 332,
      "line_end": 332
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 332,
      "line_end": 332
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "郭靖说道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 338,
      "line_end": 338
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "梁子翁道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 338,
      "line_end": 338
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "双手猛出，突以大擒拿手扣住了他后颈",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 340,
      "line_end": 340
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "欧阳先生，你在干什么？",
      "tone": "激动",
      "chapter": 39,
      "line_start": 376,
      "line_end": 376
    },
    {
      "speaker": "char_ou_yang_feng",
      "speaker_name": "欧阳锋",
      "listener": null,
      "text": "那女子道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 418,
      "line_end": 418
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖听她口中说出",
      "tone": "激动",
      "chapter": 39,
      "line_start": 428,
      "line_end": 428
    },
    {
      "speaker": "char_ou_yang_feng",
      "speaker_name": "欧阳锋",
      "listener": null,
      "text": "说着抛下手中圆石，大踏步跨进洞去。黄蓉叫道：",
      "tone": "激动",
      "chapter": 39,
      "line_start": 432,
      "line_end": 432
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "欧阳锋连声怪笑，低声道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 434,
      "line_end": 434
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "心中激动，不由得全身发颤。黄蓉两手甩开，冷冷的道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 448,
      "line_end": 448
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖一怔，道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 450,
      "line_end": 450
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 450,
      "line_end": 450
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "迳自出洞。郭靖赶上去连连作揖，求道：",
      "tone": "恳求",
      "chapter": 39,
      "line_start": 452,
      "line_end": 452
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "黄蓉哼了一声，道：",
      "tone": "冷酷",
      "chapter": 39,
      "line_start": 454,
      "line_end": 454
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 462,
      "line_end": 462
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 462,
      "line_end": 462
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 478,
      "line_end": 478
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 484,
      "line_end": 484
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "黄蓉大怒，一张俏脸儿胀得通红，道：",
      "tone": "愤怒",
      "chapter": 39,
      "line_start": 486,
      "line_end": 486
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖见她始终不肯相谅，脸色苍白，叫道：",
      "tone": "激动",
      "chapter": 39,
      "line_start": 498,
      "line_end": 498
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 500,
      "line_end": 500
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "周伯通嘻嘻一笑，没法交代，只怕她出言怪责，要想个法儿哄她欢喜，说道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 538,
      "line_end": 538
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "不是他是谁？",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 542,
      "line_end": 542
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "多半是裘千仞那老儿来了，我这就去杀他。",
      "tone": "激动",
      "chapter": 39,
      "line_start": 562,
      "line_end": 562
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "妙极，妙极！",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 591,
      "line_end": 591
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖喜极而涕，说不出话来。黄蓉伸衣袖给他抹去泪水，笑道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 593,
      "line_end": 593
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 595,
      "line_end": 595
    },
    {
      "speaker": "char_zhou_bo_tong",
      "speaker_name": "周伯通",
      "listener": null,
      "text": "他虽将这四人制住，一时却也想不出处置之法，见靖蓉二人过来，说道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 603,
      "line_end": 603
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "周伯通大喜，连叫两声：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 609,
      "line_end": 609
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "好阿姨！",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 611,
      "line_end": 611
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "周伯通大喜，侧头一想，从身上又推下不少污垢，将解药倒在里面，搓成一颗颗小丸，交给丘处机道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 622,
      "line_end": 622
    },
    {
      "speaker": "char_qiu_chu_ji",
      "speaker_name": "丘处机",
      "listener": null,
      "text": "丘处机躬身答应。黄蓉笑道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 626,
      "line_end": 626
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "周伯通仰天大笑，忽见左侧高峰上白光闪动，显是兵刃为日光所映，叫道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 638,
      "line_end": 638
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "靖蓉二人抬起头来，闪光却已不见。周伯通只怕黄蓉追问他裘千仞之事，说道：",
      "tone": "疑问",
      "chapter": 39,
      "line_start": 640,
      "line_end": 640
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 664,
      "line_end": 664
    },
    {
      "speaker": "char_ou_yang_feng",
      "speaker_name": "欧阳锋",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 674,
      "line_end": 674
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 682,
      "line_end": 682
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 684,
      "line_end": 684
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "说着板起了脸。郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 686,
      "line_end": 686
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "往后我不知要生你多少气呢。",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 690,
      "line_end": 690
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖大喜，握住她双手，连说：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 694,
      "line_end": 694
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 696,
      "line_end": 696
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 710,
      "line_end": 710
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖点头道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 714,
      "line_end": 714
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "裘千仞笑道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 736,
      "line_end": 736
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "周伯通大叫：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 736,
      "line_end": 736
    },
    {
      "speaker": "char_qiu_qian_ren",
      "speaker_name": "裘千仞",
      "listener": null,
      "text": "郭靖待要跃出，黄蓉倚在他怀里，轻声道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 738,
      "line_end": 738
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "黄蓉站起身子，笑道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 744,
      "line_end": 744
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "周伯通见裘千仞双手各握一条昂头吐舌的毒蛇，吓得脚都软了，央求道：",
      "tone": "恳求",
      "chapter": 39,
      "line_start": 746,
      "line_end": 746
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "死啦，死啦！",
      "tone": "激动",
      "chapter": 39,
      "line_start": 754,
      "line_end": 754
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "这人背向月光，面目无法看清，裘千仞心中一凛，喝道：",
      "tone": "愤怒",
      "chapter": 39,
      "line_start": 760,
      "line_end": 760
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "周伯通一楞，急忙站起，只觉背上那冰冷之物又在乱跳，不禁尖声狂呼：",
      "tone": "焦急",
      "chapter": 39,
      "line_start": 766,
      "line_end": 766
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那人道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 768,
      "line_end": 768
    },
    {
      "speaker": "char_qiu_qian_ren",
      "speaker_name": "裘千仞",
      "listener": null,
      "text": "疯婆子，你尽缠着我干么？",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 786,
      "line_end": 786
    },
    {
      "speaker": "char_qiu_qian_ren",
      "speaker_name": "裘千仞",
      "listener": null,
      "text": "还我儿子的命来！",
      "tone": "激动",
      "chapter": 39,
      "line_start": 788,
      "line_end": 788
    },
    {
      "speaker": "char_qiu_qian_ren",
      "speaker_name": "裘千仞",
      "listener": null,
      "text": "锳姑道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 790,
      "line_end": 790
    },
    {
      "speaker": "char_ying_gu",
      "speaker_name": "锳姑",
      "listener": null,
      "text": "正欲飞奔下山，锳姑叫道：",
      "tone": "激动",
      "chapter": 39,
      "line_start": 808,
      "line_end": 808
    },
    {
      "speaker": "char_ying_gu",
      "speaker_name": "锳姑",
      "listener": null,
      "text": "周伯通一楞，道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 810,
      "line_end": 810
    },
    {
      "speaker": "char_ying_gu",
      "speaker_name": "锳姑",
      "listener": null,
      "text": "锳姑道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 810,
      "line_end": 810
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "锳姑却厉声叫道：",
      "tone": "愤怒",
      "chapter": 39,
      "line_start": 824,
      "line_end": 824
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "黄蓉也道：",
      "tone": "愤怒",
      "chapter": 39,
      "line_start": 824,
      "line_end": 824
    },
    {
      "speaker": "char_shu_sheng",
      "speaker_name": "书生",
      "listener": null,
      "text": "那书生道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 830,
      "line_end": 830
    },
    {
      "speaker": "char_shu_sheng",
      "speaker_name": "书生",
      "listener": null,
      "text": "裘千仞仰天打个哈哈，说道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 830,
      "line_end": 830
    },
    {
      "speaker": "char_qiu_qian_ren",
      "speaker_name": "裘千仞",
      "listener": null,
      "text": "洪七公道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 858,
      "line_end": 858
    },
    {
      "speaker": "char_qiu_qian_ren",
      "speaker_name": "裘千仞",
      "listener": null,
      "text": "裘千仞道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 858,
      "line_end": 858
    },
    {
      "speaker": "char_qiu_qian_ren",
      "speaker_name": "裘千仞",
      "listener": null,
      "text": "洪七公道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 860,
      "line_end": 860
    },
    {
      "speaker": "char_zhou_bo_tong",
      "speaker_name": "周伯通",
      "listener": null,
      "text": "周伯通自她出现，一直胆战心惊，给她这么迎面一喝，叫声：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 900,
      "line_end": 900
    },
    {
      "speaker": "char_ying_gu",
      "speaker_name": "锳姑",
      "listener": null,
      "text": "转身急向山下奔去。锳姑道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 902,
      "line_end": 902
    },
    {
      "speaker": "char_ying_gu",
      "speaker_name": "锳姑",
      "listener": null,
      "text": "我肚子痛，要拉屎。",
      "tone": "激动",
      "chapter": 39,
      "line_start": 904,
      "line_end": 904
    },
    {
      "speaker": "char_hong_qi_gong",
      "speaker_name": "洪七公",
      "listener": null,
      "text": "洪七公躬身道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 918,
      "line_end": 918
    },
    {
      "speaker": "char_yi_deng",
      "speaker_name": "一灯",
      "listener": null,
      "text": "一灯微笑道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 920,
      "line_end": 920
    },
    {
      "speaker": "char_yi_deng",
      "speaker_name": "一灯",
      "listener": null,
      "text": "明日论剑啊，大师怎么就走了？",
      "tone": "激动",
      "chapter": 39,
      "line_start": 922,
      "line_end": 922
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "黄蓉听他取笑自己，也吟道：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 934,
      "line_end": 934
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "黄蓉笑道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 940,
      "line_end": 940
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "想到此处，突然轻叫：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 946,
      "line_end": 946
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖忙问：",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 946,
      "line_end": 946
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "黄蓉微笑道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 948,
      "line_end": 948
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "洪七公笑道：",
      "tone": "欣喜",
      "chapter": 39,
      "line_start": 972,
      "line_end": 972
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "洪七公吞了一口馋涎，哼了一声，道：",
      "tone": "冷酷",
      "chapter": 39,
      "line_start": 990,
      "line_end": 990
    }
