      "line_start": 338,
      "line_end": 338
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "双手猛出，突以大擒拿手扣住了他后颈",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 340,
      "line_end": 340
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "和背心",
      "tone": "陈述",
      "chapter": 39,
      "line_start": 340,
      "line_end": 340
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "易筋锻骨章",
      "tone": "焦急",
      "chapter": 39,
      "line_start": 352,
      "line_end": 352
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "天柱",
