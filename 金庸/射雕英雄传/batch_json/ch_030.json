      "chapter": 30,
      "line_start": 402,
      "line_end": 402
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "一灯大师点头道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 404,
      "line_end": 404
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉细细瞧了几眼，笑道：",
