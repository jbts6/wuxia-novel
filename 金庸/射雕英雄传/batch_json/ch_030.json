      "line_end": 182
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 182,
      "line_end": 182
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那书生道：",
