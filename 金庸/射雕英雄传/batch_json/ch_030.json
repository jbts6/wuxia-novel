      "chapter": 30,
      "line_start": 394,
      "line_end": 394
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖取了出来。一灯看了，神色微变，低声道：",
      "tone": "低语",
      "chapter": 30,
      "line_start": 396,
      "line_end": 396
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉接过手来一看，就道：",
