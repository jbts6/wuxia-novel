      "chapter": 30,
      "line_start": 652,
      "line_end": 652
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 656,
      "line_end": 656
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "了一声。郭靖又道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 656,
      "line_end": 656
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 658,
      "line_end": 658
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖沉吟半晌道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 660,
      "line_end": 660
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 664,
      "line_end": 664
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 664,
      "line_end": 664
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉甚是得意，笑靥如花，忽然叹了口气道：",
      "tone": "轻笑",
      "chapter": 30,
      "line_start": 666,
      "line_end": 666
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "奇什么？",
      "tone": "疑问",
      "chapter": 30,
      "line_start": 670,
      "line_end": 670
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 674,
      "line_end": 674
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉奇道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 676,
      "line_end": 676
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "咦！怎么难为情起来啦？",
      "tone": "轻笑",
      "chapter": 30,
      "line_start": 678,
      "line_end": 678
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 682,
      "line_end": 682
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 684,
      "line_end": 684
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉喜道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 686,
      "line_end": 686
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉叹道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 696,
      "line_end": 696
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
