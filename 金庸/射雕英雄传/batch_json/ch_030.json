      "line_start": 410,
      "line_end": 410
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "心道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 420,
      "line_end": 420
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "一灯随手将经书揭开，将那幅画放在书旁，道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 422,
      "line_end": 422
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 424,
      "line_end": 424
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "的一声低呼，说道：",
      "tone": "惊讶",
      "chapter": 30,
      "line_start": 424,
      "line_end": 424
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "什么纸质一样？",
