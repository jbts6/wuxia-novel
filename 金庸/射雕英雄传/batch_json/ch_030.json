      "line_start": 702,
      "line_end": 702
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "什么？",
      "tone": "疑问",
      "chapter": 30,
      "line_start": 704,
      "line_end": 704
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 706,
      "line_end": 706
    },
    {
      "speaker": "char_huang_rong",
      "speaker_name": "黄蓉",
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 706,
