      "chapter": 30,
      "line_start": 406,
      "line_end": 406
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "一灯脸色微变，说道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 408,
      "line_end": 408
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉拉着他手臂道：",
