      "chapter": 30,
      "line_start": 754,
      "line_end": 754
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那农夫道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 756,
      "line_end": 756
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "亢龙有悔",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 760,
      "line_end": 760
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "阳池穴",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 764,
      "line_end": 764
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "兰花拂穴手",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 764,
