      "chapter": 30,
      "line_start": 390,
      "line_end": 390
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉料想其中必有蹊跷，回想当时情景，说道：",
      "tone": "陈述",
