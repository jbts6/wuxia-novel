      "chapter": 30,
      "line_start": 740,
      "line_end": 740
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉摇了摇头。郭靖又道：",
      "tone": "陈述",
