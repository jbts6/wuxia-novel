      "speaker_name": "郭靖",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 706,
      "line_end": 706
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉掩面不理。郭靖还未知觉，又问一句，黄蓉怒道：",
      "tone": "愤怒",
      "chapter": 30,
      "line_start": 714,
      "line_end": 714
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 726,
      "line_end": 726
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 726,
      "line_end": 726
    },
