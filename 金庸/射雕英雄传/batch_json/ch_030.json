      "line_start": 374,
      "line_end": 374
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 30,
      "line_start": 374,
      "line_end": 374
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "一灯问道：",
