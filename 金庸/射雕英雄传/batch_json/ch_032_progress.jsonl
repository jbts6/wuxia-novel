{"segment":10,"line_start":811,"line_end":900,"dialogues":[{"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":null,"text":"妙极！这可找对了人家。","tone":"激动","chapter":32,"line_start":824,"line_end":824},{"speaker":null,"speaker_name":null,"listener":null,"text":"众客一轰而起，乱成一团。主人大叫：","tone":"陈述","chapter":32,"line_start":830,"line_end":830},{"speaker":null,"speaker_name":"颤声","listener":null,"text":"女⋯⋯女大王⋯⋯好⋯⋯姑娘⋯⋯你要金银，立时⋯⋯马上取出献上，只求你饶我一条老命⋯⋯","tone":"恳求","chapter":32,"line_start":842,"line_end":842},{"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":null,"text":"又不是三岁小孩，好好儿坐也不会吗？","tone":"厉声","chapter":32,"line_start":854,"line_end":854},{"speaker":null,"speaker_name":null,"listener":null,"text":"主人结结巴巴的道：","tone":"陈述","chapter":32,"line_start":858,"line_end":858},{"speaker":null,"speaker_name":null,"listener":null,"text":"黄蓉笑道：","tone":"轻笑","chapter":32,"line_start":860,"line_end":860},{"speaker":null,"speaker_name":null,"listener":null,"text":"那主人神色尴尬，全身颤抖，只道：","tone":"陈述","chapter":32,"line_start":866,"line_end":866},{"speaker":null,"speaker_name":null,"listener":null,"text":"也不知他说确是他自己生的，还是说：","tone":"陈述","chapter":32,"line_start":866,"line_end":866},{"speaker":null,"speaker_name":null,"listener":null,"text":"众宾客觉得好笑，却又不敢笑。黄蓉从怀里掏出一锭黄金，交给奶妈，又把孩子还给了她，道：","tone":"轻笑","chapter":32,"line_start":868,"line_end":868},{"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":null,"text":"来，敬你一碗！","tone":"激动","chapter":32,"line_start":874,"line_end":874},{"speaker":null,"speaker_name":"那主人","listener":null,"text":"晚辈量浅，阿姨恕罪则个。","tone":"陈述","chapter":32,"line_start":876,"line_end":876},{"speaker":null,"speaker_name":null,"listener":null,"text":"外婆","tone":"陈述","chapter":32,"line_start":876,"line_end":876},{"speaker":null,"speaker_name":null,"listener":null,"text":"姑娘","tone":"陈述","chapter":32,"line_start":876,"line_end":876},{"speaker":null,"speaker_name":null,"listener":null,"text":"阿姨","tone":"陈述","chapter":32,"line_start":876,"line_end":876},{"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":null,"text":"靖哥哥，今日好玩吗？","tone":"轻笑","chapter":32,"line_start":892,"line_end":892},{"speaker":null,"speaker_name":null,"listener":null,"text":"黄蓉道：","tone":"陈述","chapter":32,"line_start":894,"line_end":894},{"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":null,"text":"我要出去逛逛，你去不去？","tone":"疑问","chapter":32,"line_start":898,"line_end":898},{"speaker":null,"speaker_name":null,"listener":null,"text":"黄蓉道：","tone":"陈述","chapter":32,"line_start":900,"line_end":900}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
