    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "周伯通笑道：",
      "tone": "轻笑",
      "chapter": 17,
      "line_start": 898,
      "line_end": 898
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "一起活，一起死",
      "tone": "陈述",
      "chapter": 17,
      "line_start": 912,
      "line_end": 912
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "摩诃波罗",
      "tone": "陈述",
      "chapter": 17,
      "line_start": 920,
