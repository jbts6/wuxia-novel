      "line_start": 304,
      "line_end": 304
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖不禁骇然，隔了半晌才道：",
      "tone": "陈述",
      "chapter": 17,
      "line_start": 308,
      "line_end": 308
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "你们找不到黑风双煞，那怎么办？",
