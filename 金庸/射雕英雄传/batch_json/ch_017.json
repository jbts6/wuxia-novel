      "line_start": 332,
      "line_end": 332
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "啊哟",
      "tone": "惊讶",
      "chapter": 17,
      "line_start": 364,
      "line_end": 364
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "你怎么说这话？",
      "tone": "惊讶",
      "chapter": 17,
      "line_start": 364,
      "line_end": 364
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "你输给他啦？",
      "tone": "疑问",
