      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "铁木真笑道：",
      "tone": "轻笑",
      "chapter": 5,
      "line_start": 648,
      "line_end": 648
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁木真道：",
      "tone": "陈述",
      "chapter": 5,
      "line_start": 654,
      "line_end": 654
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "问郭靖道：",
      "tone": "陈述",
      "chapter": 5,
      "line_start": 656,
      "line_end": 656
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "拖雷喜道：",
      "tone": "陈述",
      "chapter": 5,
      "line_start": 656,
      "line_end": 656
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁木真笑道：",
      "tone": "轻笑",
      "chapter": 5,
      "line_start": 658,
      "line_end": 658
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁木真笑道：",
      "tone": "轻笑",
      "chapter": 5,
      "line_start": 664,
      "line_end": 664
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁木真道：",
      "tone": "陈述",
      "chapter": 5,
      "line_start": 670,
