{"segment":13,"line_start":1081,"line_end":1170,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"但郭靖救人要紧，挨到农夫身边，蹲下身去举手托住岩石，道：","tone":"陈述","chapter":29,"line_start":1081,"line_end":1081},{"speaker":null,"speaker_name":null,"listener":null,"text":"郭靖道：","tone":"陈述","chapter":29,"line_start":1093,"line_end":1093},{"speaker":"char_guo_jing","speaker_name":"郭靖","listener":null,"text":"那农夫道：","tone":"恳求","chapter":29,"line_start":1093,"line_end":1093},{"speaker":null,"speaker_name":null,"listener":null,"text":"于是又问：","tone":"陈述","chapter":29,"line_start":1103,"line_end":1103},{"speaker":null,"speaker_name":null,"listener":null,"text":"郭靖心道：","tone":"恳求","chapter":29,"line_start":1103,"line_end":1103},{"speaker":null,"speaker_name":null,"listener":null,"text":"当下点点头。那农夫脸色微变，道：","tone":"陈述","chapter":29,"line_start":1105,"line_end":1105},{"speaker":null,"speaker_name":null,"listener":null,"text":"说着也不去牵牛，从坡上跃下地来。郭靖大叫：","tone":"陈述","chapter":29,"line_start":1107,"line_end":1107},{"speaker":null,"speaker_name":null,"listener":null,"text":"那农夫笑道：","tone":"轻笑","chapter":29,"line_start":1109,"line_end":1109},{"speaker":null,"speaker_name":null,"listener":null,"text":"黄蓉心中更怒，暗道：","tone":"愤怒","chapter":29,"line_start":1117,"line_end":1117},{"speaker":null,"speaker_name":null,"listener":null,"text":"眉尖微蹙，早有了主意，叫道：","tone":"陈述","chapter":29,"line_start":1119,"line_end":1119},{"speaker":null,"speaker_name":null,"listener":null,"text":"慢慢打开背囊，假装取信，却先抖出那副软猬甲来，回头向郭靖望了一眼，脸露惊惶神色，叫道：","tone":"惊讶","chapter":29,"line_start":1129,"line_end":1129},{"speaker":null,"speaker_name":"随即笑","listener":null,"text":"不碍事。信呢？","tone":"轻笑","chapter":29,"line_start":1133,"line_end":1133},{"speaker":null,"speaker_name":null,"listener":null,"text":"只是为了师父安危，丝毫不敢大意，从腰间拔出短刀，在软猬甲上砍了几刀，那甲果然纹丝不伤，真乃武林异宝，这时再无怀疑，道：","tone":"陈述","chapter":29,"line_start":1157,"line_end":1157},{"speaker":null,"speaker_name":null,"listener":null,"text":"他那知黄蓉容貌冰雪无邪，心中却诡计多端，当下拿着软猬甲，挨到郭靖身旁，将甲披在他的右肩，双手托住大石，臂上运劲，挺起大石，说道：","tone":"陈述","chapter":29,"line_start":1159,"line_end":1159},{"speaker":null,"speaker_name":null,"listener":null,"text":"郭靖只觉手上一松，又听得黄蓉呼叫，更无余暇多想，立时右掌前引，左掌从右手腕底穿出，使一招降龙十八掌中的","tone":"陈述","chapter":29,"line_start":1165,"line_end":1165},{"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":null,"text":"靖哥哥，咱们走罢。","tone":"陈述","chapter":29,"line_start":1167,"line_end":1167}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
