      "line_end": 46
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "欧阳锋道：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 46,
      "line_end": 46
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖心想：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 48,
      "line_end": 48
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "问道：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 48,
      "line_end": 48
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "欧阳锋冷笑一声，道：",
      "tone": "冷笑",
      "chapter": 20,
      "line_start": 50,
      "line_end": 50
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖大吃一惊，叫道：",
      "tone": "惊讶",
      "chapter": 20,
      "line_start": 52,
      "line_end": 52
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "至阳穴",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 54,
      "line_end": 54
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖摇了摇头。欧阳克笑道：",
      "tone": "轻笑",
      "chapter": 20,
      "line_start": 58,
      "line_end": 58
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖暗暗心惊：",
      "tone": "惊讶",
      "chapter": 20,
      "line_start": 60,
      "line_end": 60
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "瞪眼瞧着欧阳锋，心想：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 62,
      "line_end": 62
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖凛然道：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 68,
      "line_end": 68
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "欧阳锋哼了一声，道：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 70,
      "line_end": 70
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "欧阳锋见侄儿落入他手，当即笑道：",
      "tone": "轻笑",
      "chapter": 20,
      "line_start": 82,
      "line_end": 82
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "洪七公笑道：",
      "tone": "轻笑",
      "chapter": 20,
      "line_start": 84,
      "line_end": 84
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "洪七公连连点头，道：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 90,
      "line_end": 90
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖伤心难受，抢着道：",
      "tone": "悲伤",
      "chapter": 20,
      "line_start": 92,
      "line_end": 92
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "欧阳克不等身子落地，右手拍落，已借力站直身子，暗骂：",
      "tone": "愤怒",
      "chapter": 20,
      "line_start": 104,
      "line_end": 104
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "欧阳锋微微一笑，道：",
      "tone": "轻笑",
      "chapter": 20,
      "line_start": 106,
      "line_end": 106
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "洪七公道：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 108,
      "line_end": 108
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "抢到舱口，向郭靖叫道：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 132,
      "line_end": 132
    },
    {
      "speaker": "char_hong_qi_gong",
      "speaker_name": "洪七公",
      "listener": null,
      "text": "老毒物用蛇攻！",
      "tone": "轻笑",
      "chapter": 20,
      "line_start": 134,
      "line_end": 134
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "纵身",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 164,
      "line_end": 164
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "精神一振，拳脚如狂风暴雨般往欧阳锋攻去。洪七公激斗之际眼观六路，见十余条蝮蛇已游至郭靖身后，急叫：",
      "tone": "焦急",
      "chapter": 20,
      "line_start": 170,
      "line_end": 170
    },
    {
      "speaker": "char_hong_qi_gong",
      "speaker_name": "洪七公",
      "listener": null,
      "text": "打架要畜生做帮手，不要脸。",
      "tone": "愤怒",
      "chapter": 20,
      "line_start": 176,
      "line_end": 176
    },
    {
      "speaker": "char_hong_qi_gong",
      "speaker_name": "洪七公",
      "listener": null,
      "text": "快上桅杆。",
      "tone": "焦急",
      "chapter": 20,
      "line_start": 182,
      "line_end": 182
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "洪七公急道：",
      "tone": "焦急",
      "chapter": 20,
      "line_start": 184,
      "line_end": 184
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "莲花落",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 204,
      "line_end": 204
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "他一想到撒尿，立时拉开裤子，往下直撒下去，口中还叫：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 208,
      "line_end": 208
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖是小孩性子，正合心意，跟着师父大叫：",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 210,
      "line_end": 210
    },
    {
      "speaker": "char_ou_yang_ke",
      "speaker_name": "欧阳克",
      "listener": null,
      "text": "快撤蛇阵！",
