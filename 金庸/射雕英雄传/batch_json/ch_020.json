    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "欧阳锋站了一阵，听他胡言乱语，前后不贯，才知是说梦话，心道：",
      "tone": "陈述",
      "chapter": 20,
