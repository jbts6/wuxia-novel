      "tone": "陈述",
      "chapter": 6,
      "line_start": 924,
      "line_end": 924
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "札木合低声道：",
      "tone": "低语",
      "chapter": 6,
      "line_start": 934,
      "line_end": 934
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁木真道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 938,
      "line_end": 938
    },
    {
      "speaker": "char_cheng_ji_si_han",
      "speaker_name": "铁木真",
      "listener": null,
      "text": "札木合道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 938,
      "line_end": 938
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁木真道：",
