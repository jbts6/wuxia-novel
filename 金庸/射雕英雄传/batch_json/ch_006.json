    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "札木合惊道：",
      "tone": "惊讶",
      "chapter": 6,
      "line_start": 944,
      "line_end": 944
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "札木合道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 950,
      "line_end": 950
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁木真怒道：",
      "tone": "愤怒",
      "chapter": 6,
      "line_start": 952,
      "line_end": 952
    },
    {
      "speaker": null,
      "speaker_name": "札木合",
      "listener": null,
      "text": "王罕和桑昆都不肯背叛大金。",
