      "listener": null,
      "text": "全金发道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 514,
      "line_end": 514
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "马钰道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 516,
      "line_end": 516
    },
    {
      "speaker": "char_ma_yu",
      "speaker_name": "马钰",
      "listener": null,
      "text": "柯大侠仁心善怀，必获天佑。黑风双煞虽是桃花岛的叛徒，但黄岛主脾气怪诞，咱们今日诛了铁尸，要是黄岛主见怪，这后患可着实不小⋯⋯",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 526,
      "line_end": 526
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "马钰道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 532,
      "line_end": 532
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 534,
      "line_end": 534
    },
