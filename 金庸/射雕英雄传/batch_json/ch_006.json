      "speaker": "char_wan_yan_hong_lie",
      "speaker_name": "完颜洪烈",
      "listener": null,
      "text": "去把铁木真拿来。",
      "tone": "厉声",
      "chapter": 6,
      "line_start": 1044,
      "line_end": 1044
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "我叫郭靖。",
      "tone": "陈述",
