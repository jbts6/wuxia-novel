      "line_start": 484,
      "line_end": 484
    },
    {
      "speaker": "char_hua_zheng",
      "speaker_name": "华筝",
      "listener": null,
      "text": "郭靖道：",
      "tone": "惊讶",
      "chapter": 6,
      "line_start": 484,
      "line_end": 484
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "华筝道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 486,
      "line_end": 486
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "转念一想：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 490,
      "line_end": 490
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪道：",
