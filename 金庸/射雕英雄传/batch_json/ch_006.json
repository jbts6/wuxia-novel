      "line_end": 634
    },
    {
      "speaker": "char_zhu_cong",
      "speaker_name": "朱聪",
      "listener": null,
      "text": "志平，小心！",
      "tone": "激动",
      "chapter": 6,
      "line_start": 686,
      "line_end": 686
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "听得二师父这句话，才道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 688,
      "line_end": 688
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "马钰顺口答道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 700,
      "line_end": 700
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "梅超风又道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 704,
      "line_end": 704
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "马钰猛地省悟她是在求教内功秘诀，大声喝道：",
      "tone": "厉声",
      "chapter": 6,
      "line_start": 706,
      "line_end": 706
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "梅超风哈哈一笑，说道：",
      "tone": "大笑",
      "chapter": 6,
      "line_start": 708,
      "line_end": 708
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "马钰谦逊了几句，眉头深蹙，似有隐忧。朱聪道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 720,
      "line_end": 720
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "各人大惊，齐问：",
      "tone": "惊讶",
      "chapter": 6,
      "line_start": 726,
      "line_end": 726
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "马钰道：",
      "tone": "惊讶",
      "chapter": 6,
      "line_start": 726,
      "line_end": 726
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "韩小莹道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 742,
      "line_end": 742
    },
    {
      "speaker": "char_han_xiao_ying",
      "speaker_name": "韩小莹",
      "listener": null,
      "text": "马钰道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 742,
      "line_end": 742
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "沉吟道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 744,
      "line_end": 744
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖大吃一惊，忙问：",
      "tone": "惊讶",
      "chapter": 6,
      "line_start": 750,
      "line_end": 750
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "众人心想：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 756,
      "line_end": 756
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "大汗去了有多久啦？",
      "tone": "焦急",
      "chapter": 6,
      "line_start": 760,
      "line_end": 760
    },
    {
      "speaker": "char_cheng_ji_si_han",
      "speaker_name": "铁木真",
      "listener": null,
      "text": "怎么？",
      "tone": "疑问",
      "chapter": 6,
      "line_start": 806,
      "line_end": 806
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "大汗，你派人向来路查探便知。",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 812,
      "line_end": 812
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "命令次子察合台与大将赤老温：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 816,
      "line_end": 816
    },
    {
      "speaker": "char_zhe_bie",
      "speaker_name": "哲别",
      "listener": null,
      "text": "郭靖，咱俩接应他们去。",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 830,
      "line_end": 830
    },
    {
      "speaker": null,
      "speaker_name": "大声叫",
      "listener": null,
      "text": "铁木真，快投降罢。",
      "tone": "焦急",
      "chapter": 6,
      "line_start": 850,
      "line_end": 850
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "桑昆道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 852,
