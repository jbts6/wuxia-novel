    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "从怀内摸出一个小包，掷在札木合身前，说道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 988,
      "line_end": 988
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "伸手在自己脖子里作势一砍，说道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 990,
      "line_end": 990
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "叹道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 992,
      "line_end": 992
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 1008,
