      "line_start": 1008,
      "line_end": 1008
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "指着远处点点火光，说道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 1010,
      "line_end": 1010
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "眼睛望着远处的天边，昂然道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 1012,
      "line_end": 1012
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁木真微笑，伸手抚了抚他头，说道：",
      "tone": "微笑",
      "chapter": 6,
      "line_start": 1032,
      "line_end": 1032
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 1034,
      "line_end": 1034
    },
