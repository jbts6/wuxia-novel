    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪笑道：",
      "tone": "轻笑",
      "chapter": 6,
      "line_start": 590,
      "line_end": 590
    },
    {
      "speaker": "char_han_xiao_ying",
      "speaker_name": "韩小莹",
      "listener": null,
      "text": "谭师哥你说怎样？",
      "tone": "疑问",
      "chapter": 6,
      "line_start": 596,
      "line_end": 596
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱聪道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 598,
      "line_end": 598
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "南希仁道：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 600,
      "line_end": 600
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "铁脚仙",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 606,
      "line_end": 606
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "九夏迎阳立，三冬抱雪眠",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 608,
      "line_end": 608
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "梅超风心中窃喜：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 620,
      "line_end": 620
    },
    {
      "speaker": "char_guo_jing",
      "speaker_name": "郭靖",
      "listener": null,
      "text": "快救我，快救我！",
      "tone": "焦急",
      "chapter": 6,
      "line_start": 626,
      "line_end": 626
    },
    {
      "speaker": "char_quan_jin_fa",
      "speaker_name": "全金发",
      "listener": null,
      "text": "志平，刚才是你说话来着？",
      "tone": "疑问",
      "chapter": 6,
