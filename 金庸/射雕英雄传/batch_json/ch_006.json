      "chapter": 6,
      "line_start": 326,
      "line_end": 326
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "郭靖只见到这人的背影，悄悄爬过数尺，瞧他侧面，这人好生面熟，身穿镶貂的黄色锦袍，服饰华贵，琢磨他的语气，这才想起：",
      "tone": "陈述",
      "chapter": 6,
      "line_start": 330,
      "line_end": 330
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "桑昆大喜，道：",
