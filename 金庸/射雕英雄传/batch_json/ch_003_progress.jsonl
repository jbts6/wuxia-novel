{"segment":7,"line_start":541,"line_end":630,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"从手腕上褪下一只粗大的黄金镯子，递给郭靖，道：","tone":"陈述","chapter":3,"line_start":568,"line_end":568},{"speaker":null,"speaker_name":null,"listener":null,"text":"郭靖摇头道：","tone":"陈述","chapter":3,"line_start":570,"line_end":570},{"speaker":null,"speaker_name":null,"listener":null,"text":"那人哈哈大笑，叫道：","tone":"大笑","chapter":3,"line_start":572,"line_end":572},{"speaker":null,"speaker_name":"那人","listener":null,"text":"好孩子，你家里有弓箭么？","tone":"疑问","chapter":3,"line_start":580,"line_end":580},{"speaker":null,"speaker_name":null,"listener":null,"text":"见茅屋内外委实无地可躲，情势紧迫，便向屋旁一个大干草堆指了指，说道：","tone":"陈述","chapter":3,"line_start":590,"line_end":590},{"speaker":null,"speaker_name":"名军士喝","listener":null,"text":"孩子，见到一个骑黑马的汉子么？","tone":"厉声","chapter":3,"line_start":604,"line_end":604},{"speaker":null,"speaker_name":null,"listener":null,"text":"我只不说。","tone":"陈述","chapter":3,"line_start":610,"line_end":610},{"speaker":null,"speaker_name":"子大声喝","listener":null,"text":"小孩怎么说？","tone":"厉声","chapter":3,"line_start":614,"line_end":614},{"speaker":null,"speaker_name":null,"listener":null,"text":"大王子凝目四望，见到那匹黑马在远处吃草，低沉了声音道：","tone":"陈述","chapter":3,"line_start":616,"line_end":616},{"speaker":null,"speaker_name":null,"listener":null,"text":"众军士齐声道：","tone":"陈述","chapter":3,"line_start":624,"line_end":624},{"speaker":null,"speaker_name":null,"listener":null,"text":"大王子提起马鞭，唰的一声，在郭靖的小脑袋上轻轻抽了一下，喝道：","tone":"厉声","chapter":3,"line_start":624,"line_end":624}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":631,"line_end":720,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"他只知做了坏事才该挨打。术赤怒道：","tone":"愤怒","chapter":3,"line_start":634,"line_end":634},{"speaker":null,"speaker_name":"众军士","listener":null,"text":"大汗来啦！","tone":"激动","chapter":3,"line_start":644,"line_end":644},{"speaker":null,"speaker_name":null,"listener":null,"text":"铁木真道：","tone":"陈述","chapter":3,"line_start":664,"line_end":664},{"speaker":"char_cheng_ji_si_han","speaker_name":"铁木真","listener":null,"text":"术赤道：","tone":"陈述","chapter":3,"line_start":664,"line_end":664},{"speaker":null,"speaker_name":null,"listener":null,"text":"奔回到郭靖面前，拔出腰刀，在空中虚劈两刀，喝道：","tone":"厉声","chapter":3,"line_start":666,"line_end":666},{"speaker":null,"speaker_name":null,"listener":null,"text":"郭靖给他打得满脸是血，反而更加倔强，不住叫道：","tone":"陈述","chapter":3,"line_start":668,"line_end":668},{"speaker":null,"speaker_name":null,"listener":null,"text":"铁木真听这孩子说话天真，不说","tone":"陈述","chapter":3,"line_start":670,"line_end":670},{"speaker":"char_cheng_ji_si_han","speaker_name":"铁木真","listener":null,"text":"而说","tone":"陈述","chapter":3,"line_start":670,"line_end":670},{"speaker":"char_cheng_ji_si_han","speaker_name":"铁木真","listener":null,"text":"，那必是知晓哲别的所在，低声对三子窝阔台道：","tone":"低语","chapter":3,"line_start":670,"line_end":670},{"speaker":null,"speaker_name":null,"listener":null,"text":"郭靖仍道：","tone":"陈述","chapter":3,"line_start":676,"line_end":676},{"speaker":"char_cheng_ji_si_han","speaker_name":"铁木真","listener":null,"text":"放狗！","tone":"激动","chapter":3,"line_start":678,"line_end":678},{"speaker":null,"speaker_name":null,"listener":null,"text":"随即低沉了声音道：","tone":"陈述","chapter":3,"line_start":712,"line_end":712},{"speaker":"char_cheng_ji_si_han","speaker_name":"铁木真","listener":null,"text":"你说什么？","tone":"疑问","chapter":3,"line_start":716,"line_end":716}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
