72,"line_end":172},{"speaker":"char_ke_zhen_e","speaker_name":"柯镇恶","listener":null,"text":"朱聪道：","tone":"陈述","chapter":7,"line_start":172,"line_end":172},{"speaker":null,"speaker_name":null,"listener":null,"text":"柯镇恶道：","tone":"陈述","chapter":7,"line_start":174,"line_end":174},{"speaker":null,"speaker_name":null,"listener":null,"text":"韩宝驹道：","tone":"陈述","chapter":7,"line_start":180,"line_end":180}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
