[
  {
    "id": "faction_quan_zhen_pai",
    "name": "全真派",
    "type": "武林门派",
    "location": null,
    "sub_divisions": [],
    "one_line": "丘处机所属的武林门派，以道家武功闻名",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 639,
        "line_end": 640,
        "text": "原来是全真派大侠长春子，真是有幸相见。"
      },
      {
        "chapter": 2,
        "line_start": 384,
        "line_end": 384,
        "text": "这位是全真派长春子丘道长"
      },
      {
        "chapter": 2,
        "line_start": 1006,
        "line_end": 1006,
        "text": "素闻全真七子武功了得，已得当年重阳真人真传"
      },
      {
        "chapter": 22,
        "line_start": 261,
        "line_end": 261,
        "text": "全真七子的师叔"
      }
    ]
  },
  {
    "id": "faction_jiang_nan_qi_guai",
    "name": "江南七怪",
    "type": "帮派",
    "location": "嘉兴府",
    "sub_divisions": [],
    "one_line": "嘉兴七位奇人结义，各怀绝技，仗义行侠",
    "source_refs": [
      {
        "chapter": 2,
        "line_start": 401,
        "line_end": 401,
        "text": "我七兄弟人称江南七怪，不过是怪物而已"
      },
      {
        "chapter": 4,
        "line_start": 279,
        "line_end": 284,
        "text": "这几人便是江南七怪。他们自南而北，一路追踪段天德直到大漠，此后就再也没了音讯。六年多来，他们在沙漠中、草原上到处打听段天德和李萍的行踪，七人都学会了一口蒙古话，但段李两人却一直渺无讯息。江南七怪人人性格坚毅，更十分好胜，既与丘处机打了这场赌，别说只不过找寻个女子，便再艰难十倍、凶险万分之事，他们也绝不会罢手退缩。"
      },
      {
        "chapter": 11,
        "line_start": 118,
        "line_end": 118,
        "text": "这六人正是江南六怪"
      },
      {
        "chapter": 14,
        "line_start": 4,
        "line_end": 4,
        "text": "五男一女，走进厅来，却是江南六怪"
      }
    ]
  },
  {
    "id": "faction_meng_gu_bu_luo",
    "name": "蒙古部族",
    "type": "部族",
    "location": "漠北草原",
    "sub_divisions": [
      "铁木真部",
      "王罕部",
      "札木合部"
    ],
    "one_line": "漠北草原的游牧部族，铁木真统一后成为强大的军事力量",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 947,
        "line_end": 948,
        "text": "得悉漠北王罕、铁木真等部强盛，生怕成为北方之患"
      }
    ]
  },
  {
    "id": "faction_jin_guo",
    "name": "金国",
    "type": "王族",
    "location": "中都大兴府",
    "sub_divisions": [
      "荣王府",
      "赵王府"
    ],
    "one_line": "统治中国北方的大金国，皇帝完颜璟派太子册封漠北各部",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 947,
        "line_end": 948,
        "text": "其时金国明昌皇帝完颜璟在位"
      },
      {
        "chapter": 4,
        "line_start": 4,
        "line_end": 4,
        "text": "完颜洪熙笑道：好，再打他个痛快。"
      },
      {
        "chapter": 22,
        "line_start": 807,
        "line_end": 807,
        "text": "大金国的六王爷赵王完颜洪烈"
      },
      {
        "chapter": 23,
        "line_start": 520,
        "line_end": 520,
        "text": "大金国"
      },
      {
        "chapter": 36,
        "line_start": 526,
        "line_end": 526,
        "text": "拖雷与木华黎统兵攻打金国"
      }
    ]
  },
  {
    "id": "faction_tai_yi_chi_wu_bu",
    "name": "泰亦赤兀部",
    "type": "部族",
    "location": "漠北草原",
    "sub_divisions": [],
    "one_line": "铁木真的世仇部族，曾擒获并侮辱铁木真，后被铁木真歼灭主力",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 531,
        "line_end": 532,
        "text": "铁木真大获全胜，把世仇泰亦赤兀部的主力歼灭大半"
      }
    ]
  },
  {
    "id": "faction_nai_man_bu",
    "name": "乃蛮部",
