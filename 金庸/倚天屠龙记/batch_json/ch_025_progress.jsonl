{"segment":40,"line_start":700,"line_end":718,"dialogues":[{"speaker":"char_chang_yu_chun","speaker_name":"常遇春","listener":null,"text":"是那一路的兄弟前来相助？\n常某感激不尽。","tone":"豪迈","chapter":25,"line_start":704,"line_end":706},{"speaker":"char_zhang_wuji","speaker_name":"张无忌","listener":"char_chang_yu_chun","text":"常大哥，想煞小弟也。","tone":"欣喜","chapter":25,"line_start":708,"line_end":708},{"speaker":"char_chang_yu_chun","speaker_name":"常遇春","listener":"char_zhang_wuji","text":"教主兄弟，我既是你大哥，又是你属下，真高兴得不知如何才好。","tone":"欣喜","chapter":25,"line_start":710,"line_end":712}],"new_entities":{"characters":[{"id":"char_chang_yu_chun","name":"常遇春","alias":["常大哥"],"identity":"明教将领","faction":"faction_ming_jiao","role":"义军猛将","archetype":"冲阵英雄","rank":"一流","one_line":"常遇春率军与元兵激战，和张无忌久别重逢后洒泪相见。","personality":{"traits":["豪迈","勇烈","重情","谦敬","感恩"],"speech_style":"洪亮爽快，称兄道弟而不失部属礼","temperament":"慷慨刚烈"},"relationships":[{"target":"char_zhang_wuji","type":"兄弟兼部属","intensity":90,"bond_level":5,"dynamic":"久别重逢，既称大哥又尊教主"}],"known_skills":[],"related_skills":[],"rag_refs":["ch_025:704","ch_025:710"],"source_refs":[{"chapter":25,"line_start":704,"line_end":712,"text":"常遇春横矛大笑询问援兵，随后与张无忌重逢下拜"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_chang_yu_chun","updates":{"source_refs":[{"chapter":25,"line_start":704,"line_end":712,"text":"常遇春与张无忌战场重逢，既称兄弟又行属下礼"}]},"relationship_updates":[]}]}
