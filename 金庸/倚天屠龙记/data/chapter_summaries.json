      { "event_type": "冲突", "chapter": 19, "anchor": "成昆讲述阴谋" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_cheng_kun"]
  },
  {
    "chapter": 20,
    "title": "第二十回",
    "summary": "张无忌与小昭在光明顶秘道中发现阳顶天遗书和乾坤大挪移心法。张无忌凭九阳神功根基练成乾坤大挪移，推开石门脱困。小昭对张无忌产生深情。",
    "key_events": [
      { "event_type": "背景", "chapter": 20, "anchor": "张无忌与小昭发现阳顶天遗书" },
      { "event_type": "背景", "chapter": 20, "anchor": "张无忌练成乾坤大挪移" },
      { "event_type": "背景", "chapter": 20, "anchor": "小昭对张无忌产生深情" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_xiao_zhao"]
  },
  {
    "chapter": 21,
    "title": "第二十一回",
    "summary": "张无忌在光明顶上以七伤拳理说服崆峒五老，揭露成昆冒名杀人真相。他以乾坤大挪移对抗华山、昆仑两派的正反两仪刀剑联手。周芷若指点方位助其获胜。",
    "key_events": [
      { "event_type": "冲突", "chapter": 21, "anchor": "张无忌说服崆峒五老" },
      { "event_type": "冲突", "chapter": 21, "anchor": "张无忌对抗正反两仪刀剑" },
      { "event_type": "背景", "chapter": 21, "anchor": "揭露成昆冒名杀人" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_zhou_zhi_ruo"]
  },
  {
    "chapter": 22,
    "title": "第二十二回",
    "summary": "六大派围攻光明顶以失败告终。张无忌身受重伤，众人为其疗伤。明教总坛被焚，众人退入密道。张无忌述说阳顶天遗书和乾坤大挪移之事，被推举为教主。",
    "key_events": [
      { "event_type": "冲突", "chapter": 22, "anchor": "六大派围攻失败" },
