      { "event_type": "冲突", "chapter": 18, "anchor": "灭绝师太斩杀锐金旗" }
    ],
    "key_characters": ["char_yin_li_ting", "char_yin_li", "char_mie_jue_shi_tai"]
  },
  {
    "chapter": 19,
    "title": "第十九回",
    "summary": "张无忌被困说不得的乾坤一气袋中，机缘巧合下九阳神功大成。成昆在光明顶密道中现身，讲述与阳顶天的恩怨。张无忌听闻成昆阴谋，愤怒之下冲破气袋。",
    "key_events": [
      { "event_type": "背景", "chapter": 19, "anchor": "张无忌九阳神功大成" },
