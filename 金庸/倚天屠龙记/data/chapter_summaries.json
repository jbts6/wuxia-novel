[
  {
    "chapter": 1,
    "title": "第一回",
    "summary": "郭襄游历江湖来到少林寺，听闻昆仑三圣何足道挑战少林。觉远大师为保护经书圆寂，临终前背诵九阳真经。张君宝偷听习得部分九阳功，却被逐出少林。无色禅师赠铁罗汉给郭襄，张君宝随郭襄下山。",
    "key_events": [
      { "event_type": "背景", "chapter": 1, "anchor": "觉远大师圆寂前默诵九阳真经" },
      { "event_type": "背景", "chapter": 1, "anchor": "无色禅师赠铁罗汉给郭襄" },
      { "event_type": "背景", "chapter": 1, "anchor": "张君宝被逐出少林" }
    ],
    "key_characters": ["char_zhang_san_feng"]
  },
  {
    "chapter": 2,
    "title": "第二回",
    "summary": "张君宝随郭襄来到武当山，郭襄将铁罗汉转赠张君宝。张三丰创立武当派，研创武当武功。多年后，武当七侠名震江湖。本章交代武当派的创立和七侠的来历。",
    "key_events": [
      { "event_type": "背景", "chapter": 2, "anchor": "张三丰创立武当派" },
      { "event_type": "背景", "chapter": 2, "anchor": "武当七侠名震江湖" }
    ],
    "key_characters": ["char_zhang_san_feng"]
  },
  {
    "chapter": 3,
    "title": "第三回",
    "summary": "俞岱岩奉师命前赴福建诛杀剧盗，归途中遭遇海沙派与白袍客争夺屠龙刀。俞岱岩卷入其中，被白袍客以大力金刚指所伤，从此残废。本章交代俞岱岩受伤的经过。",
    "key_events": [
      { "event_type": "背景", "chapter": 3, "anchor": "俞岱岩遭遇海沙派与白袍客" },
      { "event_type": "冲突", "chapter": 3, "anchor": "白袍客以大力金刚指伤俞岱岩" },
      { "event_type": "背景", "chapter": 3, "anchor": "俞岱岩从此残废" }
    ],
    "key_characters": ["char_yu_dai_yan"]
  },
  {
    "chapter": 4,
    "title": "第四回",
    "summary": "谢逊携张翠山、殷素素漂流至冰火岛，三人在此共居十年。张翠山与殷素素成婚，生下张无忌。谢逊讲述与成昆的恩怨，张无忌在岛上成长。",
    "key_events": [
      { "event_type": "背景", "chapter": 4, "anchor": "三人漂流至冰火岛" },
      { "event_type": "背景", "chapter": 4, "anchor": "张翠山殷素素成婚" },
      { "event_type": "背景", "chapter": 4, "anchor": "张无忌出生" },
      { "event_type": "背景", "chapter": 4, "anchor": "谢逊讲述成昆恩怨" }
    ],
    "key_characters": ["char_zhang_cui_shan", "char_yin_su_su", "char_xie_xun", "char_zhang_wu_ji"]
  },
  {
    "chapter": 5,
    "title": "第五回",
    "summary": "张翠山在钱塘江畔遇到殷素素，两人在舟中交谈。殷素素承认杀了龙门镖局满门数十口，并安排少林僧冤枉张翠山。张翠山与殷素素初次相遇，展开恩怨纠葛。",
    "key_events": [
      { "event_type": "背景", "chapter": 5, "anchor": "张翠山与殷素素在钱塘江相遇" },
      { "event_type": "冲突", "chapter": 5, "anchor": "殷素素承认杀害龙门镖局" },
      { "event_type": "背景", "chapter": 5, "anchor": "殷素素安排少林僧冤枉张翠山" }
    ],
    "key_characters": ["char_zhang_cui_shan", "char_yin_su_su"]
  },
  {
    "chapter": 6,
    "title": "第六回",
    "summary": "谢逊讲述当年如何被成昆灭门，如何苦练武功报仇。谢逊提及空见神僧为化解冤孽甘受其十三记七伤拳，成昆却不守诺言。张翠山夫妇决心保护义兄。",
    "key_events": [
      { "event_type": "背景", "chapter": 6, "anchor": "谢逊讲述成昆灭门往事" },
      { "event_type": "背景", "chapter": 6, "anchor": "空见神僧受十三记七伤拳" }
    ],
    "key_characters": ["char_xie_xun", "char_zhang_cui_shan"]
  },
  {
    "chapter": 7,
    "title": "第七回",
    "summary": "谢逊详述成昆如何以混元霹雳手杀害其全家十三口，自己如何苦练七伤拳两次报仇失败，最终打死空见神僧。谢逊讲述当年客店中苦练七伤拳的情景。",
    "key_events": [
      { "event_type": "背景", "chapter": 7, "anchor": "谢逊讲述成昆灭门经过" },
      { "event_type": "背景", "chapter": 7, "anchor": "谢逊苦练七伤拳报仇" },
      { "event_type": "背景", "chapter": 7, "anchor": "谢逊打死空见神僧" }
    ],
    "key_characters": ["char_xie_xun", "char_cheng_kun"]
  },
  {
    "chapter": 8,
    "title": "第八回",
    "summary": "谢逊在冰火岛上最后一次狂性发作，张翠山一家决定回归中原。谢逊割刀自尽被阻止，最终放三人离去。张无忌回归中土后身中玄冥神掌寒毒，张三丰带他四处求医。",
    "key_events": [
      { "event_type": "背景", "chapter": 8, "anchor": "谢逊放张翠山一家回归中原" },
      { "event_type": "背景", "chapter": 8, "anchor": "张无忌身中玄冥神掌" },
      { "event_type": "背景", "chapter": 8, "anchor": "张三丰带张无忌求医" }
    ],
    "key_characters": ["char_xie_xun", "char_zhang_wu_ji", "char_zhang_san_feng"]
  },
  {
    "chapter": 9,
    "title": "第九回",
    "summary": "俞莲舟讲述当年俞岱岩被金刚指力所伤、各派围攻天鹰教的往事。张翠山夫妇携张无忌抵达武当山，各派追问谢逊下落。灭绝师太首次出场，殷素素与各派冲突。",
    "key_events": [
      { "event_type": "冲突", "chapter": 9, "anchor": "各派追问谢逊下落" },
      { "event_type": "背景", "chapter": 9, "anchor": "灭绝师太首次出场" },
      { "event_type": "背景", "chapter": 9, "anchor": "俞岱岩往事" }
    ],
    "key_characters": ["char_yu_lian_zhou", "char_zhang_cui_shan", "char_mie_jue_shi_tai"]
  },
  {
    "chapter": 10,
    "title": "第十回",
    "summary": "张翠山在六大派逼迫下自刎而死，殷素素随即自尽殉夫。临死前告知张无忌俞岱岩受伤真相。张三丰悲痛万分，收留张无忌。空见大师圆寂真相初现端倪。",
    "key_events": [
      { "event_type": "死亡", "chapter": 10, "anchor": "张翠山自刎而死" },
      { "event_type": "死亡", "chapter": 10, "anchor": "殷素素自尽殉夫" },
      { "event_type": "背景", "chapter": 10, "anchor": "张三丰收留张无忌" }
    ],
    "key_characters": ["char_zhang_cui_shan", "char_yin_su_su", "char_zhang_wu_ji", "char_zhang_san_feng"]
  },
  {
    "chapter": 11,
    "title": "第十一回",
    "summary": "张无忌被玄冥神掌寒毒折磨，张三丰带他四处求医无果。途中遇到常遇春、周芷若等人。张无忌在汉水船上与周芷若相遇，周芷若喂他饮食，二人结下情缘。",
    "key_events": [
      { "event_type": "背景", "chapter": 11, "anchor": "张无忌寒毒发作" },
      { "event_type": "背景", "chapter": 11, "anchor": "张无忌与周芷若汉水相遇" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_zhou_zhi_ruo", "char_zhang_san_feng"]
  },
  {
    "chapter": 12,
    "title": "第十二回",
    "summary": "张无忌在蝴蝶谷中学习医术，为常遇春疗伤。纪晓芙出场，她受灭绝师太之命追杀杨逍。张无忌认出蛛儿即是当年的殷离，二人重逢。",
    "key_events": [
      { "event_type": "背景", "chapter": 12, "anchor": "张无忌在蝴蝶谷学医" },
      { "event_type": "背景", "chapter": 12, "anchor": "纪晓芙出场" },
      { "event_type": "背景", "chapter": 12, "anchor": "张无忌认出殷离" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_ji_xiao_fu", "char_yin_li"]
  },
  {
    "chapter": 13,
    "title": "第十三回",
    "summary": "灭绝师太率峨眉弟子追杀杨逍，纪晓芙被逼供后宁死不屈，被灭绝师太亲手击毙。张无忌在旁目睹一切，为纪晓芙之死悲痛不已。灭绝师太传位给周芷若。",
    "key_events": [
      { "event_type": "死亡", "chapter": 13, "anchor": "纪晓芙被灭绝师太击毙" },
      { "event_type": "背景", "chapter": 13, "anchor": "灭绝师太传位给周芷若" }
    ],
    "key_characters": ["char_mie_jue_shi_tai", "char_ji_xiao_fu", "char_zhou_zhi_ruo"]
  },
  {
    "chapter": 14,
    "title": "第十四回",
    "summary": "张无忌带杨不悔寻找其父杨逍，途中历经艰险。二人在蝴蝶谷附近遇到朱九真、武烈等人，张无忌被朱九真所骗。常遇春出场相助。",
    "key_events": [
      { "event_type": "背景", "chapter": 14, "anchor": "张无忌带杨不悔寻父" },
      { "event_type": "冲突", "chapter": 14, "anchor": "张无忌被朱九真所骗" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_yang_bu_hui"]
  },
  {
    "chapter": 15,
    "title": "第十五回",
    "summary": "张无忌发现朱长龄父女的骗局，原来他们觊觎谢逊下落。张无忌逃出朱家庄，跌落悬崖。在山洞中与蛛儿（殷离）重逢，二人相伴疗伤。",
    "key_events": [
      { "event_type": "冲突", "chapter": 15, "anchor": "朱长龄父女骗局" },
      { "event_type": "背景", "chapter": 15, "anchor": "张无忌跌落悬崖" },
      { "event_type": "背景", "chapter": 15, "anchor": "张无忌与殷离重逢" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_yin_li"]
  },
  {
    "chapter": 16,
    "title": "第十六回",
    "summary": "张无忌在昆仑山谷中发现白猿腹中的九阳真经，开始修炼九阳神功。蛛儿陪伴在侧，二人感情渐深。张无忌内力渐增，驱除体内寒毒。",
    "key_events": [
      { "event_type": "背景", "chapter": 16, "anchor": "张无忌从白猿腹中取出九阳真经" },
      { "event_type": "背景", "chapter": 16, "anchor": "张无忌修炼九阳神功" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_yin_li"]
  },
  {
    "chapter": 17,
    "title": "第十七回",
    "summary": "张无忌九阳神功初成，与蛛儿离开山谷。途中遇到丁敏君、周芷若等人。周芷若在汉水边认出张无忌，二人重逢。周芷若指点张无忌易数方位之法。",
    "key_events": [
      { "event_type": "背景", "chapter": 17, "anchor": "张无忌九阳神功初成" },
      { "event_type": "背景", "chapter": 17, "anchor": "张无忌与周芷若重逢" }
    ],
    "key_characters": ["char_zhang_wu_ji", "char_yin_li", "char_zhou_zhi_ruo"]
  },
  {
    "chapter": 18,
    "title": "第十八回",
    "summary": "殷梨亭与魔教道人战斗，展现武当剑法。蛛儿向殷梨亭打听张无忌下落，透露对张无忌的深情。灭绝师太斩杀锐金旗教众，展现倚天剑威力。本章展现六大派围攻光明顶前的遭遇战。",
    "key_events": [
      { "event_type": "冲突", "chapter": 18, "anchor": "殷梨亭与魔教道人战斗" },
