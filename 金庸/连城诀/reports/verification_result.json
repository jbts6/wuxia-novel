        {
          "id": "skill_shen_zhao_gong",
          "name": "神照功",
          "total_refs": 1,
          "grounded": 0,
          "weak": 1,
          "unverified": 0,
          "grounded_ratio": 0,
          "alt_total": 4,
          "alt_grounded": 2,
