[
  {
    "id": "faction_shang_jia_bao",
    "name": "商家堡",
    "type": "堡寨",
    "location": "loc_shang_jia_bao",
    "sub_divisions": [
      "练武厅",
      "花厅"
    ],
    "one_line": "商老太等人所在的堡寨，设练武厅和花厅，门下练金镖。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 2,
        "line_end": 34,
        "text": "第一回题为大雨商家堡，练武厅中商老太命少年以金镖射木牌。"
      },
      {
        "chapter": 3,
        "line_start": 80,
        "line_end": 116,
        "text": "商老太太嘶哑着嗓子，问道：\"阎老大，这儿是商家堡不是？\"阎基道：\"是啊，商家堡怎么啦？\"商老太道：\"我是商家堡的主人不是？\"阎基一只手仍揪住独臂汉胸口，仰天大笑，说道：\"商老婆子，你绕着弯儿跟我说什么啊？你商家堡墙高门宽，财物定积得不少，你"
      },
      {
        "chapter": 4,
        "line_start": 726,
        "line_end": 730,
        "text": "今日想逃出我商家堡的铁厅"
      }
    ]
  },
  {
    "id": "faction_guan_fu",
    "name": "官府",
    "type": "官府",
    "location": "",
    "sub_divisions": [
      "武官"
    ],
    "one_line": "三名避雨武官所属的官方势力，马行空因不愿得罪官府而压住徐铮。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 128,
        "line_end": 134,
        "text": "马行空说人家官老爷们爱说笑话，马春花知道爹爹素来不肯得罪官府。"
      }
    ]
  },
  {
    "id": "faction_fei_ma_biao_ju",
    "name": "飞马镖局",
    "type": "镖局",
    "location": "",
    "sub_divisions": [],
    "one_line": "马行空任总镖头的镖局，以插翅飞马镖旗为标识。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 208,
        "line_end": 210,
        "text": "我师父是飞马镖局总镖头，百胜神拳马行空。"
      },
      {
        "chapter": 4,
        "line_start": 1130,
        "line_end": 1138,
        "text": "马行空与徐铮出了铁厅，立即找寻马春花"
      },
      {
        "chapter": 12,
        "line_start": 378,
        "line_end": 382,
        "text": "胡斐认出黄底黑线、背生双翼骏马的镖旗是飞马镖局旗号。"
      },
      {
        "chapter": 12,
        "line_start": 998,
        "line_end": 998,
        "text": "飞马镖局开设以来从没承保过这样一枝小镖。"
      }
    ],
    "relationships": []
  },
  {
    "id": "faction_yu_qian_shi_wei",
    "name": "御前侍卫",
    "type": "官府",
    "location": "京师",
    "sub_divisions": [
      "蓝翎侍卫"
    ],
    "one_line": "皇帝身边侍卫系统，何思豪自称御前侍卫，实为末等蓝翎侍卫。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 214,
        "line_end": 222,
        "text": "在下是御前侍卫何思豪；何思豪在侍卫处中只是最末等的蓝翎侍卫。"
      }
    ]
  },
  {
    "id": "faction_cha_quan_men",
    "name": "查拳门",
    "type": "武学门派",
    "location": "北方",
    "sub_divisions": [],
    "one_line": "北拳四大家之一，徐铮以查拳起手式对拳迎战。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 230,
        "line_end": 234,
        "text": "徐铮摆个\"对拳\"，何思豪见是\"查拳\"门人起手式。"
      }
    ]
  },
  {
    "id": "faction_tai_ji_men",
    "name": "太极门",
    "type": "武学门派",
    "location": "",
    "sub_divisions": [],
    "one_line": "声势甚盛的内家拳门派，何思豪以太极拳上步野马分鬃攻击徐铮。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 238,
        "line_end": 240,
        "text": "一招\"上步野马分鬃\"，向徐铮打了过去，他使的是太极拳。"
      },
      {
        "chapter": 3,
        "line_start": 1543,
        "line_end": 1597,
        "text": "陈禹见这小女孩肤色微黑，脸上满是痛恨之色，自己却从没见过，转过头向王剑杰道：\"赵三爷是南派温州太极门，兄弟是直隶广平府太极门，咱们是同派不同宗。赵三爷是本门前辈，兄弟向来仰慕得紧。\"说着走近身去，抱拳为礼，神色恭谨。那知赵半山宛如不见，双手"
      },
      {
        "chapter": 4,
        "line_start": 74,
        "line_end": 78,
        "text": "广平府太极门师兄弟三人"
      }
    ]
  },
  {
    "id": "faction_shi_er_lu_tan_tui_men",
    "name": "潭腿门",
    "type": "武学门派",
    "location": "北方",
    "sub_divisions": [
      "十二路潭腿"
    ],
    "one_line": "北拳四大家之一，十二路潭腿在北方流传甚广。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 366,
        "line_end": 370,
        "text": "商宝震使的是十二路潭腿，这路拳脚使得倒也纯熟。"
      }
    ]
  },
  {
    "id": "faction_ba_gua_dao_men",
    "name": "八卦刀门",
    "type": "武学门派",
    "location": "山东武定县",
    "sub_divisions": [
      "商家堡"
    ],
    "one_line": "商剑鸣所属的八卦刀一脉，商家堡梁上绘有八卦图形。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 402,
        "line_end": 412,
        "text": "商剑鸣是山东武定县人，正梁上绘着八卦图形，徐铮惊呼撞到仇家窝里。"
      }
    ]
  },
  {
    "id": "faction_yan_ji_dao_huo",
    "name": "阎基盗伙",
    "type": "黑道",
    "location": "商家堡外道上",
    "sub_divisions": [
      "黑衣大汉"
    ],
    "one_line": "阎基率领的劫镖盗伙，索要马行空三十万镖银的一半。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 492,
        "line_end": 516,
        "text": "阎基指墙头黑衣汉子说弟兄们饿了几天，随后命众人取一半镖银。"
      }
    ]
  },
  {
    "id": "faction_shao_lin_pai",
    "name": "少林派",
    "type": "武学门派",
    "location": "少林",
    "sub_divisions": [
      "查拳",
      "燕青拳"
    ],
    "one_line": "马行空烂熟于胸的各路少林拳术来源。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 606,
        "line_end": 608,
        "text": "马行空号称百胜神拳，少林派各路拳术全烂熟于胸。"
      }
    ]
  },
  {
    "id": "faction_tian_long_men_bei_zong",
    "name": "天龙门北宗",
    "type": "武学门派",
    "location": "未明",
    "sub_divisions": [
      "北宗"
    ],
    "one_line": "田归农担任掌门的门派，门下擒拿武功极强。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 722,
        "line_end": 722,
        "text": "这相公打扮之人，正是天龙门北宗掌门人田归农。"
      }
    ]
  },
  {
    "id": "faction_e_bei_gui_jian_chou_zhong_jia",
    "name": "鄂北鬼见愁钟家",
    "type": "家族",
    "location": "鄂北",
    "sub_divisions": [
      "钟氏三兄弟",
      "钟门门徒"
    ],
    "one_line": "雄霸荆襄的武林家族，以轻功、判官笔和怪异身法闻名。",
    "source_refs": [
      {
        "chapter": 2,
        "line_start": 54,
        "line_end": 56,
        "text": "这身奈何功是鄂北鬼见愁钟家的功夫。"
      },
      {
        "chapter": 2,
        "line_start": 527,
        "line_end": 531,
        "text": "鄂北鬼见愁钟门雄霸荆襄，钟氏三兄弟亲自到来。"
      }
    ]
  },
  {
    "id": "faction_gui_zhou_jiang_shi",
    "name": "贵州蒋氏",
    "type": "家族",
    "location": "贵州",
    "sub_divisions": [
      "蒋氏毒针"
    ],
    "one_line": "以绝门毒针闻名江湖的暗器家族。",
    "source_refs": [
      {
        "chapter": 2,
        "line_start": 310,
        "line_end": 314,
        "text": "苗人凤听到绝门毒针四字，知贵州蒋氏毒针天下闻名。"
      }
    ]
  },
  {
    "id": "faction_ba_gua_men",
    "name": "八卦门",
    "type": "武林门派",
    "location": "河朔一带",
    "sub_divisions": [
      "王氏一脉",
      "商剑鸣一脉"
    ],
    "one_line": "八卦门王氏兄弟曾随福公子前往商家堡。",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 1000,
        "line_end": 1057,
        "text": "你师父姓褚还是姓商？\"一副傲慢的神色，全没把对方放在眼里。商宝震大怒，喝道：\"你管得着么？\"那人微微一笑，说道：\"天下只要是八卦门的，我们就管得着。\"商宝震为人本来精细，但此番连受挫折，盛怒之下，没细想他言语中的含意，一招\"劈雷坠地\"，往他"
      },
      {
        "chapter": 4,
        "line_start": 774,
        "line_end": 800,
        "text": "王剑杰道：地底也是铁铸的？用刀接连撬起几块青砖"
      },
      {
        "chapter": 13,
        "line_start": 729,
        "line_end": 731,
        "text": "王剑英、王剑杰兄弟以八卦门功夫深厚之象现身。"
      },
      {
        "chapter": 13,
        "line_start": 90,
        "line_end": 90,
        "text": "秦耐之说八卦门王氏兄弟跟随福公子去商家堡。"
      },
      {
        "chapter": 19,
        "line_start": 182,
        "line_end": 184,
        "text": "圆性称王剑英为八卦门的掌门人王老师。"
      }
    ]
  },
  {
    "id": "faction_zhen_yuan_biao_ju",
    "name": "镇远镖局",
    "type": "帮派",
    "location": "北京",
    "sub_divisions": [],
    "one_line": "王维扬曾任总镖头的镖局，是王氏兄弟门第来源。",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 1044,
        "line_end": 1057,
        "text": "\"王氏兄弟相顾一笑。那老者道：\"那是咱哥儿俩的先父。你还不信么？商师哥呢？\"商宝震更无迟疑，扑翻在地，磕了几个头，口称师叔，说道：\"先父早已去世，师叔当年没接到讣告么？\"那年老的武师名叫王剑英，他兄弟名叫王剑杰，都是王维扬的儿子。王维扬当年"
      }
    ]
  },
  {
    "id": "faction_hong_hua_hui",
    "name": "红花会",
    "type": "帮派",
    "location": "江湖各地",
    "sub_divisions": [
      "赵半山一支"
    ],
    "one_line": "红花会夺杯后被福康安引为群豪追逐的众矢之的。",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 1504,
        "line_end": 1517,
        "text": "\"王剑英猛地省起，说道：\"啊，原来是红花会赵三爷光临，真得恕小弟眼拙。\"群豪一听，眼前此人竟是红花会的大头领千手如来赵半山，无不耸然动容。六年前红花会英雄火烧雍和宫，大闹紫禁城，乃轰动武林的大事，天下皆知（请参阅拙作《书剑恩仇录》）。此后红"
      },
      {
        "chapter": 4,
        "line_start": 34,
        "line_end": 34,
        "text": "我红花会只僻处回疆数年"
      },
      {
        "chapter": 7,
        "line_start": 529,
        "line_end": 537,
        "text": "胡斐说赵半山所在红花会曾擒拿福公子，袁紫衣确认此人就是福康安。"
      },
      {
        "chapter": 14,
        "line_start": 789,
        "line_end": 805,
        "text": "福康安曾给赵半山、文四叔、无尘道长他们逮去，胁迫皇帝重建福建少林寺。"
      },
      {
        "chapter": 17,
        "line_start": 1020,
        "line_end": 1040,
        "text": "红花会常赫志、常伯志兄弟...胡斐听到红花会三字，已心中怦怦而跳。"
      },
      {
        "chapter": 18,
        "line_start": 60,
        "line_end": 74,
        "text": "那胖侍卫正是千臂如来赵半山所乔装改扮。那个去救书生的侍卫，则是红花会中的鬼见愁石双英。"
      },
      {
        "chapter": 18,
        "line_start": 142,
        "line_end": 144,
        "text": "给红花会伏下了一个心腹大患。"
      },
      {
        "chapter": 19,
        "line_start": 1046,
        "line_end": 1070,
        "text": "无尘道人是红花会英雄，赵三哥的朋友。"
      }
    ],
    "relationships": []
  },
  {
    "id": "faction_tian_long_men",
    "name": "天龙门",
    "type": "武林门派",
    "location": "江湖",
    "sub_divisions": [],
    "one_line": "殷仲翔所属门派，本章因护陈禹而被赵半山震断长剑。",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 1609,
        "line_end": 1613,
        "text": "天龙门好手殷仲翔是陈禹至交，当赵陈二人口头相争之时，他已拔剑在手，跃跃欲试，眼见陈禹一招即败，便即挺剑向赵半山身后刺去，喝道：\"放手！\"赵半山更不回身，顺手在陈禹腰间抽出佩剑，回剑一挡。这一下分寸拿捏得恰到好处，双剑一交，当的一声，殷仲翔的"
      },
      {
        "chapter": 8,
        "line_start": 718,
        "line_end": 722,
        "text": "苗人凤不答，向那使刀之人说道：\"你是田归农的弟子吧？ 天龙门的武功也学到七成火候了。\"那人正是田归农的二弟子，名叫张云飞。 他吓得魂不附体，双膝跪倒，连连磕头，说道：\"苗大侠，小人是受命差遣，概不由己，请你老人家高抬贵手。"
      },
      {
        "chapter": 13,
        "line_start": 485,
        "line_end": 485,
        "text": "胡斐认出第三人是天龙门殷仲翔。"
      }
    ]
  },
  {
    "id": "faction_song_shan_shao_lin_pai",
    "name": "嵩山少林派",
    "type": "武林门派",
    "location": "嵩山",
    "sub_divisions": [],
    "one_line": "古般若所属少林支派，以飞刀暗器手法见称。",
    "source_refs": [
      {
        "chapter": 4,
        "line_start": 26,
        "line_end": 30,
        "text": "这位好朋友原来是嵩山少林派的"
      }
    ]
  },
  {
    "id": "faction_wu_hu_men",
    "name": "五虎门",
    "type": "武林门派",
    "location": "佛山镇",
    "sub_divisions": "凤天南门下、岭南飞虎等",
    "one_line": "凤天南手创并执掌的岭南门派，弟子各处发财后向掌门抽份孝敬。",
    "source_refs": [
      {
        "chapter": 5,
        "line_start": 146,
        "line_end": 150,
        "text": "那胖商人道：\"凤老爷在佛山镇上开了一家大典当，叫作英雄当铺；一家酒楼，便是这家英雄楼；又有一家大赌场，叫作英雄会馆。\n\n他武艺算得全广东第一，财雄势大，交游广阔，别说广东省城，就京城直隶、湖南湖北，不少大官也都是他好朋友。\n\n镇上的人私下里还说，每个月有人从粤东、粤西、粤北三处送银子来孝敬他，听说他是什么五虎派的掌门人，凡是五虎派的弟兄们在各处发财，便得抽个份儿给他。"
      },
      {
        "chapter": 13,
        "line_start": 819,
        "line_end": 819,
        "text": "凤天南是广东佛山镇上杀害钟阿四全家的五虎门掌门人。"
      },
      {
        "chapter": 17,
        "line_start": 74,
        "line_end": 74,
        "text": "西首第四席上坐着五虎门掌门人凤天南。"
      }
    ]
  },
  {
    "id": "faction_feng_fu",
    "name": "凤府",
    "type": "家族",
    "location": "佛山镇",
    "sub_divisions": "英雄楼、英雄典当、英雄会馆、南海凤第",
    "one_line": "凤天南在佛山镇经营的豪强家族势力，兼具家丁、产业与地方官面关系。",
    "source_refs": [
      {
        "chapter": 5,
        "line_start": 293,
        "line_end": 297,
        "text": "带狗的家丁共有六人，仗着凤天南威势，在佛山镇上一向凶横惯了的，眼见胡斐施展绝技杀狗，竟不知死活，一齐怒喝：\"什么人到佛山镇来撒野？\n\n打死了凤老爷的狗，要你这小子偿命。\"各人身上都带着单刀铁链，纷纷取出，蜂拥着抢上楼来。\n\n众酒客见到这副阵仗，登时一阵大乱。那\"英雄楼\"是凤天南的产业，掌柜的、站堂的、送菜的、大厨二厨，见到凤府家丁上楼拿人，各自抄起火叉、菜刀、铁棒，都要相帮动手。"
      }
    ]
  },
  {
    "id": "faction_shao_lin_wei_tuo_men",
    "name": "少林韦陀门",
    "type": "武林门派",
    "location": "衡阳枫叶庄",
    "sub_divisions": [],
