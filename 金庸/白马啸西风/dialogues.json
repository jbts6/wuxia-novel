    "rag_refs": [1]
  },
  {
    "id": "dlg_006",
    "speaker": "char_li_wen_xiu",
    "listener": "char_wa_er_la_qi",
    "text": "师父，我在这里陪着你。",
    "tone": "恳求",
    "chapter": 1,
    "line_start": 1160,
    "line_end": 1160,
    "source_refs": [
      {
        "chapter": 1,
        "anchor": "李文秀陪伴瓦耳拉齐",
        "event_type": "resolution"
      }
