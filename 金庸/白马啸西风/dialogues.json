    "rag_refs": [1]
  },
  {
    "id": "dlg_005",
    "speaker": "char_wa_er_la_qi",
    "listener": "char_li_wen_xiu",
    "text": "阿秀，你⋯⋯你也要去了吗？",
    "tone": "悲伤",
    "chapter": 1,
    "line_start": 1174,
    "line_end": 1174,
    "source_refs": [
      {
        "chapter": 1,
        "anchor": "瓦耳拉齐临死前的询问",
        "event_type": "resolution"
      }
