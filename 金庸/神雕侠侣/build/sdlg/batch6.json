[
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_yin_ke_xi","listener_name":"尹克西","text":"今日我是来向全真教的道人寻仇，与旁人无干，你快退开了。","tone":"冷酷","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_ma_guang_zuo","speaker_name":"麻光佐","listener":"char_xiao_xiang_zi","listener_name":"潇湘子","text":"不要脸啊，真正不要脸，三个武林大宗师，围攻一个小姑娘。","tone":"愤怒","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_zhen_zhi_bing","listener_name":"甄志丙","text":"你何苦如此？","tone":"悲伤","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_zhen_zhi_bing","speaker_name":"甄志丙","listener":"char_xiao_long_nyu","listener_name":"小龙女","text":"龙姑娘，我实⋯⋯实在对你不起，罪不容诛，你⋯⋯你原谅了我么？","tone":"恳求","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_yang_guo","listener_name":"杨过","text":"过儿，是你，这不是做梦么？","tone":"欣喜","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_yang_guo","speaker_name":"杨过","listener":"char_xiao_long_nyu","listener_name":"小龙女","text":"不是做梦，我不是抱着你么？","tone":"欣喜","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_yang_guo","listener_name":"杨过","text":"你的右臂呢？怎么没了？怎么没了？","tone":"悲伤","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_yang_guo","speaker_name":"杨过","listener":"char_xiao_long_nyu","listener_name":"小龙女","text":"只要我见了你面，永远不跟你分开，少一条臂膀又算得什么？","tone":"激动","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_yang_guo","listener_name":"杨过","text":"我没多久好活了，你陪着我罢，一直瞧着我死，别去陪你的郭⋯⋯郭芙姑娘。","tone":"悲伤","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_yang_guo","speaker_name":"杨过","listener":"char_xiao_long_nyu","listener_name":"小龙女","text":"姑姑，我自然陪着你。那郭姑娘跟我有什么相干？我这条手臂便是给她斩断的。","tone":"愤怒","chapter":26,"line_start":0,"line_end":0},
  {"speaker":"char_guo_jing","speaker_name":"郭靖","listener":"char_guo_fu","listener_name":"郭芙","text":"好，你伸出右臂来。你斩断人家一臂，我也斩断你一臂。","tone":"冷酷","chapter":27,"line_start":0,"line_end":0},
  {"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":"char_guo_fu","listener_name":"郭芙","text":"芙儿还不快逃！","tone":"焦急","chapter":27,"line_start":0,"line_end":0},
  {"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":"char_guo_jing","listener_name":"郭靖","text":"靖哥哥，你便饶了芙儿罢！","tone":"恳求","chapter":27,"line_start":0,"line_end":0},
  {"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":"char_li_mo_chou","listener_name":"李莫愁","text":"这位想必是赤练仙子李道长了，幸会，幸会！","tone":"嘲讽","chapter":27,"line_start":0,"line_end":0},
  {"speaker":"char_li_mo_chou","speaker_name":"李莫愁","listener":"char_huang_rong","listener_name":"黄蓉","text":"小妹久慕郭夫人大名，今日得见芳颜，实慰平生。","tone":"嘲讽","chapter":27,"line_start":0,"line_end":0},
  {"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":"char_li_mo_chou","listener_name":"李莫愁","text":"棒号打狗，见狗便打，事所必至，岂有他哉？","tone":"嘲讽","chapter":27,"line_start":0,"line_end":0},
  {"speaker":"char_huang_rong","speaker_name":"黄蓉","listener":"char_li_mo_chou","listener_name":"李莫愁","text":"李道长，多谢你对我襄儿如此关怀。","tone":"嘲讽","chapter":27,"line_start":0,"line_end":0},
  {"speaker":"char_yang_guo","speaker_name":"杨过","listener":"char_xiao_long_nyu","listener_name":"小龙女","text":"什么师徒名分，什么名节清白，咱们通通当是放屁！通通滚他妈的蛋！","tone":"激动","chapter":28,"line_start":0,"line_end":0},
  {"speaker":"char_yang_guo","speaker_name":"杨过","listener":"char_xiao_long_nyu","listener_name":"小龙女","text":"从今而后，你不是我师父，不是我姑姑，是我媳妇！是我妻子！是我老婆！","tone":"激动","chapter":28,"line_start":0,"line_end":0},
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_yang_guo","listener_name":"杨过","text":"这是你的真心话么？是不是为了让我欢喜，故意说些好听言语？","tone":"疑问","chapter":28,"line_start":0,"line_end":0},
  {"speaker":"char_yang_guo","speaker_name":"杨过","listener":"char_xiao_long_nyu","listener_name":"小龙女","text":"姑姑，我和你回古墓去，别理会这些人啦！","tone":"陈述","chapter":28,"line_start":0,"line_end":0},
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_yang_guo","listener_name":"杨过","text":"过儿，你待我真好。","tone":"欣喜","chapter":28,"line_start":0,"line_end":0},
  {"speaker":"char_zhou_bo_tong","speaker_name":"周伯通","listener":"char_xiao_long_nyu","listener_name":"小龙女","text":"乖乖不得了，我服侍不了这批蜜蜂老太爷，好姑娘快来救命。","tone":"恐惧","chapter":28,"line_start":0,"line_end":0},
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_yang_guo","listener_name":"杨过","text":"是啊。师父不许我收男弟子，更不许我嫁人，我却没一件遵守。","tone":"陈述","chapter":28,"line_start":0,"line_end":0},
  {"speaker":"char_yi_deng_da_shi","speaker_name":"一灯大师","listener":"char_ci_en","listener_name":"慈恩","text":"行罪而能生悔，本为难得。人非圣贤，孰能无过？知过能改，善莫大焉。","tone":"陈述","chapter":30,"line_start":0,"line_end":0},
  {"speaker":"char_xiao_long_nyu","speaker_name":"小龙女","listener":"char_yang_guo","listener_name":"杨过","text":"生死有命，人生无常，因缘离合，岂能强求？","tone":"陈述","chapter":30,"line_start":0,"line_end":0},
  {"speaker":"char_yi_deng_da_shi","speaker_name":"一灯大师","listener":"char_ci_en","listener_name":"慈恩","text":"我何必还手？我打胜你有什么用？你打胜我有什么用？须得胜过自己、克制自己，这才有用。","tone":"陈述","chapter":30,"line_start":0,"line_end":0}
]