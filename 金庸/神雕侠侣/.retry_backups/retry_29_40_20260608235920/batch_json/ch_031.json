      "line_start": 924,
      "line_end": 955
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "哎哟",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 956,
      "line_end": 977
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "绝情丹便在青砖之下",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 956,
      "line_end": 977
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "嗯、嗯、嗯",
