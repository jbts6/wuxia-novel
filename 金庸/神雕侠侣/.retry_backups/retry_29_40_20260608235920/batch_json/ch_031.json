    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "阿弥陀佛",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 978,
      "line_end": 997
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "当下摸了东首那瓷瓶出来，说道：",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 998,
      "line_end": 1021
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "她生性偏狭狠恶，刻薄寡恩，决不信世上有人甘愿舍却自己性命以救旁人，说道：",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 998,
      "line_end": 1021
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "绿萼道：",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 998,
      "line_end": 1021
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "多谢厚意。",
      "tone": "陈述",
