      "tone": "陈述",
      "chapter": 31,
      "line_start": 924,
      "line_end": 955
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "绿萼大奇：",
      "tone": "陈述",
