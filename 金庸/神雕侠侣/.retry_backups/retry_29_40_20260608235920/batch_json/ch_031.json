      "line_end": 997
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "老婆婆说",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 978,
      "line_end": 997
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "天眼通",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 978,
      "line_end": 997
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "天耳通",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 978,
      "line_end": 997
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "能闻六道众生语言及世间种种音声，通达无碍",
      "tone": "陈述",
      "chapter": 31,
      "line_start": 978,
      "line_end": 997
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "我的伤能好么？",
      "tone": "疑问",
      "chapter": 31,
      "line_start": 978,
      "line_end": 997
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "每问一句，刚好将一灯所说",
      "tone": "陈述",
