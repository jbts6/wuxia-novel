    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 102,
      "line_end": 123
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "绿萼道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 102,
      "line_end": 123
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "顿了一顿，说道：",
