    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "龙儿！",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1070,
      "line_end": 1091
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过一回头，猛见崖壁上用剑尖刻着两行字，一行大的写道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1092,
      "line_end": 1117
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "另一行较小的字写道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1092,
      "line_end": 1117
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "程英点点头，道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1092,
      "line_end": 1117
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "谁也不许过来！",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1118,
      "line_end": 1147
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1118,
      "line_end": 1147
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "程英缓步走到崖上，顺着杨过的目光，向石壁上那两行字低声读了一遍，也大惑不解，说道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1118,
      "line_end": 1147
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过惊喜交集，颤声道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1118,
      "line_end": 1147
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1118,
      "line_end": 1147
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过脸色迷惘，问道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1118,
      "line_end": 1147
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过将信将疑，喃喃的道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1148,
      "line_end": 1175
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过喃喃的道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1148,
      "line_end": 1175
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "一灯",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1148,
      "line_end": 1175
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "一灯摇头道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1148,
      "line_end": 1175
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "黄蓉叹道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1148,
      "line_end": 1175
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "说着哈哈一笑。杨过道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1148,
      "line_end": 1175
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "黄蓉问道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1148,
      "line_end": 1175
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1148,
      "line_end": 1175
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "南海神尼",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1176,
      "line_end": 1201
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1176,
      "line_end": 1201
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "没有。",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1176,
      "line_end": 1201
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "黄蓉拍手道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "转头向朱子柳说道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "朱子柳只知这断肠草剧毒无比，如何用来以毒攻毒却全无头绪，向一灯道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "少海",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "通里",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "神门",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "极泉",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "手少阴心经",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1202,
      "line_end": 1233
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "断肠",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1234,
      "line_end": 1255
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "啊",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1256,
      "line_end": 1281
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过一跃而起，说道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1256,
      "line_end": 1281
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "你身上的毒质都解去了吗？",
      "tone": "疑问",
      "chapter": 32,
      "line_start": 1256,
      "line_end": 1281
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "陆无双道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1256,
      "line_end": 1281
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1256,
      "line_end": 1281
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "芙儿你瞎说什么？",
      "tone": "疑问",
      "chapter": 32,
      "line_start": 1256,
      "line_end": 1281
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "陆无双再也忍耐不住，戟指喝道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1256,
      "line_end": 1281
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "陆无双听他叫自己为",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1282,
      "line_end": 1305
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "，而叫郭芙为",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1282,
      "line_end": 1305
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过躬身道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1282,
      "line_end": 1305
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1282,
      "line_end": 1305
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "郭芙奇道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1282,
      "line_end": 1305
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "黄蓉道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1282,
      "line_end": 1305
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "陆无双脸上一红，道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1306,
      "line_end": 1329
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "程英接口道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1306,
      "line_end": 1329
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "陆无双道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1306,
      "line_end": 1329
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "杨过道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1306,
      "line_end": 1329
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "程英心中一酸，知他对小龙女之情生死不渝，因有十六年遥遥相待，故要定下兄妹名份，以免日久相处，各自尴尬，但见陆无双低下了头，眼中含泪，忙道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1306,
      "line_end": 1329
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "程英道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1330,
      "line_end": 1357
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "微一沉吟，心想：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1358,
      "line_end": 1379
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "说道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1358,
      "line_end": 1379
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "陆无双大喜，道：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1358,
      "line_end": 1379
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "他⋯⋯他终于去了。",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1380,
      "line_end": 1397
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "心想：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1424,
      "line_end": 1445
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "雕兄，我往北有事，咱们就此别过。",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1466,
      "line_end": 1491
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "千斤坠",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1492,
      "line_end": 1511
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "又想：",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1512,
      "line_end": 1533
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "问世间，情是何物，直教生死相许？",
      "tone": "疑问",
      "chapter": 32,
      "line_start": 1534,
      "line_end": 1549
    },
    {
      "speaker": null,
      "speaker_name": "未判定",
      "listener": null,
      "text": "雁丘",
      "tone": "陈述",
      "chapter": 32,
      "line_start": 1534,
      "line_end": 1549
    }
