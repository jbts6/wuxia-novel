    "line_end": 528
  },
  {
    "speaker": null,
    "speaker_name": null,
    "listener": null,
    "text": "李靖少年时便通兵法，韩擒虎和他谈论军事，常说：",
    "tone": "陈述",
    "chapter": 1,
    "line_start": 540,
    "line_end": 540
  },
  {
    "speaker": null,
    "speaker_name": null,
    "listener": null,
    "text": "《唐书》说他",
