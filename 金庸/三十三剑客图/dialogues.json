    "text": "狱吏便向狱官报告。狱官查问此人犯了什么罪。狱吏道：",
    "tone": "疑问",
    "chapter": 1,
    "line_start": 568,
    "line_end": 568
  },
  {
    "speaker": null,
    "speaker_name": null,
    "listener": null,
    "text": "狱官亲去查问，说：",
    "tone": "疑问",
    "chapter": 1,
    "line_start": 570,
    "line_end": 570
  },
  {
    "speaker": null,
    "speaker_name": null,
    "listener": null,
    "text": "囚犯道：",
    "tone": "疑问",
    "chapter": 1,
    "line_start": 572,
    "line_end": 572
  },
  {
    "speaker": null,
    "speaker_name": null,
    "listener": null,
    "text": "狱官问：",
