  "dialogues": [
    {"chapter": 1, "speaker": "char_lu_fei_qing", "quote": "姓陆的还不致于这么不要脸，去给满清鞑子做鹰犬"},
    {"chapter": 1, "speaker": "char_lu_fei_qing", "quote": "沅芷，你我师生三年，总算相处不错"},
    {"chapter": 3, "speaker": "char_wen_tai_lai", "quote": "文某岂是贪生怕死之徒"},
    {"chapter": 11, "speaker": "char_chen_jia_luo", "quote": "哥哥，你到今日还不认我么"},
    {"chapter": 11, "speaker": "char_qian_long", "quote": "你要杀便杀，何必多言"},
    {"chapter": 14, "speaker": "char_xiang_xiang_gong_zhu", "quote": "你十年不来，我等你十年；一辈子不来，我等你一辈子"},
    {"chapter": 19, "speaker": "char_lu_fei_qing", "quote": "师弟，我来救你"},
    {"chapter": 19, "speaker": "char_zhang_zhao_zhong", "quote": "大家一起死了，谁也别活"},
    {"chapter": 20, "speaker": "char_tai_hou", "quote": "你真要恢复汉家衣冠么？要把我们满洲人赶尽杀绝么"},
    {"chapter": 20, "speaker": "char_xiang_xiang_gong_zhu", "quote": "不可相信皇帝"}
