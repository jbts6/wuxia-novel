[
  {
    "id": "faction_qing_ting",
    "name": "清廷",
    "type": "帮派",
    "location": "loc_shan_xi_fu_feng",
    "sub_divisions": [
      "延绥镇总兵衙门"
    ],
    "one_line": "乾隆年间朝廷势力，曾镇压反清秘帮屠龙帮，并持续搜捕陆菲青等钦犯。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 4,
        "line_end": 26,
        "text": "清乾隆十八年六月，陕西扶风延绥镇总兵衙门内院...总兵李可秀"
      },
      {
        "chapter": 1,
        "line_start": 90,
        "line_end": 96,
        "text": "雍正、乾隆两朝厉行镇压...清廷曾四下派人追拿...清廷继续严加查缉"
      },
      {
        "chapter": 5,
        "line_start": 1279,
        "line_end": 1283,
        "text": "清军将官称兆惠得报有小股土匪骚扰，派他领兵打发，大军未停。"
      }
    ],
    "relationships": []
  },
  {
    "id": "faction_li_ke_xiu_jia",
    "name": "李可秀家",
    "type": "家族",
    "location": "loc_yan_sui_zhen_zong_bing_ya_men",
    "sub_divisions": [],
    "one_line": "李可秀在总兵衙门中的家宅，李沅芷在此读书生活。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 4,
        "line_end": 26,
        "text": "延绥镇总兵衙门内院...李沅芷是总兵李可秀的独生女儿"
      }
    ]
  },
  {
    "id": "faction_wu_dang_pai",
    "name": "武当派",
    "type": "武林门派",
    "location": "",
    "sub_divisions": [],
    "one_line": "陆菲青出身的武林门派，以大侠身份和高强武功见称。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 88,
        "line_end": 88,
        "text": "陆菲青，是武当派的大侠"
      },
      {
        "chapter": 8,
        "line_start": 200,
        "line_end": 200,
        "text": "陈家洛认出李沅芷施展武当派上乘轻功。"
      }
    ]
  },
  {
    "id": "faction_tu_long_bang",
    "name": "屠龙帮",
    "type": "帮派",
    "location": "",
    "sub_divisions": [],
    "one_line": "雍正初年声势浩大的反清秘帮，后在雍正、乾隆两朝镇压下瓦解。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 88,
        "line_end": 90,
        "text": "原是屠龙帮中一位响当当人物。屠龙帮是反清的秘帮...终于落得瓦解冰消"
      },
      {
        "chapter": 2,
        "line_start": 658,
        "line_end": 660,
        "text": "陆菲青说当年与赵半山在屠龙帮时出生入死，真比亲兄弟还亲。"
      }
    ]
  },
  {
    "id": "faction_zhen_yuan_biao_ju",
    "name": "镇远镖局",
    "type": "帮派",
    "location": "不详",
    "sub_divisions": [],
    "one_line": "镇远镖局在王维扬经狮子峰险战后趋向收束退避，不再轻易与红花会为敌。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 720,
        "line_end": 720,
        "text": "店门前插了\"镇远镖局\"的镖旗"
      },
      {
        "chapter": 4,
        "line_start": 644,
        "line_end": 646,
        "text": "常伯志说镇远镖局那批人和鹰爪孙混在一起，武功好的约有十人。"
      },
      {
        "chapter": 5,
        "line_start": 194,
        "line_end": 204,
        "text": "镇远镖局受托护送皇上赏赐陈府的金珠宝贝至江南老宅，并让韩文冲协助。"
      },
      {
        "chapter": 8,
        "line_start": 803,
        "line_end": 815,
        "text": "石双英听到镇远镖局护送珍物到海宁陈阁老府。"
      },
      {
        "chapter": 13,
        "line_start": 114,
        "line_end": 118,
        "text": "韩文冲不肯回镇远镖局任事，反劝总镖头王维扬及早收山；王维扬随即北上收束镖局。"
      }
    ],
    "relationships": []
  },
  {
    "id": "faction_guan_dong_liu_mo",
    "name": "关东六魔",
    "type": "帮派",
    "location": "关东",
    "sub_divisions": [],
    "one_line": "关东六魔误以为焦文期和阎氏兄弟之死都与红花会有关，滕顾哈三人南下复仇。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 730,
        "line_end": 730,
        "text": "果然是关东六魔中的第五魔阎世魁"
      },
      {
        "chapter": 12,
        "line_start": 967,
        "line_end": 977,
        "text": "关东六魔中滕一雷、顾金标、哈合台南下，要为焦文期、阎氏兄弟向红花会寻仇。"
      }
    ]
  },
  {
    "id": "faction_tian_shan_pai",
    "name": "天山派",
    "type": "武林门派",
    "location": "天山",
    "sub_divisions": [],
    "one_line": "霍青桐所使剑法所属门派，剑法中有海市蜃楼等虚实难辨的秘招。",
    "source_refs": [
      {
        "chapter": 2,
        "line_start": 74,
        "line_end": 74,
        "text": "霍青桐使出天山派剑法的独得之秘海市蜃楼，剑光虚实闪动，逼得李沅芷手足无措。"
      },
      {
        "chapter": 4,
        "line_start": 1104,
        "line_end": 1104,
        "text": "霍青桐剑法陡变，施出天山派绝技海市蜃楼。"
      }
    ],
    "relationships": []
  },
  {
    "id": "faction_hong_hua_hui",
    "name": "红花会",
    "type": "帮派",
    "location": "江湖",
    "sub_divisions": [],
    "one_line": "红花会在误会中明确表态行侠仗义、绝不对满清屈膝。",
    "source_refs": [
      {
        "chapter": 2,
        "line_start": 290,
        "line_end": 292,
        "text": "公差宣称到店中捉拿红花会钦犯，准备向内闯去。"
      },
      {
        "chapter": 2,
        "line_start": 1196,
        "line_end": 1202,
        "text": "红花会举行总舵主接任礼仪，陈家洛接红花后率众分批赶赴铁胆庄。"
      },
      {
        "chapter": 5,
        "line_start": 1209,
        "line_end": 1217,
        "text": "红花会群雄紧跟常氏双侠冲入清兵队中，杀开血路奔到黄河岸边。"
      },
      {
        "chapter": 7,
        "line_start": 192,
        "line_end": 198,
        "text": "东方耳指称红花会鼓动灾民抢粮、犯上作乱，陈家洛故作初闻。"
      },
      {
        "chapter": 8,
        "line_start": 6,
        "line_end": 14,
        "text": "陈家洛等和红花会群豪在湖岸与清军对峙。"
      },
      {
        "chapter": 11,
        "line_start": 434,
        "line_end": 442,
        "text": "杨成协忍耐不住，喝道：\"这位是我们陈总舵主，你别胡言乱道。\"那老妇面露诧异之色，问道：\"你们是红花会的？\"杨成协道：\"不错。\"那老妇转向陈家洛，厉声道：\"你们投降了清朝么？\"陈家洛道：\"红花会行侠仗义，岂能对满清屈膝？老太太请坐，咱们慢慢说"
      },
      {
        "chapter": 18,
        "line_start": 1131,
        "line_end": 1155,
        "text": "陈家洛道：\"在杭州提督府地牢之中，文四爷和我擒住你后饶你不死；狮子峰上、兆惠大营之外，又曾两次饶你；日前在狼群，再救你一次性命。 红花会对你可算得仁至义尽。那知你至死不悟，今日不论如何，决不能再饶了。 \"张召重道：\"你上吧，我也让你四招不还"
      }
    ],
    "relationships": []
  },
  {
    "id": "faction_tie_dan_zhuang",
    "name": "铁胆庄",
    "type": "家族",
    "location": "客店附近二三十里",
    "sub_divisions": [],
    "one_line": "周仲英世居之庄，离客店二三十里，被陆菲青提议作为文泰来暂避之地。",
    "source_refs": [
      {
        "chapter": 2,
        "line_start": 620,
        "line_end": 628,
        "text": "信封写明请面陈铁胆庄周仲英，陆菲青说铁胆庄离此不过二三十里。"
      },
      {
        "chapter": 2,
        "line_start": 1202,
        "line_end": 1202,
        "text": "红花会总舵主陈家洛率众分批赶赴铁胆庄。"
      }
    ],
    "relationships": []
  },
  {
    "id": "faction_tai_ji_men",
    "name": "太极门",
    "type": "武林门派",
    "location": "江湖",
    "sub_divisions": [],
    "one_line": "赵半山所属门派，陆菲青以“太极门的赵半山”称之。",
    "source_refs": [
      {
        "chapter": 2,
        "line_start": 656,
        "line_end": 658,
        "text": "陆菲青问太极门的赵半山跟文泰来怎样称呼。"
      },
      {
        "chapter": 7,
        "line_start": 346,
        "line_end": 346,
        "text": "久闻太极门武功深得内家秘奥，赵三哥的轻功果然了得。"
      }
    ]
  },
  {
    "id": "faction_bei_shao_lin",
    "name": "北少林",
    "type": "武林门派",
    "location": "loc_shao_shi_shan_shao_lin_si",
    "sub_divisions": [],
    "one_line": "周仲英所说少室山少林寺一脉，与南少林同出少林门户。",
    "source_refs": [
      {
        "chapter": 4,
        "line_start": 271,
        "line_end": 273,
        "text": "周仲英道：\"我是河南少室山少林寺本寺学的。北少林南少林本是一家，我跟于老当家虽非同寺学艺，却也可算得是同门。\""
      }
    ]
  },
  {
    "id": "faction_nan_shao_lin",
    "name": "南少林",
    "type": "武林门派",
    "location": "loc_fu_jian_shao_lin_si",
    "sub_divisions": [],
    "one_line": "于老当家曾学艺的福建少林寺一脉，与北少林同出少林门户。",
    "source_refs": [
      {
        "chapter": 4,
        "line_start": 269,
        "line_end": 273,
        "text": "徐天宏道：\"于老当家...以前是在福建少林寺学的武艺。\"周仲英道：\"...北少林南少林本是一家...\""
      }
    ]
  },
  {
    "id": "faction_da_nei_shi_wei",
    "name": "大内侍卫",
    "type": "帮派",
    "location": "loc_huang_gong",
    "sub_divisions": [],
    "one_line": "奉钦命前来要求文泰来、骆冰赴京的宫廷侍卫高手。",
    "source_refs": [
      {
        "chapter": 4,
        "line_start": 401,
        "line_end": 403,
        "text": "骆冰道：\"众兄弟分批来迎接少舵主，我们夫妇是最后一批，到得肃州，忽有八名大内侍卫来到客店相见，说是奉有钦命，要我们前往北京。\""
      }
    ]
  },
  {
    "id": "faction_luo_yang_han_jia_men",
    "name": "洛阳韩家门",
    "type": "武林门派",
    "description": "洛阳一带武林门派，韩文冲所属，门中武功包括铁琵琶手。",
    "source_refs": [
      {
        "chapter": 5,
        "line_start": 24,
        "line_end": 30,
        "text": "心砚称被擒者是洛阳韩家门的人，陈家洛亦以此询问其身份。"
      },
      {
        "chapter": 5,
        "line_start": 82,
        "line_end": 94,
        "text": "陈家洛欲向洛阳韩家门解释误会；韩文冲讲述韩家门焦文期遇害经过。"
      }
    ],
    "relationships": []
  },
