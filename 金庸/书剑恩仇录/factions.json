  {
    "id": "faction_long_men_bang",
    "name": "龙门帮",
    "type": "帮派",
    "location": "潼关一带",
    "sub_divisions": [],
    "one_line": "孟津一带协助红花会寻访余鱼同踪迹的地方帮会。",
    "source_refs": [
      {
        "chapter": 12,
        "line_start": 1313,
        "line_end": 1321,
        "text": "潼关一带占码头的帮会是龙门帮，红花会和他们素无交往，徐天宏拜访龙头大哥上官毅山后，上官毅山立即派人查问余鱼同。"
      }
    ],
    "rag_refs": [
      {
        "chapter": 13,
        "line_start": 10,
        "line_end": 10,
        "text": "上官毅山把当地龙门帮得力的弟兄都派了出去，叮嘱发现可疑眼生之人立即回报。"
      }
    ]
