{"segment":33,"line_start":1145,"line_end":1178,"dialogues":[{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"阿九脸上又是一红，道：","tone":"惊讶","chapter":17,"line_start":1152,"line_end":1152},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"殿下叫人吗？","tone":"疑问","chapter":17,"line_start":1154,"line_end":1154},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"宫女道：","tone":"疑问","chapter":17,"line_start":1156,"line_end":1156},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"你知道五毒教么？","tone":"疑问","chapter":17,"line_start":1166,"line_end":1166},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"承志道：","tone":"疑问","chapter":17,"line_start":1168,"line_end":1168},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"阿九面色一变，道：","tone":"疑问","chapter":17,"line_start":1170,"line_end":1170},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"承志道：","tone":"疑问","chapter":17,"line_start":1172,"line_end":1172},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"站起身来，道：","tone":"疑问","chapter":17,"line_start":1172,"line_end":1172},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"好的。","tone":"陈述","chapter":17,"line_start":1176,"line_end":1176},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"你冒险进宫来瞧我，我⋯⋯我是很感激的⋯⋯","tone":"陈述","chapter":17,"line_start":1176,"line_end":1176},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"你既见到我画你的肖像，我的⋯⋯心事⋯⋯你⋯⋯你自然也明白了⋯⋯","tone":"陈述","chapter":17,"line_start":1176,"line_end":1176}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":34,"line_start":1179,"line_end":1216,"dialogues":[{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"只听她又道：","tone":"陈述","chapter":17,"line_start":1180,"line_end":1180},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"殿下，我进宫来是⋯⋯","tone":"温柔","chapter":17,"line_start":1184,"line_end":1184},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"承志道：","tone":"疑问","chapter":17,"line_start":1188,"line_end":1188},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"忽然之间，想起当日在秦淮河中与青青一起听两个歌女所唱的〈挂枝儿〉：","tone":"疑问","chapter":17,"line_start":1190,"line_end":1190},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"大哥！","tone":"低语","chapter":17,"line_start":1194,"line_end":1194},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"嗯，阿九。","tone":"低语","chapter":17,"line_start":1196,"line_end":1196},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"阿九道：","tone":"痛苦","chapter":17,"line_start":1202,"line_end":1202},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"承志听她体念民间疾苦，说道：","tone":"痛苦","chapter":17,"line_start":1206,"line_end":1206},{"speaker":"char_a_jiu","speaker_name":"阿九","listener":null,"text":"阿九叹道：","tone":"痛苦","chapter":17,"line_start":1208,"line_end":1208},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"承志道：","tone":"陈述","chapter":17,"line_start":1216,"line_end":1216},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"寻思：","tone":"陈述","chapter":17,"line_start":1216,"line_end":1216}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
