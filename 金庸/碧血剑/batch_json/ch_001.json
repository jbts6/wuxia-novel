      "tone": "陈述",
      "chapter": 1,
      "line_start": 920,
      "line_end": 920
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "流寇",
      "tone": "疑问",
      "chapter": 1,
      "line_start": 926,
      "line_end": 926
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "那汉子说道：",
      "tone": "陈述",
      "chapter": 1,
      "line_start": 942,
      "line_end": 942
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "孙仲寿道：",
      "tone": "陈述",
      "chapter": 1,
      "line_start": 944,
      "line_end": 944
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "那白净面皮的人道：",
      "tone": "陈述",
      "chapter": 1,
      "line_start": 946,
