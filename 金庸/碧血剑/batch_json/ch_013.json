{
  "chapter": 13,
  "chapter_summary": "第十三回写袁承志参与更接近军国局势的行动，毁炮、挫敌和刺击之事显示江湖武力进入战场。章末注释补足回目典故和历史背景。",
  "dialogues": [
    {
      "speaker": "char_an_da_niang",
      "speaker_name": "安大娘",
      "listener": null,
      "text": "好啊，谋杀亲夫！",
