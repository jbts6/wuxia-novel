      "line_start": 42,
      "line_end": 42
    },
    {
      "speaker": "char_an_da_niang",
      "speaker_name": "安大娘",
      "listener": null,
      "text": "过了一会，又道：",
      "tone": "疑问",
      "chapter": 13,
      "line_start": 44,
      "line_end": 44
    },
    {
      "speaker": "char_an_da_niang",
      "speaker_name": "安大娘",
      "listener": null,
      "text": "安大娘厉声道：",
