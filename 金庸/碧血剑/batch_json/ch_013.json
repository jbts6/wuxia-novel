    },
    {
      "speaker": "char_an_da_niang",
      "speaker_name": "安大娘",
      "listener": null,
      "text": "乘那安大人哈哈狂笑、安大娘破口大骂之际，缩身从门角边钻了进去，轻轻摸到墙壁，施展",
      "tone": "愤怒",
      "chapter": 13,
      "line_start": 24,
      "line_end": 24
    },
    {
      "speaker": "char_an_da_niang",
      "speaker_name": "安大娘",
      "listener": null,
      "text": "胡老三，进去点火！",
      "tone": "愤怒",
