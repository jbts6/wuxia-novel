      "line_start": 372,
      "line_end": 372
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "穆人清道：",
      "tone": "疑问",
      "chapter": 3,
      "line_start": 376,
      "line_end": 376
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "说着叹了口气，又道：",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 405,
      "line_end": 405
    },
    {
      "speaker": "char_mu_sang_dao_ren",
      "speaker_name": "木桑道人",
      "listener": null,
      "text": "木桑点头道：",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 413,
      "line_end": 413
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "木桑一听到",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 429,
      "line_end": 429
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "两字，脸上肌肉一跳，登时容光焕发，斗然间宛如年轻了二十岁，只听穆人清道：",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 429,
      "line_end": 429
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "他忙道：",
      "tone": "焦急",
