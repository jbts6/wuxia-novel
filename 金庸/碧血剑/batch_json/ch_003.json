      "line_start": 246,
      "line_end": 246
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 252,
      "line_end": 252
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "穆人清点点头，从匣中提起长剑，脸色一沉，说道：",
      "tone": "惊讶",
      "chapter": 3,
      "line_start": 256,
      "line_end": 256
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "穆人清道：",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 276,
      "line_end": 276
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志黯然点头，知道师父提出崇祯杀他父亲的事来，是要他将",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 290,
      "line_end": 290
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "好！",
      "tone": "惊讶",
      "chapter": 3,
      "line_start": 302,
      "line_end": 302
    },
    {
      "speaker": "char_mu_sang_dao_ren",
      "speaker_name": "木桑道人",
      "listener": null,
      "text": "罢了！",
      "tone": "轻笑",
      "chapter": 3,
      "line_start": 318,
      "line_end": 318
    },
    {
      "speaker": "char_mu_sang_dao_ren",
      "speaker_name": "木桑道人",
      "listener": null,
      "text": "混元功",
      "tone": "轻笑",
      "chapter": 3,
      "line_start": 320,
      "line_end": 320
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "说道：",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 338,
      "line_end": 338
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "承志跪下叩谢。穆人清正色道：",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 358,
      "line_end": 358
    },
    {
      "speaker": "char_mu_sang_dao_ren",
      "speaker_name": "木桑道人",
      "listener": null,
      "text": "那人近来有消息没有？",
      "tone": "疑问",
