      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "大威",
      "tone": "欣喜",
      "chapter": 3,
      "line_start": 656,
      "line_end": 656
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "小乖",
      "tone": "欣喜",
      "chapter": 3,
      "line_start": 656,
      "line_end": 656
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "难道来了敌人？",
      "tone": "疑问",
      "chapter": 3,
      "line_start": 686,
      "line_end": 686
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "穆人清也暗暗纳罕，说道：",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 698,
      "line_end": 698
    },
    {
      "speaker": "char_mu_sang_dao_ren",
      "speaker_name": "木桑道人",
      "listener": null,
      "text": "木桑道：",
      "tone": "陈述",
