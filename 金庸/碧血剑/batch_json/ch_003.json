      "line_start": 431,
      "line_end": 431
    },
    {
      "speaker": "char_mu_ren_qing",
      "speaker_name": "穆人清",
      "listener": null,
      "text": "穆人清笑道：",
      "tone": "疑问",
      "chapter": 3,
      "line_start": 433,
      "line_end": 433
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "胜固欣然败亦喜",
      "tone": "欣喜",
      "chapter": 3,
      "line_start": 485,
      "line_end": 485
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "胜固欣然败亦喜",
      "tone": "欣喜",
      "chapter": 3,
      "line_start": 487,
      "line_end": 487
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "欣然",
      "tone": "欣喜",
      "chapter": 3,
      "line_start": 487,
      "line_end": 487
    },
    {
      "speaker": null,
      "speaker_name": "未知",
