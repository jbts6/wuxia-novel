{
  "chapter": 18,
  "chapter_summary": "第十八回写宝剑、宫城和明廷覆亡前后的惨烈情势，袁承志在权力倾轧中见到帝王、宗室和百姓的不同命运，家国判断更趋沉重。",
  "dialogues": [
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "什么事？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 4,
      "line_end": 4
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 6,
      "line_end": 6
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "那宫女道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 6,
      "line_end": 6
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 8,
      "line_end": 8
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "另一个女子声音说道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 8,
      "line_end": 8
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "何铁手！",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 12,
      "line_end": 12
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "干什么？",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 26,
      "line_end": 26
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 30,
      "line_end": 30
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "曹化淳道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 32,
      "line_end": 32
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "好啦，你们来瞧吧！",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 42,
      "line_end": 42
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "曹公公，多谢你费心。",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 46,
      "line_end": 46
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "床底下也查过了，我没藏着刺客吧？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 52,
      "line_end": 52
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "对四名宫女道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 60,
      "line_end": 60
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "四名宫女俯身道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 62,
      "line_end": 62
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "放下帐子，我要睡啦！",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 66,
      "line_end": 66
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "大喜之余，暗自庆幸。阿九心中只是说：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 76,
      "line_end": 76
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "过了良久，只听袁承志低声道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 78,
      "line_end": 78
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "我说了你别见怪。",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 86,
      "line_end": 86
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志低声道：",
      "tone": "低语",
      "chapter": 18,
      "line_start": 88,
      "line_end": 88
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "轻笑",
      "chapter": 18,
      "line_start": 90,
      "line_end": 90
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "承志道：",
      "tone": "轻笑",
      "chapter": 18,
      "line_start": 90,
      "line_end": 90
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九低声笑道：",
      "tone": "轻笑",
      "chapter": 18,
      "line_start": 90,
      "line_end": 90
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "大哥，我要你永远这样抱着我⋯⋯",
      "tone": "低语",
      "chapter": 18,
      "line_start": 100,
      "line_end": 100
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "忙缩开嘴唇，低声问道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 108,
      "line_end": 108
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 110,
      "line_end": 110
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 112,
      "line_end": 112
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "什么？谁？",
      "tone": "惊讶",
      "chapter": 18,
      "line_start": 116,
      "line_end": 116
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九怒道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 118,
      "line_end": 118
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "承志道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 120,
      "line_end": 120
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 120,
      "line_end": 120
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "承志道：",
      "tone": "惊讶",
      "chapter": 18,
      "line_start": 122,
      "line_end": 122
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九吃了一惊，说道：",
      "tone": "惊讶",
      "chapter": 18,
      "line_start": 122,
      "line_end": 122
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "承志仍是沉吟未决。阿九悄声道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 134,
      "line_end": 134
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "悄声道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 140,
      "line_end": 140
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 142,
      "line_end": 142
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "承志忽然想到青青，登觉为难异常，但身当此时，只得紧紧搂住了她，说道：",
      "tone": "低语",
      "chapter": 18,
      "line_start": 160,
      "line_end": 160
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "你跟我来！",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 164,
      "line_end": 164
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "让开！",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 176,
      "line_end": 176
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "停步！",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 188,
      "line_end": 188
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "向一个身穿黄袍、头戴黑缎软帽的人奔去。袁承志打量这人，见他约莫三十五六岁年纪，面目清秀，脸上神色惊怒交集，心道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 192,
      "line_end": 192
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "你来干什么？快出去。",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 198,
      "line_end": 198
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "惠叔爷，你胆敢对皇上无礼！",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 208,
      "line_end": 208
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "嚓的一声，将佩剑抽出一半，怒目挺眉，厉声喝道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 212,
      "line_end": 212
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "崇祯身子发颤，喝道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 222,
      "line_end": 222
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "先料理这小子！",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 244,
      "line_end": 244
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "师命有三，目前他说的是第一师命。",
      "tone": "欣喜",
      "chapter": 18,
      "line_start": 284,
      "line_end": 284
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "阿九与何铁手答应了。三人往崇祯身周一站，正待向前夺路，曹化淳忽然叫道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 310,
      "line_end": 310
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "众亲兵即与锦衣卫交起手来。惠王惊得呆了，叫道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 312,
      "line_end": 312
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "众亲兵将锦衣卫拿下。一出殿门，曹化淳叫道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 320,
      "line_end": 320
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "你⋯⋯你⋯⋯",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 328,
      "line_end": 328
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "快谢恩！",
      "tone": "低语",
      "chapter": 18,
      "line_start": 334,
      "line_end": 334
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "他做皇帝便只受罪，一点也不快活！",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 340,
      "line_end": 340
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崇祯一呆，似乎没听清楚他的话，问道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 348,
      "line_end": 348
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 348,
      "line_end": 348
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "崇祯默然半晌，叹道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 350,
      "line_end": 350
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "隔了片刻道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 350,
      "line_end": 350
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "好，究竟是你忠心。",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 366,
      "line_end": 366
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "承志道：",
      "tone": "焦急",
      "chapter": 18,
      "line_start": 376,
      "line_end": 376
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "伸出手要去拿剑。阿九手一缩，道：",
      "tone": "焦急",
      "chapter": 18,
      "line_start": 376,
      "line_end": 376
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "说着凝视着承志的脸，眼光中的含意甚是明显：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 378,
      "line_end": 378
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "袁承志心想眼下不是解释之时，也非细谈之地，说道：",
      "tone": "低语",
      "chapter": 18,
      "line_start": 386,
      "line_end": 386
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "承志正色道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 422,
      "line_end": 422
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何铁手笑道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 422,
      "line_end": 422
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 426,
      "line_end": 426
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志登时满脸通红，手足失措，道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 432,
      "line_end": 432
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何铁手笑道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 434,
      "line_end": 434
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志点了点头，道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 442,
      "line_end": 442
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "众人登时默不作声。隔了好一会，何红药忽然冷冷的道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 488,
      "line_end": 488
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "众人沉默不语。何铁手道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 494,
      "line_end": 494
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "她连问三声，教众无人回答。何铁手冷笑道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 496,
      "line_end": 496
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "侮慢教主，该当何罪？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 518,
      "line_end": 518
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "含沙射影",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 560,
      "line_end": 560
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "大家住手！",
      "tone": "焦急",
      "chapter": 18,
      "line_start": 566,
      "line_end": 566
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "我来救你！",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 574,
      "line_end": 574
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 578,
      "line_end": 578
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "谁敢上来！",
      "tone": "惊讶",
      "chapter": 18,
      "line_start": 582,
      "line_end": 582
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 588,
      "line_end": 588
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 596,
      "line_end": 596
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青笑道：",
      "tone": "轻笑",
      "chapter": 18,
      "line_start": 602,
      "line_end": 602
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "罗立如道：",
      "tone": "轻笑",
      "chapter": 18,
      "line_start": 602,
      "line_end": 602
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "讯息是否确实？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 606,
      "line_end": 606
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 610,
      "line_end": 610
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "金蛇营",
      "tone": "焦急",
      "chapter": 18,
      "line_start": 614,
      "line_end": 614
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志吃了一惊，道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 618,
      "line_end": 618
    },
    {
      "speaker": "char_jiao_wan_er",
      "speaker_name": "焦宛儿",
      "listener": null,
      "text": "啊哟！",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 622,
      "line_end": 622
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 624,
      "line_end": 624
    },
    {
      "speaker": "char_jiao_wan_er",
      "speaker_name": "焦宛儿",
      "listener": null,
      "text": "焦宛儿道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 628,
      "line_end": 628
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志踌躇道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 630,
      "line_end": 630
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "我去会他们！",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 644,
      "line_end": 644
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "你瞧瞧，我不是好好的吗？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 680,
      "line_end": 680
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "齐云璈道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 684,
      "line_end": 684
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何铁手喝道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 686,
      "line_end": 686
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "齐云璈道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 688,
      "line_end": 688
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "你既诚心悔过，便饶了你这遭，死罪可免，活罪难饶⋯⋯",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 694,
      "line_end": 694
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何铁手摇头道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 722,
      "line_end": 722
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "你怎么跟着我？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 724,
      "line_end": 724
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "忽地在承志面前跪下，连连磕头。承志大惊，忙作揖还礼，说道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 726,
      "line_end": 726
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何铁手道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 728,
      "line_end": 728
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "说着转身便要入内。何铁手大急，叫道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 748,
      "line_end": 748
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 750,
      "line_end": 750
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何铁手道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 750,
      "line_end": 750
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "师父，还是答允了的好。",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 756,
      "line_end": 756
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何铁手大喜，说道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 758,
      "line_end": 758
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "你讲什么故事？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 762,
      "line_end": 762
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "当下正色道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 768,
      "line_end": 768
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何教主⋯⋯",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 772,
      "line_end": 772
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志想了一下，说道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 774,
      "line_end": 774
    },
    {
      "speaker": "char_he_tie_shou",
      "speaker_name": "何铁手",
      "listener": null,
      "text": "何铁手喜道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 780,
      "line_end": 780
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青笑道：",
      "tone": "轻笑",
      "chapter": 18,
      "line_start": 784,
      "line_end": 784
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "何惕守在她耳边悄声道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 786,
      "line_end": 786
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "黄木道长的下落，你对两位说了吧。",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 792,
      "line_end": 792
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "他是在云南丽⋯⋯",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 792,
      "line_end": 792
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "那是炮声。",
      "tone": "惊讶",
      "chapter": 18,
      "line_start": 796,
      "line_end": 796
    },
    {
      "speaker": "char_hong_sheng_hai",
      "speaker_name": "洪胜海",
      "listener": null,
      "text": "闯王大军到啦！",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 798,
      "line_end": 798
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "道长，她已拜我为师。尊师的事，咱们慢一步再说⋯⋯",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 800,
      "line_end": 800
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "金蛇营",
      "tone": "豪迈",
      "chapter": 18,
      "line_start": 812,
      "line_end": 812
    },
    {
      "speaker": "char_li_zi_cheng",
      "speaker_name": "李自成",
      "listener": null,
      "text": "又听东城的闲汉们唱道：",
      "tone": "恳求",
      "chapter": 18,
      "line_start": 822,
      "line_end": 822
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "曹化淳道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 850,
      "line_end": 850
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 852,
      "line_end": 852
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "快开城门，迎接闯王！",
      "tone": "痛苦",
      "chapter": 18,
      "line_start": 856,
      "line_end": 856
    },
    {
      "speaker": "char_hu_gui_nan",
      "speaker_name": "胡桂南",
      "listener": null,
      "text": "金蛇营",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 872,
      "line_end": 872
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "先君故兵部尚书蓟辽督师袁",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 886,
      "line_end": 886
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "正是长平公主阿九。她转头对一名太监道：",
      "tone": "焦急",
      "chapter": 18,
      "line_start": 908,
      "line_end": 908
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "那太监名叫王承恩，垂泪道：",
      "tone": "悲伤",
      "chapter": 18,
      "line_start": 910,
      "line_end": 910
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "悲伤",
      "chapter": 18,
      "line_start": 912,
      "line_end": 912
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "王承恩道：",
      "tone": "悲伤",
      "chapter": 18,
      "line_start": 912,
      "line_end": 912
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 914,
      "line_end": 914
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "你要等袁崇焕的儿子？",
      "tone": "低语",
      "chapter": 18,
      "line_start": 916,
      "line_end": 916
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "崇祯道：",
      "tone": "低语",
      "chapter": 18,
      "line_start": 918,
      "line_end": 918
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九道：",
      "tone": "低语",
      "chapter": 18,
      "line_start": 918,
      "line_end": 918
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "崇祯道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 920,
      "line_end": 920
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "接过阿九手中那柄金蛇宝剑，长叹一声，说道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 920,
      "line_end": 920
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "你动手吧！",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 936,
      "line_end": 936
    },
    {
      "speaker": "char_chong_zhen",
      "speaker_name": "崇祯",
      "listener": null,
      "text": "别杀我父皇，求你⋯⋯",
      "tone": "恳求",
      "chapter": 18,
      "line_start": 940,
      "line_end": 940
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "放下阿九，要待追赶。阿九右手搂住他脖子，哭叫：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 950,
      "line_end": 950
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 964,
      "line_end": 964
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "干么不杀？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 968,
      "line_end": 968
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "青青怒道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 970,
      "line_end": 970
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志尚未回答，何惕守道：",
      "tone": "愤怒",
      "chapter": 18,
      "line_start": 970,
      "line_end": 970
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "什么公主？什么肖像？",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 976,
      "line_end": 976
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "青青横了她一眼道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 978,
      "line_end": 978
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "转身入内去了。何惕守对袁承志道：",
      "tone": "疑问",
      "chapter": 18,
      "line_start": 978,
      "line_end": 978
    }
  ],
