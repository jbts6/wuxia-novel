      "line_start": 212,
      "line_end": 212
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔秋山笑道：",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 214,
      "line_end": 214
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志忙道：",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 214,
      "line_end": 214
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "应松道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 260,
      "line_end": 260
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志一听，已明其意，当即跪下，说道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 272,
      "line_end": 272
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "他不知立誓的规矩，道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 272,
      "line_end": 272
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "很好。",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 276,
      "line_end": 276
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "这招不错！",
      "tone": "欣喜",
      "chapter": 2,
      "line_start": 284,
      "line_end": 284
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔秋山笑道：",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 307,
      "line_end": 307
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "深入虎穴",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 309,
      "line_end": 309
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "不错，就是这样。",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 311,
      "line_end": 311
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志点头受教。崔秋山道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 327,
      "line_end": 327
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 339,
      "line_end": 339
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔秋山笑道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 339,
      "line_end": 339
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔秋山道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 347,
      "line_end": 347
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "灵机一动，道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 347,
      "line_end": 347
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志大为兴奋，忙问：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 349,
      "line_end": 349
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "朱安国等在房内聚谈，听得叫声，开门出来。崔秋山笑道：",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 357,
      "line_end": 357
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "倪浩是杀虎能手，连说：",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 359,
      "line_end": 359
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "倪大哥，别伤那畜生。",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 361,
      "line_end": 361
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志，别出去，咱们在这里看。",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 365,
      "line_end": 365
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "此言一出，众人都吃了一惊。孙仲寿道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 387,
      "line_end": 387
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔秋山道：",
      "tone": "惊讶",
      "chapter": 2,
      "line_start": 389,
      "line_end": 389
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志道：",
      "tone": "惊讶",
      "chapter": 2,
      "line_start": 389,
      "line_end": 389
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "挺了短枪，就去开门。崔秋山道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 391,
      "line_end": 391
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "你怕了么？",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 397,
      "line_end": 397
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "胡",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 397,
      "line_end": 397
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "罗汉传经",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 399,
      "line_end": 399
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "菩萨低眉",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 419,
      "line_end": 419
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "取它眼睛！",
      "tone": "痛苦",
      "chapter": 2,
      "line_start": 431,
      "line_end": 431
    },
    {
      "speaker": "char_li_zi_cheng",
      "speaker_name": "李自成",
      "listener": null,
      "text": "又想：",
      "tone": "惊讶",
      "chapter": 2,
      "line_start": 439,
      "line_end": 439
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "崔秋山打开殿门，在豹子后臀上踢了一脚，笑道：",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 441,
      "line_end": 441
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "罗大千应令去了。孙仲寿又道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 457,
      "line_end": 457
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔大哥，有一件重任要交托给你。",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 461,
      "line_end": 461
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "孙仲寿道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 463,
      "line_end": 463
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "说着和应松两人拜了下去。崔秋山吃了一惊，连忙还礼，说道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 463,
      "line_end": 463
    },
    {
      "speaker": "char_yuan_chong_huan",
      "speaker_name": "袁崇焕",
      "listener": null,
      "text": "崔秋山道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 471,
      "line_end": 471
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "孙叔叔、应叔叔、朱叔叔、倪叔叔，我，我⋯⋯",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 479,
      "line_end": 479
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "你跟着崔叔叔去，要好好听他的话。",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 481,
      "line_end": 481
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔秋山道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 489,
      "line_end": 489
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "毒龙出洞",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 507,
      "line_end": 507
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "弟兄们上啊！",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 509,
      "line_end": 509
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "没受伤吧？",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 523,
      "line_end": 523
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔叔叔，血⋯⋯血⋯⋯",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 523,
      "line_end": 523
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 525,
      "line_end": 525
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔秋山道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 525,
      "line_end": 525
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "一个声音骂道：",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 547,
      "line_end": 547
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "听口音正是应松的声音。承志悄声道：",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 549,
      "line_end": 549
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "那人又骂：",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 549,
      "line_end": 549
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔叔叔。",
      "tone": "痛苦",
      "chapter": 2,
      "line_start": 583,
      "line_end": 583
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志，快走，快走，我挡住他们。",
      "tone": "惊讶",
      "chapter": 2,
      "line_start": 585,
      "line_end": 585
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "凭你这点功夫，居然想保护我。",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 587,
      "line_end": 587
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "崔叔叔！",
      "tone": "惊讶",
      "chapter": 2,
      "line_start": 615,
      "line_end": 615
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 643,
      "line_end": 643
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 651,
      "line_end": 651
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "富贵恒昌",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 653,
      "line_end": 653
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁公子承志周岁之庆",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 653,
      "line_end": 653
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "小将赵率教敬赠",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 653,
      "line_end": 653
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志说：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 665,
      "line_end": 665
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 669,
      "line_end": 669
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "那朝奉脸色登时变了，向袁承志上上下下打量良久，说道：",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 669,
      "line_end": 669
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "拿了项圈到里面去，半天不出来。袁承志和那店伴等的着急，又过了好一会，那朝奉才出来，说道：",
      "tone": "焦急",
      "chapter": 2,
      "line_start": 671,
      "line_end": 671
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "就是这孩子！",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 681,
      "line_end": 681
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "我不是。",
      "tone": "大笑",
      "chapter": 2,
      "line_start": 685,
      "line_end": 685
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志急道：",
      "tone": "大笑",
      "chapter": 2,
      "line_start": 687,
      "line_end": 687
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "那公差笑道：",
      "tone": "大笑",
      "chapter": 2,
      "line_start": 687,
      "line_end": 687
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志不敢回答，奔进店房，猛力去推崔秋山，只听得外面公差喊了起来：",
      "tone": "轻笑",
      "chapter": 2,
      "line_start": 689,
      "line_end": 689
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "横拖单鞭",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 701,
      "line_end": 701
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "避扑击虚",
      "tone": "疑问",
      "chapter": 2,
      "line_start": 737,
      "line_end": 737
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "横踹虎腰",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 739,
      "line_end": 739
    },
    {
      "speaker": "char_an_xiao_hui",
      "speaker_name": "安小慧",
      "listener": null,
      "text": "小慧，快拿茶壶茶碗来。",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 769,
      "line_end": 769
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "小慧道：",
      "tone": "惊讶",
      "chapter": 2,
      "line_start": 791,
      "line_end": 791
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志惊道：",
      "tone": "惊讶",
      "chapter": 2,
      "line_start": 791,
      "line_end": 791
    },
    {
      "speaker": "char_an_xiao_hui",
      "speaker_name": "安小慧",
      "listener": null,
      "text": "承志那里肯听？小慧叫道：",
      "tone": "悲伤",
      "chapter": 2,
      "line_start": 797,
      "line_end": 797
    },
    {
      "speaker": "char_an_xiao_hui",
      "speaker_name": "安小慧",
      "listener": null,
      "text": "他见崔叔叔他们走了，哭起来啦！",
      "tone": "悲伤",
      "chapter": 2,
      "line_start": 799,
      "line_end": 799
    },
    {
      "speaker": "char_an_da_niang",
      "speaker_name": "安大娘",
      "listener": null,
      "text": "承志点点头。安大娘又道：",
      "tone": "温柔",
      "chapter": 2,
      "line_start": 803,
      "line_end": 803
    },
    {
      "speaker": "char_an_xiao_hui",
      "speaker_name": "安小慧",
      "listener": null,
      "text": "你在这里杀鸡，我去买肉。",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 839,
      "line_end": 839
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "岳家神枪",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 849,
      "line_end": 849
    },
    {
      "speaker": "char_an_xiao_hui",
      "speaker_name": "安小慧",
      "listener": null,
      "text": "呸！你这小妞也来找死。",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 859,
      "line_end": 859
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "你这小鬼，不要性命了？",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 883,
      "line_end": 883
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "小鬼，你还敢来么？",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 885,
      "line_end": 885
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "拿了火叉，紧追不舍。那大汉怒从心起，恶念顿生，想道：",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 889,
      "line_end": 889
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "倒扭金钟",
      "tone": "焦急",
      "chapter": 2,
      "line_start": 899,
      "line_end": 899
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "岳家神枪",
      "tone": "焦急",
      "chapter": 2,
      "line_start": 919,
      "line_end": 919
    },
    {
      "speaker": "char_an_da_niang",
      "speaker_name": "安大娘",
      "listener": null,
      "text": "安大娘秀眉直竖，挥湿布横扫过去。胡老三早防到她这着，话刚说完，已转身跃出，远远的戟指骂道：",
      "tone": "愤怒",
      "chapter": 2,
      "line_start": 943,
      "line_end": 943
    },
    {
      "speaker": "char_an_xiao_hui",
      "speaker_name": "安小慧",
      "listener": null,
      "text": "对小慧道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 957,
      "line_end": 957
    },
    {
      "speaker": "char_an_xiao_hui",
      "speaker_name": "安小慧",
      "listener": null,
      "text": "又想：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 967,
      "line_end": 967
    }
  ],
