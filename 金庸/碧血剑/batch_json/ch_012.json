      "speaker_name": "归二娘",
      "listener": null,
      "text": "归二娘道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 484,
      "line_end": 484
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "孟铮道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 486,
      "line_end": 486
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "言下越来越不客气。归二娘厉声道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 488,
      "line_end": 488
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "孟铮道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 494,
      "line_end": 494
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "命家丁搬开厅中桌椅，露出一片空地，叫道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 496,
      "line_end": 496
    },
    {
      "speaker": "char_gui_xin_shu",
      "speaker_name": "归辛树",
      "listener": null,
      "text": "归辛树不爱多言，低声道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 508,
      "line_end": 508
    },
    {
      "speaker": "char_gui_xin_shu",
      "speaker_name": "归辛树",
      "listener": null,
      "text": "旁人没听见，纷纷互相询问。孟铮怒极而笑，大声说道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 510,
      "line_end": 510
    },
    {
      "speaker": "char_gui_xin_shu",
      "speaker_name": "归辛树",
      "listener": null,
      "text": "不错，接招吧！",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 516,
      "line_end": 516
    },
    {
      "speaker": "char_gui_xin_shu",
      "speaker_name": "归辛树",
      "listener": null,
      "text": "泰山压顶",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 516,
      "line_end": 516
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 520,
      "line_end": 520
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 520,
      "line_end": 520
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 522,
      "line_end": 522
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 560,
      "line_end": 560
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "搜那姓董的。",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 570,
      "line_end": 570
    },
    {
      "speaker": "char_gui_xin_shu",
      "speaker_name": "归辛树",
      "listener": null,
      "text": "丸药放在那里？",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 572,
      "line_end": 572
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "归二娘怒问：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 574,
      "line_end": 574
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "董开山道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 576,
      "line_end": 576
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "归二娘又惊又怒，喝道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 576,
      "line_end": 576
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "董开山道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 578,
      "line_end": 578
    },
    {
      "speaker": "char_hu_gui_nan",
      "speaker_name": "胡桂南",
      "listener": null,
      "text": "怎么？",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 592,
      "line_end": 592
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "说着向",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 594,
      "line_end": 594
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "字大锦轴下的一盘寿桃一指。袁承志很是奇怪，低声问道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 594,
      "line_end": 594
    },
    {
      "speaker": "char_hu_gui_nan",
      "speaker_name": "胡桂南",
      "listener": null,
      "text": "胡桂南笑道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 596,
      "line_end": 596
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青在一旁听着，笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 598,
      "line_end": 598
    },
    {
      "speaker": "char_hu_gui_nan",
      "speaker_name": "胡桂南",
      "listener": null,
      "text": "胡桂南笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 600,
      "line_end": 600
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "璇玑",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 606,
      "line_end": 606
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "神庭",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 606,
      "line_end": 606
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "怎么？你又要来多管闲事？",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 608,
      "line_end": 608
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "瓜棚拂扇",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 614,
      "line_end": 614
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "古道扬鞭",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 614,
      "line_end": 614
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "大家住手！",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 632,
      "line_end": 632
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "双龙抢珠",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 634,
      "line_end": 634
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "师父，师娘！快，快，他抢了小师弟⋯⋯",
      "tone": "惊讶",
      "chapter": 12,
      "line_start": 638,
      "line_end": 638
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "青青掷过剑去，袁承志伸左手接住了，叫道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 642,
      "line_end": 642
    },
    {
      "speaker": "char_gui_xin_shu",
      "speaker_name": "归辛树",
      "listener": null,
      "text": "说着要扑上去拚命。归辛树左手拉住，低声道：",
      "tone": "焦急",
      "chapter": 12,
      "line_start": 648,
      "line_end": 648
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "二师哥，请你把孟老爷子的穴道解开了。",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 652,
      "line_end": 652
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "快还我孩子！",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 660,
      "line_end": 660
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "咦！",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 680,
      "line_end": 680
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "这董镖头可真够神的。",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 682,
      "line_end": 682
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "你去问他啊，问我干么？",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 684,
      "line_end": 684
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "嘻嘻哈哈的捧着一把药丸，举起交给承志。袁承志将剑交了给她，空出手来接过一颗药丸，说道：",
      "tone": "大笑",
      "chapter": 12,
      "line_start": 688,
      "line_end": 688
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "归辛树只道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 702,
      "line_end": 702
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青和胡桂南、洪胜海把丸药尽数都递给归二娘，青青笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 702,
      "line_end": 702
    },
    {
      "speaker": "char_gui_xin_shu",
      "speaker_name": "归辛树",
      "listener": null,
      "text": "孟伯飞默然，心想：",
      "tone": "焦急",
      "chapter": 12,
      "line_start": 708,
      "line_end": 708
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "孟铸怒道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 714,
      "line_end": 714
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 714,
      "line_end": 714
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "众人一听，都想：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 718,
      "line_end": 718
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "一拉丈夫，与三个徒弟一齐拜了下去。孟伯飞呵呵笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 734,
      "line_end": 734
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "孟伯飞道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 772,
      "line_end": 772
    },
    {
      "speaker": "char_gui_er_niang",
      "speaker_name": "归二娘",
      "listener": null,
      "text": "归二娘道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 774,
      "line_end": 774
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "孟伯飞道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 776,
      "line_end": 776
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "沙天广道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 776,
      "line_end": 776
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "孟伯飞哈哈笑道：",
      "tone": "大笑",
      "chapter": 12,
      "line_start": 778,
      "line_end": 778
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "承志道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 784,
      "line_end": 784
    },
    {
      "speaker": "char_hong_sheng_hai",
      "speaker_name": "洪胜海",
      "listener": null,
      "text": "燕赵居",
      "tone": "焦急",
      "chapter": 12,
      "line_start": 788,
      "line_end": 788
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "那人不问情由，顺手就是一记耳 光。那掌柜左手按住面颊，又气又急，说道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 802,
      "line_end": 802
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "那人喝道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 802,
      "line_end": 802
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "掌柜忙道：",
      "tone": "焦急",
      "chapter": 12,
      "line_start": 808,
      "line_end": 808
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "沙天广奇道：",
      "tone": "焦急",
      "chapter": 12,
      "line_start": 808,
      "line_end": 808
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "掌柜的悄声道：",
      "tone": "焦急",
      "chapter": 12,
      "line_start": 810,
      "line_end": 810
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "我去教训教训这小子。",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 814,
      "line_end": 814
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "把众人邀入房里，说道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 816,
      "line_end": 816
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "沙天广道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 820,
      "line_end": 820
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 820,
      "line_end": 820
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 834,
      "line_end": 834
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "彼得道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 858,
      "line_end": 858
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "那西洋女人微笑道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 860,
      "line_end": 860
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "彼得道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 860,
      "line_end": 860
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "雷蒙笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 862,
      "line_end": 862
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "彼得道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 862,
      "line_end": 862
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "若克琳笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 864,
      "line_end": 864
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "对青青道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 880,
      "line_end": 880
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "原来是个姑娘，怪不得这般美貌。",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 882,
      "line_end": 882
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "彼得道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 884,
      "line_end": 884
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "雷蒙道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 886,
      "line_end": 886
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "彼得道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 888,
      "line_end": 888
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "雷蒙脸有怒色，问道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 888,
      "line_end": 888
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "若克琳道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 890,
      "line_end": 890
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "抿嘴笑道：",
      "tone": "愤怒",
      "chapter": 12,
      "line_start": 890,
      "line_end": 890
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "通四钱，你过来！",
      "tone": "焦急",
      "chapter": 12,
      "line_start": 894,
      "line_end": 894
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "雷蒙道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 896,
      "line_end": 896
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "钱通四道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 898,
      "line_end": 898
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "雷蒙从袋里抓出十多块金洋，抛在桌上，笑道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 898,
      "line_end": 898
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "亲一个嘴",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 904,
      "line_end": 904
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "哇",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 906,
      "line_end": 906
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "啊，啊",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 906,
      "line_end": 906
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "这女孩子果然有点力气！",
      "tone": "大笑",
      "chapter": 12,
      "line_start": 908,
      "line_end": 908
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青弟，你过来。",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 914,
      "line_end": 914
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 916,
      "line_end": 916
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 920,
      "line_end": 920
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志喜道：",
      "tone": "欣喜",
      "chapter": 12,
      "line_start": 922,
      "line_end": 922
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "快来，快来！",
      "tone": "欣喜",
      "chapter": 12,
      "line_start": 924,
      "line_end": 924
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "雷震剑法",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 932,
      "line_end": 932
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "回去把金柱给两个军官看。雷蒙道：",
      "tone": "惊讶",
      "chapter": 12,
      "line_start": 952,
      "line_end": 952
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "彼得道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 954,
      "line_end": 954
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "胡桂南道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 958,
      "line_end": 958
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "沙天广笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 958,
      "line_end": 958
    },
    {
      "speaker": "char_hu_gui_nan",
      "speaker_name": "胡桂南",
      "listener": null,
      "text": "胡桂南笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 960,
      "line_end": 960
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "沙天广笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 962,
      "line_end": 962
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "程青竹笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 976,
      "line_end": 976
    },
    {
      "speaker": "char_sha_tian_guang",
      "speaker_name": "沙天广",
      "listener": null,
      "text": "袁承志笑着点点头。阿九向沙天广道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 986,
      "line_end": 986
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "阿九道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 992,
      "line_end": 992
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "程青竹道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 992,
      "line_end": 992
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九很是欢喜，说道：",
      "tone": "欣喜",
      "chapter": 12,
      "line_start": 994,
      "line_end": 994
    },
    {
      "speaker": "char_a_jiu",
      "speaker_name": "阿九",
      "listener": null,
      "text": "阿九早瞧出她是女子，脸上一红，唔了一声，道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1008,
      "line_end": 1008
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "袁承志道：",
      "tone": "低语",
      "chapter": 12,
      "line_start": 1018,
      "line_end": 1018
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "程青竹低声道：",
      "tone": "低语",
      "chapter": 12,
      "line_start": 1018,
      "line_end": 1018
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "陈述",
