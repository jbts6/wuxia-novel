    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "程青竹道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 1028,
      "line_end": 1028
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "袁承志点头道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 1030,
      "line_end": 1030
    },
    {
      "speaker": "char_cheng_qing_zhu",
      "speaker_name": "程青竹",
      "listener": null,
      "text": "程青竹道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 1030,
      "line_end": 1030
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "袁承志道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 1032,
      "line_end": 1032
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "门外青青笑道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1042,
      "line_end": 1042
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "多谢了，这么晚了，怎还不睡？",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1044,
      "line_end": 1044
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "说着浅浅一笑。袁承志笑道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1046,
      "line_end": 1046
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青笑道：",
      "tone": "轻笑",
      "chapter": 12,
      "line_start": 1048,
      "line_end": 1048
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "袁承志知她很小性儿，如说阿九美，定要不高兴，说阿九不美吧，又是明明撒谎，既违良心，她也不信，只得笑道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1050,
      "line_end": 1050
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1052,
      "line_end": 1052
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "袁承志拿匙羹抄了个鸡蛋，咬了一口，突然把匙羹一掷，叫道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1052,
      "line_end": 1052
    },
    {
      "speaker": "char_yuan_cheng_zhi",
      "speaker_name": "袁承志",
      "listener": null,
      "text": "什么是他？",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1056,
      "line_end": 1056
    },
    {
      "speaker": "char_hong_sheng_hai",
      "speaker_name": "洪胜海",
      "listener": null,
      "text": "青青见他不吃鸡蛋，有些着恼，问：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1058,
      "line_end": 1058
    },
    {
      "speaker": "char_hong_sheng_hai",
      "speaker_name": "洪胜海",
      "listener": null,
      "text": "袁承志从洪胜海身旁拿了一柄剑，交给她道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1058,
      "line_end": 1058
    },
    {
      "speaker": "char_wen_qing_qing",
      "speaker_name": "温青青",
      "listener": null,
      "text": "青青点点头，低声道：",
      "tone": "低语",
      "chapter": 12,
      "line_start": 1068,
      "line_end": 1068
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "那人道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1086,
      "line_end": 1086
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "一人道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1086,
      "line_end": 1086
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "那安大人道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1088,
      "line_end": 1088
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "一人道：",
      "tone": "大笑",
      "chapter": 12,
      "line_start": 1090,
      "line_end": 1090
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "安大人道：",
      "tone": "大笑",
      "chapter": 12,
      "line_start": 1090,
      "line_end": 1090
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "众人道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 1092,
      "line_end": 1092
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "安大人道：",
      "tone": "陈述",
      "chapter": 12,
      "line_start": 1092,
      "line_end": 1092
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "谁啊？",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1110,
      "line_end": 1110
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "女人声音惊道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1112,
      "line_end": 1112
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "安大人叫道：",
      "tone": "惊讶",
      "chapter": 12,
      "line_start": 1114,
      "line_end": 1114
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "声音中显得又惊又喜。那女人道：",
      "tone": "惊讶",
      "chapter": 12,
      "line_start": 1116,
      "line_end": 1116
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "安大人笑道：",
      "tone": "疑问",
      "chapter": 12,
      "line_start": 1118,
      "line_end": 1118
    },
    {
      "speaker": null,
      "speaker_name": "未知",
      "listener": null,
      "text": "那女人怒道：",
      "tone": "愤怒",
