{"segment":33,"line_start":1207,"line_end":1252,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"他越下越得意，又道：","tone":"陈述","chapter":9,"line_start":1210,"line_end":1210},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"袁承志奇道：","tone":"陈述","chapter":9,"line_start":1224,"line_end":1224},{"speaker":"char_mu_sang_dao_ren","speaker_name":"木桑道人","listener":null,"text":"木桑叹了口气，说道：","tone":"陈述","chapter":9,"line_start":1226,"line_end":1226},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"袁承志见他脸有忧色，浑不是平时潇洒自若的模样，知他此行关系重大，说道：","tone":"焦急","chapter":9,"line_start":1234,"line_end":1234},{"speaker":"char_mu_sang_dao_ren","speaker_name":"木桑道人","listener":null,"text":"木桑摇摇头：","tone":"焦急","chapter":9,"line_start":1236,"line_end":1236},{"speaker":"char_mu_sang_dao_ren","speaker_name":"木桑道人","listener":null,"text":"木桑道：","tone":"恳求","chapter":9,"line_start":1248,"line_end":1248}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":34,"line_start":1253,"line_end":1290,"dialogues":[{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"袁承志会意，说道：","tone":"轻笑","chapter":9,"line_start":1258,"line_end":1258},{"speaker":"char_mu_sang_dao_ren","speaker_name":"木桑道人","listener":null,"text":"大有长进，大有长进！","tone":"陈述","chapter":9,"line_start":1262,"line_end":1262},{"speaker":"char_mu_sang_dao_ren","speaker_name":"木桑道人","listener":null,"text":"沉吟片刻，转去东北角下了一子。木桑呵呵大笑，续在西隅下子，说道：","tone":"大笑","chapter":9,"line_start":1270,"line_end":1270},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"袁承志笑道：","tone":"轻笑","chapter":9,"line_start":1278,"line_end":1278},{"speaker":"char_jiao_wan_er","speaker_name":"焦宛儿","listener":null,"text":"木桑呵呵大笑，打从心底里欢喜出来，自吹自擂一会，才转头对宛儿道：","tone":"大笑","chapter":9,"line_start":1280,"line_end":1280},{"speaker":"char_yuan_cheng_zhi","speaker_name":"袁承志","listener":null,"text":"右脚飞出，将一名奸细踢得脑浆迸裂。他伸脚又待再踢，袁承志道：","tone":"愤怒","chapter":9,"line_start":1290,"line_end":1290}],"new_entities":{"characters":[{"id":"char_hong_sheng_hai","name":"洪胜海","alias":["洪胜海"],"identity":"江湖人物，曾受制于袁承志后转为追随。","faction":null,"role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"由敌转友、受袁承志信任的江湖人。","personality":{"traits":["知恩","机警","务实","勇敢","谨慎"],"speech_style":"恭谨实际。","temperament":"由桀骜转为忠诚。"},"relationships":[{"target":"char_yuan_cheng_zhi","type":"合作者","intensity":65,"bond_level":3,"dynamic":"受制后感念信任"}],"known_skills":[],"related_skills":[],"rag_refs":[9],"source_refs":[{"chapter":9,"line_start":1286,"line_end":1286,"text":"书信中有一封是满清九王多尔衮写信给北京皇宫司礼太监曹化淳的，说道关口盘查严密，是以特地绕道，从海上派遣使者前来，机密大事，可与持信的使者洪胜海接头云云。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
