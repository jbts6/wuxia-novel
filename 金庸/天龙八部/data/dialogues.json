[
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": "char_zhong_ling", "text": "咱们有福共享，有难同当，瓜子一齐吃，刀剑一块挨。", "tone": "陈述", "chapter": 1, "line_start": 100, "line_end": 102},
  {"speaker": null, "speaker_name": "钟灵", "listener": "char_zi_mu", "text": "我的尊姓大名，可不能跟你说，这叫做天机不可泄漏。", "tone": "调侃", "chapter": 1, "line_start": 80, "line_end": 82},
  {"speaker": null, "speaker_name": "钟灵", "listener": "char_zi_mu", "text": "哈哈，我才不上你的当呢。我跟你说我令尊是谁，你便知道我的尊姓了。", "tone": "调侃", "chapter": 1, "line_start": 84, "line_end": 86},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": null, "text": "这么高，跳下来可不摔坏了么？你快叫人去拿架梯子来！", "tone": "焦急", "chapter": 1, "line_start": 50, "line_end": 52},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": "char_nan_hai_e_shen", "text": "你的规矩，乃是'不杀无力还手之人'这八个字，是不是？", "tone": "陈述", "chapter": 4, "line_start": 280, "line_end": 282},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": "char_nan_hai_e_shen", "text": "很好，很好！你没有打木姑娘，木姑娘却放箭射你，这并不是'还手'，这是'先下手为强'。你如杀她，那便是改了你的规矩，你如改了规矩，那便是乌龟儿子王八蛋。", "tone": "陈述", "chapter": 4, "line_start": 290, "line_end": 295},
  {"speaker": null, "speaker_name": "木婉清", "listener": "char_duan_yu", "text": "我杀他不得，惟有自尽。", "tone": "悲伤", "chapter": 4, "line_start": 260, "line_end": 262},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": null, "text": "佛经有云：'无量有四：一慈、二悲、三喜、四舍。'", "tone": "陈述", "chapter": 1, "line_start": 20, "line_end": 22},
  {"speaker": null, "speaker_name": "钟夫人", "listener": "char_duan_yu", "text": "别忘了跟你爹爹说，钟夫人说：'请他出手救我们的女儿。'这十个字。", "tone": "恳求", "chapter": 2, "line_start": 400, "line_end": 402},
  {"speaker": null, "speaker_name": "玉虚散人", "listener": "char_mu_wan_qing", "text": "姑娘，我这个孩儿淘气得紧，爹娘管他不住，以后你得帮我管管他才是。", "tone": "欣喜", "chapter": 7, "line_start": 10, "line_end": 12},
  {"speaker": null, "speaker_name": "木婉清", "listener": "char_dao_bai_feng", "text": "师恩深重，师命难违！", "tone": "愤怒", "chapter": 7, "line_start": 30, "line_end": 32},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": "char_mu_wan_qing", "text": "婉妹，都是我不好。你别生气，咱们慢慢想法子逃出去。", "tone": "恳求", "chapter": 7, "line_start": 300, "line_end": 302},
  {"speaker": "char_duan_zheng_ming", "speaker_name": "保定帝", "listener": null, "text": "咱们只有一面凭正道行事，一面谦逊自抑，处处让人一步。淳弟，你须牢牢记得'持正忍让'这四个字。", "tone": "陈述", "chapter": 9, "line_start": 380, "line_end": 383},
  {"speaker": "char_jiu_mo_zhi", "speaker_name": "鸠摩智", "listener": null, "text": "小僧生平有一知交，是大宋姑苏人氏，复姓慕容，单名一个'博'字。昔年小僧与彼邂逅相逢，讲武论剑。", "tone": "陈述", "chapter": 10, "line_start": 200, "line_end": 203},
  {"speaker": null, "speaker_name": "枯荣大师", "listener": "char_jiu_mo_zhi", "text": "明王既坚要此经，老衲等又何敢吝惜？我们便以六脉神剑，领教明王几手高招。", "tone": "陈述", "chapter": 10, "line_start": 320, "line_end": 323},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": null, "text": "阿朱、阿碧两位姊姊，你们快快逃走，再迟便来不及了。", "tone": "焦急", "chapter": 11, "line_start": 350, "line_end": 352},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": null, "text": "你们是我朋友啊！这和尚自恃武功高强，横行霸道的欺侮人。只可惜我不会武功，敌他不过，你们快快走罢。", "tone": "愤怒", "chapter": 11, "line_start": 355, "line_end": 358},
  {"speaker": null, "speaker_name": "王夫人", "listener": null, "text": "你已有了妻子，就不该再去纠缠别家闺女，既然花言巧语的将人家骗上了，那就非得娶她为妻不可。", "tone": "冷酷", "chapter": 12, "line_start": 100, "line_end": 103},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": null, "text": "岂有此理，岂有此理！", "tone": "激动", "chapter": 12, "line_start": 110, "line_end": 112},
  {"speaker": "char_xiao_feng", "speaker_name": "乔峰", "listener": "char_bao_bu_tong", "text": "原来是包三先生，在下久慕英名，今日得见尊范，大是幸事。", "tone": "陈述", "chapter": 14, "line_start": 180, "line_end": 182},
  {"speaker": "char_xiao_feng", "speaker_name": "乔峰", "listener": null, "text": "众位兄弟，我今日好生欢喜，新交了一位好朋友，这位是大理段氏的段誉兄弟，我二人意气相投，已结拜为金兰兄弟。", "tone": "欣喜", "chapter": 14, "line_start": 400, "line_end": 403},
  {"speaker": "char_xiao_feng", "speaker_name": "乔峰", "listener": "char_quan_guan_qing", "text": "你煽动叛乱，一死难免，只是今日暂且寄下，待真相大白之后，我再亲自杀你。你去罢，解下背上布袋，自今而后，丐帮中没了你这号人物。", "tone": "冷酷", "chapter": 15, "line_start": 50, "line_end": 55},
  {"speaker": null, "speaker_name": "全冠清", "listener": "char_xiao_feng", "text": "乔峰，你好泰然自若！难道你自己真的不知？", "tone": "嘲讽", "chapter": 15, "line_start": 70, "line_end": 72},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": null, "text": "你干什么？", "tone": "愤怒", "chapter": 16, "line_start": 380, "line_end": 382},
  {"speaker": "char_xiao_feng", "speaker_name": "乔峰", "listener": null, "text": "乔某有事相求薛神医，还盼鲍兄引路。", "tone": "陈述", "chapter": 19, "line_start": 20, "line_end": 22},
  {"speaker": null, "speaker_name": "鲍千灵", "listener": null, "text": "乔兄肯去，再好也没有了。自来会无好会，宴无好宴，乔兄此去凶多吉少，莫怪鲍千灵事先不加关照。", "tone": "陈述", "chapter": 19, "line_start": 30, "line_end": 33},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": "char_a_zhu", "text": "从今而后，我是萧峰，不再是乔峰了。", "tone": "悲伤", "chapter": 21, "line_start": 120, "line_end": 122},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": "char_a_zhu", "text": "阿朱，你对我这么好，不以我是契丹贱种而厌弃我么？", "tone": "恳求", "chapter": 21, "line_start": 350, "line_end": 352},
  {"speaker": "char_a_zhu", "speaker_name": "阿朱", "listener": "char_xiao_feng", "text": "汉人是人，契丹人也是人，又有什么贵贱之分？我……我喜欢做契丹人，这是真心诚意，半点也不勉强。", "tone": "陈述", "chapter": 21, "line_start": 355, "line_end": 358},
  {"speaker": "char_a_zhu", "speaker_name": "阿朱", "listener": "char_xiao_feng", "text": "便跟着你杀人放火，打家劫舍，也永不后悔。跟着你吃尽千般苦楚，万种熬煎，也是欢欢喜喜。", "tone": "欣喜", "chapter": 21, "line_start": 365, "line_end": 368},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": "char_a_zhu", "text": "萧某得有今日，别说要我重当丐帮帮主，便叫我做大宋皇帝，我也不干。阿朱，这就到信阳找马夫人去，一句话问过，咱们便到塞外打猎放羊去也！", "tone": "欣喜", "chapter": 21, "line_start": 370, "line_end": 375},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": "char_a_zhu", "text": "从今而后，你别再叫我什么大爷、二爷了，你叫我大哥！", "tone": "欣喜", "chapter": 21, "line_start": 380, "line_end": 382},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": null, "text": "阿朱，阿朱！", "tone": "悲伤", "chapter": 23, "line_start": 200, "line_end": 202},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": null, "text": "不错，是我打死了你姊姊，你该为你姊姊报仇。快，快杀了我罢！", "tone": "悲痛", "chapter": 23, "line_start": 210, "line_end": 213},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": null, "text": "段正淳，我杀了你女儿，你来杀我啊，我决不还手，你快出来，快来杀我！", "tone": "悲痛", "chapter": 23, "line_start": 300, "line_end": 303},
  {"speaker": "char_a_zi", "speaker_name": "阿紫", "listener": "char_xiao_feng", "text": "姊夫，我不是怕回去受师父责罚，他最多不过杀了我，杀就杀好了。我是舍不得离开你，我要永永远远陪在你身边。", "tone": "恳求", "chapter": 27, "line_start": 200, "line_end": 204},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": null, "text": "干什么啊？为什么话也没说，便动手杀人？", "tone": "愤怒", "chapter": 26, "line_start": 150, "line_end": 152},
  {"speaker": "char_xu_zhu", "speaker_name": "虚竹", "listener": null, "text": "我来解这棋局。", "tone": "陈述", "chapter": 31, "line_start": 200, "line_end": 202},
  {"speaker": null, "speaker_name": "苏星河", "listener": "char_xu_zhu", "text": "胡闹，胡闹，你自填一气，共活变成不活，自己杀死一块白棋，那有这等下棋的？", "tone": "愤怒", "chapter": 31, "line_start": 210, "line_end": 213},
  {"speaker": "char_xu_zhu", "speaker_name": "虚竹", "listener": null, "text": "小僧棋艺低劣，胡乱下子，志在救人。这盘棋小僧是不会下的，请老前辈原谅。", "tone": "陈述", "chapter": 31, "line_start": 230, "line_end": 233},
  {"speaker": null, "speaker_name": "天山童姥", "listener": "char_xu_zhu", "text": "你不听我话，要自行离去，是不是？", "tone": "冷酷", "chapter": 35, "line_start": 300, "line_end": 302},
  {"speaker": null, "speaker_name": "天山童姥", "listener": null, "text": "你们当我是谁？你姥姥身如女童，难道你们瞎了眼，瞧不出来？", "tone": "愤怒", "chapter": 35, "line_start": 350, "line_end": 353},
  {"speaker": "char_xu_zhu", "speaker_name": "虚竹", "listener": null, "text": "我以为你是个借尸还魂的老女鬼！", "tone": "陈述", "chapter": 35, "line_start": 360, "line_end": 362},
  {"speaker": "char_xuan_ci", "speaker_name": "玄慈", "listener": "char_xu_zhu", "text": "你在寺中二十四年，我竟始终不知你便是我的儿子！", "tone": "悲伤", "chapter": 42, "line_start": 400, "line_end": 403},
  {"speaker": null, "speaker_name": "叶二娘", "listener": null, "text": "我不苦！你有苦说不出，那才是真苦。", "tone": "悲伤", "chapter": 42, "line_start": 420, "line_end": 422},
  {"speaker": "char_xuan_ci", "speaker_name": "玄慈", "listener": null, "text": "二娘，既已作下了恶业，反悔固然无用，隐瞒也是无用。这些年来，可苦了你啦！", "tone": "悲伤", "chapter": 42, "line_start": 415, "line_end": 418},
  {"speaker": "char_xuan_ci", "speaker_name": "玄慈", "listener": "char_xu_zhu", "text": "虚竹，你自立门户，日后当走侠义正道，约束门人弟子，令他们不致为非作歹，祸害江湖，那便是广积福德资粮，多种善因，在家出家，都是一样。", "tone": "陈述", "chapter": 42, "line_start": 250, "line_end": 255},
  {"speaker": "char_duan_yu", "speaker_name": "段誉", "listener": "char_mu_rong_fu", "text": "慕容公子，我善言劝你，荣华富贵，转瞬成空，你就算做成了西夏驸马，再要做大燕皇帝，还不知要杀多少人？", "tone": "陈述", "chapter": 45, "line_start": 200, "line_end": 204},
  {"speaker": "char_mu_rong_fu", "speaker_name": "慕容复", "listener": "char_duan_yu", "text": "你满口子仁义道德，一肚皮却是蛇蝎心肠。", "tone": "嘲讽", "chapter": 45, "line_start": 210, "line_end": 212},
  {"speaker": "char_mu_rong_fu", "speaker_name": "慕容复", "listener": null, "text": "对付你这等小人，又岂能用君子手段？", "tone": "冷酷", "chapter": 45, "line_start": 250, "line_end": 252},
  {"speaker": null, "speaker_name": "王语嫣", "listener": "char_mu_rong_fu", "text": "表哥，我对你一片真心，难道……难道你还不信么？", "tone": "悲伤", "chapter": 45, "line_start": 280, "line_end": 283},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": "char_mu_rong_fu", "text": "慕容公子、庄帮主、丁老怪，你们便三位齐上，萧某何惧？", "tone": "愤怒", "chapter": 41, "line_start": 350, "line_end": 353},
  {"speaker": "char_ye_lv_hong_ji", "speaker_name": "耶律洪基", "listener": "char_xiao_feng", "text": "兄弟，你所以铸成这个大错，推寻罪魁祸首，都是那些汉人南蛮不好。你也休得烦恼，我克日兴兵，讨伐南蛮。", "tone": "陈述", "chapter": 49, "line_start": 100, "line_end": 104},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": null, "text": "阿朱就是阿朱，四海列国，千秋万载，就只一个阿朱。岂是一千个、一万个汉人美女所能代替得了的？", "tone": "悲伤", "chapter": 49, "line_start": 110, "line_end": 114},
  {"speaker": "char_xiao_feng", "speaker_name": "萧峰", "listener": "char_ye_lv_hong_ji", "text": "多谢陛下厚恩，只是臣与中原武人之间的仇怨，已一笔勾销。战衅一启，兵连祸结，更加非同小可。", "tone": "陈述", "chapter": 49, "line_start": 120, "line_end": 124}
]
