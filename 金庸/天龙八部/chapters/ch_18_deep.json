  "dialogues": [
    {
      "speaker": "char_azhu",
      "listener": "char_duanyu",
      "text": "段公子，要乔装我家公子，实在颇为不易。好在丐帮诸人本来不识我家公子，他的声音笔貌到底如何，只须得个大意也就是了。",
      "tone": "俏皮",
      "chapter": 18
    },
    {
      "speaker": "char_nanhaieshen",
      "listener": "char_duanyu",
      "text": "你自称于天下武功无所不知，无所不晓，如能走得三步'凌波微步'，岳老二便服了你。",
      "tone": "挑衅",
      "chapter": 18
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_nanhaieshen",
      "text": "凌波微步虽难，在下却也曾学得几步。岳老爷子，你倒来捉捉我看。",
      "tone": "从容",
      "chapter": 18
    },
    {
      "speaker": "char_azhu",
      "listener": "char_nanhaieshen",
      "text": "南海鳄神，慕容公子这凌波微步，比之你师父如何？",
      "tone": "激将",
      "chapter": 18
    },
    {
      "speaker": "char_qiaofeng",
      "listener": "char_yunzhonghe",
      "text": "我乔峰和丐帮再无瓜葛，要这打狗棒何用？徐长老，你也将乔峰瞧得忒也小了。",
      "tone": "悲凉",
      "chapter": 18
    },
    {
      "speaker": "char_xuanku",
      "listener": "char_qiaofeng",
      "text": "你……你……原来便是你，你便是乔峰，我……我亲手调教出来的好徒儿？",
      "tone": "惊骇悲恸",
      "chapter": 18
    },
    {
      "speaker": "char_xuanku",
      "listener": "char_zhuseng",
      "text": "小弟受戒之日，先师给我取名为玄苦。佛祖所说七苦，乃是生、老、病、死、怨憎会、爱别离、求不得。",
      "tone": "平静禅机",
      "chapter": 18
    },
    {
      "speaker": "char_xuanci",
      "listener": "char_qiaofeng",
      "text": "阿弥陀佛，乔施主，你到少林寺来杀人之余，又再损毁佛像。",
      "tone": "威严",
      "chapter": 18
    },
    {
      "speaker": "char_xuanji",
      "listener": "char_qiaofeng",
      "text": "吃我一掌！",
      "tone": "怒喝",
      "chapter": 18
    },
    {
      "speaker": "char_qiaofeng",
      "listener": "char_azhu",
      "text": "我只须静坐吐纳，练上几个时辰，真气内力便又恢复如常，又说得上什么报答？我和你家主人慕容公子千里神交，虽未见面，我心中已将他当作了朋友。",
      "tone": "豪迈诚恳",
      "chapter": 18
    }
  ]
}
