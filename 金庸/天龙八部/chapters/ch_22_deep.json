  "dialogues": [
    {
      "speaker": "char_gu_du_cheng",
      "listener": "char_xiao_feng",
      "text": "你……你是好人还是恶人？",
      "tone": "疯癫",
      "chapter": 22
    },
    {
      "speaker": "char_ruan_xing_zhu",
      "listener": "char_duan_zheng_chun",
      "text": "是男人我就救，若是女人，你免开尊口。",
      "tone": "娇嗔",
      "chapter": 22
    },
    {
      "speaker": "char_ruan_xing_zhu",
      "listener": "char_duan_zheng_chun",
      "text": "我叫你永远住在这儿，你也依我么？",
      "tone": "幽怨",
      "chapter": 22
    },
    {
      "speaker": "char_a_zi",
      "listener": "char_xiao_feng",
      "text": "我便是喜欢无端杀生，你待怎样？",
      "tone": "刁蛮",
      "chapter": 22
    },
    {
      "speaker": "char_chu_wan_li",
      "listener": "char_duan_zheng_chun",
      "text": "主公，褚万里宁死不辱，一生对得住大理段家。",
      "tone": "壮烈",
      "chapter": 22
    },
    {
      "speaker": "char_a_zi",
      "listener": "char_zhong_ren",
      "text": "人家叫你主公，那我便是他的小主人。杀死一两个奴仆，又有什么了不起了？",
      "tone": "轻蔑",
      "chapter": 22
    },
    {
      "speaker": "char_duan_zheng_chun",
      "listener": "char_duan_yan_qing",
      "text": "你要杀我，尽管来取我性命便是。我段氏以仁义治国，多杀无辜，纵然得国，时候也不久长。",
      "tone": "凛然",
      "chapter": 22
    },
    {
      "speaker": "char_a_zi",
      "listener": "char_duan_zheng_chun",
      "text": "我爹爹如是英雄好汉，我便认他。他倘若是无耻之徒，打架要靠人帮手，我认这种爹爹作甚？",
      "tone": "讥嘲",
      "chapter": 22
    },
    {
      "speaker": "char_nan_hai_e_shen",
      "listener": "char_xiao_feng",
      "text": "你将我摔下湖去，用的是什么手法？老子这功夫倒是不会。",
      "tone": "莽撞",
      "chapter": 22
    },
    {
      "speaker": "char_a_zi",
      "listener": "char_nan_hai_e_shen",
      "text": "好吧，我跟你说了。他这功夫叫做掷龟功。",
      "tone": "嘲讽",
      "chapter": 22
    }
  ]
}
