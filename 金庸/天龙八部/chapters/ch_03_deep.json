  "dialogues": [
    {
      "speaker": "char_ruipo",
      "listener": "char_duanyu",
      "text": "小子你油头粉脸，是这小贱人的相好吗？",
      "tone": "阴冷",
      "chapter": 3
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_ruipo",
      "text": "这位姑娘我生平从来没见过。不过瑞婆婆哪，我劝你说话客气些。你开口骂人，这位姑娘大人大量，不来跟你计较，你自己的人品可就不怎么高明了。",
      "tone": "不卑不亢",
      "chapter": 3
    },
    {
      "speaker": "char_muwanqing",
      "listener": "char_duanyu",
      "text": "你为我送了性命，不后悔么？",
      "tone": "冰冷",
      "chapter": 3
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_muwanqing",
      "text": "死而无悔。",
      "tone": "坚定",
      "chapter": 3
    },
    {
      "speaker": "char_muwanqing",
      "listener": "char_duanyu",
      "text": "你手无缚鸡之力，逞什么英雄好汉？",
      "tone": "讥讽",
      "chapter": 3
    },
    {
      "speaker": "char_muwanqing",
      "listener": "char_duanyu",
      "text": "你服了么？听我的话了么？",
      "tone": "冷傲",
      "chapter": 3
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_muwanqing",
      "text": "不服，不服！不听，不听！适才我死在临头，尚自不惧。你小小折磨我一下，我怕……我怕……",
      "tone": "倔强",
      "chapter": 3
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_muwanqing",
      "text": "大丈夫行事，但求义所当为，有何后悔可言？",
      "tone": "慷慨",
      "chapter": 3
    },
    {
      "speaker": "char_muwanqing",
      "listener": "char_duanyu",
      "text": "我本不想杀你，可是你私自逃走不算，还偷了我的黑玫瑰，这还算是大丈夫吗？",
      "tone": "冰冷",
      "chapter": 3
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_muwanqing",
      "text": "我又不是你奴仆，要走便走，怎说得上'私自逃走'四字？黑玫瑰是你先前借给我的，我并没还你，可算不得偷。你要杀就杀好了。",
      "tone": "从容",
      "chapter": 3
    },
    {
      "speaker": "char_sikongxuan",
      "listener": "char_duanyu",
      "text": "神农帮司空玄，恭请童姥万寿圣安！",
      "tone": "惶恐恭敬",
      "chapter": 3
    },
    {
      "speaker": "char_muwanqing",
      "listener": "char_duanyu",
      "text": "喂，段誉，我的名字，不用钟灵这小鬼跟你说，我自己说好了，我叫木婉清。",
      "tone": "冷傲",
      "chapter": 3
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_muwanqing",
      "text": "啊，水木清华，婉兮清扬。姓得好，名字也好。",
      "tone": "赞叹",
      "chapter": 3
    },
    {
      "speaker": "char_muwanqing",
      "listener": "char_duanyu",
      "text": "好过你的一段木头，名誉极坏。",
      "tone": "讥讽",
      "chapter": 3
    }
  ]
}
