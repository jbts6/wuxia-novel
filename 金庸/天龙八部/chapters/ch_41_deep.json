  "dialogues": [
    {
      "speaker": "char_xiaofeng",
      "listener": "char_duanyu",
      "text": "兄弟，你我生死与共，不枉了结义一场，死也罢，活也罢，大家痛痛快快地喝他一场。",
      "tone": "豪迈",
      "chapter": 41
    },
    {
      "speaker": "char_xuzhu",
      "listener": "char_xiaofeng",
      "text": "大哥，三弟，你们喝酒，怎么不来叫我？",
      "tone": "激昂",
      "chapter": 41
    },
    {
      "speaker": "char_xiaofeng",
      "listener": "char_furongfu",
      "text": "慕容公子、庄帮主、丁老怪，你们便三位齐上，萧某何惧？",
      "tone": "豪迈不屑",
      "chapter": 41
    },
    {
      "speaker": "char_azi",
      "listener": "char_youtanzhi",
      "text": "贤哥，这里人多得很啊，我好像听到有人在大唱什么'星宿老仙，德配天地，威震寰宇，古今无比。'丁春秋这小子和他的虾兵蟹将，也都来了么？",
      "tone": "得意",
      "chapter": 41
    },
    {
      "speaker": "char_youtanzhi",
      "listener": "char_dingchunqiu",
      "text": "师父在上，弟子……弟子庄聚贤磕头！",
      "tone": "惶急",
      "chapter": 41
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_wangyuyan",
      "text": "王姑娘，待会倘若情势凶险，我再负你出去。",
      "tone": "关切",
      "chapter": 41
    },
    {
      "speaker": "char_wangyuyan",
      "listener": "char_duanyu",
      "text": "我表哥武功高强，护我绰绰有余。段公子，你还是出去吧。",
      "tone": "疏离",
      "chapter": 41
    },
    {
      "speaker": "char_furongfu",
      "listener": "char_duanyu",
      "text": "段兄要做抱打不平的英雄好汉，一并上来赐教便是。",
      "tone": "冷傲",
      "chapter": 41
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_furongfu",
      "text": "你敢打我爹爹？",
      "tone": "愤怒",
      "chapter": 41
    },
    {
      "speaker": "char_xuanci",
      "listener": "char_youtanzhi",
      "text": "庄帮主已拜丁先生为师，算是星宿派门人了。星宿派乃西域门派，非我大宋武林同道。阁下是星宿派门人，却也不便参与了。",
      "tone": "庄重",
      "chapter": 41
    }
  ]
