  "events": [
    {
      "id": "evt_09_zhongji_zhuanbian",
      "name": "段誉从石室抱出钟灵，钟万仇害人反害己",
      "participants": ["char_duanyu", "char_zhongling", "char_zhongwanchou", "char_duanzhengchun", "char_baodingdi", "char_daobaifeng"],
      "location": "loc_wanjiegue",
      "description": "钟万仇与四大恶人合力推开石屋大石，本欲当众羞辱段誉与木婉清乱伦，不料段誉抱出的是钟灵。钟万仇害人反害己，羞怒交加掌掴女儿。段正淳反讽说钟灵已是他段家之人",
      "chapter": 9
    },
    {
      "id": "evt_09_didao_diaobao",
      "name": "华赫艮以地道掉包木婉清与钟灵",
      "participants": ["char_huahuagen", "char_fanhua", "char_batianshi", "char_duanyu", "char_muwanqing", "char_zhongling"],
      "location": "loc_wanjiegue",
      "description": "华赫艮奉保定帝之命挖掘地道至石屋，大理三公本欲救段誉，但段誉狂走疾奔不可接近。范骅灵机一动，将钟灵外衫给木婉清穿上，抱起钟灵交给段誉，自己带木婉清从地道逃走",
      "chapter": 9
    },
    {
      "id": "evt_09_huangmei_duiyi",
      "name": "黄眉僧与延庆太子弈棋比拼内力",
      "participants": ["char_huangmeiseng", "char_duanyanqing", "char_duanyu"],
      "location": "loc_wanjiegue",
      "description": "黄眉僧与段延庆比拼内力兼弈棋一日一夜，双方在青石上刻棋盘对弈，正打一个生死劫。段誉见黄眉僧将败，伸手抓延庆太子铁杖，以北冥神功吸取其内力，延庆太子内力失控铁杖误落填死活眼，棋差一着败走",
      "chapter": 9
    },
    {
      "id": "evt_09_zhongling_shenshi",
      "name": "木婉清交出金盒，揭穿钟灵身份",
      "participants": ["char_muwanqing", "char_duanzhengchun", "char_daobaifeng"],
      "location": "loc_dali",
      "description": "宴席上木婉清将甘宝宝所托金盒交给段正淳，内装钟灵生辰八字。段正淳从背后小字推算钟灵是自己亲生女儿，刀白凤看穿后怒掴段正淳，钟灵与段誉的婚事作罢",
      "chapter": 9
    },
    {
      "id": "evt_09_shaolin_baoxun",
      "name": "少林寺慧真慧观报玄悲大师死讯",
      "participants": ["char_huihuizhen", "char_baodingdi", "char_duanzhengchun", "char_huangmeiseng"],
      "location": "loc_dali",
      "description": "少林寺慧真慧观二僧奉方丈玄慈之命送信，称玄悲大师在陆凉州身戒寺圆寂，胸口中大韦陀杵而死。五叶方丈推断凶手是姑苏慕容氏，以彼之道还施彼身",
      "chapter": 9
    },
    {
      "id": "evt_09_guoyanzhi_daofang",
      "name": "追魂鞭过彦之来访，崔百泉身份暴露",
      "participants": ["char_guoyanzhi", "char_cuibaiquan", "char_duanzhengchun", "char_gaoshengtai"],
      "location": "loc_dali",
      "description": "过彦之到镇南王府，高升泰点破帐房霍先生即是金算盘崔百泉。崔百泉跪地请罪，言十八年前因杀人被慕容博夫妇以算盘珠钉穴，被迫隐居大理段府避难",
      "chapter": 9
    },
    {
      "id": "evt_09_huangmei_xueshi",
      "name": "黄眉僧讲述四十三年前被慕容博所伤",
      "participants": ["char_huangmeiseng", "char_baodingdi", "char_duanzhengchun", "char_cuibaiquan", "char_guoyanzhi", "char_duanyu"],
      "location": "loc_dali",
      "description": "黄眉僧自述四十三年前在青豹岗以金刚指毙四盗，被一少年以金刚指力反击，一指点穿左胸，因心脏偏右才得活命。这对母子正是姑苏慕容氏",
      "chapter": 9
    },
    {
      "id": "evt_09_muwanqing_liqu",
      "name": "木婉清断门离去，以修罗刀逼段誉殉情",
      "participants": ["char_muwanqing", "char_qinhongmian", "char_duanyu"],
      "location": "loc_dali",
      "description": "深夜木婉清与秦红棉翻墙欲走，段誉追至花园。木婉清以修罗刀切断门闩，逼段誉伸脖子让她一刀割断然后她自杀，以求来世做夫妻。段誉惊惧拒绝，木婉清失望而去",
      "chapter": 9
    },
    {
      "id": "evt_09_duanzhengchun_didao",
      "name": "段正淳夜钻地道与甘宝宝私会",
      "participants": ["char_duanzhengchun", "char_ganbaobao", "char_zhongwanchou"],
      "location": "loc_wanjiegue",
      "description": "段正淳从地道爬入甘宝宝卧室，二人重逢拥抱亲热。钟万仇在门外听到男人声音破门而入却找不到人，段正淳已从地道逃走。后崔百泉与黄眉僧相继入地道相助",
      "chapter": 9
    },
    {
      "id": "evt_09_didao_xili",
      "name": "地道连环吸取内力奇观",
      "participants": ["char_duanyu", "char_yeerniang", "char_nanhaieshen", "char_zhongwanchou", "char_yunzhonghe", "char_zhongling", "char_cuibaiquan", "char_huangmeiseng"],
      "location": "loc_wanjiegue",
      "description": "地道中云中鹤抓钟灵足踝，钟万仇抓云中鹤，南海鳄神抓钟万仇，叶二娘抓南海鳄神，段誉抓叶二娘。段誉以北冥神功连环吸取五人之内力，一半内力转移至段誉体内。黄眉僧与崔百泉后来加入也被吸走部分内力",
      "chapter": 9
    },
    {
      "id": "evt_09_nanhaieshen_zhuazou",
      "name": "南海鳄神抓走段誉欲逼拜师",
      "participants": ["char_nanhaieshen", "char_duanyu"],
      "location": "loc_dali",
      "description": "段誉在花园中呆立时被南海鳄神抓住后颈提起，南海鳄神想出一套先磕还头再拜师的所谓妙计，逼段誉磕十六个响头。段誉宁死不从，以师徒名分令南海鳄神不知所措",
      "chapter": 9
    },
    {
      "id": "evt_09_duanyu_shaoce",
      "name": "段誉烧毁神仙姊姊卷轴",
      "participants": ["char_duanyu"],
      "location": "loc_dali",
      "description": "段誉发现怀中的北冥神功卷轴已在石屋中扯成碎片，残存无几。他如释重负，将碎帛投入火炉烧成灰烬，心想如此可免亵渎神仙姊姊",
      "chapter": 9
    },
    {
      "id": "evt_09_dali_jiaodai",
      "name": "保定帝叮嘱持正忍让，安排祭奠玄悲",
      "participants": ["char_baodingdi", "char_duanzhengchun", "char_huangmeiseng"],
      "location": "loc_dali",
      "description": "保定帝命段正淳率三公去身戒寺祭奠玄悲大师，叮嘱不得参与中原武林仇杀，只可持正忍让。黄眉僧辞别后独自重返万劫谷复盘棋局",
      "chapter": 9
    }
  ],
  "dialogues": [
    {
      "speaker": "char_baodingdi",
      "listener": "char_zhongwanchou",
      "text": "舍倒段誉得罪行了钟谷主，被扣贵处，在下今日一来求情，二来请罪。还望钟谷主瞧在下薄面，恕过小儿无知，在下感激不尽。",
      "tone": "谦和",
      "chapter": 9
    },
    {
      "speaker": "char_duanzhengchun",
      "listener": "char_zhongwanchou",
      "text": "钟谷主，你对我孩儿可优待得紧啊，怕他独自一个儿寂静，竟命你令爱千金相陪。在下实在感激之至。既然如此，令爱已是我段家的人了，在下这可不能不管。",
      "tone": "讥讽",
      "chapter": 9
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_nanhaieshen",
      "text": "岳老三，你师父有命，快将这个小姑娘夺下来。你拜了我为师，头也磕过了，难道想赖？你说过的话是放屁么？你定是想做乌龟儿子王八蛋了！",
      "tone": "激将",
      "chapter": 9
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_nanhaieshen",
      "text": "这个姓钟的小姑娘是我妻子，就是你的师娘，快去给我夺回来。这云中鹤侮辱她，就是辱你师娘，你太也丢脸了，太不是英雄好汉了。",
      "tone": "激将",
      "chapter": 9
    },
    {
      "speaker": "char_muwanqing",
      "listener": "char_duanyu",
      "text": "你伸过脖子来，让我一刀割断了，我立刻自杀。咱俩投胎再世做人，那时不是兄妹，就好做夫妻了。",
      "tone": "决绝",
      "chapter": 9
    },
    {
      "speaker": "char_muwanqing",
      "listener": "char_duanyu",
      "text": "我肯，你为什么不肯？要不然你先杀我，你再自镣。",
      "tone": "凄厉",
      "chapter": 9
    },
    {
      "speaker": "char_huangmeiseng",
      "listener": "char_zhongwanchou",
      "text": "三个恶人，今日便饶了你们性命，今后再到大理来罗唣，休怪老僧无情！",
      "tone": "威严",
      "chapter": 9
    },
    {
      "speaker": "char_cuibaiquan",
      "listener": "char_duanzhengchun",
      "text": "我这可要上姑苏去了。我师哥跟我是亲兄弟一般。杀兄之仇，岂能不报？",
      "tone": "激昂",
      "chapter": 9
    },
    {
      "speaker": "char_ganbaobao",
      "listener": "char_duanzhengchun",
      "text": "倘若你不是王爷，只是个耕田打猎的汉子，要不然，是偷鸡摸狗的小贼也好，是打家劫舍的强人出好，我便能跟了你去……我一辈了跟了你去……",
      "tone": "幽怨",
      "chapter": 9
    },
    {
      "speaker": "char_duanzhengchun",
      "listener": "char_ganbaobao",
      "text": "你跟我逃走！我去做小贼、强盗，我不做王爷了！",
      "tone": "深情",
      "chapter": 9
    },
    {
      "speaker": "char_qinhongmian",
      "listener": "char_duanyu",
      "text": "进来干什么？好让你妈妈杀了我吗？",
      "tone": "冷淡",
      "chapter": 9
    },
    {
      "speaker": "char_huangmeiseng",
      "listener": "char_duanyanqing",
      "text": "纵横十九道，迷煞多少人。居士可有清兴，与老僧手谈一局么？",
      "tone": "平和",
      "chapter": 9
    },
    {
      "speaker": "char_duanzhengchun",
      "listener": "char_daobaifeng",
      "text": "钟万仇这家伙……这家伙心术太坏，安排了这等毒计，陷害我段氏满门，咱们决不能……决不能跟他结成亲家。此事无论如何不可！",
      "tone": "慌乱",
      "chapter": 9
    },
    {
      "speaker": "char_daobaifeng",
      "listener": "char_duanzhengchun",
      "text": "原来……原来，哈哈，钟灵这小丫头，也是你的私生女儿。",
      "tone": "怒极而笑",
      "chapter": 9
    }
  ]
}