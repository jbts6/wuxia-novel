  "dialogues": [
    {
      "speaker": "char_duanyu",
      "listener": "char_muwanqing_5",
      "text": "婉妹，婉妹！我这么叫你好不好？",
      "tone": "温柔缠绵",
      "chapter": 6
    },
    {
      "speaker": "char_muwanqing_5",
      "listener": "char_duanyu",
      "text": "我是你什么人？还是木姑娘、木姑娘的叫我。",
      "tone": "娇嗔",
      "chapter": 6
    },
    {
      "speaker": "char_zhudanchen",
      "listener": "char_duanyu",
      "text": "仗剑行千里，微躯敢一言。曾为大梁客，不负信陵恩。",
      "tone": "慷慨含蓄",
      "chapter": 6
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_zhudanchen",
      "text": "映门淮水绿，留骑主人心。明月随良椽，春潮夜夜深。",
      "tone": "绸缪雅致",
      "chapter": 6
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_yuxusanren_6",
      "text": "妈，我叫妈妈，你没听见么？",
