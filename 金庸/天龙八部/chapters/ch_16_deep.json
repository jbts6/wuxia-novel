  "events": [
    {
      "id": "evt_16_zhiguang_xushu",
      "name": "智光大师讲述三十年前雁门关血战",
      "participants": ["char_zhiguang", "char_zhaoqiansun", "char_qiaofeng"],
      "location": "loc_xingzilin",
      "description": "智光大师当众回忆三十年前雁门关外乱石谷之战：中原群侠二十一人伏击契丹武士十九骑得手，后一对契丹夫妇到来，丈夫武功惊世骇俗连杀九人，最终投崖自尽，临死将婴儿抛上崖来——那婴儿便是乔峰",
      "chapter": 16
    },
    {
      "id": "evt_16_qiaofeng_zhenxiang",
      "name": "乔峰惊悉自己是契丹人",
      "participants": ["char_qiaofeng", "char_zhiguang", "char_zhaoqiansun"],
      "location": "loc_xingzilin",
      "description": "智光说出乔峰养父是少室山下乔三槐，乔峰激动中抓住智光，单氏三子来救被乔峰如稻草人般抛掷。赵钱孙以亲身经历佐证。乔峰心中一片茫然",
      "chapter": 16
    },
    {
      "id": "evt_16_zhiguang_sixin",
      "name": "智光吞信撕去带头大哥署名",
      "participants": ["char_zhiguang", "char_qiaofeng"],
      "location": "loc_xingzilin",
      "description": "智光假借看信近火堆，将信尾署名撕下吞入肚中。乔峰一掌凌空拍中其穴道抢回信笺但署名已被毁。智光甘愿承担一切罪孽",
      "chapter": 16
    },
    {
      "id": "evt_16_qiaofeng_duxin",
      "name": "乔峰看汪剑通遗令和带头大哥书信",
      "participants": ["char_qiaofeng", "char_xuzhanglao"],
      "location": "loc_xingzilin",
      "description": "徐长老递过带头大哥劝阻传位书信和汪剑通手谕——传位之日汪帮主写下'乔峰若亲辽叛汉全帮合力击杀'密令。乔峰认出确系恩师笔迹，泪滴手谕",
      "chapter": 16
    },
    {
      "id": "evt_16_qiaofeng_cizhi",
      "name": "乔峰辞去丐帮帮主掷还打狗棒",
      "participants": ["char_qiaofeng", "char_songzhanglao", "char_xizhanglao", "char_wuzhanglao", "char_quanguanqing"],
      "location": "loc_xingzilin",
      "description": "乔峰朗声宣布辞去帮主之位，自打狗棒袋中抽出碧绿竹棒高举过头。他连问三声无人接棒，交于徐长老传功执法三人保管。随即以擒龙功凌空夺单正单刀弹断，立誓'有生之年决不伤一条汉人性命'，扬长而去",
      "chapter": 16
    },
    {
      "id": "evt_16_gaibang_fenlie",
      "name": "丐帮分裂为两派",
      "participants": ["char_songzhanglao", "char_xizhanglao", "char_wuzhanglao", "char_quanguanqing", "char_chenzhanglao", "char_xuzhanglao"],
      "location": "loc_xingzilin",
      "description": "宋长老力挺乔峰非契丹人，奚长老率众站到东首，大仁大信大义三舵跟随，约占五成。全冠清陈长老和传功长老等留原地占三成，其余犹豫不决。丐帮分裂",
      "chapter": 16
    },
    {
      "id": "evt_16_yipintang_daolai",
      "name": "西夏一品堂赫连铁树率众到来",
      "participants": ["char_helian", "char_nuerhai", "char_xuzhanglao", "char_chuangongzhanglao"],
      "location": "loc_xingzilin",
      "description": "西夏征东大将军赫连铁树率一品堂武士涌入杏子林，努儿海出言侮辱打狗棒为'扫帚柄'，传功长老以臂挡鞭拉其下马护住帮中信物",
      "chapter": 16
    },
    {
      "id": "evt_16_duanyu_xi_tudi",
      "name": "段誉以师父身份喝退南海鳄神",
      "participants": ["char_duanyu", "char_nanhaieshen"],
      "location": "loc_xingzilin",
      "description": "南海鳄神从一品堂人群中挤出来叫阵，段誉叫声'徒儿'令他当众跪拜磕头，南海鳄神忍气跪拜后含怒跃走，啸声如潮",
      "chapter": 16
    },
    {
      "id": "evt_16_wuzhanglao_zhan_yun",
      "name": "吴长老以奇门三才刀伤云中鹤",
      "participants": ["char_wuzhanglao", "char_yunzhonghe", "char_wangyuyan"],
      "location": "loc_xingzilin",
      "description": "奚长老被云中鹤钢抓所伤后，吴长老出战。王语嫣故意将吴长老刀法说成'四象六合刀'，引云中鹤使'鹤蛇八打'破解，实际吴长老用的是奇门三才刀，云中鹤左手被削伤",
      "chapter": 16
    },
    {
      "id": "evt_16_beisuqingfeng",
      "name": "西夏一品堂以悲酥清风毒倒群丐",
      "participants": ["char_helian", "char_nuerhai", "char_wangyuyan", "char_duanyu", "char_azhu"],
      "location": "loc_xingzilin",
      "description": "努儿海暗中施放悲酥清风，无色无臭的毒气令群丐眼泪长流全身不能动弹。段誉因服莽牯朱蛤万毒不侵，以六脉神剑击断努儿海手臂，抱王语嫣施展凌波微步冲出重围，夺马落荒而逃",
      "chapter": 16
    },
    {
      "id": "evt_16_mafuren_zhezi",
      "name": "马夫人以折扇陷害乔峰",
      "participants": ["char_mafuren", "char_azhu", "char_qiaofeng"],
      "location": "loc_xingzilin",
      "description": "阿朱追问马夫人遗书既无人看过何来杀人灭口，马夫人以家中被盗掉落乔峰折扇为由反将一军。扇面有汪帮主题诗徐长老绘图，乔峰认出确为自己之物但坚称遭人陷害",
      "chapter": 16
    }
  ],
  "dialogues": [
    {
      "speaker": "char_zhiguang",
      "listener": "char_qiaofeng",
      "text": "乔帮主，倘若你得知了这项讯息，那便如何？",
      "tone": "试探",
      "chapter": 16
    },
    {
      "speaker": "char_qiaofeng",
      "listener": "char_zhiguang",
      "text": "智光大师，乔某见识浅陋，才德不足以服众，致令帮中兄弟见疑，说来好生惭愧。但乔某纵然无能，却也是个有肝胆、有骨气的男儿汉，于这大节大义份上决不致不明是非。我大宋受辽狗欺凌，家国之仇，谁不思报？",
      "tone": "慷慨激昂",
      "chapter": 16
    },
    {
      "speaker": "char_qiaofeng",
      "listener": "char_zhiguang",
      "text": "智光大师，那……那少室山下的农人，他，他，他姓什么？",
      "tone": "颤抖",
      "chapter": 16
    },
    {
      "speaker": "char_zhiguang",
      "listener": "char_qiaofeng",
      "text": "你既已猜到，我也不必隐瞒。那农人姓乔，名字叫作三槐。",
      "tone": "平静慈悲",
      "chapter": 16
    },
    {
      "speaker": "char_qiaofeng",
      "listener": "char_zhiguang",
      "text": "不，不！你胡说八道，捏造这么一篇鬼话来诬陷我。我是堂堂汉人，如何是契丹胡虏？……三槐公是我亲生的爹爹，你再瞎说……",
      "tone": "激动悲愤",
      "chapter": 16
    },
    {
      "speaker": "char_zhaoqiansun",
      "listener": "char_qiaofeng",
      "text": "可笑啊可笑！汉人未必高人一等，契丹人也未必便猪狗不如！明明是契丹，却硬要冒充汉人，那有什么滋味？连自己的亲生父母也不肯认，枉自称什么男子汉、大丈夫？",
      "tone": "冷笑讥讽",
      "chapter": 16
    },
    {
      "speaker": "char_mafuren",
      "listener": "char_xuzhanglao",
      "text": "各位伯伯叔叔，先夫不幸亡故，到底是何人下的毒手，此时自是难加断言。……然而常言道得好：'慢藏诲盗'，是不是因为先夫手中握有什么重要物事，别人想得之而甘心？",
      "tone": "哀怨锋利",
      "chapter": 16
    },
    {
      "speaker": "char_azhu",
      "listener": "char_mafuren",
      "text": "马夫人，我心中有一个疑团，能不能请问你一句话？",
      "tone": "冷静清晰",
      "chapter": 16
    },
    {
      "speaker": "char_songzhanglao",
      "listener": "char_xuzhanglao",
      "text": "我瞧乔帮主不是契丹人。……契丹人穷凶极恶，残暴狠毒。乔帮主却是大仁大义的英雄好汉。适才我们反他，他却甘愿为我们受刀流血，赦了我们背叛的大罪。契丹人那会如此？",
      "tone": "激愤",
      "chapter": 16
    },
    {
      "speaker": "char_quanguanqing",
      "listener": "char_qiaofeng",
      "text": "众位兄弟，乔帮主才略过人，英雄了得，谁不佩服？然而咱们都是大宋百姓，岂能听从一个契丹人的号令？乔峰的本事越大，大伙儿越是危险。",
      "tone": "煽动",
      "chapter": 16
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_nanhaieshen",
      "text": "喂，徒儿，你也来了，见了师父怎么不磕头？",
      "tone": "得意",
      "chapter": 16
    },
    {
      "speaker": "char_wangyuyan",
      "listener": "char_wuzhanglao",
      "text": "吴长老好精妙的'奇门三才刀'！",
      "tone": "笑盈盈",
      "chapter": 16
    }
  ]
}
