  "skills_detail": [
    {
      "id": "skill_beiming",
      "name": "北冥神功",
      "techniques": [
        {
          "id": "tech_beiming_shaoshang",
          "name": "少商取内力",
          "type": "attack",
          "description": "以拇指少商穴吸取他人内力，经手太阴肺经送至任脉天突穴，再转至膻中穴储藏"
        },
        {
          "id": "tech_beiming_qihai",
          "name": "气海纳流",
          "type": "passive",
          "description": "膻中穴为气海，可无限储藏吸来的内力，取一分储一分，永不泄尽"
        }
      ],
      "progression": [
        {
          "level": 1,
          "unlock": "领悟手太阴肺经和任脉的逆运之法，可接收他人打入膻中穴的内力"
        },
        {
          "level": 2,
          "unlock": "少商穴与对方拇指相接时，可主动吸取对方内力"
        }
      ],
      "effects": [
        {
          "type": "吸收",
          "condition": "少商穴接触对方身体且对方运劲",
          "description": "对方内力如江河决堤般涌入自身气海"
        },
        {
          "type": "转化",
          "condition": "对方内力打入膻中穴",
          "description": "内力自动转化为己有，走一个周天便可永存体内"
        }
      ],
      "combat_style": "以逸待劳，借力打力，不主动攻击而以接收对方内力为主"
    },
