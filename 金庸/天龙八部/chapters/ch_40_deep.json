  "dialogues": [
    {
      "speaker": "char_jiumozhi",
      "listener": "char_xuzhu",
      "text": "小师父服了么？",
      "tone": "得意",
      "chapter": 40
    },
    {
      "speaker": "char_xuzhu",
      "listener": "char_jiumozhi",
      "text": "国师手下留情！",
      "tone": "谦恭",
      "chapter": 40
    },
    {
      "speaker": "char_jiumozhi",
      "listener": null,
      "text": "少林寺不但倚多为胜，而且暗藏春色，数百年令誉，原来如此，我今日可领教了！",
      "tone": "嘲讽",
      "chapter": 40
    },
    {
      "speaker": "char_mojian",
      "listener": "char_xuzhu",
      "text": "主人，咱姊妹私自下山，前来服侍你，你可别责怪。",
      "tone": "坦然",
      "chapter": 40
    },
    {
      "speaker": "char_xuzhu",
      "listener": "char_mojian",
      "text": "胡闹，胡闹！",
      "tone": "窘迫",
      "chapter": 40
    },
    {
      "speaker": "char_zhujian",
      "listener": "char_xuzhu",
      "text": "主人，你也别做什么劳什子的和尚啦，大伙儿不如回缥缈峰去罢，在这儿青菜豆腐，没半点油水，又得受人管束，有什么好！",
      "tone": "直爽",
      "chapter": 40
    },
    {
      "speaker": "char_xuancheng",
      "listener": null,
      "text": "老衲职为本寺方丈，于此六件大事，无一件能善为料理，实是汗颜无地。",
      "tone": "沉重",
      "chapter": 40
    },
    {
      "speaker": "char_xuzhu",
      "listener": "char_xuancheng",
      "text": "弟子无明障重，尘垢不除，一遇外魔，便即把持不定，连犯荤戒、酒戒、杀戒、淫戒，背弃本门，学练旁门外道的武功，又招致四位姑娘入寺，败坏本寺清誉，罪大恶极，罚不胜罚，只求我佛慈悲，方丈慈悲。",
      "tone": "悲切",
      "chapter": 40
    },
    {
      "speaker": "char_xuanci",
      "listener": null,
      "text": "虚竹，老衲罚你破门出寺，却非对你心存恶念，断你皈依我佛之路。天下庄严宝刹，何止千千万万。盼你另投名寺，拜高僧为师，清净身心，早证正觉。",
      "tone": "慈和恳切",
      "chapter": 40
    },
    {
      "speaker": "char_xuansi",
      "listener": "char_xuzhu",
      "text": "虚竹，方丈所指罪业，你都承认么？有何辩解？",
      "tone": "冷峻",
      "chapter": 40
    },
    {
      "speaker": "char_yieniang",
      "listener": null,
      "text": "丁春秋大显神通，已将慕容公子打得全无招架之功。大伙可要去瞧瞧热闹么？",
      "tone": "阴笑",
      "chapter": 40
    },
    {
      "speaker": "char_jiumozhi",
      "listener": "char_duanzhengchun",
      "text": "慕容公子，既已上得少室山来，怎地还不进寺礼佛？",
      "tone": "挑衅",
      "chapter": 40
    },
    {
      "speaker": "char_baobutongshen",
      "listener": "char_murongfu",
      "text": "公子爷做晋文公，咱四兄弟便是狐毛、狐偃、介子推……",
      "tone": "激昂",
      "chapter": 40
    },
    {
      "speaker": "char_wangyuyan",
      "listener": null,
      "text": "表哥，这……这是去燕子坞的路么？",
      "tone": "疑惑",
      "chapter": 40
    }
  ]
}
