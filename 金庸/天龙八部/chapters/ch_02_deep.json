  "dialogues": [
    {
      "speaker": "char_ganuanghao",
      "listener": "char_geguangpei",
      "text": "葛师妹，五年前剑湖宫比剑，我败在你剑下之后……",
      "tone": "柔情",
      "chapter": 2
    },
    {
      "speaker": "char_geguangpei",
      "listener": "char_ganuanghao",
      "text": "别再说你败在我剑下。当时你假装内力不济，故意让我，别人虽然瞧不出来，难道我自己也不知道？",
      "tone": "娇嗔",
      "chapter": 2
    },
    {
      "speaker": "char_duanyu",
      "listener": null,
      "text": "神仙姊姊，小生段誉今日得睹芳容，死而无憾。姊姊在此离世独居，不也太寂寞了么？",
      "tone": "痴迷",
      "chapter": 2
    },
    {
      "speaker": "char_duanyu",
      "listener": null,
      "text": "神仙姊姊，你若能活过来跟我说一句话，我便为你死一千遍，一万遍，也如身登极乐，欢喜无限。",
      "tone": "痴情",
      "chapter": 2
    },
    {
      "speaker": "char_duanyu",
      "listener": "char_zhongwanchou",
      "text": "我姓段，你要杀就快快动手。不清不楚的胡言乱语什么？",
      "tone": "愤怒",
      "chapter": 2
    },
    {
      "speaker": "char_zhongwanchou",
      "listener": "char_zhongfuren",
      "text": "阿宝，你………终于要离我而去了？",
      "tone": "悲苦",
      "chapter": 2
    }
  ]
