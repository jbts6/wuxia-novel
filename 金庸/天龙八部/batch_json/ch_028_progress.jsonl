{"segment":1,"line_start":1,"line_end":24,"dialogues":[{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"这奸贼为什么不杀我？哼，他压根儿便瞧我不起，觉得杀了我污手。他⋯⋯他在辽国做了什么大王，我今后报仇，可更加难了。但总算找到了这奸贼的所在。","tone":"陈述","chapter":28,"line_start":4,"line_end":8},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"这多半是契丹文字，那奸贼随身携带这本书，于他定大有用处。我偏不还他。","tone":"陈述","chapter":28,"line_start":14,"line_end":16},{"speaker":null,"speaker_name":"游氏双雄","listener":null,"text":"我游家子弟出了这般三脚猫的把式，岂不让人笑歪了嘴巴？别人一听他是聚贤庄游氏双雄子侄，不动手则已，一出手便使全力，第一招便送了他小命。还是让他乖乖的学文，以保性命为是。","tone":"疑问","chapter":28,"line_start":20,"line_end":24}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_you_tan_zhi","updates":{"alias":["铁丑","铁头人"],"one_line":"游坦之拾得《易筋经》后被阿紫折磨并戴上铁面具，后来被用作毒功试验。","rag_refs":[28],"source_refs":[{"chapter":28,"line_start":4,"line_end":16,"text":"游坦之拾得萧峰遗落的《易筋经》，藏入怀中不还。"},{"chapter":28,"line_start":353,"line_end":357,"text":"游坦之被烧红铁罩套头，两个半圆铁罩镶成铁球。"},{"chapter":28,"line_start":879,"line_end":901,"text":"阿紫令蜈蚣吸游坦之血，游坦之意识到她在练毒功。"}]},"relationship_updates":[{"action":"update","target":"char_ah_zi","type":"痴恋与受虐","intensity":85,"bond_level":4,"dynamic":"被阿紫残酷折磨仍执迷，愿为她赴汤蹈火。"},{"action":"update","target":"char_xiao_feng","type":"仇敌","intensity":95,"bond_level":5,"dynamic":"拾得《易筋经》后仍一心寻机报复萧峰。"}]},{"id":"char_xiao_feng","updates":{"alias":["乔峰","萧大王"],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":12,"line_end":16,"text":"萧峰遗落油布包中的《易筋经》，被游坦之拾得。"}]}},{"id":"item_yi_jin_jing","updates":{"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":10,"line_end":16,"text":"游坦之拾得萧峰遗落的《易筋经》，因不识文字误以为是契丹文字。"}]}}]}
{"segment":2,"line_start":26,"line_end":48,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"我想法去捉一条毒蛇或是大蜈蚣来，去偷偷放在他床上，他睡进被窝，便一口咬死了他。那个小姑娘⋯⋯那个小姑娘，唉，她⋯⋯她这样好看！","tone":"陈述","chapter":28,"line_start":36,"line_end":40},{"speaker":null,"speaker_name":"未知","listener":null,"text":"不知什么时候，能再见到这脸色雪白、苗条秀美的小姑娘。","tone":"陈述","chapter":28,"line_start":40,"line_end":42}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":50,"line_end":72,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"乔峰这厮嘴里说得好听，说是放了我，一转头却又派兵来捉了我去。这次给他抓了去，那里还有命在？","tone":"恐惧","chapter":28,"line_start":60,"line_end":62}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":74,"line_end":98,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"原来他要将我在地下拖死！","tone":"陈述","chapter":28,"line_start":84,"line_end":84},{"speaker":null,"speaker_name":"未知","listener":null,"text":"哈哈，这人鸢子只怕放不起来！","tone":"大笑","chapter":28,"line_start":86,"line_end":88},{"speaker":null,"speaker_name":"未知","listener":null,"text":"什么是人鸢子？","tone":"陈述","chapter":28,"line_start":90,"line_end":90},{"speaker":null,"speaker_name":"未知","listener":null,"text":"好极，好极，果真放起了人鸢子！","tone":"轻笑","chapter":28,"line_start":92,"line_end":94}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":100,"line_end":120,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"放人鸢","tone":"疑问","chapter":28,"line_start":102,"line_end":102},{"speaker":null,"speaker_name":"未知","listener":null,"text":"放","tone":"陈述","chapter":28,"line_start":104,"line_end":104},{"speaker":null,"speaker_name":"未知","listener":null,"text":"让我来放！","tone":"陈述","chapter":28,"line_start":106,"line_end":106},{"speaker":null,"speaker_name":"未知","listener":null,"text":"你下去！","tone":"陈述","chapter":28,"line_start":106,"line_end":108},{"speaker":null,"speaker_name":"未知","listener":null,"text":"人鸢","tone":"陈述","chapter":28,"line_start":108,"line_end":108},{"speaker":null,"speaker_name":"未知","listener":null,"text":"有趣，有趣！","tone":"陈述","chapter":28,"line_start":108,"line_end":110},{"speaker":null,"speaker_name":"未知","listener":null,"text":"这笨小子重得要命！","tone":"陈述","chapter":28,"line_start":112,"line_end":112},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"行啦，行啦！咱们再玩，再放他上去，越高越好。","tone":"陈述","chapter":28,"line_start":118,"line_end":118}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":122,"line_end":152,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"起！","tone":"焦急","chapter":28,"line_start":122,"line_end":124},{"speaker":null,"speaker_name":"未知","listener":null,"text":"放","tone":"焦急","chapter":28,"line_start":124,"line_end":124},{"speaker":null,"speaker_name":"未知","listener":null,"text":"这番死了也！","tone":"陈述","chapter":28,"line_start":130,"line_end":132},{"speaker":null,"speaker_name":"未知","listener":null,"text":"姑娘还想玩什么玩意儿？","tone":"疑问","chapter":28,"line_start":146,"line_end":146},{"speaker":null,"speaker_name":"未知","listener":null,"text":"人鸢","tone":"陈述","chapter":28,"line_start":148,"line_end":148},{"speaker":null,"speaker_name":"未知","listener":null,"text":"玩得够了。这小子倘若没死，明天再带来见我，我另想法儿消遣他。这人想暗算萧大王，可不能让他死得太容易。","tone":"陈述","chapter":28,"line_start":148,"line_end":152}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":154,"line_end":180,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"我死了没有？","tone":"激动","chapter":28,"line_start":154,"line_end":156},{"speaker":null,"speaker_name":"未知","listener":null,"text":"水！水！","tone":"激动","chapter":28,"line_start":156,"line_end":158},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"他们把我拉到那里去？是拖出去杀头么？","tone":"陈述","chapter":28,"line_start":176,"line_end":178}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":182,"line_end":204,"dialogues":[{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"想个什么新鲜法儿来折磨他才好？","tone":"陈述","chapter":28,"line_start":192,"line_end":194},{"speaker":null,"speaker_name":"未知","listener":null,"text":"呵呵","tone":"陈述","chapter":28,"line_start":196,"line_end":196}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":206,"line_end":226,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"啊哟！他咬住了我脚趾头。","tone":"焦急","chapter":28,"line_start":208,"line_end":210},{"speaker":null,"speaker_name":"未知","listener":null,"text":"你们快走开，这人发了疯，啊哟，别让他咬断了我的脚趾。","tone":"惊讶","chapter":28,"line_start":210,"line_end":212},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"快别咬，我饶你不死便是。","tone":"激动","chapter":28,"line_start":214,"line_end":216},{"speaker":null,"speaker_name":"未知","listener":null,"text":"喂！你咬我干么？快张开嘴巴，我叫人给你治伤，放你回中原。","tone":"疑问","chapter":28,"line_start":218,"line_end":220}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":10,"line_start":228,"line_end":260,"dialogues":[{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"住手，别打啦！","tone":"惊讶","chapter":28,"line_start":228,"line_end":228},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"想些什么法子来折磨他才好？","tone":"陈述","chapter":28,"line_start":230,"line_end":232},{"speaker":null,"speaker_name":"未知","listener":null,"text":"你瞧着我干么？","tone":"疑问","chapter":28,"line_start":232,"line_end":234},{"speaker":null,"speaker_name":"未知","listener":null,"text":"你很好看，我就看着你！","tone":"陈述","chapter":28,"line_start":236,"line_end":238},{"speaker":null,"speaker_name":"未知","listener":null,"text":"这小子好大胆，竟敢对我说这等轻薄言语。","tone":"陈述","chapter":28,"line_start":238,"line_end":240},{"speaker":null,"speaker_name":"未知","listener":null,"text":"我留他在身边，拿他来消遣消遣，倒也很好。只是姊夫说过要放了他，倘若知道我又抓了他来，必定生气。要姊夫始终不知，有什么法子？倘若姊夫忽然进来，瞧见了他，那便如何？","tone":"陈述","chapter":28,"line_start":248,"line_end":254},{"speaker":null,"speaker_name":"未知","listener":null,"text":"阿朱最会装扮，扮了我爹爹，姊夫就认她不出。我将这小子改头换面，姊夫也就认不得了。可是他若非自愿，我跟他化装之后，他又立即洗去化装，回复本来面目，岂非没用？","tone":"疑问","chapter":28,"line_start":256,"line_end":260}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":11,"line_start":262,"line_end":290,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"好主意，好主意！便这么办！","tone":"轻笑","chapter":28,"line_start":262,"line_end":264},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我要看她，我要看这个狠心的美丽小姑娘。","tone":"激动","chapter":28,"line_start":268,"line_end":270},{"speaker":null,"speaker_name":"未知","listener":null,"text":"狗契丹人，不得好死，大爷将你们千刀万剐。","tone":"愤怒","chapter":28,"line_start":284,"line_end":286},{"speaker":null,"speaker_name":"未知","listener":null,"text":"原来他们封住我七窍，要闷死我！","tone":"陈述","chapter":28,"line_start":288,"line_end":290}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":12,"line_start":292,"line_end":311,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"这些恶贼不知要用什么古怪法儿害死我？","tone":"疑问","chapter":28,"line_start":294,"line_end":296},{"speaker":null,"speaker_name":"未知","listener":null,"text":"臭辽狗，叫你个个死无葬身之地。","tone":"陈述","chapter":28,"line_start":298,"line_end":300},{"speaker":null,"speaker_name":"未知","listener":null,"text":"是了，他们在我脸上涂了毒药，过不多久，我便满脸溃烂，脱去皮肉，变成个鬼怪⋯⋯","tone":"陈述","chapter":28,"line_start":302,"line_end":302},{"speaker":null,"speaker_name":"未知","listener":null,"text":"与其受他们折磨至死，不如自己撞死了！","tone":"陈述","chapter":28,"line_start":302,"line_end":304}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":13,"line_start":313,"line_end":335,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"做这东西干什么？","tone":"陈述","chapter":28,"line_start":321,"line_end":321},{"speaker":null,"speaker_name":"未知","listener":null,"text":"啊哟，这面具是给我定制的。那日他们用湿面贴在我的脸上，便是做这面具的模型了。他们仔细做这铁面具，有何用意？莫非⋯⋯莫非⋯⋯","tone":"惊讶","chapter":28,"line_start":327,"line_end":331}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":14,"line_start":337,"line_end":359,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"天杀的辽狗，老天爷叫你们个个不得好死！叫你们的牛马倒毙，婴儿夭亡！","tone":"激动","chapter":28,"line_start":337,"line_end":339}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_you_tan_zhi","updates":{"alias":["铁丑","铁头人"],"one_line":"游坦之拾得《易筋经》后被阿紫折磨并戴上铁面具，后来被用作毒功试验。","rag_refs":[28],"source_refs":[{"chapter":28,"line_start":4,"line_end":16,"text":"游坦之拾得萧峰遗落的《易筋经》，藏入怀中不还。"},{"chapter":28,"line_start":353,"line_end":357,"text":"游坦之被烧红铁罩套头，两个半圆铁罩镶成铁球。"},{"chapter":28,"line_start":879,"line_end":901,"text":"阿紫令蜈蚣吸游坦之血，游坦之意识到她在练毒功。"}]},"relationship_updates":[{"action":"update","target":"char_ah_zi","type":"痴恋与受虐","intensity":85,"bond_level":4,"dynamic":"被阿紫残酷折磨仍执迷，愿为她赴汤蹈火。"},{"action":"update","target":"char_xiao_feng","type":"仇敌","intensity":95,"bond_level":5,"dynamic":"拾得《易筋经》后仍一心寻机报复萧峰。"}]}]}
{"segment":15,"line_start":361,"line_end":393,"dialogues":[{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"乔峰这狗贼在我脸上套只铁罩子，究竟有什么用意？","tone":"陈述","chapter":28,"line_start":373,"line_end":375},{"speaker":null,"speaker_name":"未知","listener":null,"text":"端福郡主","tone":"陈述","chapter":28,"line_start":385,"line_end":385},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"我这妙法管用。这小子戴上了这么一副面具，姊夫便和他相对而立，也决计认他不出。","tone":"陈述","chapter":28,"line_start":387,"line_end":391},{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"室里，这面具做得很好，赏你五十两银子，再拿三十两银子去赏给铁匠！","tone":"陈述","chapter":28,"line_start":391,"line_end":393},{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"是！多谢郡主！","tone":"恳求","chapter":28,"line_start":393,"line_end":393}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ah_zi","updates":{"identity":"辽国端福郡主、星宿派弟子","one_line":"阿紫以铁面具遮掩游坦之身份，折磨他并借其鲜血修炼不老长春功与化功大法。","rag_refs":[28],"source_refs":[{"chapter":28,"line_start":383,"line_end":391,"text":"阿紫被耶律洪基封为端福郡主，并命室里把铁面具做成。"},{"chapter":28,"line_start":905,"line_end":911,"text":"阿紫偷听师父练功之法，尝试以毒质修炼不老长春功与化功大法。"}]},"relationship_updates":[{"action":"update","target":"char_you_tan_zhi","type":"折磨与利用","intensity":90,"bond_level":4,"dynamic":"以铁面具、鞭打、狮咬和毒虫吸血反复折磨利用游坦之。"},{"action":"update","target":"char_xiao_feng","type":"依恋","intensity":70,"bond_level":3,"dynamic":"因萧峰冷淡而郁闷，转以折磨游坦之取乐。"}]}]}
{"segment":16,"line_start":395,"line_end":423,"dialogues":[{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"傻小子，你瞧着我干什么？","tone":"疑问","chapter":28,"line_start":395,"line_end":397},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我⋯⋯我⋯⋯不知道。你⋯⋯你很好看。","tone":"微笑","chapter":28,"line_start":397,"line_end":399},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"你也很好看！你戴了这面具，舒不舒服？","tone":"微笑","chapter":28,"line_start":399,"line_end":401},{"speaker":null,"speaker_name":"未知","listener":null,"text":"你想舒不舒服？","tone":"轻笑","chapter":28,"line_start":401,"line_end":401},{"speaker":null,"speaker_name":"未知","listener":null,"text":"我想不出。","tone":"轻笑","chapter":28,"line_start":401,"line_end":403},{"speaker":null,"speaker_name":"未知","listener":null,"text":"我叫你戴上这面具，便不能再咬我了。","tone":"轻笑","chapter":28,"line_start":403,"line_end":405},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"姑娘是叫我⋯⋯叫我⋯⋯常常在你身边服侍么？","tone":"嘲讽","chapter":28,"line_start":407,"line_end":409},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"呸！你这小子是个大坏蛋。在我身边，你时时会想法子害我，如何容得？","tone":"嘲讽","chapter":28,"line_start":409,"line_end":411},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我⋯⋯我⋯⋯我决计不会害姑娘。我的仇人只是乔峰。","tone":"疑问","chapter":28,"line_start":411,"line_end":413},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"你想害我姊夫？岂不是跟害我一样？","tone":"疑问","chapter":28,"line_start":413,"line_end":413},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"你想害我姊夫，那是难于登天。傻小子，你想不想死？","tone":"轻笑","chapter":28,"line_start":415,"line_end":417},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我自然不想死。不过现在头上套了这劳什子，给整治得人不像人，鬼不像鬼，跟死了也没多大分别。","tone":"陈述","chapter":28,"line_start":417,"line_end":419},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"你真要想死，那也容易，不过我不会让你干干脆脆的死了。我先砍了你的左手。","tone":"陈述","chapter":28,"line_start":419,"line_end":421},{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"室里，你拉他出去，先将他左手砍了下来！","tone":"陈述","chapter":28,"line_start":421,"line_end":423},{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"是！","tone":"陈述","chapter":28,"line_start":423,"line_end":423}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":17,"line_start":425,"line_end":455,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"不，不！姑娘，我不想死，你⋯⋯你⋯⋯你别砍我手。","tone":"激动","chapter":28,"line_start":425,"line_end":427},{"speaker":null,"speaker_name":"未知","listener":null,"text":"我说过了的话，很难不算，除非⋯⋯除非⋯⋯你跪下磕头。","tone":"陈述","chapter":28,"line_start":427,"line_end":429},{"speaker":null,"speaker_name":"未知","listener":null,"text":"磕头的声音这么好听，我可从来没听见过，你再多磕几个听听。","tone":"陈述","chapter":28,"line_start":433,"line_end":435},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"很好，以后你听我话，没半点违拗，那也罢了，否则我便随时砍下你的手臂，记不记得？","tone":"轻笑","chapter":28,"line_start":441,"line_end":443},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"是，是！","tone":"疑问","chapter":28,"line_start":443,"line_end":443},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我给你戴上这个铁罩，你可懂得是什么缘故？","tone":"疑问","chapter":28,"line_start":443,"line_end":445},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我就是不明白。","tone":"陈述","chapter":28,"line_start":445,"line_end":445},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"你这人真笨死了，我救了你性命，你还不知道谢我。萧大王要将你砍成肉酱，你也不知道么？","tone":"疑问","chapter":28,"line_start":445,"line_end":447},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"他是我杀父仇人，自然容我不得。","tone":"疑问","chapter":28,"line_start":447,"line_end":449},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"他假装放你，又捉你回来，命人将你砍成肉酱。我见你这小子不算太坏，杀了可惜，因此瞒着他将你藏了起来。可是萧大王如撞到了你，你还有命么？连我也担代了好大干系。","tone":"疑问","chapter":28,"line_start":449,"line_end":455}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":18,"line_start":457,"line_end":489,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"啊，原来姑娘铸了这个铁面给我戴，是为我好，救了我命。我⋯⋯我好生感激，真的⋯⋯我好生感激。","tone":"陈述","chapter":28,"line_start":457,"line_end":459},{"speaker":null,"speaker_name":"未知","listener":null,"text":"所以啊，下次你要是见到萧大王，千万不可说话，以免给他听出声音。他如认出是你，哼，哼！这么一拉，将你左臂拉了下来，再这么一扯，将你右臂撕了下来。室里，你去给他换一身契丹人的衣衫，将他身上洗一洗，满身血腥气的，难闻死了。","tone":"嘲讽","chapter":28,"line_start":461,"line_end":467},{"speaker":null,"speaker_name":"未知","listener":null,"text":"我给你起个名字，叫做⋯⋯叫做铁丑。以后我叫铁丑，你便得答应。铁丑！","tone":"轻笑","chapter":28,"line_start":473,"line_end":475},{"speaker":null,"speaker_name":"未知","listener":null,"text":"是！","tone":"陈述","chapter":28,"line_start":475,"line_end":477},{"speaker":null,"speaker_name":"未知","listener":null,"text":"室里！西域大食国送来了一头狮子，是不是？你叫驯狮人带狮子来，再召十几个卫士来。","tone":"疑问","chapter":28,"line_start":479,"line_end":481}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_you_tan_zhi","updates":{"alias":["铁丑","铁头人"],"one_line":"游坦之拾得《易筋经》后被阿紫折磨并戴上铁面具，后来被用作毒功试验。","rag_refs":[28],"source_refs":[{"chapter":28,"line_start":4,"line_end":16,"text":"游坦之拾得萧峰遗落的《易筋经》，藏入怀中不还。"},{"chapter":28,"line_start":353,"line_end":357,"text":"游坦之被烧红铁罩套头，两个半圆铁罩镶成铁球。"},{"chapter":28,"line_start":879,"line_end":901,"text":"阿紫令蜈蚣吸游坦之血，游坦之意识到她在练毒功。"}]},"relationship_updates":[{"action":"update","target":"char_ah_zi","type":"痴恋与受虐","intensity":85,"bond_level":4,"dynamic":"被阿紫残酷折磨仍执迷，愿为她赴汤蹈火。"},{"action":"update","target":"char_xiao_feng","type":"仇敌","intensity":95,"bond_level":5,"dynamic":"拾得《易筋经》后仍一心寻机报复萧峰。"}]},{"id":"char_ah_zi","updates":{"identity":"辽国端福郡主、星宿派弟子","one_line":"阿紫以铁面具遮掩游坦之身份，折磨他并借其鲜血修炼不老长春功与化功大法。","rag_refs":[28],"source_refs":[{"chapter":28,"line_start":383,"line_end":391,"text":"阿紫被耶律洪基封为端福郡主，并命室里把铁面具做成。"},{"chapter":28,"line_start":905,"line_end":911,"text":"阿紫偷听师父练功之法，尝试以毒质修炼不老长春功与化功大法。"}]},"relationship_updates":[{"action":"update","target":"char_you_tan_zhi","type":"折磨与利用","intensity":90,"bond_level":4,"dynamic":"以铁面具、鞭打、狮咬和毒虫吸血反复折磨利用游坦之。"},{"action":"update","target":"char_xiao_feng","type":"依恋","intensity":70,"bond_level":3,"dynamic":"因萧峰冷淡而郁闷，转以折磨游坦之取乐。"}]}]}
{"segment":19,"line_start":491,"line_end":515,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"铁丑，你嘴里说得好听，也不知是真是假。现下我要试你一件事，瞧你听不听我话。","tone":"陈述","chapter":28,"line_start":491,"line_end":493},{"speaker":null,"speaker_name":"未知","listener":null,"text":"是！","tone":"疑问","chapter":28,"line_start":493,"line_end":495},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"不知你头上的铁套子牢不牢，你把头伸到铁笼中，瞧狮子能不能将铁套子咬烂了。","tone":"陈述","chapter":28,"line_start":497,"line_end":499},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"这个⋯⋯这个是不能试的。倘若咬烂了，我的脑袋⋯⋯","tone":"惊讶","chapter":28,"line_start":501,"line_end":501},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"你这人有什么用？这样一点小事也害怕，男子汉大丈夫，应当视死如归才是。而且我看多半是咬不烂的。","tone":"恐惧","chapter":28,"line_start":501,"line_end":505},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"姑娘，这件事可不是玩的，就算咬不烂，这畜生把铁罩咬扁了，我的头⋯⋯","tone":"轻笑","chapter":28,"line_start":505,"line_end":505},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"最多你的头也不过是扁了。你这小子真麻烦，你本来的长相也没什么美，脑袋扁了，套在罩子之内，人家也瞧不见，还管他什么好看不好看。","tone":"嘲讽","chapter":28,"line_start":505,"line_end":509},{"speaker":null,"speaker_name":"未知","listener":null,"text":"我不是贪图好看⋯⋯","tone":"嘲讽","chapter":28,"line_start":509,"line_end":509},{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"你不听话，现下试出来啦，你存心骗我，将你整个人塞进笼去，喂狮子吃了罢！","tone":"嘲讽","chapter":28,"line_start":509,"line_end":511},{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"是！","tone":"陈述","chapter":28,"line_start":511,"line_end":511},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"身入狮笼，那里还有命在？还不如听姑娘的话，将铁脑袋去试试运气罢！","tone":"陈述","chapter":28,"line_start":513,"line_end":515},{"speaker":null,"speaker_name":"未知","listener":null,"text":"别拉，别拉！姑娘，我听话啦！","tone":"陈述","chapter":28,"line_start":515,"line_end":515}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":20,"line_start":517,"line_end":545,"dialogues":[{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"这才乖呢！我跟你说，下次我叫你做什么，立刻便做，推三阻四的，惹姑娘生气。室里，你抽他三十鞭。","tone":"轻笑","chapter":28,"line_start":517,"line_end":519},{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"是！","tone":"陈述","chapter":28,"line_start":519,"line_end":519},{"speaker":null,"speaker_name":"未知","listener":null,"text":"啊","tone":"激动","chapter":28,"line_start":521,"line_end":521},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"铁丑，我跟你说，我叫人打你，是瞧得起你。你这么大叫，是不喜欢我打你吗？","tone":"疑问","chapter":28,"line_start":523,"line_end":525},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我喜欢，多谢姑娘恩典！","tone":"嘲讽","chapter":28,"line_start":525,"line_end":527},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"好，打罢！","tone":"嘲讽","chapter":28,"line_start":527,"line_end":527},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"铁丑，你说喜欢我叫人打你，是不是？","tone":"嘲讽","chapter":28,"line_start":529,"line_end":531},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"是！","tone":"嘲讽","chapter":28,"line_start":531,"line_end":531},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"你这话是真是假？是不是胡说八道的骗我？","tone":"嘲讽","chapter":28,"line_start":531,"line_end":533},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"是真的，不敢欺骗姑娘。","tone":"疑问","chapter":28,"line_start":533,"line_end":533},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"你既喜欢，为什么不笑？为什么不说打得痛快？","tone":"大笑","chapter":28,"line_start":533,"line_end":535},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"姑娘待我很好，叫人打我，哈哈哈！很是痛快！","tone":"恳求","chapter":28,"line_start":535,"line_end":537},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"这才像话，咱们试试！","tone":"焦急","chapter":28,"line_start":537,"line_end":537},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"多谢姑娘救命之恩，这一鞭打得好！","tone":"恳求","chapter":28,"line_start":539,"line_end":541},{"speaker":null,"speaker_name":"未知","listener":null,"text":"今天就这么算了。你将脑袋伸进笼子里。","tone":"陈述","chapter":28,"line_start":543,"line_end":545}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":21,"line_start":547,"line_end":569,"dialogues":[{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"叫狮子咬啊，它怎么不咬？","tone":"激动","chapter":28,"line_start":551,"line_end":551},{"speaker":null,"speaker_name":"未知","listener":null,"text":"啊","tone":"激动","chapter":28,"line_start":559,"line_end":559},{"speaker":null,"speaker_name":"未知","listener":null,"text":"很好，很好！谁也别理会，让他们两人拚个你死我活。","tone":"陈述","chapter":28,"line_start":565,"line_end":567}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":22,"line_start":571,"line_end":595,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"咬，用力咬他！","tone":"激动","chapter":28,"line_start":573,"line_end":573},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"铁丑赢了！","tone":"轻笑","chapter":28,"line_start":575,"line_end":575},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"这就对了！你能逗我喜欢，我要赏你。赏些什么好呢？","tone":"轻笑","chapter":28,"line_start":575,"line_end":577},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"姑娘，我不要你赏赐，只求你一件事。","tone":"疑问","chapter":28,"line_start":579,"line_end":579},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"求什么？","tone":"疑问","chapter":28,"line_start":579,"line_end":581},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"求你许我陪在你身边，做你的奴仆。","tone":"疑问","chapter":28,"line_start":581,"line_end":581},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"做我奴仆？为什么？有什么好？嗯，我知道啦，你想等萧大王来看我时，乘机下手害他，为你父母报仇。","tone":"疑问","chapter":28,"line_start":581,"line_end":585},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"不，不！决计不是。","tone":"疑问","chapter":28,"line_start":585,"line_end":585},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"难道你不想报仇吗？","tone":"疑问","chapter":28,"line_start":585,"line_end":587},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"不是不想。但一来报不了，二来不能将姑娘牵连在内。","tone":"陈述","chapter":28,"line_start":587,"line_end":589},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"那么你为什么喜欢做我奴仆？","tone":"疑问","chapter":28,"line_start":591,"line_end":591},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"姑娘是天仙下凡，天下第一美人，我⋯⋯我⋯⋯想天天见到你。","tone":"疑问","chapter":28,"line_start":591,"line_end":593}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":23,"line_start":597,"line_end":617,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"天下第一美人","tone":"陈述","chapter":28,"line_start":597,"line_end":597},{"speaker":null,"speaker_name":"未知","listener":null,"text":"大王驾到！","tone":"疑问","chapter":28,"line_start":599,"line_end":599},{"speaker":null,"speaker_name":"未知","listener":null,"text":"萧大王要来啦，你怕不怕？","tone":"疑问","chapter":28,"line_start":599,"line_end":601},{"speaker":null,"speaker_name":"未知","listener":null,"text":"不怕！","tone":"陈述","chapter":28,"line_start":601,"line_end":601},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"今天你气色很好啊，又在玩什么新花样了？这人头上搅了些什么古怪？","tone":"轻笑","chapter":28,"line_start":603,"line_end":605},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"这是西域高昌国进贡的铁头人，名叫铁丑，连狮子也咬不破他的铁头，你瞧，这是狮子的牙齿印。","tone":"轻笑","chapter":28,"line_start":605,"line_end":607},{"speaker":null,"speaker_name":"未知","listener":null,"text":"姊夫，你有没本事将他的铁套子除了下来？","tone":"疑问","chapter":28,"line_start":607,"line_end":609},{"speaker":null,"speaker_name":"未知","listener":null,"text":"这铁罩甚是牢固，打造得又很精细，毁了岂不可惜？","tone":"轻笑","chapter":28,"line_start":615,"line_end":617}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":24,"line_start":619,"line_end":643,"dialogues":[{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"高昌国的使者说道，这个铁头人生来青面獠牙，三分像人，七分像鬼，见到他的人无不惊避，因此他父母打造了一个铁面给他戴着，免他惊吓旁人。姊夫，我很想瞧瞧他的本来面目，到底怎样的可怕。","tone":"恐惧","chapter":28,"line_start":619,"line_end":621},{"speaker":null,"speaker_name":"未知","listener":null,"text":"这人怕得厉害，何必去揭开他的铁面？这人既是自小戴惯了铁面，倘若强行除去，只怕使他日后难以过活。","tone":"恐惧","chapter":28,"line_start":625,"line_end":629},{"speaker":null,"speaker_name":"未知","listener":null,"text":"那才好玩啊。好像揭了乌龟的硬壳，岂不好看？","tone":"疑问","chapter":28,"line_start":629,"line_end":631},{"speaker":null,"speaker_name":"未知","listener":null,"text":"阿紫，前些时候你倒挺乖的，怎么近来又喜欢干这等害得人不死不活的事？","tone":"疑问","chapter":28,"line_start":631,"line_end":633}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":25,"line_start":645,"line_end":673,"dialogues":[{"speaker":"char_xiao_feng","speaker_name":"萧峰","listener":null,"text":"你又不喜欢我啦！我当然没阿朱那么好，要是我像阿朱一样，你怎么会接连几天不来睬我。","tone":"嘲讽","chapter":28,"line_start":649,"line_end":651},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"做了这劳什子的什么南院大王，每日里忙得不可开交。但我不是每天总来陪你一阵么？","tone":"嘲讽","chapter":28,"line_start":651,"line_end":653},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"陪我一阵，哼，陪我一阵！我就是不喜欢你这么'陪我一阵'的敷衍了事。倘若我是阿朱，你一定老是陪在我身旁，赶你也不会走开，不会什么'一阵'、'半阵'的！","tone":"嘲讽","chapter":28,"line_start":653,"line_end":657},{"speaker":null,"speaker_name":"未知","listener":null,"text":"姊夫是大人，没兴致陪你孩子玩，你找些年轻女伴来陪你说笑解闷罢！","tone":"陈述","chapter":28,"line_start":659,"line_end":661},{"speaker":"char_xiao_feng","speaker_name":"萧峰","listener":null,"text":"孩子，孩子⋯⋯我才不是孩子呢。你没兴致陪我玩，却又干什么来了？","tone":"疑问","chapter":28,"line_start":661,"line_end":663},{"speaker":"char_xiao_feng","speaker_name":"萧峰","listener":null,"text":"我来瞧瞧你身子好些没有？今天吃了熊胆么？","tone":"疑问","chapter":28,"line_start":663,"line_end":665},{"speaker":null,"speaker_name":"未知","listener":null,"text":"我心里不快活，每天便吃一百副熊胆，身子也好不了。","tone":"陈述","chapter":28,"line_start":667,"line_end":669},{"speaker":null,"speaker_name":"未知","listener":null,"text":"你休息一会儿！","tone":"陈述","chapter":28,"line_start":671,"line_end":673}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":26,"line_start":675,"line_end":701,"dialogues":[{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"室里，再抽他三十鞭！","tone":"激动","chapter":28,"line_start":675,"line_end":677},{"speaker":"char_shi_li","speaker_name":"室里","listener":null,"text":"是！","tone":"陈述","chapter":28,"line_start":677,"line_end":677},{"speaker":null,"speaker_name":"未知","listener":null,"text":"姑娘，我又犯了什么错啦？","tone":"焦急","chapter":28,"line_start":679,"line_end":679},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"快打！","tone":"疑问","chapter":28,"line_start":679,"line_end":681},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"姑娘，到底我犯了什么错，让我知道，免得下次再犯。","tone":"陈述","chapter":28,"line_start":681,"line_end":683},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我要打便打，你就不该问什么罪名，难道打错了你？你问自己犯了什么错，正因为你问，这才要打！","tone":"疑问","chapter":28,"line_start":685,"line_end":687},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"是你先打我，我才问的。我还没问，你就叫人打我了。","tone":"疑问","chapter":28,"line_start":687,"line_end":689},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"我料到你会问，因此叫人先打你。你果然要问，那不是我料事如神么？这证明你对我不够死心塌地。姑娘忽然想到要打人，你倘若忠心，须得自告奋勇，自动献身就打才是。偏偏啰里啰唆的心中不服。好罢，你不喜欢给我打，不打你就是了。","tone":"轻笑","chapter":28,"line_start":691,"line_end":697},{"speaker":null,"speaker_name":"未知","listener":null,"text":"不打你就是了","tone":"焦急","chapter":28,"line_start":699,"line_end":699},{"speaker":null,"speaker_name":"未知","listener":null,"text":"是小人错了，姑娘打我是大恩大德，对小人身子有益，请姑娘多多鞭打，打得越多越好。姑娘肯打我，小人再开心也没有了！","tone":"焦急","chapter":28,"line_start":699,"line_end":701}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":27,"line_start":703,"line_end":727,"dialogues":[{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"总算你还聪明。我可不给人取巧，你说打得越多越好，以为我一高兴，便饶了你么？","tone":"轻笑","chapter":28,"line_start":703,"line_end":705},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"不是的，小人不敢向姑娘取巧。","tone":"疑问","chapter":28,"line_start":705,"line_end":705},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"你说打得越多越好，那是你衷心所愿的了？","tone":"疑问","chapter":28,"line_start":705,"line_end":707},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"是，是小人衷心所愿。","tone":"陈述","chapter":28,"line_start":707,"line_end":707},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"既然如此，我就成全你。室里，打足一百鞭，他喜欢多挨鞭子。","tone":"陈述","chapter":28,"line_start":707,"line_end":709},{"speaker":null,"speaker_name":"未知","listener":null,"text":"这一百鞭打了下来，还有命么？","tone":"陈述","chapter":28,"line_start":711,"line_end":713},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"你为什么不说话？是心中不服吗？我叫人打你，你觉得不公道么？","tone":"疑问","chapter":28,"line_start":715,"line_end":717},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"小人心悦诚服，知道姑娘鞭打小人，出于成全小人的好心。","tone":"陈述","chapter":28,"line_start":717,"line_end":719},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"那么刚才你为什么不说话？","tone":"陈述","chapter":28,"line_start":719,"line_end":719},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"这个⋯⋯这个⋯⋯小人心想姑娘待我这般恩德如山，小人心中感激，什么话也说不出来，只想将来不知如何报答姑娘才是。","tone":"恳求","chapter":28,"line_start":719,"line_end":721},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"好啊！你说如何报答于我。我一鞭鞭打你，你将这一鞭鞭的仇恨，都记在心中。","tone":"恳求","chapter":28,"line_start":721,"line_end":723},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"不，不！不是。我说的报答，是真正的报答。小人一心想要为姑娘粉身碎骨，赴汤蹈火。","tone":"恳求","chapter":28,"line_start":723,"line_end":725},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"好，那就打罢！","tone":"陈述","chapter":28,"line_start":727,"line_end":727},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"是！","tone":"陈述","chapter":28,"line_start":727,"line_end":727}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":28,"line_start":729,"line_end":753,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"抬了下去罢！这个人不好玩！室里，还有什么别的新鲜玩意儿没有？","tone":"疑问","chapter":28,"line_start":737,"line_end":741},{"speaker":null,"speaker_name":"未知","listener":null,"text":"什么时候，姑娘再叫我去鞭打？","tone":"疑问","chapter":28,"line_start":749,"line_end":751}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":29,"line_start":755,"line_end":777,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"啊哟，这铁丑还没死啊！我还道他早死了呢！铁丑，你过来！","tone":"轻笑","chapter":28,"line_start":755,"line_end":757},{"speaker":null,"speaker_name":"未知","listener":null,"text":"铁丑，该死的！我叫你过来，你没听见么？","tone":"激动","chapter":28,"line_start":761,"line_end":763},{"speaker":null,"speaker_name":"未知","listener":null,"text":"是，姑娘！","tone":"陈述","chapter":28,"line_start":763,"line_end":763},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"铁丑，你怎么没死？","tone":"轻笑","chapter":28,"line_start":767,"line_end":767},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我说要⋯⋯要报答姑娘的恩典，还没报答，可不能便死。","tone":"恳求","chapter":28,"line_start":767,"line_end":769},{"speaker":null,"speaker_name":"未知","listener":null,"text":"我正要找一个忠心不二的奴才去做一件事，只怕契丹人粗手粗脚的误事，你还没死，那好得很。你跟我来！","tone":"陈述","chapter":28,"line_start":769,"line_end":771},{"speaker":null,"speaker_name":"未知","listener":null,"text":"是！","tone":"陈述","chapter":28,"line_start":771,"line_end":771},{"speaker":null,"speaker_name":"未知","listener":null,"text":"请姑娘早回！","tone":"疑问","chapter":28,"line_start":775,"line_end":777}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":30,"line_start":779,"line_end":803,"dialogues":[{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"好了，便在这里！","tone":"疑问","chapter":28,"line_start":785,"line_end":785},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"你今天瞧见的事，不得向旁人泄露半点，以后也不许向我提起，记得么？","tone":"疑问","chapter":28,"line_start":785,"line_end":787},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"是，是！","tone":"陈述","chapter":28,"line_start":789,"line_end":789},{"speaker":null,"speaker_name":"未知","listener":null,"text":"待会儿有什么古怪虫豸出现，你不许大惊小怪，千万不能出声。","tone":"惊讶","chapter":28,"line_start":791,"line_end":793},{"speaker":null,"speaker_name":"未知","listener":null,"text":"是！","tone":"陈述","chapter":28,"line_start":793,"line_end":793},{"speaker":null,"speaker_name":"未知","listener":null,"text":"咱们到那边树下守着。","tone":"陈述","chapter":28,"line_start":797,"line_end":799}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"item_shen_mu_wang_ding","updates":{"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":795,"line_end":813,"text":"阿紫用小木鼎与香气引出红头大蜈蚣，并收进革囊。"}]}}]}
{"segment":31,"line_start":805,"line_end":831,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"走罢！","tone":"轻笑","chapter":28,"line_start":811,"line_end":813},{"speaker":null,"speaker_name":"未知","listener":null,"text":"她这座小木鼎古怪得紧，多半还是因烧起香料，才引得这条大蜈蚣到来。不知这条大蜈蚣有什么好玩，姑娘巴巴的到这山谷中来捉？","tone":"陈述","chapter":28,"line_start":815,"line_end":819},{"speaker":null,"speaker_name":"未知","listener":null,"text":"你瞧，是不是很雄壮？","tone":"轻笑","chapter":28,"line_start":827,"line_end":829}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":32,"line_start":833,"line_end":861,"dialogues":[{"speaker":null,"speaker_name":"未知","listener":null,"text":"成啦，成啦！这一门功夫可练得成功了！","tone":"陈述","chapter":28,"line_start":835,"line_end":837},{"speaker":null,"speaker_name":"未知","listener":null,"text":"原来你捉了蜈蚣，要来练一门功夫。这叫蜈蚣功吗？","tone":"陈述","chapter":28,"line_start":839,"line_end":841},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"铁丑，我待你怎样？","tone":"疑问","chapter":28,"line_start":845,"line_end":847},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"姑娘待我恩重如山。","tone":"疑问","chapter":28,"line_start":847,"line_end":847},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"你说过要为我粉身碎骨，赴汤蹈火，是真的还是假的？","tone":"疑问","chapter":28,"line_start":847,"line_end":849},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"自然是真！姑娘但有所命，小人必定遵从。","tone":"陈述","chapter":28,"line_start":849,"line_end":851},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"那好得很啊。我跟你说，我要练一门功夫，须得有人相助才行。你肯不肯助我练功？倘若练成了，我重重有赏。","tone":"疑问","chapter":28,"line_start":851,"line_end":853},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"小人当然听姑娘吩咐，也不用什么赏赐。","tone":"疑问","chapter":28,"line_start":853,"line_end":855},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"那好得很，咱们这就练了。","tone":"陈述","chapter":28,"line_start":855,"line_end":855},{"speaker":null,"speaker_name":"未知","listener":null,"text":"你伸手到瓦瓮中去，这蜈蚣必定咬你，你千万不可动弹，要让它吸你血液，吸得越多越好。","tone":"陈述","chapter":28,"line_start":857,"line_end":859}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":33,"line_start":863,"line_end":885,"dialogues":[{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"怎么啦，你不愿意吗？","tone":"疑问","chapter":28,"line_start":863,"line_end":863},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"不是不愿，只不过⋯⋯只不过⋯⋯","tone":"疑问","chapter":28,"line_start":863,"line_end":863},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"怎么？只不过蜈蚣毒性厉害，你怕死是不是？你是人，还是公鸡？","tone":"疑问","chapter":28,"line_start":863,"line_end":867},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"我不是公鸡。","tone":"疑问","chapter":28,"line_start":867,"line_end":867},{"speaker":"char_you_tan_zhi","speaker_name":"游坦之","listener":null,"text":"是啊，公鸡给蜈蚣吸了血会死，你又不是公鸡，怎么会死？你说过愿意为我赴汤蹈火，粉身碎骨，蜈蚣吸你一点血玩玩，你会粉身碎骨么？","tone":"疑问","chapter":28,"line_start":867,"line_end":871},{"speaker":null,"speaker_name":"未知","listener":null,"text":"好，我遵从姑娘吩咐。","tone":"陈述","chapter":28,"line_start":873,"line_end":875},{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"别动，别动！","tone":"激动","chapter":28,"line_start":879,"line_end":879}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_you_tan_zhi","updates":{"alias":["铁丑","铁头人"],"one_line":"游坦之拾得《易筋经》后被阿紫折磨并戴上铁面具，后来被用作毒功试验。","rag_refs":[28],"source_refs":[{"chapter":28,"line_start":4,"line_end":16,"text":"游坦之拾得萧峰遗落的《易筋经》，藏入怀中不还。"},{"chapter":28,"line_start":353,"line_end":357,"text":"游坦之被烧红铁罩套头，两个半圆铁罩镶成铁球。"},{"chapter":28,"line_start":879,"line_end":901,"text":"阿紫令蜈蚣吸游坦之血，游坦之意识到她在练毒功。"}]},"relationship_updates":[{"action":"update","target":"char_ah_zi","type":"痴恋与受虐","intensity":85,"bond_level":4,"dynamic":"被阿紫残酷折磨仍执迷，愿为她赴汤蹈火。"},{"action":"update","target":"char_xiao_feng","type":"仇敌","intensity":95,"bond_level":5,"dynamic":"拾得《易筋经》后仍一心寻机报复萧峰。"}]}]}
{"segment":34,"line_start":887,"line_end":911,"dialogues":[{"speaker":"char_ah_zi","speaker_name":"阿紫","listener":null,"text":"你轻轻将蜈蚣放入小木鼎中，小心些，可别弄伤了它。","tone":"陈述","chapter":28,"line_start":891,"line_end":893},{"speaker":null,"speaker_name":"未知","listener":null,"text":"这是我的血液，却到了她体中。原来她是在练蜈蚣毒掌。","tone":"陈述","chapter":28,"line_start":901,"line_end":903},{"speaker":null,"speaker_name":"未知","listener":null,"text":"不老长春功","tone":"陈述","chapter":28,"line_start":905,"line_end":905},{"speaker":null,"speaker_name":"未知","listener":null,"text":"化功大法","tone":"陈述","chapter":28,"line_start":905,"line_end":905}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ah_zi","updates":{"identity":"辽国端福郡主、星宿派弟子","one_line":"阿紫以铁面具遮掩游坦之身份，折磨他并借其鲜血修炼不老长春功与化功大法。","rag_refs":[28],"source_refs":[{"chapter":28,"line_start":383,"line_end":391,"text":"阿紫被耶律洪基封为端福郡主，并命室里把铁面具做成。"},{"chapter":28,"line_start":905,"line_end":911,"text":"阿紫偷听师父练功之法，尝试以毒质修炼不老长春功与化功大法。"}]},"relationship_updates":[{"action":"update","target":"char_you_tan_zhi","type":"折磨与利用","intensity":90,"bond_level":4,"dynamic":"以铁面具、鞭打、狮咬和毒虫吸血反复折磨利用游坦之。"},{"action":"update","target":"char_xiao_feng","type":"依恋","intensity":70,"bond_level":3,"dynamic":"因萧峰冷淡而郁闷，转以折磨游坦之取乐。"}]},{"id":"skill_bu_lao_chang_chun_gong","updates":{"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":905,"line_end":907,"text":"阿紫练的不是毒掌，而是不老长春功与化功大法。"}]}},{"id":"skill_hua_gong_da_fa","updates":{"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":905,"line_end":907,"text":"化功大法是消人内力的邪术，阿紫正尝试修炼。"}]}}]}
