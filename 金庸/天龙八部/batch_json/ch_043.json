      "chapter": 43,
      "line_start": 618,
      "line_end": 618
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "中宗昭武帝讳盛",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 620,
      "line_end": 620
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "昭文帝讳熙",
