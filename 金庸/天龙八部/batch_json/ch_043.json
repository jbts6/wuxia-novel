      "chapter": 43,
      "line_start": 524,
      "line_end": 524
    },
    {
      "speaker": "char_mu_rong_fu",
      "speaker_name": "慕容复",
      "listener": null,
      "text": "爹爹，我众彼寡⋯⋯",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 532,
      "line_end": 532
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容博道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 534,
      "line_end": 534
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "顿了一顿，又道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 572,
      "line_end": 572
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "萧远山道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 580,
      "line_end": 580
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容博微微一笑，说道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 582,
      "line_end": 582
    },
    {
      "speaker": "char_mu_rong_bo",
      "speaker_name": "慕容博",
      "listener": null,
      "text": "萧兄这一下可猜错了。",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 592,
      "line_end": 592
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 594,
      "line_end": 594
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容博道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 596,
      "line_end": 596
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 598,
      "line_end": 598
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容博道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 600,
      "line_end": 600
    },
    {
      "speaker": "char_mu_rong_fu",
      "speaker_name": "慕容复",
      "listener": null,
      "text": "是！",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 604,
      "line_end": 604
    },
    {
      "speaker": "char_jiu_mo_zhi",
      "speaker_name": "鸠摩智",
      "listener": null,
      "text": "大燕皇帝之宝",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 608,
      "line_end": 608
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 612,
      "line_end": 612
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "太祖文明帝讳皝",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 616,
      "line_end": 616
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "烈祖景昭帝讳隽",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 616,
      "line_end": 616
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "幽帝讳暐",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 616,
      "line_end": 616
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "世祖武成帝讳垂",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 618,
      "line_end": 618
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "烈宗惠愍帝讳宝",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 618,
      "line_end": 618
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "开封公讳详",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 618,
      "line_end": 618
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "赵王讳麟",
