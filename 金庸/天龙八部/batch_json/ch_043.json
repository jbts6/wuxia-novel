    },
    {
      "speaker": "char_mu_rong_bo",
      "speaker_name": "慕容博",
      "listener": null,
      "text": "这里萧氏父子欲杀我而甘心，大师以为如何？",
      "tone": "疑问",
      "chapter": 43,
      "line_start": 496,
      "line_end": 496
    },
    {
      "speaker": "char_jiu_mo_zhi",
      "speaker_name": "鸠摩智",
      "listener": null,
      "text": "忝在多年知交，焉能袖手？",
      "tone": "疑问",
      "chapter": 43,
      "line_start": 498,
      "line_end": 498
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "萧远山道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 512,
      "line_end": 512
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容博道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 514,
      "line_end": 514
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "萧远山道：",
      "tone": "恳求",
      "chapter": 43,
      "line_start": 516,
      "line_end": 516
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容博道：",
      "tone": "陈述",
      "chapter": 43,
      "line_start": 518,
      "line_end": 518
    },
    {
      "speaker": "char_xiao_yuan_shan",
      "speaker_name": "萧远山",
      "listener": null,
      "text": "这老贼不知又生什么诡计？",
