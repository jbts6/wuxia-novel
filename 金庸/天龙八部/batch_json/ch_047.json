      "line_end": 228
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "段誉、巴天石等都笑了起来。朱丹臣道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 230,
      "line_end": 230
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王语嫣问道：",
