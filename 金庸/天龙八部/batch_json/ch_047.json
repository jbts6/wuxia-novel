      "line_start": 464,
      "line_end": 464
    },
    {
      "speaker": "char_zhong_ling",
      "speaker_name": "钟灵",
      "listener": null,
      "text": "蜜蜂刺马！",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 466,
      "line_end": 466
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "木婉清道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 488,
      "line_end": 488
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "钟灵惊呼一声，道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 490,
      "line_end": 490
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那女子道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 518,
      "line_end": 518
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段誉",
      "listener": null,
      "text": "老狗",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 522,
      "line_end": 522
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段誉",
      "listener": null,
      "text": "小狗",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 522,
      "line_end": 522
    },
    {
      "speaker": null,
      "speaker_name": "那老妇",
      "listener": null,
      "text": "段王爷这次来到中原，逗留时日已经不少，中途折而向东⋯⋯",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 526,
      "line_end": 526
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那老妇道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 528,
      "line_end": 528
    },
    {
      "speaker": "char_wang_yu_yan",
      "speaker_name": "小姐",
      "listener": null,
      "text": "那女子喝道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 528,
      "line_end": 528
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那老妇道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 530,
      "line_end": 530
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那女子轻轻叹了口气，黯然道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 530,
      "line_end": 530
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那老妇道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 542,
      "line_end": 542
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那女子怒道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 544,
      "line_end": 544
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那女子尖声道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 556,
      "line_end": 556
    },
    {
      "speaker": null,
      "speaker_name": "忽听得一个男",
      "listener": null,
      "text": "舅妈，甥儿叩见。",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 568,
      "line_end": 568
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "曼陀山庄",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 578,
      "line_end": 578
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那公子求道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 592,
      "line_end": 592
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "那时王夫人答道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 594,
      "line_end": 594
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "抓破美人脸",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 600,
      "line_end": 600
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "这句话大触王夫人之怒，骂他：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 606,
      "line_end": 606
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "岂有此理",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 612,
      "line_end": 612
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "语嫣呢",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 644,
      "line_end": 644
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人颤声道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 662,
      "line_end": 662
    },
    {
      "speaker": "char_wang_fu_ren",
      "speaker_name": "王夫人",
      "listener": null,
      "text": "砰的一声，在桌上重重击了一下，怒道：",
      "tone": "颤声",
      "chapter": 47,
      "line_start": 662,
      "line_end": 662
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "万万不许",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 678,
      "line_end": 678
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人怒道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 684,
      "line_end": 684
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复笑道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 704,
      "line_end": 704
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 706,
      "line_end": 706
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 708,
      "line_end": 708
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 712,
      "line_end": 712
    },
    {
      "speaker": "char_mu_rong_fu",
      "speaker_name": "慕容复",
      "listener": null,
      "text": "青裙玉面如相识，九月茶花满路开！",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 716,
      "line_end": 716
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 720,
      "line_end": 720
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 722,
      "line_end": 722
    },
    {
      "speaker": "char_wang_fu_ren",
      "speaker_name": "王夫人",
      "listener": null,
      "text": "你说我怎么能见得到他？",
      "tone": "颤声",
      "chapter": 47,
      "line_start": 728,
      "line_end": 728
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "最后两句话已大有轻薄之意，但王夫人心情激荡，丝毫不以为忤，叹了口气，道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 734,
      "line_end": 734
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 746,
      "line_end": 746
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 748,
      "line_end": 748
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "难道我已晕倒了四五日？",
      "tone": "惊讶",
      "chapter": 47,
      "line_start": 754,
      "line_end": 754
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "但转念又想：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 790,
      "line_end": 790
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "言念及此，颇觉坦然，但不禁又想：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 794,
      "line_end": 794
    },
    {
      "speaker": "char_wang_fu_ren",
      "speaker_name": "王夫人",
      "listener": null,
      "text": "总而言之，是你不中用。",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 808,
      "line_end": 808
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 816,
      "line_end": 816
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复拍手道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 818,
      "line_end": 818
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "啊",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 824,
      "line_end": 824
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "但想到和段正淳相见、劝他喝酒的情景，不由得眉花眼笑，心魂皆酥，甜腻腻的道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 842,
      "line_end": 842
    },
    {
      "speaker": "char_mu_rong_fu",
      "speaker_name": "慕容复",
      "listener": null,
      "text": "舅妈，你外甥出的这个主意还不错罢？",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 846,
      "line_end": 846
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 848,
      "line_end": 848
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人皱眉道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 850,
      "line_end": 850
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 852,
      "line_end": 852
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复摇头道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 862,
      "line_end": 862
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人听他语气，似乎并非当真时机紧迫，凶险万分，又稍宽心，连问：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 864,
      "line_end": 864
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 874,
      "line_end": 874
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 882,
      "line_end": 882
    },
    {
      "speaker": "char_wang_fu_ren",
      "speaker_name": "王夫人",
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 882,
      "line_end": 882
    },
    {
      "speaker": "char_wang_fu_ren",
      "speaker_name": "王夫人",
      "listener": null,
      "text": "这倒也有点道理，你却又怎么知道？",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 892,
      "line_end": 892
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 894,
      "line_end": 894
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人问道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 900,
      "line_end": 900
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 902,
      "line_end": 902
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复笑道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 912,
      "line_end": 912
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人喜道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 914,
      "line_end": 914
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 926,
      "line_end": 926
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 942,
      "line_end": 942
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 946,
      "line_end": 946
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 968,
      "line_end": 968
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 970,
      "line_end": 970
    },
    {
      "speaker": "char_wang_fu_ren",
      "speaker_name": "王夫人",
      "listener": null,
      "text": "你说这段小子是香饵？",
      "tone": "轻笑",
      "chapter": 47,
      "line_start": 981,
      "line_end": 981
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 983,
      "line_end": 983
    },
    {
      "speaker": "char_wang_fu_ren",
      "speaker_name": "王夫人",
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 983,
      "line_end": 983
    },
    {
      "speaker": "char_wang_fu_ren",
      "speaker_name": "舅妈",
      "listener": null,
      "text": "王夫人道：",
