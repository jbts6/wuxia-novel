      "line_start": 428,
      "line_end": 428
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "字，在",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 428,
      "line_end": 428
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "字，变成",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 428,
      "line_end": 428
    },
    {
      "speaker": "char_zhong_ling",
      "speaker_name": "钟灵",
      "listener": null,
      "text": "这些木材是什么树上来的，可香得紧！",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 438,
      "line_end": 438
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段誉",
      "listener": null,
      "text": "好香！",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 440,
      "line_end": 440
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "钟灵道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 452,
      "line_end": 452
    },
    {
      "speaker": "char_zhong_ling",
      "speaker_name": "钟灵",
      "listener": null,
      "text": "巴天石却道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 452,
      "line_end": 452
    },
    {
      "speaker": "char_mu_wan_qing",
      "speaker_name": "木婉清",
      "listener": null,
      "text": "是蜜蜂！",
