    },
    {
      "speaker": "char_zhong_ling",
      "speaker_name": "钟灵",
      "listener": null,
      "text": "巴天石道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 384,
      "line_end": 384
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "朱丹臣一听，当即会意，道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 392,
      "line_end": 392
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "春沟水动茶花（　）",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 418,
      "line_end": 418
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "夏谷（　）生荔枝红",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 418,
      "line_end": 418
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "当即伸手出去，但听得嗤嗤声响，已在对联的",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 428,
      "line_end": 428
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "字下写了个",
      "tone": "陈述",
