      "line_start": 1003,
      "line_end": 1003
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1011,
      "line_end": 1011
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "转念又想：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1025,
      "line_end": 1025
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人又惊又怒，砰的一声，在桌上重重拍了一下，道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1049,
      "line_end": 1049
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复叹了口气，悠悠的道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1051,
      "line_end": 1051
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人惊怒愈甚，大声道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1053,
      "line_end": 1053
    },
    {
      "speaker": "char_mu_rong_fu",
      "speaker_name": "慕容复",
      "listener": null,
      "text": "一个姓秦，一个姓阮⋯⋯",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1071,
      "line_end": 1071
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "慕容复道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1073,
      "line_end": 1073
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人怒道：",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1077,
      "line_end": 1077
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人",
      "tone": "陈述",
      "chapter": 47,
      "line_start": 1088,
      "line_end": 1088
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "王夫人",
