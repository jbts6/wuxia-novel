  {
    "id": "faction_shen_shui_gong",
    "name": "神水宫",
    "type": "武林门派",
    "location": "loc_shen_shui_gong",
    "sub_divisions": [],
    "one_line": "水母阴姬所创的神秘门派，宫中只有女子，以天一神水闻名",
    "source_refs": [
      {
        "chapter": 19,
        "line_start": 18,
        "line_end": 18,
        "text": "神水宫的主人"
      },
      {
        "chapter": 22,
        "line_start": 20,
        "line_end": 20,
        "text": "楚留香道：\"你也莫要忘记，这里已到了神水宫的禁区之内。\""
      },
      {
        "chapter": 23,
        "line_start": 208,
        "line_end": 212,
        "text": "神水宫乃是一座山谷，谷中繁花如锦，宛如桃源"
      },
      {
        "chapter": 26,
        "line_start": 138,
        "line_end": 140,
        "text": "他终于看到了神水宫"
      },
      {
        "chapter": 27,
        "line_start": 1,
        "line_end": 1,
        "text": "第二十七回 水母阴姬"
      },
      {
        "chapter": 28,
        "line_start": 2,
        "line_end": 2,
        "text": "水母阴姬随手向胡铁花一指"
      },
      {
        "chapter": 32,
        "line_start": 2,
        "line_end": 3,
        "text": "神水宫门规之严，江湖中人人都知道的"
      },
      {
        "chapter": 33,
        "line_start": 88,
        "line_end": 88,
        "text": "神水宫见血封喉的独门暗器"
      }
    ]
  },
