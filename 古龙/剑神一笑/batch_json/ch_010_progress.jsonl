t":121,"line_end":121,"text":"每个指甲上都套着一种用薄铜打成的指套，锋利如剑"}]},{"id":"item_jian_xue","name":"箭靴","type":"weapon","owner":"char_gong_ping","one_line":"宫萍脚上穿的靴子，一脚踢出碎石如粉","description":"宫萍脚上穿的特制靴子，鞋尖坚硬如箭头，一脚踢出能碎石如粉，是近身搏斗的致命武器，配合轻功使用威力倍增。","effects":["碎石如粉的踢击"],"origin":"未知","rarity":"上乘佳品","related_characters":["char_gong_ping"],"related_skills":[],"rag_refs":[10],"source_refs":[{"chapter":10,"line_start":123,"line_end":123,"text":"宫萍的脚上，穿的是箭靴，一脚踢出，碎石如粉"}]}]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":205,"dialogues":[{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":"char_lao_ban_niang","text":"你要杀我？","tone":"疑问","chapter":10,"line_start":149,"line_end":149},{"speaker":"char_lao_ban_niang","speaker_name":"老板娘","listener":"char_lu_xiao_feng","text":"我一定要杀你。","tone":"冷酷","chapter":10,"line_start":151,"line_end":151},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":"char_lao_ban_niang","text":"为什么？","tone":"疑问","chapter":10,"line_start":153,"line_end":153},{"speaker":"char_lao_ban_niang","speaker_name":"老板娘","listener":"char_lu_xiao_feng","text":"因为你不但是柳乘风的朋友，也是我的朋友，你如果不死，我怎么对得起柳乘风？","tone":"悲伤","chapter":10,"line_start":155,"line_end":155},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":"char_lao_ban_niang","text":"你疯了。","tone":"惊讶","chapter":10,"line_start":157,"line_end":157},{"speaker":"char_lao_ban_niang","speaker_name":"老板娘","listener":"char_lu_xiao_feng","text":"我没有疯，我只是太伤心了。","tone":"悲伤","chapter":10,"line_start":159,"line_end":159},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你伤心？","tone":"疑问","chapter":10,"line_start":161,"line_end":161},{"speaker":"char_lao_ban_niang","speaker_name":"老板娘","listener":"char_lu_xiao_feng","text":"我当然伤心，柳乘风死了，我怎么能不伤心？","tone":"悲痛","chapter":10,"line_start":163,"line_end":163},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":"char_lao_ban_niang","text":"你和柳乘风是什么关系？","tone":"疑问","chapter":10,"line_start":165,"line_end":165},{"speaker":"char_lao_ban_niang","speaker_name":"老板娘","listener":"char_lu_xiao_feng","text":"他是我的情郎。","tone":"悲伤","chapter":10,"line_start":167,"line_end":167},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":"char_lao_ban_niang","text":"你的情郎？","tone":"惊讶","chapter":10,"line_start":169,"line_end":169},{"speaker":"char_lao_ban_niang","speaker_name":"老板娘","listener":"char_lu_xiao_feng","text":"不错，他是我的情郎，他死了，我一定要为他报仇。","tone":"认真","chapter":10,"line_start":171,"line_end":171}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
