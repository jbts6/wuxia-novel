{
  "chapter": 18,
  "dialogues": [
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_su_su", "text": "你知道陆小凤的死因？", "tone": "逼问", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_niu_rou_tang", "text": "那么好的人，为什么偏偏那么早死呢？", "tone": "叹息", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_su_su", "text": "是谁杀他的？", "tone": "追问", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_niu_rou_tang", "text": "陆小凤是我最仰慕的人，居然死在黄石镇上，我实在难过极了。", "tone": "悲伤", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_su_su", "text": "讲难过，最难过的应该是我。", "tone": "争辩", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_niu_rou_tang", "text": "为什么？", "tone": "疑问", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_su_su", "text": "难道你不知道我和他的关系？", "tone": "反问", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_su_su", "text": "你快告诉我，是谁杀的？我一定要替他报仇。", "tone": "急切", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_niu_rou_tang", "text": "谁杀的？谁能杀得了陆小凤？能杀他的人，当然是他最亲近的人，是他最不会提防的人。", "tone": "暗示", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_su_su", "text": "是谁？", "tone": "追问", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_niu_rou_tang", "text": "你马上就知道了。我已经派人去把这些人找来，他们还没来以前，我们为什么不多喝两杯，遥祝陆大侠在天之灵？", "tone": "提议", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_gong_ping", "text": "宫萍，你想干什么？", "tone": "叱喝", "chapter": 18},
    {"speaker": "char_gong_ping", "speaker_name": "宫萍", "listener": "char_gong_su_su", "text": "我听说西门公子的剑术已经练到无剑的境界，我想领教一下。", "tone": "挑衅", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_ping", "text": "哼！我看你是活得不耐烦了。", "tone": "讽刺", "chapter": 18},
    {"speaker": "char_gong_ping", "speaker_name": "宫萍", "listener": "char_xi_men_chui_xue", "text": "拔剑吧。", "tone": "挑衅", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_ping", "text": "我看你真的是活得不耐烦了，", "tone": "警告", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_ping", "text": "你居然敢叫西门大侠拔剑，你知道他一拔剑的后果吗？", "tone": "警告", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_gong_ping", "text": "你死定了。", "tone": "断言", "chapter": 18},
    {"speaker": "char_gong_ping", "speaker_name": "宫萍", "listener": "char_niu_rou_tang", "text": "每件事都有例外的。", "tone": "自信", "chapter": 18},
    {"speaker": "char_sha_da_hu", "speaker_name": "沙大户", "listener": "char_xi_men_chui_xue", "text": "好剑法！", "tone": "赞叹", "chapter": 18},
    {"speaker": "char_sha_da_hu", "speaker_name": "沙大户", "listener": "char_xi_men_chui_xue", "text": "西门吹雪无剑的境界，果然名不虚传。", "tone": "赞叹", "chapter": 18},
    {"speaker": "char_wang_da_yan", "speaker_name": "王大眼", "listener": null, "text": "其实，我早就知道谁是凶手了。", "tone": "得意", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_wang_da_yan", "text": "是谁？", "tone": "追问", "chapter": 18},
    {"speaker": "char_lao_ban_niang", "speaker_name": "老板娘", "listener": "char_wang_da_yan", "text": "他根本就不知道谁是凶手。", "tone": "否定", "chapter": 18},
    {"speaker": "char_wang_da_yan", "speaker_name": "王大眼", "listener": "char_lao_ban_niang", "text": "你为什么认为我不知道谁是凶手？", "tone": "反问", "chapter": 18},
    {"speaker": "char_lao_ban_niang", "speaker_name": "老板娘", "listener": "char_wang_da_yan", "text": "你如果知道，你会不早说吗？", "tone": "反问", "chapter": 18},
    {"speaker": "char_wang_da_yan", "speaker_name": "王大眼", "listener": "char_lao_ban_niang", "text": "早说？早说出来，我会活到现在吗？", "tone": "反问", "chapter": 18},
    {"speaker": "char_huang_xiao_chong", "speaker_name": "黄小虫", "listener": "char_wang_da_yan", "text": "你不怕凶手杀你灭口？", "tone": "质疑", "chapter": 18},
    {"speaker": "char_wang_da_yan", "speaker_name": "王大眼", "listener": "char_huang_xiao_chong", "text": "杀我灭口？那他岂不自己暴露身份？", "tone": "反问", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": null, "text": "到底谁是凶手？", "tone": "追问", "chapter": 18},
    {"speaker": "char_zhao_xia_zi", "speaker_name": "赵瞎子", "listener": null, "text": "最好凶手是很多人。", "tone": "调侃", "chapter": 18},
    {"speaker": "char_huang_xiao_chong", "speaker_name": "黄小虫", "listener": "char_zhao_xia_zi", "text": "为什么？", "tone": "疑问", "chapter": 18},
    {"speaker": "char_zhao_xia_zi", "speaker_name": "赵瞎子", "listener": "char_huang_xiao_chong", "text": "为什么？凶手愈多，我的棺材生意不就愈好吗？哈哈哈哈……", "tone": "调侃", "chapter": 18},
    {"speaker": "char_xi_men_chui_xue", "speaker_name": "西门吹雪", "listener": null, "text": "凶手是很多。", "tone": "断言", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_xi_men_chui_xue", "text": "是什么人？", "tone": "追问", "chapter": 18},
    {"speaker": "char_xi_men_chui_xue", "speaker_name": "西门吹雪", "listener": "char_sha_da_hu", "text": "他。", "tone": "指向", "chapter": 18},
    {"speaker": "char_xi_men_chui_xue", "speaker_name": "西门吹雪", "listener": "char_wang_da_yan", "text": "他。", "tone": "指向", "chapter": 18},
    {"speaker": "char_xi_men_chui_xue", "speaker_name": "西门吹雪", "listener": "char_lao_ban_niang", "text": "他。", "tone": "指向", "chapter": 18},
    {"speaker": "char_xi_men_chui_xue", "speaker_name": "西门吹雪", "listener": "char_zhao_xia_zi", "text": "他。", "tone": "指向", "chapter": 18},
    {"speaker": "char_xi_men_chui_xue", "speaker_name": "西门吹雪", "listener": "char_huang_xiao_chong", "text": "他。", "tone": "指向", "chapter": 18},
    {"speaker": "char_xi_men_chui_xue", "speaker_name": "西门吹雪", "listener": null, "text": "还有。", "tone": "补充", "chapter": 18},
    {"speaker": "char_niu_rou_tang", "speaker_name": "牛肉汤", "listener": "char_xi_men_chui_xue", "text": "还有？", "tone": "惊讶", "chapter": 18},
    {"speaker": "char_xi_men_chui_xue", "speaker_name": "西门吹雪", "listener": "char_gong_su_su", "text": "她。", "tone": "指向", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_xi_men_chui_xue", "text": "西门吹雪，你猜对了。黄石镇上的每一个人，都是杀死陆小凤的凶手。", "tone": "得意", "chapter": 18},
    {"speaker": "char_lao_ban_niang", "speaker_name": "老板娘", "listener": null, "text": "只可惜，", "tone": "转折", "chapter": 18},
    {"speaker": "char_lao_ban_niang", "speaker_name": "老板娘", "listener": "char_xi_men_chui_xue", "text": "你知道得太迟了。", "tone": "得意", "chapter": 18},
    {"speaker": "char_zhao_xia_zi", "speaker_name": "赵瞎子", "listener": null, "text": "不，一点也不迟。", "tone": "否定", "chapter": 18},
    {"speaker": "char_huang_xiao_chong", "speaker_name": "黄小虫", "listener": "char_zhao_xia_zi", "text": "为什么不迟？", "tone": "疑问", "chapter": 18},
    {"speaker": "char_zhao_xia_zi", "speaker_name": "赵瞎子", "listener": "char_huang_xiao_chong", "text": "因为刚好来得及睡我的棺材。", "tone": "调侃", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_niu_rou_tang", "text": "你想问，酒里是不是有毒，对不对？", "tone": "得意", "chapter": 18},
    {"speaker": "char_gong_su_su", "speaker_name": "宫素素", "listener": "char_niu_rou_tang", "text": "我告诉你，酒里有毒。", "tone": "得意", "chapter": 18},
    {"speaker": "char_huang_xiao_chong", "speaker_name": "黄小虫", "listener": "char_niu_rou_tang", "text": "你现在是不是愈来愈看不清楚面前的东西？", "tone": "调侃", "chapter": 18},
    {"speaker": "char_huang_xiao_chong", "speaker_name": "黄小虫", "listener": "char_niu_rou_tang", "text": "你还得意得了吗？你还有没有西门大侠的什么话，要告诉我们？", "tone": "调侃", "chapter": 18},
    {"speaker": "char_xiao_lao_tou", "speaker_name": "小老头", "listener": "char_xiao_lao_tai_po", "text": "你现在就去黄石镇？", "tone": "疑问", "chapter": 18},
    {"speaker": "char_xiao_lao_tai_po", "speaker_name": "小老太婆", "listener": "char_xiao_lao_tou", "text": "现在不去，什么时候才去？", "tone": "反问", "chapter": 18},
    {"speaker": "char_xiao_lao_tou", "speaker_name": "小老头", "listener": "char_xiao_lao_tai_po", "text": "当然等一切情况都明了的时候才去。", "tone": "建议", "chapter": 18},
    {"speaker": "char_xiao_lao_tai_po", "speaker_name": "小老太婆", "listener": "char_xiao_lao_tou", "text": "我怕太迟了。", "tone": "担忧", "chapter": 18},
    {"speaker": "char_xiao_lao_tou", "speaker_name": "小老头", "listener": "char_xiao_lao_tai_po", "text": "怎么会太迟？", "tone": "疑问", "chapter": 18},
    {"speaker": "char_xiao_lao_tai_po", "speaker_name": "小老太婆", "listener": "char_xiao_lao_tou", "text": "到时案子破了，我的小朋友却也许被害了。", "tone": "担忧", "chapter": 18},
    {"speaker": "char_xiao_lao_tou", "speaker_name": "小老头", "listener": "char_xiao_lao_tai_po", "text": "西门吹雪会被害？", "tone": "质疑", "chapter": 18},
    {"speaker": "char_xiao_lao_tai_po", "speaker_name": "小老太婆", "listener": "char_xiao_lao_tou", "text": "就是他。", "tone": "肯定", "chapter": 18},
    {"speaker": "char_xiao_lao_tou", "speaker_name": "小老头", "listener": "char_xiao_lao_tai_po", "text": "他会被害？你说些新鲜一点的笑话可以吧？", "tone": "调侃", "chapter": 18},
    {"speaker": "char_xiao_lao_tai_po", "speaker_name": "小老太婆", "listener": "char_xiao_lao_tou", "text": "你觉得这很好笑吗？", "tone": "不满", "chapter": 18},
    {"speaker": "char_xiao_lao_tou", "speaker_name": "小老头", "listener": "char_xiao_lao_tai_po", "text": "你不觉得好笑？", "tone": "反问", "chapter": 18},
    {"speaker": "char_xiao_lao_tai_po", "speaker_name": "小老太婆", "listener": "char_xiao_lao_tou", "text": "一点也不。你别忘了，柳如钢死在黄石镇，陆小凤也死在黄石镇。", "tone": "严肃", "chapter": 18},
    {"speaker": "char_xiao_lao_tai_po", "speaker_name": "小老太婆", "listener": "char_xiao_lao_tou", "text": "你想干什么？", "tone": "疑问", "chapter": 18},
    {"speaker": "char_xiao_lao_tou", "speaker_name": "小老头", "listener": "char_xiao_lao_tai_po", "text": "干什么？去黄石镇呀。", "tone": "决定", "chapter": 18}
  ]
}
