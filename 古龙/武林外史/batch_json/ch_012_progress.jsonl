{"segment":9,"line_start":801,"line_end":900,"dialogues":[{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你说的话可算数？","tone":"陈述","chapter":12,"line_start":802,"line_end":802},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"好，我也依你这一次，且等到明天再说。","tone":"陈述","chapter":12,"line_start":808,"line_end":808},{"speaker":null,"speaker_name":null,"listener":"char_zhu_qi_qi","text":"姑娘，早。","tone":"陈述","chapter":12,"line_start":818,"line_end":818},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你抬起头来，让我瞧瞧。","tone":"陈述","chapter":12,"line_start":830,"line_end":830},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"嗯","tone":"陈述","chapter":12,"line_start":832,"line_end":832},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"我我……怎比得上姑娘……","tone":"陈述","chapter":12,"line_start":840,"line_end":840},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你也莫要客气，但……但也不该骗我。","tone":"陈述","chapter":12,"line_start":842,"line_end":842},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"我怎敢骗姑娘。","tone":"陈述","chapter":12,"line_start":844,"line_end":844},{"speaker":null,"speaker_name":null,"listener":"char_zhu_qi_qi","text":"我……我……","tone":"陈述","chapter":12,"line_start":850,"line_end":850},{"speaker":null,"speaker_name":null,"listener":null,"text":"如此说来，便不是他了……","tone":"喃喃","chapter":12,"line_start":862,"line_end":862},{"speaker":null,"speaker_name":null,"listener":null,"text":"不是谁？","tone":"陈述","chapter":12,"line_start":864,"line_end":864},{"speaker":null,"speaker_name":null,"listener":null,"text":"没……没有什么。","tone":"陈述","chapter":12,"line_start":868,"line_end":868},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"当真是颜如春花，艳冠群芳……","tone":"无奈","chapter":12,"line_start":874,"line_end":874},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你……你说谁？","tone":"陈述","chapter":12,"line_