{"segment":11,"line_start":1001,"line_end":1085,"dialogues":[{"speaker":"char_ou_yang_xi","speaker_name":"欧阳喜","listener":null,"text":"这……","tone":"陈述","chapter":12,"line_start":1004,"line_end":1004},{"speaker":null,"speaker_name":null,"listener":"char_ou_yang_xi","text":"好……搬四坛酒来。","tone":"陈述","chapter":12,"line_start":1018,"line_end":1018},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","listener":null,"text":"如此最好，一人一坛，谁也不吃亏。","tone":"陈述","chapter":12,"line_start":1022,"line_end":1022},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","listener":null,"text":"若是一坛不醉，又当如何？","tone":"陈述","chapter":12,"line_start":1024,"line_end":1024},{"speaker":"char_shen_lang","speaker_name":"沈浪","listener":"char_wang_lian_hua","text":"这四坛不醉，再来八坛。","tone":"陈述","chapter":12,"line_start":1026,"line_end":1026},{"speaker":"char_shen_lang","speaker_name":"沈浪","listener":null,"text":"若还不醉呢？","tone":"陈述","chapter":12,"line_start":1028,"line_end":1028},{"speaker":"char_shen_lang","speaker_name":"沈浪","listener":null,"text":"若还无人醉倒，就喝他个三天，又有何妨？","tone":"陈述","chapter":12,"line_start":1030,"line_end":1030},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","listener":"char_shen_lang","text":"妙极妙极，但，还有……","tone":"大笑","chapter":12,"line_start":1032,"line_end":1032},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_wang_lian_hua","text":"还有什么？","tone":"陈述","chapter":12,"line_start":1034,"line_end":1034},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"喝酒的快慢，也大有学问……","tone":"疑问","chapter":12,"line_start":1036,"line_end":1036},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你这猫儿能喝多快，咱们就能喝多快。","tone":"陈述","chapter":12,"line_start":1038,"line_end":1038},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"好……","tone":"大笑","chapter":12,"line_start":1040,"line_end":1040},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"倒了一个……","tone":"大笑","chapter":12,"line_start":1064,"