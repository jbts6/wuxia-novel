{"segment":8,"line_start":701,"line_end":800,"dialogues":[{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"他要你回去，你就回去么？你这么听话？","tone":"陈述","chapter":12,"line_start":706,"line_end":706},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"无论如何，人家总是一片好意……","tone":"无奈","chapter":12,"line_start":708,"line_end":708},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"我偏不领这个情，我偏要去瞧个明白。","tone":"陈述","chapter":12,"line_start":710,"line_end":710},{"speaker":null,"speaker_name":null,"listener":"char_xiong_mao_er","text":"谁？……什么人……捉贼！","tone":"陈述","chapter":12,"line_start":726,"line_end":726},{"speaker":null,"speaker_name":null,"listener":null,"text":"不好……快退……","tone":"陈述","chapter":12,"line_start":728,"line_end":728},{"speaker":null,"speaker_name":null,"listener":null,"text":"随我来。","tone":"陈述","chapter":12,"line_start":734,"line_end":734},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"只怕他是故意如此的。","tone":"陈述","chapter":12,"line_start":746,"line_end":746},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你说他故意要被人发现，莫非他疯了么？","tone":"陈述","chapter":12,"line_start":748,"line_end":748},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你又要怎样？","tone":"陈述","chapter":12,"line_start":762,"line_end":762},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"我还要回去瞧瞧。","tone":"陈述","chapter":12,"line_start":764,"line_end":764},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你疯了么？","tone":"陈述","chapter":12,"line_start":766,"line_end":766},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"你怎能断定？","tone":"陈述","chapter":12,"line_start":782,"line_end":782},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"我实在说不过你。","tone":"无奈","chapter":12,"line_start":790,"line_end":790},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":