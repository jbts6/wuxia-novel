{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"吱咯","tone":"陈述","chapter":12,"line_start":610,"line_end":610},{"speaker":null,"speaker_name":null,"listener":null,"text":"好么……好么……","tone":"陈述","chapter":12,"line_start":626,"line_end":626},{"speaker":null,"speaker_name":null,"listener":null,"text":"好人……好人……我受不了……受不了，你杀了我吧，我……我已经快要死了……","tone":"陈述","chapter":12,"line_start":628,"line_end":628},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"不要脸，不要脸……好不要脸。","tone":"陈述","chapter":12,"line_start":636,"line_end":636},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"你头上是什么？","tone":"陈述","chapter":12,"line_start":652,"line_end":652},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"哪有什么……","tone":"陈述","chapter":12,"line_start":654,"line_end":654},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你……你头上是什么？","tone":"陈述","chapter":12,"line_start":656,"line_end":656},{"speaker":null,"speaker_name":null,"listener":"char_zhu_qi_qi","text":"傻蛋之后。","tone":"陈述","chapter":12,"line_start":662,"line_end":662},{"speaker":null,"speaker_name":null,"listener":null,"text":"傻蛋之王。","tone":"陈述","chapter":12,"line_start":664,"line_end":664},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"不管他是谁，我们还是……","tone":"陈述","chapter":12,"line_start":688,"line_end":688},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"我们还是回去吧。","tone":"陈述","chapter":12,"line_start":690,"line_end":690},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"回去，回去，你只知道回去。","tone":"陈述","chapter":12,"line_start":692,"line_end":692},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"为什么……为什么……","tone":"陈述","chapter":12,"line_start":700,"line_end":700}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[