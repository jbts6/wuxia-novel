{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"为你……自然是为你着急。","tone":"焦急","chapter":12,"line_start":104,"line_end":104},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"那么，你鬼丫头、死丫头也骂的是我了。","tone":"陈述","chapter":12,"line_start":106,"line_end":106},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"好……咳咳，很好……","tone":"陈述","chapter":12,"line_start":114,"line_end":114},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"好","tone":"陈述","chapter":12,"line_start":116,"line_end":116},{"speaker":null,"speaker_name":null,"listener":"char_xiong_mao_er","text":"姑娘……","tone":"苦笑","chapter":12,"line_start":124,"line_end":124},{"speaker":null,"speaker_name":null,"listener":null,"text":"快过来，让我为你擦擦脸……","tone":"陈述","chapter":12,"line_start":126,"line_end":126},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"我方才和你闹着玩的，你难道还放在心上？","tone":"陈述","chapter":12,"line_start":132,"line_end":132},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"我？","tone":"陈述","chapter":12,"line_start":134,"line_end":134},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你笑什么？","tone":"陈述","chapter":12,"line_start":142,"line_end":142},{"speaker":null,"speaker_name":null,"listener":"char_xiong_mao_er","text":"死猫，瘟猫，你……你……","tone":"陈述","chapter":12,"line_start":154,"line_end":154},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你说的可是真心话？","tone":"陈述","chapter":12,"line_start":162,"line_end":162},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"我说的话正如陈年老酒，决不掺假。","tone":"陈述","chapter":12,"line_start":164,"line_end":164},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"但……但你为何要如此？","tone":"陈述","chapter":12,"line_start":166,"line_end":166},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"我……我……","tone":"陈述","chapter":12,"line_start":168,"line_end":168},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"洛阳城里的路，不知你可熟么？","tone":"无奈","chapter":12,"line_start":174,"line_end":174},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"好，你先带我去洛阳的花市。","tone":"陈述","chapter":12,"line_start":180,"line_end":180},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"洛阳城只有这么一个花市？","tone":"喃喃","chapter":12,"line_start":190,"line_end":190},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"我不是来买花的。","tone":"陈述","chapter":12,"line_start":196,"line_end":196}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"这其中有个秘密。","tone":"陈述","chapter":12,"line_start":202,"line_end":202},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"什么秘密？","tone":"陈述","chapter":12,"line_start":204,"line_end":204},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你若想听，我不妨说给你听，但……","tone":"陈述","chapter":12,"line_start":206,"line_end":206},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你几时也变得如此哕嗦了……问吧。","tone":"疑问","chapter":12,"line_start":212,"line_end":212},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"我且问你，我所说的有关王怜花的话，你可相信么？","tone":"疑问","chapter":12,"line_start":214,"line_end":214},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你真聪明。","tone":"陈述","chapter":12,"line_start":228,"line_end":228},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"总该不笨就是。","tone":"大笑","chapter":12,"line_start":230,"line_end":230},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"好，聪明人，先替我去找辆大车来。","tone":"陈述","chapter":12,"line_start":232,"line_end":232},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"要大车干什么？","tone":"陈述","chapter":12,"line_start":234,"line_end":234},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"刚说你聪明，你就变笨了。那日我躲在车底下，什么都瞧不见，只有在暗中记着车行的方向，今日自然也得寻辆大车……","tone":"无奈","chapter":12,"line_start":236,"line_end":236},{"speaker":null,"speaker_name":null,"listener":"char_xiong_mao_er","text":"但……但……","tone":"陈述","chapter":12,"line_start":246,"line_end":246},{"speaker":null,"speaker_name":null,"listener":null,"text":"求求你，好么……求求你。","tone":"陈述","chapter":12,"line_start":248,"line_end":248},{"speaker":null,"speaker_name":null,"listener":null,"text":"好吧，我去试试。","tone":"无奈","chapter":12,"line_start":252,"line_end":252},{"speaker":null,"speaker_name":null,"listener":null,"text":"这才是听话的乖孩子！快快去吧，我在这里等你……","tone":"陈述","chapter":12,"line_start":254,"line_end":254},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"噗哧","tone":"陈述","chapter":12,"line_start":272,"line_end":272},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"算你有理。","tone":"陈述","chapter":12,"line_start":272,"line_end":272},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你这是干么？","tone":"陈述","chapter":12,"line_start":274,"line_end":274},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"是极是极，我是笨人。","tone":"陈述","chapter":12,"line_start":280,"line_end":280},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你难道不笨？你笑什么？","tone":"陈述","chapter":12,"line_start":282,"line_end":282},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"谁得意了？","tone":"陈述","chapter":12,"line_start":294,"line_end":294},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"好，就算我得意了……","tone":"苦笑","chapter":12,"line_start":300,"line_end":300}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_da_che","name":"大车","type":"special","owner":null,"one_line":"朱七七让熊猫儿找来的大车，用以重现当日路线","description":"一辆可容马车进入的大车，朱七七要求用来模拟当日被囚时的车行路线，以便凭记忆找回囚禁之地。","effects":[],"origin":"熊猫儿不知从何处寻来","rarity":"寻常凡品","related_characters":["char_zhu_qi_qi","char_xiong_mao_er"],"related_skills":[],"rag_refs":[12],"source_refs":[{"chapter":12,"line_start":260,"line_end":260,"text":"熊猫儿果然赶着辆大车回来了"}]}]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"你说什么？","tone":"陈述","chapter":12,"line_start":310,"line_end":310},{"speaker":null,"speaker_name":null,"listener":null,"text":"没有什么，好姑娘，请你快上车吧。","tone":"陈述","chapter":12,"line_start":312,"line_end":312},{"speaker":null,"speaker_name":null,"listener":null,"text":"一，二，三，四，五，六……","tone":"陈述","chapter":12,"line_start":316,"line_end":316},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"四十七","tone":"陈述","chapter":12,"line_start":318,"line_end":318},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"不对不对。","tone":"陈述","chapter":12,"line_start":318,"line_end":318},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"什么不对？","tone":"陈述","chapter":12,"line_start":320,"line_end":320},{"speaker":null,"speaker_name":null,"listener":"char_xiong_mao_er","text":"是，遵命。","tone":"无奈","chapter":12,"line_start":326,"line_end":326},{"speaker":null,"speaker_name":null,"listener":null,"text":"一，二，三……","tone":"陈述","chapter":12,"line_start":330,"line_end":330},{"speaker":null,"speaker_name":null,"listener":null,"text":"四十七","tone":"陈述","chapter":12,"line_start":332,"line_end":332},{"speaker":null,"speaker_name":null,"listener":null,"text":"你难道不能快些发觉么？定要走这么远后，才……","tone":"陈述","chapter":12,"line_start":336,"line_end":336},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你真是个好人。","tone":"陈述","chapter":12,"line_start":348,"line_end":348},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"九十","tone":"陈述","chapter":12,"line_start":350,"line_end":350},{"speaker":null,"speaker_name":null,"listener":"char_zhu_qi_qi","text":"到了，就在这里。","tone":"陈述","chapter":12,"line_start":360,"line_end":360},{"speaker":null,"speaker_name":null,"listener":null,"text":"哪里？","tone":"疑问","chapter":12,"line_start":362,"line_end":362},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你可是说那边的门？","tone":"陈述","chapter":12,"line_start":368,"line_end":368},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"不错。","tone":"陈述","chapter":12,"line_start":370,"line_end":370},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你这次只怕必定错了。","tone":"陈述","chapter":12,"line_start":372,"line_end":372},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"不错，不错，万万不会错的。","tone":"陈述","chapter":12,"line_start":374,"line_end":374},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"万万是错了，只因这家人我早就认得。","tone":"沉声","chapter":12,"line_start":376,"line_end":376},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你认得？莫非果然是王怜花的家……","tone":"陈述","chapter":12,"line_start":378,"line_end":378},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"这地方王怜花虽然来过，但却绝非他的产业。","tone":"陈述","chapter":12,"line_start":380,"line_end":380},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"那么……这究竟是什么地方？","tone":"陈述","chapter":12,"line_start":382,"line_end":382},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"说不得……说不得……","tone":"陈述","chapter":12,"line_start":384,"line_end":384},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"要我红脸，哪有如此容易。","tone":"陈述","chapter":12,"line_start":394,"line_end":394},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"好，我告诉你，这是暗门子。","tone":"低语","chapter":12,"line_start":396,"line_end":396},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"暗门子","tone":"陈述","chapter":12,"line_start":398,"line_end":398}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"好姑娘，莫哭……莫要哭……","tone":"陈述","chapter":12,"line_start":420,"line_end":420},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你若不信，为何不进去瞧瞧。","tone":"陈述","chapter":12,"line_start":440,"line_end":440},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"进去就进去，难道我还怕了不成？","tone":"陈述","chapter":12,"line_start":442,"line_end":442},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"正该如此，姑娘快进去吧。","tone":"陈述","chapter":12,"line_start":462,"line_end":462},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你……你要我一个人进去？","tone":"陈述","chapter":12,"line_start":464,"line_end":464},{"speaker":null,"speaker_name":null,"listener":"char_xiong_mao_er","text":"姑娘难道要我陪你进去？","tone":"陈述","chapter":12,"line_start":466,"line_end":466},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你……你……","tone":"陈述","chapter":12,"line_start":480,"line_end":480},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"我怎样？","tone":"陈述","chapter":12,"line_start":482,"line_end":482},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你不进去么？","tone":"陈述","chapter":12,"line_start":484,"line_end":484}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":501,"line_end":600,"dialogues":[{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"好，好，我算服了你。","tone":"陈述","chapter":12,"line_start":502,"line_end":502},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"既是服了我，便该听我的话。","tone":"陈述","chapter":12,"line_start":504,"line_end":504},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"不错。","tone":"陈述","chapter":12,"line_start":510,"line_end":510},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"我知道……随我来吧。","tone":"陈述","chapter":12,"line_start":516,"line_end":516},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"小心点别在雪地留下脚印。","tone":"陈述","chapter":12,"line_start":524,"line_end":524},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":"char_zhu_qi_qi","text":"不用你费心，我知道。","tone":"陈述","chapter":12,"line_start":526,"line_end":526},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":"char_xiong_mao_er","text":"莫……莫非这是死人？","tone":"陈述","chapter":12,"line_start":556,"line_end":556},{"speaker":null,"speaker_name":null,"listener":"char_zhu_qi_qi","text":"这两人已被点了穴道。","tone":"陈述","chapter":12,"line_start":562,"line_end":562},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"不错。","tone":"陈述","chapter":12,"line_start":568,"line_end":568},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"但……这两人是被谁点了穴道？","tone":"陈述","chapter":12,"line_start":570,"line_end":570},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你问我，我去问谁？","tone":"疑问","chapter":12,"line_start":572,"line_end":572},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"你不会解开他们的穴道，问问他们自己么？","tone":"焦急","chapter":12,"line_start":574,"line_end":574},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","listener":null,"text":"……这又是什么人？","tone":"陈述","chapter":12,"line_start":580,"line_end":580},{"speak