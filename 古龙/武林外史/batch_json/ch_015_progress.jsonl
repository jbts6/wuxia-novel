{"segment":4,"line_start":281,"line_end":380,"dialogues":[{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"我要你们放了她。","tone":"陈述","chapter":15,"line_start":282,"line_end":282},{"speaker":"char_li_chang_qing","speaker_name":"李长青","listener":null,"text":"放了她……放了这位朱姑娘？","tone":"陈述","chapter":15,"line_start":284,"line_end":284},{"speaker":"char_li_chang_qing","speaker_name":"李长青","listener":null,"text":"但……但我怎能信得过你？","tone":"陈述","chapter":15,"line_start":290,"line_end":290},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"信不信由你。","tone":"淡然","chapter":15,"line_start":292,"line_end":292},{"speaker":"char_li_chang_qing","speaker_name":"李长青","listener":null,"text":"也好。","tone":"陈述","chapter":15,"line_start":294,"line_end":294},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"不肯","tone":"陈述","chapter":15,"line_start":298,"line_end":298},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你快走吧。","tone":"冷笑","chapter":15,"line_start":304,"line_end":304},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你真的要我走？","tone":"陈述","chapter":15,"line_start":306,"line_end":306},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"你不走，反而拖累了我。","tone":"淡然","chapter":15,"line_start":308,"line_end":308},{"speaker":null,"speaker_name":null,"listener":null,"text":"我不走，我陪着你一齐打……我们要走一齐走，要战一齐战，要死一齐死","tone":"陈述","chapter":15,"line_start":310,"line_end":310},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"可怜呀可怜，可叹呀可叹，原来这位姑娘对我们的金老大，竟是如此无情无义，说走就走，连头都不回……","tone":"冷笑","chapter":15,"line_start":322,"line_end":322},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"畜生！啐！","tone":"愤怒","chapter":15,"line_start":324,"line_end":324},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"你干什么？","tone":"愤怒","chapter":15,"line_start":332,"line_end":332}],"new_entities":{"characters":[{"id":"char_j