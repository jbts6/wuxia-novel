{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"什么事？","tone":"陈述","chapter":14,"line_start":604,"line_end":604},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你……瞧……","tone":"陈述","chapter":14,"line_start":606,"line_end":606},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"喀喀","tone":"陈述","chapter":14,"line_start":606,"line_end":606},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"窗……窗外有个人。","tone":"颤声","chapter":14,"line_start":612,"line_end":612},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"哪有什么人？你眼花了么？","tone":"陈述","chapter":14,"line_start":614,"line_end":614},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"方才有的，你一回头，他就走了。","tone":"陈述","chapter":14,"line_start":616,"line_end":616},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"是谁？","tone":"陈述","chapter":14,"line_start":618,"line_end":618},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"就……就是那恶魔，那害得我又瘫又哑的恶魔。","tone":"陈述","chapter":14,"line_start":620,"line_end":620},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"你可瞧清楚了？","tone":"陈述","chapter":14,"line_start":622,"line_end":622},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你可要追出去？","tone":"陈述","chapter":14,"line_start":630,"line_end":630},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"此刻必定已追不着了。","tone":"陈述","chapter":14,"line_start":632,"line_end":632},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"哪……哪里去？","tone":"陈述","chapter":14,"line_start":642,"line_end":642},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"他","tone":"陈述","chapter":14,"line_start":648,"line_end":648},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"前面是什么地方？","tone":"陈述","chapter":14,"line_start":660,"line_end":660},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"我也不知道。","tone":"陈述","chapter":14,"line_start":662,"line_end":662},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"那……那么你要走到哪里去？","tone":"陈述","chapter":14,"line_start":664,"line_end":664},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"我也不知道。","tone":"陈述","chapter":14,"line_start":666,"line_end":666},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你……你……","tone":"陈述","chapter":14,"line_start":668,"line_end":668},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"我这是在做什么，你立刻便会知道的。","tone":"陈述","chapter":14,"line_start":670,"line_end":670},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"来了。","tone":"陈述","chapter":14,"line_start":672,"line_end":672},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"他","tone":"陈述","chapter":14,"line_start":690,"line_end":690},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"他","tone":"陈述","chapter":14,"line_start":692,"line_end":692},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"他","tone":"陈述","chapter":14,"line_start":694,"line_end":694},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"传音","tone":"陈述","chapter":14,"line_start":698,"line_end":698}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":701,"line_end":800,"dialogues":[{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"好……好。","tone":"陈述","chapter":14,"line_start":706,"line_end":706},{"speaker":null,"speaker_name":null,"listener":null,"text":"好……好。","tone":"微笑","chapter":14,"line_start":708,"line_end":708},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"我明知你要来的。","tone":"陈述","chapter":14,"line_start":710,"line_end":710},{"speaker":null,"speaker_name":null,"listener":null,"text":"我明知你要来的。","tone":"陈述","chapter":14,"line_start":712,"line_end":712},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"你既来了，为何不说话？","tone":"陈述","chapter":14,"line_start":714,"line_end":714},{"speaker":null,"speaker_name":null,"listener":null,"text":"你既来了，为何不说话？","tone":"陈述","chapter":14,"line_start":716,"line_end":716},{"speaker":null,"speaker_name":null,"listener":null,"text":"噫","tone":"陈述","chapter":14,"line_start":722,"line_end":722},{"speaker":null,"speaker_name":null,"listener":null,"text":"你此刻可是在戏弄于我，需知……","tone":"陈述","chapter":14,"line_start":722,"line_end":722},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"你是什么人？","tone":"愤怒","chapter":14,"line_start":724,"line_end":724},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"恶魔","tone":"陈述","chapter":14,"line_start":728,"line_end":728},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"是……是你。","tone":"陈述","chapter":14,"line_start":732,"line_end":732},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"原来是你。","tone":"愤怒","chapter":14,"line_start":734,"line_end":734},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"是我……两位未曾想到吧？","tone":"微笑","chapter":14,"line_start":736,"line_end":736},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你鬼鬼祟祟，跟在我们身后，要干什么？","tone":"陈述","chapter":14,"line_start":738,"line_end":738},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"住嘴。","tone":"愤怒","chapter":14,"line_start":744,"line_end":744},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"好，住嘴。大哥叫我住嘴，我就住嘴。","tone":"陈述","chapter":14,"line_start":746,"line_end":746},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你放的什么屁？","tone":"陈述","chapter":14,"line_start":754,"line_end":754},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"其实怎样？","tone":"陈述","chapter":14,"line_start":760,"line_end":760},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"其实我这大哥却风流得很。自他十五岁那年，就不知有多少女子为他害相思病了，到后来……","tone":"陈述","chapter":14,"line_start":762,"line_end":762},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"到后来怎样？","tone":"陈述","chapter":14,"line_start":766,"line_end":766},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"咳咳，我不敢说。","tone":"陈述","chapter":14,"line_start":768,"line_end":768},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你说，没关系。","tone":"陈述","chapter":14,"line_start":770,"line_end":770},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"呀……","tone":"陈述","chapter":14,"line_start":776,"line_end":776},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"骗你……我可没有骗你……","tone":"陈述","chapter":14,"line_start":786,"line_end":786},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"啐！谁跟你说话。","tone":"陈述","chapter":14,"line_start":788,"line_end":788},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"嫂子","tone":"陈述","chapter":14,"line_start":794,"line_end":794},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"放你的屁，谁是你的嫂子！","tone":"陈述","chapter":14,"line_start":796,"line_end":796}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":801,"line_end":900,"dialogues":[{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"好，给你。","tone":"陈述","chapter":14,"line_start":802,"line_end":802},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"你说完了没有？","tone":"淡然","chapter":14,"line_start":814,"line_end":814},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"说完了。","tone":"陈述","chapter":14,"line_start":816,"line_end":816},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"我与你虽已情义断绝，但是今日念在你自幼随我长大，我再次饶你一命……","tone":"陈述","chapter":14,"line_start":818,"line_end":818},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"滚，快滚！莫等我改变了主意。","tone":"陈述","chapter":14,"line_start":820,"line_end":820},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"你找沈浪做甚？","tone":"陈述","chapter":14,"line_start":830,"line_end":830},{"speaker":"char_shen_lang","speaker_name":"沈浪","listener":null,"text":"要找沈浪的人可多啦，何止我一人。","tone":"微笑","chapter":14,"line_start":832,"line_end":832},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"还有谁要找他？","tone":"陈述","chapter":14,"line_start":834,"line_end":834},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"这些人都要找他，找他干什么？","tone":"陈述","chapter":14,"line_start":840,"line_end":840},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"没有什么，只不过要宰他的脑袋。","tone":"陈述","chapter":14,"line_start":842,"line_end":842},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"为什么……为什么？","tone":"陈述","chapter":14,"line_start":844,"line_end":844},{"speaker":"char_shen_lang","speaker_name":"沈浪","listener":null,"text":"展英松等人全是沈浪送去的么？","tone":"陈述","chapter":14,"line_start":854,"line_end":854},{"speaker":"char_shen_lang","speaker_name":"沈浪","listener":null,"text":"不错，全是沈浪送去的。","tone":"陈述","chapter":14,"line_start":858,"line_end":858},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"你可以作证，是么？","tone":"陈述","chapter":14,"line_start":860,"line_end":860},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"这难道还有什么差错不成？","tone":"陈述","chapter":14,"line_start":866,"line_end":866},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"不错，他们的确都已入庄了。","tone":"微笑","chapter":14,"line_start":868,"line_end":868},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"这就是了……","tone":"陈述","chapter":14,"line_start":870,"line_end":870},{"speaker":"char_jin_wu_wang","speaker_name":"金无望","listener":null,"text":"他……他们是如何死的？","tone":"陈述","chapter":14,"line_start":878,"line_end":878},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"这……这绝非沈浪下的毒。","tone":"颤声","chapter":14,"line_start":890,"line_end":890},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"人是他送去的，毒不是他下的，是谁下的？","tone":"冷笑","chapter":14,"line_start":892,"line_end":892},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"是她……是那女子！","tone":"陈述","chapter":14,"line_start":894,"line_end":894},{"speaker":"char_jin_bu_huan","speaker_name":"金不换","listener":null,"text":"她是谁？那女子又是谁？","tone":"陈述","chapter":14,"line_start":896,"line_end":896},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","listener":null,"text":"我跟你说，也说不清的。","tone":"陈述","chapter":14,"line_start":898,"line_end":898}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
