{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"沈浪，你究竟想怎样？","tone":"低语","line_start":12,"line_end":12},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"这是……","tone":"疑问","line_start":16,"line_end":16},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"你猜猜这是什么？","tone":"微笑","line_start":18,"line_end":18},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"我猜不出。","tone":"陈述","line_start":20,"line_end":20},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"你可曾瞧见我用过暗器？","tone":"微笑","line_start":26,"line_end":26},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"从未见过。","tone":"陈述","line_start":28,"line_end":28},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"所以，你们便以为我不善于使用暗器，是么？","tone":"陈述","line_start":30,"line_end":30},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"嗯。","tone":"陈述","line_start":32,"line_end":32},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"不错不错，我……我错了。","tone":"苦笑","line_start":42,"line_end":42},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"他行事光明正大，自然不屑以暗器伤人。","tone":"温柔","line_start":44,"line_end":44},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"这倒有些道理，但也不太对。","tone":"陈述","line_start":46,"line_end":46},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"你到底想说什么，说吧。","tone":"苦笑","line_start":48,"line_end":48},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"我不愿使用暗器，只因我所用的暗器太过狠毒。","tone":"大笑","line_start":50,"line_end":50},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"哦……","tone":"陈述","line_start":52,"line_end":52},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"这就是我素来不肯轻易施展的暗器。","tone":"陈述","line_start":54,"line_end":54},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"这……这究竟是什么暗器？","tone":"陈述","line_start":58,"line_end":58},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"你这种暗器，只怕未必只有你沈浪会用。","tone":"淡然","line_start":64,"line_end":64},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"但这暗器还有一个最厉害的地方。","tone":"陈述","line_start":66,"line_end":66},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"哦……","tone":"陈述","line_start":68,"line_end":68},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"说来别人也许不信，这暗器委实已近通灵，本身已有搜魂的魔力，此刻，只要我的手一扬……","tone":"陈述","line_start":70,"line_end":70},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"世上真有这样的暗器？","tone":"陈述","line_start":76,"line_end":76},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"我说话几时骗过你？","tone":"陈述","line_start":78,"line_end":78},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"在下也正想开开眼界。","tone":"陈述","line_start":94,"line_end":94},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"其实，这也没有什么好瞧的。","tone":"陈述","line_start":96,"line_end":96},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"你就让他们瞧瞧吧。","tone":"陈述","line_start":98,"line_end":98},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"最想瞧的，只怕是你，是么？","tone":"陈述","line_start":100,"line_end":100}],"new_entities":{"characters":[{"id":"char_ji_feng_di_san_qi","name":"急风第三骑","alias":[],"identity":"快活王麾下急风三十六骑之一，排名第三","faction":"快活王麾下","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"急风三十六骑中的第三骑，负责林中暗卡调派","personality":{"traits":["忠诚","服从","谨慎","机敏","勤奋","执行力强"],"speech_style":"恭谨","temperament":"沉稳"},"relationships":[{"target":"char_kuai_huo_wang","type":"主仆","intensity":80,"bond_level":4,"dynamic":"绝对服从"}],"known_skills":[],"related_skills":[],"rag_refs":[40],"source_refs":[{"chapter":40,"line_start":290,"line_end":292,"text":"只见他英俊强悍，护心铜镜上有个\"三\"字，正是急风三十六骑中的第三骑。"}]},{"id":"char_ji_feng_di_yi_qi","name":"急风第一骑","alias":[],"identity":"快活王麾下急风三十六骑之一，排名第一","faction":"快活王麾下","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"急风三十六骑中的第一骑，搜索听涛馆一带","personality":{"traits":["忠诚","服从","谨慎","机敏","果敢"],"speech_style":"恭谨","temperament":"沉稳"},"relationships":[{"target":"char_kuai_huo_wang","type":"主仆","intensity":85,"bond_level":4,"dynamic":"绝对服从"}],"known_skills":[],"related_skills":[],"rag_refs":[40],"source_refs":[{"chapter":40,"line_start":402,"line_end":402,"text":"一个英悍少年应声抢出，恭身道：\"在！\""}]},{"id":"char_ji_feng_di_er_qi","name":"急风第二骑","alias":[],"identity":"快活王麾下急风三十六骑之一，排名第二","faction":"快活王麾下","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"急风三十六骑中的第二骑，搜索松香馆一带","personality":{"traits":["忠诚","服从","谨慎","沉稳","执行力强"],"speech_style":"恭谨","temperament":"沉稳"},"relationships":[{"target":"char_kuai_huo_wang","type":"主仆","intensity":80,"bond_level":4,"dynamic":"绝对服从"}],"known_skills":[],"related_skills":[],"rag_refs":[40],"source_refs":[{"chapter":40,"line_start":588,"line_end":588,"text":"急风第二骑伏地道：\"弟子几乎已将……\""}]},{"id":"char_yuan_lian_shao_nv","name":"圆脸少女","alias":[],"identity":"快活王身边的侍女","faction":"快活王麾下","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"快活王身边的圆脸侍女，性格直率大胆","personality":{"traits":["直率","大胆","泼辣","机灵","口是心非","多情"],"speech_style":"娇俏","temperament":"活泼"},"relationships":[{"target":"char_kuai_huo_wang","type":"主仆","intensity":60,"bond_level":3,"dynamic":"敬畏但有私心"},{"target":"char_wang_lian_hua","type":"对手","intensity":30,"bond_level":2,"dynamic":"被其魅力吸引"}],"known_skills":[],"related_skills":[],"rag_refs":[40],"source_refs":[{"chapter":40,"line_start":998,"line_end":998,"text":"那圆脸少女道：\"你们看，他今夜能逃得了么？\""}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_shen_lang","updates":{"source_refs":[{"chapter":40,"line_start":4,"line_end":4,"text":"沈浪不急不缓地走着，就像是在游山玩水似的"}]},"relationship_updates":[]},{"id":"char_kuai_huo_wang","updates":{"source_refs":[{"chapter":40,"line_start":134,"line_end":134,"text":"快活王皱着眉头，仿佛已开始有些坐立不安"}]},"relationship_updates":[]}]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"嗯。","tone":"陈述","line_start":102,"line_end":102},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"让你们瞧瞧，想来也无妨……","tone":"微笑","line_start":104,"line_end":104},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"这……这……这……是什么？","tone":"陈述","line_start":110,"line_end":110},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"这不叫'搜魂针'，这叫做'唬人针'。","tone":"微笑","line_start":112,"line_end":112},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"我懂了，我懂了……","tone":"大笑","line_start":114,"line_end":114},{"speaker":null,"speaker_name":"大汉们扑地跪了一片，惶声","text":"启禀王爷，只因那……那沈浪……","tone":"陈述","line_start":142,"line_end":142},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"本王还未出手，沈浪难道敢先向你们出手？","tone":"陈述","line_start":144,"line_end":144},{"speaker":null,"speaker_name":"为首一条大汉伏地","text":"他……他的暗器……","tone":"陈述","line_start":146,"line_end":146},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"沈浪居然也使出了暗器？他使的是什么暗器？","tone":"陈述","line_start":148,"line_end":148},{"speaker":null,"speaker_name":"大汉","text":"属下还不知道。","tone":"陈述","line_start":150,"line_end":150},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"为何还不知道？","tone":"厉声","line_start":152,"line_end":152},{"speaker":null,"speaker_name":"大汉嗫嚅","text":"他……他还未使出……","tone":"陈述","line_start":154,"line_end":154},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"放屁……简直是放屁。","tone":"陈述","line_start":164,"line_end":164},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"九天十地搜魂神针？你怎会知道？","tone":"陈述","line_start":170,"line_end":170},{"speaker":null,"speaker_name":"大汉","text":"属下听他自己说的。","tone":"陈述","line_start":172,"line_end":172},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"他自己说的？你们居然相信了！","tone":"愤怒","line_start":174,"line_end":174},{"speaker":null,"speaker_name":"大汉","text":"属下等不能不信……","tone":"陈述","line_start":176,"line_end":176},{"speaker":null,"speaker_name":"大汉以首顿地额上已流出了鲜血，","text":"这话若是别人说的，属下等自然不信，但沈浪……沈浪他……","tone":"陈述","line_start":182,"line_end":182},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"你们就如此怕他？","tone":"陈述","line_start":184,"line_end":184},{"speaker":null,"speaker_name":"大汉","text":"属下……属下等委实……委实有些怕他。","tone":"颤声","line_start":186,"line_end":186}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"咱们不出去。","tone":"陈述","line_start":208,"line_end":208},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"不出去？难道还留在这里？","tone":"陈述","line_start":210,"line_end":210},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"不错，咱们只有躲在这快活林里。","tone":"陈述","line_start":212,"line_end":212},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"为什么？","tone":"陈述","line_start":214,"line_end":214},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"你难道真的想不通这道理？","tone":"微笑","line_start":216,"line_end":216},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"这若也有道理，那么世上的道理也未免太多了。","tone":"冷笑","line_start":218,"line_end":218},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"这好像是废话，你好像已说过二十次了。","tone":"陈述","line_start":224,"line_end":224},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"他既然已将咱们看成他惟一的强仇大敌，行事自然不敢有疏忽……\"说到这里，他语气中再无讥诮之意，失声道：","tone":"陈述","line_start":230,"line_end":230},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"只是这快活林中，又怎会有咱们的藏身之处？","tone":"无奈","line_start":246,"line_end":246},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"但……但咱们究竟要退到哪里？","tone":"陈述","line_start":264,"line_end":264},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"究竟什么地方才是这快活林中惟一的安全之处？","tone":"陈述","line_start":266,"line_end":266},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"你们跟着我走，自然就会知道了。","tone":"微笑","line_start":268,"line_end":268},{"speaker":null,"speaker_name":"画的是快活林的地图，口中喃喃","text":"沈浪现在正在这里……这里从第十二道暗卡到第三十道暗卡都已被他骇退，他必定要由这条路继续往前走……","tone":"陈述","line_start":276,"line_end":276},{"speaker":null,"speaker_name":"条大汉恭身","text":"在！","tone":"陈述","line_start":282,"line_end":282},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"为何到此刻还未有消息报来？","tone":"陈述","line_start":284,"line_end":284},{"speaker":null,"speaker_name":"大汉","text":"属下不知。","tone":"陈述","line_start":286,"line_end":286},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"林中暗卡，是谁调派的？","tone":"厉声","line_start":288,"line_end":288},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"此刻外面还有几道暗卡？","tone":"陈述","line_start":294,"line_end":294},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"你派在哪里？","tone":"陈述","line_start":300,"line_end":300}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"你能确定？","tone":"厉声","line_start":306,"line_end":306},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"弟子已将园中地势全都仔细衡量过，决不会错。","tone":"陈述","line_start":308,"line_end":308},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"也许，沈浪已走不动了。","tone":"陈述","line_start":314,"line_end":314},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"放屁！他爬也要爬的。","tone":"愤怒","line_start":316,"line_end":316},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"莫非沈浪已出手将暗卡拔了去？","tone":"陈述","line_start":318,"line_end":318},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"是。","tone":"陈述","line_start":324,"line_end":324},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"你还不快去查个明白？","tone":"陈述","line_start":326,"line_end":326},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"是！","tone":"陈述","line_start":328,"line_end":328},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"他……他竟未往前走，难道他竟真的留在原地？","tone":"陈述","line_start":346,"line_end":346},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"弟子也曾到那里窥探，沈浪也并未留在那里。","tone":"陈述","line_start":348,"line_end":348},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"他到哪里去了？","tone":"陈述","line_start":350,"line_end":350},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"看来，他好像失踪了。","tone":"陈述","line_start":352,"line_end":352},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"岂有此理，世上哪有这样的事。","tone":"愤怒","line_start":362,"line_end":362},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"但……但他明明……","tone":"陈述","line_start":364,"line_end":364},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"混账，住口！","tone":"陈述","line_start":366,"line_end":366},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"往后退？难道他要自投死路不成！难道他……","tone":"陈述","line_start":374,"line_end":374},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"但……但他怎敢……","tone":"陈述","line_start":380,"line_end":380},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"但他纵然后退，又能退到哪里？","tone":"陈述","line_start":390,"line_end":390},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"他自然先要找个隐秘之处躲起来。","tone":"冷笑","line_start":392,"line_end":392},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"但在这快活林中，他又能躲在哪里。","tone":"陈述","line_start":394,"line_end":394},{"speaker":null,"speaker_name":"戛然顿住","text":"急风第一骑何在？","tone":"厉声","line_start":400,"line_end":400}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":null,"speaker_name":"英悍少年应声抢出，恭身","text":"在！","tone":"陈述","line_start":402,"line_end":402},{"speaker":"char_ji_feng_di_yi_qi","speaker_name":"急风第一骑","text":"遵命！","tone":"陈述","line_start":408,"line_end":408},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"急风第二骑何在？你与十一、十二两骑，另率九人，前往松香馆一带搜索，只要发现沈浪……","tone":"厉声","line_start":412,"line_end":412},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"就凭本王这几条神犬的鼻子，你也是躲不了的。","tone":"陈述","line_start":430,"line_end":430},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"沈浪行事果然周密。","tone":"无奈","line_start":440,"line_end":440},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"好好的路不走，为什么要在水里跑？","tone":"陈述","line_start":442,"line_end":442},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"当真什么事都被你想到了。","tone":"温柔","line_start":448,"line_end":448},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"你这又是在干什么？","tone":"陈述","line_start":452,"line_end":452},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"脱走的工具，这是什么意思？","tone":"陈述","line_start":458,"line_end":458},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"究竟是在干什么呀？","tone":"陈述","line_start":468,"line_end":468},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"这么绝的主意，真亏你想得出。","tone":"陈述","line_start":474,"line_end":474},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"这……这不是快活王住的地方么？","tone":"陈述","line_start":478,"line_end":478},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"正是。","tone":"陈述","line_start":480,"line_end":480},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"咱们难道……难道要躲在快活王住的屋子里？","tone":"陈述","line_start":482,"line_end":482},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"正是。","tone":"陈述","line_start":484,"line_end":484},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"你不是开玩笑吧？","tone":"陈述","line_start":486,"line_end":486},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"自然不是。","tone":"陈述","line_start":488,"line_end":488},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"快活林里地方很多，咱们为何偏偏要躲在这里？","tone":"陈述","line_start":490,"line_end":490},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"只因这地方是快活林中惟一安全之处。","tone":"陈述","line_start":492,"line_end":492},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"他决不会回来的。","tone":"沉声","line_start":498,"line_end":498}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":501,"line_end":600,"dialogues":[{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"但……但他们……","tone":"陈述","line_start":512,"line_end":512},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"但……但万一他们想到了呢？","tone":"陈述","line_start":518,"line_end":518},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"这……这还是太冒险。","tone":"陈述","line_start":528,"line_end":528},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"这就是我惟一佩服沈浪之处。","tone":"陈述","line_start":538,"line_end":538},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"咱们躲在这里，还有样好处。","tone":"陈述","line_start":544,"line_end":544},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"什么好处？","tone":"陈述","line_start":546,"line_end":546},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"还没有找到么？","tone":"厉声","line_start":574,"line_end":574},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"无用的东西！","tone":"愤怒","line_start":580,"line_end":580},{"speaker":"char_ji_feng_di_er_qi","speaker_name":"急风第二骑","text":"弟子几乎已将……","tone":"陈述","line_start":588,"line_end":588},{"speaker":"char_ji_feng_di_er_qi","speaker_name":"急风第二骑","text":"是。","tone":"陈述","line_start":594,"line_end":594}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"混账，没用的东西。","tone":"陈述","line_start":606,"line_end":606},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"人没有用，狗总该有用些吧？","tone":"陈述","line_start":610,"line_end":610},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"弟子牵着它们一路追到溪旁，但……","tone":"陈述","line_start":612,"line_end":612},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"沈浪比你们聪明得多，他想必下水去了。","tone":"冷笑","line_start":614,"line_end":614},{"speaker":"char_ji_feng_di_san_qi","speaker_name":"急风第三骑","text":"是。","tone":"陈述","line_start":616,"line_end":616},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"但对岸呢？他们总要上岸的。","tone":"厉声","line_start":618,"line_end":618},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"放屁，沈浪难道借水遁走了不成？","tone":"愤怒","line_start":624,"line_end":624},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"既是如此，为何找不着沈浪……","tone":"陈述","line_start":636,"line_end":636},{"speaker":null,"speaker_name":"","text":"只怕你并没有……","tone":"冷笑","line_start":638,"line_end":638},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"你早就想到了，是么？","tone":"愤怒","line_start":646,"line_end":646},{"speaker":"char_ji_feng_di_yi_qi","speaker_name":"急风第一骑","text":"弟子……弟子……","tone":"颤声","line_start":648,"line_end":648},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"你为何不早说？","tone":"厉声","line_start":650,"line_end":650},{"speaker":"char_ji_feng_di_yi_qi","speaker_name":"急风第一骑","text":"弟子本想不到沈浪会……","tone":"陈述","line_start":652,"line_end":652},{"speaker":"char_ji_feng_di_yi_qi","speaker_name":"急风第一骑","text":"弟子该死，弟子该死……","tone":"陈述","line_start":660,"line_end":660},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"此刻还不快去，还等什么？","tone":"厉声","line_start":662,"line_end":662},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"咱们什么时候闯出去？","tone":"疑问","line_start":670,"line_end":670},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"莫要着急，再等等。","tone":"微笑","line_start":672,"line_end":672},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"这只因快活王太厉害的缘故。","tone":"陈述","line_start":680,"line_end":680},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"他被你骗了，还算厉害？","tone":"陈述","line_start":682,"line_end":682},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"不错，他实在是个独夫。","tone":"陈述","line_start":688,"line_end":688}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":701,"line_end":800,"dialogues":[{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"但……但那人为什么连一个过来瞧瞧的都没有呢？","tone":"陈述","line_start":712,"line_end":712},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"没有快活王之令，谁敢闯入他的寝宫？","tone":"微笑","line_start":714,"line_end":714},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"咱们此刻往哪里去？","tone":"陈述","line_start":744,"line_end":744},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"但别的地方……","tone":"陈述","line_start":764,"line_end":764},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"不错。","tone":"陈述","line_start":770,"line_end":770},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"不错。","tone":"陈述","line_start":776,"line_end":776},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"但……但你万一算错了呢？","tone":"陈述","line_start":800,"line_end":800}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":801,"line_end":900,"dialogues":[{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"我但愿你们莫要将性命押下，只是……","tone":"苦笑","line_start":824,"line_end":824},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"你说……你是说我们三个人去那岩洞？","tone":"陈述","line_start":826,"line_end":826},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"不错！你们三个人。","tone":"陈述","line_start":828,"line_end":828},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"你！……你呢？","tone":"陈述","line_start":830,"line_end":830},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"我留在这里。","tone":"陈述","line_start":832,"line_end":832},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"你留在这里？为什么？","tone":"陈述","line_start":834,"line_end":834},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"虽然危险，但却是势在必行。","tone":"陈述","line_start":844,"line_end":844},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"莫要孩子气，乖乖的，在那边等我。","tone":"柔声","line_start":850,"line_end":850},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"不……不……不……","tone":"陈述","line_start":852,"line_end":852},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"但……但你若万一……","tone":"陈述","line_start":862,"line_end":862},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"我若万一遇险，也比四个人都死的好……我留在这里，咱们四个人才有生路，否则，只怕……","tone":"陈述","line_start":864,"line_end":864},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"你若遇险，我……我……","tone":"陈述","line_start":866,"line_end":866},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"为什么人间总有些令人忍不住要流泪的事，为什么……","tone":"陈述","line_start":876,"line_end":876},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"去。","tone":"陈述","line_start":880,"line_end":880},{"speaker":"char_shen_lang","speaker_name":"沈浪","text":"快活王门下，果然都是好手。","tone":"陈述","line_start":896,"line_end":896}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":10,"line_start":901,"line_end":1000,"dialogues":[{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"好，既是如此……","tone":"厉声","line_start":924,"line_end":924},{"speaker":null,"speaker_name":"二十余人一齐冲了进去，立刻","text":"沈浪不在这里。","tone":"陈述","line_start":930,"line_end":930},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"搜！","tone":"厉声","line_start":936,"line_end":936},{"speaker":"char_kuai_huo_wang","speaker_name":"快活王","text":"杀狗！追人。","tone":"陈述","line_start":956,"line_end":956},{"speaker":"char_yuan_lian_shao_nv","speaker_name":"圆脸少女","text":"你们看，他今夜能逃得了么？","tone":"陈述","line_start":998,"line_end":998}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":11,"line_start":1001,"line_end":1100,"dialogues":[{"speaker":null,"speaker_name":"另一人","text":"沈浪年纪轻轻，就这样死了，真有点可惜。","tone":"无奈","line_start":1006,"line_end":1006},{"speaker":"char_shao_nv","speaker_name":"少女","text":"我看你呀，莫非是看上他了？","tone":"陈述","line_start":1008,"line_end":1008},{"speaker":"char_yuan_lian_shao_nv","speaker_name":"圆脸少女","text":"像沈浪那样的男人，谁不喜欢？","tone":"陈述","line_start":1010,"line_end":1010},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"冲过去！","tone":"陈述","line_start":1014,"line_end":1014},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"要不要先打灭那盏灯笼？","tone":"陈述","line_start":1016,"line_end":1016},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"那……怎么办呢？","tone":"陈述","line_start":1022,"line_end":1022},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"你们在这里莫要动，我先出去。","tone":"陈述","line_start":1024,"line_end":1024},{"speaker":"char_shao_nv","speaker_name":"少女","text":"你不是喜欢他么？怎的又希望他死？","tone":"陈述","line_start":1030,"line_end":1030},{"speaker":"char_shao_nv","speaker_name":"少女","text":"你的心真狠。","tone":"陈述","line_start":1036,"line_end":1036},{"speaker":"char_yuan_lian_shao_nv","speaker_name":"圆脸少女","text":"女人的心，本来就……","tone":"陈述","line_start":1038,"line_end":1038},{"speaker":"char_wang_lian_hua","speaker_name":"王怜花","text":"能死在姑娘们的纤手之下，在下死也甘心。","tone":"柔声","line_start":1054,"line_end":1054},{"speaker":"char_shao_nv","speaker_name":"少女","text":"你以为你长得很俊，我们舍不得杀你？","tone":"陈述","line_start":1056,"line_end":1056},{"speaker":"char_shao_nv","speaker_name":"少女","text":"你瞧他说得多可怜。","tone":"陈述","line_start":1064,"line_end":1064},{"speaker":"char_xiong_mao_er","speaker_name":"熊猫儿","text":"不想你也很了解女人的心理。","tone":"陈述","line_start":1074,"line_end":1074},{"speaker":"char_zhu_qi_qi","speaker_name":"朱七七","text":"我到底也是个女人呀。","tone":"温柔","line_start":1076,"line_end":1076},{"speaker":"char_shao_nv","speaker_name":"少女","text":"你倒很会体贴人，只可惜……","tone":"无奈","line_start":1082,"line_end":1082},{"speaker":"char_yuan_lian_shao_nv","speaker_name":"圆脸少女","text":"你说吧，无论什么我都答应你。","tone":"陈述","line_start":1090,"line_end":1090}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
