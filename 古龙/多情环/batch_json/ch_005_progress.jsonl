{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"这碗汤不好，我替你门换一碗。","tone":"调侃","chapter":5,"line_start":24,"line_end":24},{"speaker":"char_pang_da_ye","speaker_name":"庞大爷","listener":null,"text":"这小子是干什么的？","tone":"愤怒","chapter":5,"line_start":32,"line_end":32},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"我是干你娘的。","tone":"调侃","chapter":5,"line_start":36,"line_end":36},{"speaker":null,"speaker_name":"外路镖头","listener":null,"text":"先废了他这张脸，再阉了他，看他下次还敢不敢到处撤尿。","tone":"愤怒","chapter":5,"line_start":44,"line_end":44},{"speaker":"char_pang_da_ye","speaker_name":"庞大爷","listener":null,"text":"是什么人敢多管闲事？","tone":"愤怒","chapter":5,"line_start":52,"line_end":52},{"speaker":"char_ge_er_ge","speaker_name":"葛二哥","listener":null,"text":"是我。","tone":"陈述","chapter":5,"line_start":54,"line_end":54},{"speaker":"char_pang_da_ye","speaker_name":"庞大爷","listener":null,"text":"原来是葛二哥。","tone":"陈述","chapter":5,"line_start":58,"line_end":58},{"speaker":"char_ge_er_ge","speaker_name":"葛二哥","listener":"char_pang_da_ye","text":"你知不知道这个人是谁？","tone":"疑问","chapter":5,"line_start":60,"line_end":60},{"speaker":"char_pang_da_ye","speaker_name":"庞大爷","listener":null,"text":"这位仁兄既然喜欢躺在这里，我们就换个地方喝酒去吧。","tone":"无奈","chapter":5,"line_start":66,"line_end":67},{"speaker":"char_niu_zong_biao_tou","speaker_name":"牛总镖头","listener":null,"text":"这小子究竟是谁？咱们凭什么要让他？","tone":"愤怒","chapter":5,"line_start":72,"line_end":72},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"看来天香堂的威风倒真不小。","tone":"喃喃","chapter":5,"line_start":80,"line_end":81},{"speaker":"char_ge_er_ge","speaker_name":"葛二哥","listener":null,"text":"好好照顾着屏风内的那位大爷，他若醒了，无论要什么，都赶快给他，再派人到隔壁来通知我。","tone":"陈述","chapter":5,"line_start":84,"line_end":85},{"speaker":null,"speaker_name":"伙计","listener":null,"text":"这酒鬼究竟是干什么的？凭什么横行霸道？","tone":"疑问","chapter":5,"line_start":92,"line_end":92},{"speaker":null,"speaker_name":"伙计","listener":null,"text":"据说他就是天香堂新来的分堂主。","tone":"陈述","chapter":5,"line_start":94,"line_end":94},{"speaker":null,"speaker_name":"伙计","listener":null,"text":"这就难怪了。","tone":"陈述","chapter":5,"line_start":96,"line_end":96},{"speaker":null,"speaker_name":"伙计","listener":null,"text":"做了天香堂的分堂主，别说要往碗里撒尿，就算要往别人嘴里撒，别人也只有张开嘴接着。","tone":"陈述","chapter":5,"line_start":98,"line_end":99}],"new_entities":{"characters":[{"id":"char_pang_da_ye","name":"庞大爷","alias":"庞大爷","identity":"当地豪绅","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"在酒楼设宴请客的乡绅，听闻萧少英是天香堂分堂主后立刻退让。","personality":{"traits":["跋扈","欺软怕硬","好面子","粗鲁","见风使舵"],"speech_style":"直来直去","temperament":"暴躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":16,"line_end":74,"text":"庞大爷请客，请的是牛总镖头...庞大爷的脸色立刻变了，勉强地笑道..."}]},{"id":"char_niu_zong_biao_tou","name":"牛总镖头","alias":"牛总镖头","identity":"总镖头","faction":null,"role":"npc","archetype":"warrior","rank":"略有小成","one_line":"被庞大爷邀请的外地总镖头，对萧少英的嚣张感到不满。","personality":{"traits":["粗犷","不服气","直率","暴躁","重面子"],"speech_style":"粗声粗气","temperament":"暴躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":22,"line_end":74,"text":"牛总镖头已到了，还带来了几个外地来的镖头...牛总镖头的脸色也变了，走得比庞大爷还快。"}]},{"id":"char_ge_er_ge","name":"葛二虎","alias":"葛二哥","identity":"天香堂家丁","faction":"faction_tian_xiang_tang","role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"天香堂的家丁，在酒楼认出萧少英并为其解围。","personality":{"traits":["谨慎","能干","知分寸","识时务","忠心"],"speech_style":"低调简洁","temperament":"冷静"},"relationships":[{"target":"char_ge_ting_xiang","type":"主仆","intensity":70,"bond_level":3,"dynamic":"忠心"}],"known_skills":[],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":54,"line_end":85,"text":"葛二哥指了指躺在地上的萧少英：你知不知道这个人是谁？...好好照顾着屏风内的那位大爷..."}]},{"id":"char_wai_lu_biao_tou","name":"外路镖头","alias":null,"identity":"外地镖师","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"随牛总镖头赴宴的外地镖师，欲对萧少英动刀被葛二哥阻止。","personality":{"traits":["凶狠","冲动","好勇斗狠","粗鲁","听命于人"],"speech_style":"粗野","temperament":"暴躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":42,"line_end":50,"text":"已有人从靴筒里掏出把匕首。先废了他这张脸，再阉了他...庞大爷一吩咐，这人就一刀子往萧少英的脸上扎了下去。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_shao_ying","updates":{"one_line":"被逐出双环门的败家子，现为天香堂分堂主。","source_refs":[{"chapter":5,"line_start":24,"line_end":100,"text":"萧少英忽然睁开了一只眼...看来天香堂的威风倒真不小。"}]},"relationship_updates":[{"action":"add","target":"char_ge_ting_xiang","type":"合作者","intensity":40,"bond_level":2,"dynamic":"表面投靠"}]}]}
{"segment":2,"line_start":101,"line_end":196,"dialogues":[{"speaker":"char_wang_rui","speaker_name":"王锐","listener":null,"text":"什么人？","tone":"疑问","chapter":5,"line_start":138,"line_end":138},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"我是隔壁张小弟，来借小刀削竹子，削的竹子做蒸笼，做好蒸笼蒸馒头，送来给你当点心。","tone":"调侃","chapter":5,"line_start":140,"line_end":141},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":null,"text":"附近没有人？","tone":"疑问","chapter":5,"line_start":156,"line_end":156},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"连个鬼影子都没有。","tone":"陈述","chapter":5,"line_start":158,"line_end":158},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"看来你们的气色都不错，好象全都快转运了。","tone":"调侃","chapter":5,"line_start":162,"line_end":163},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你己找到了王桐？","tone":"疑问","chapter":5,"line_start":166,"line_end":166},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"不是我找到了他，是他找到了我。","tone":"陈述","chapter":5,"line_start":168,"line_end":168},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你已对付了他？","tone":"疑问","chapter":5,"line_start":170,"line_end":170},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"因为我要钓的是大鱼，他还不够大。","tone":"陈述","chapter":5,"line_start":172,"line_end":172},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"要钓大鱼的人，往往反而会被鱼吞下去。","tone":"冷笑","chapter":5,"line_start":174,"line_end":174},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我不怕，我的血已全部变成了酒，鱼不喝酒的。","tone":"调侃","chapter":5,"line_start":176,"line_end":176},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"可是葛停香却喝酒，而且酒量还很不错。","tone":"陈述","chapter":5,"line_start":178,"line_end":178},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"你已见到了他？","tone":"疑问","chapter":5,"line_start":180,"line_end":180},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"不但见过，而且还跟他喝了几杯。","tone":"陈述","chapter":5,"line_start":182,"line_end":182},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"他没有对付你？","tone":"疑问","chapter":5,"line_start":184,"line_end":184},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我现在还活着。","tone":"陈述","chapter":5,"line_start":185,"line_end":185},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"他为什么没有对你下手？","tone":"疑问","chapter":5,"line_start":188,"line_end":188},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"因为他要钓的也是大鱼，我也不够大。","tone":"陈述","chapter":5,"line_start":190,"line_end":190},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":null,"text":"我知道，我们两人一日不死，他就一日不能安枕。","tone":"冷笑","chapter":5,"line_start":192,"line_end":192},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"所以他想用我来钓你们，我正好也想用你们去钓他，只不过到现在为止，还不知道是谁会上谁的钩而已。","tone":"陈述","chapter":5,"line_start":194,"line_end":195}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wang_rui","updates":{"one_line":"双环门弟子，藏身棺材中养伤，等待复仇时机。","source_refs":[{"chapter":5,"line_start":114,"line_end":150,"text":"他正躺在棺村里，啃着块石头般淡而无味的冷牛肉...王锐轻抚着这双曾令他叱咤一时、又令他九死一生的铁环，眼泪却已不禁流下。"}]},"relationship_updates":[]},{"id":"char_yang_lin","updates":{"one_line":"双环门弟子，腿受重伤须拄拐，与王锐一同藏匿伺机复仇。","source_refs":[{"chapter":5,"line_start":156,"line_end":196,"text":"杨麟也站起来，沉声道...杨麟沉着脸，道：你己找到了王桐？"}]},"relationship_updates":[]},{"id":"char_xiao_shao_ying","updates":{"source_refs":[{"chapter":5,"line_start":150,"line_end":196,"text":"来的果然是萧少英...萧少英道：所以他想用我来钓你们..."}]},"relationship_updates":[]}]}
{"segment":3,"line_start":197,"line_end":300,"dialogues":[{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"你已有了对付他的法子？","tone":"疑问","chapter":5,"line_start":197,"line_end":197},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"只有一个法子。","tone":"陈述","chapter":5,"line_start":198,"line_end":198},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"什么法子？","tone":"疑问","chapter":5,"line_start":199,"line_end":199},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"还是那个老法子！","tone":"陈述","chapter":5,"line_start":200,"line_end":200},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"哪个老法子？","tone":"疑问","chapter":5,"line_start":201,"line_end":201},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"荆轲用的老法子。","tone":"陈述","chapter":5,"line_start":202,"line_end":202},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"你还是想来借我们的人头？","tone":"惊讶","chapter":5,"line_start":203,"line_end":203},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"嗯。","tone":"陈述","chapter":5,"line_start":204,"line_end":204},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"我们怎知你不是想用我们的人头去做进身阶，去投靠葛停香。","tone":"冷笑","chapter":5,"line_start":206,"line_end":207},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我看来象个卖友求荣的人？","tone":"疑问","chapter":5,"line_start":209,"line_end":209},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"很象。","tone":"冷笑","chapter":5,"line_start":210,"line_end":210},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"何况，你若没有跟葛停香串通，他怎么肯放你走！","tone":"冷笑","chapter":5,"line_start":211,"line_end":212},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"这么样看来，你是不肯借的了？","tone":"疑问","chapter":5,"line_start":213,"line_end":214},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"我的人头只有一颗，我不想送给那些卖友求荣的小人。","tone":"淡然","chapter":5,"line_start":216,"line_end":216},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"既然借不到，就只有偷，偷不着就只有抢了。","tone":"苦笑","chapter":5,"line_start":217,"line_end":217},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你为什么还不过来抢？","tone":"厉声","chapter":5,"line_start":218,"line_end":218},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"好！好功夫！","tone":"大笑","chapter":5,"line_start":271,"line_end":272},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_yang_lin","text":"等一等。","tone":"陈述","chapter":5,"line_start":276,"line_end":276},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_wang_rui","text":"还等什么？等他来拿我们的脑袋？","tone":"愤怒","chapter":5,"line_start":278,"line_end":278},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_yang_lin","text":"他一直都在闪避，没有还击。","tone":"陈述","chapter":5,"line_start":280,"line_end":280},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_wang_rui","text":"他能有还击之力？","tone":"冷笑","chapter":5,"line_start":282,"line_end":282},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_yang_lin","text":"他也没有找天香堂的人来作帮手，所以……","tone":"陈述","chapter":5,"line_start":284,"line_end":284},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_wang_rui","text":"所以你就想把脑袋借给他。","tone":"嘲讽","chapter":5,"line_start":286,"line_end":286},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_yang_lin","text":"看来他并不是真想来借我们脑袋的。","tone":"陈述","chapter":5,"line_start":288,"line_end":288},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"我本来就没有这意思。","tone":"微笑","chapter":5,"line_start":290,"line_end":290},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你是什么意思？","tone":"疑问","chapter":5,"line_start":292,"line_end":292},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我只不过想试试你们，是不是还能杀人。","tone":"陈述","chapter":5,"line_start":294,"line_end":294},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"现在你已试出来？","tone":"疑问","chapter":5,"line_start":296,"line_end":296}],"new_entities":{"characters":[],"skills":[],"techniques":[{"id":"tech_shao_lin_fu_hu_luo_han_quan","name":"少林伏虎罗汉拳","type":"attack","description":"少林正宗拳法，以降龙伏虎之势发动，威力刚猛。王锐从小入少林，在这趟拳法上至少有十五年苦功。","source_skill":"skill_shao_lin_wu_gong","source_refs":[{"chapter":5,"line_start":262,"line_end":264,"text":"王锐咬了咬牙，忽然抛下铁环，以独臂施展出少林伏虎罗汉拳。他从小人少林，在这趟拳法上，至少已有十五年寒暑不断的苦功夫。"}]},{"id":"tech_da_ying_zhao_gong","name":"大鹰爪功","type":"attack","description":"凌厉的爪功，以擒拿抓裂为主要技巧，可配合铁拐杖法使用。","source_skill":"skill_shuang_huan_wu_gong","source_refs":[{"chapter":5,"line_start":266,"line_end":268,"text":"杨麟也不甘示弱，以木杖作铁拐，夹杂着左手的大鹰爪功力使出来。双环门下，本就以他的武功所学最杂。"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_shao_ying","updates":{"source_refs":[{"chapter":5,"line_start":197,"line_end":300,"text":"萧少英道：你们是不是还能杀人...他身法的轻灵飘忽，变化奇诡，更是王锐想不到的。"}]},"relationship_updates":[{"action":"add","target":"char_wang_rui","type":"合作者","intensity":50,"bond_level":2,"dynamic":"试探结盟"},{"action":"add","target":"char_yang_lin","type":"合作者","intensity":40,"bond_level":2,"dynamic":"互不信任"}]},{"id":"char_wang_rui","updates":{"source_refs":[{"chapter":5,"line_start":262,"line_end":264,"text":"王锐咬了咬牙，忽然抛下铁环，以独臂施展出少林伏虎罗汉拳。"}]},"relationship_updates":[]},{"id":"char_yang_lin","updates":{"source_refs":[{"chapter":5,"line_start":266,"line_end":268,"text":"杨麟也不甘示弱，以木杖作铁拐，夹杂着左手的大鹰爪功力使出来。"}]},"relationship_updates":[]}]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"杀谁？","tone":"疑问","chapter":5,"line_start":300,"line_end":300},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"葛停香！","tone":"陈述","chapter":5,"line_start":306,"line_end":306},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"我们能杀得了他？","tone":"疑问","chapter":5,"line_start":308,"line_end":308},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"至少有五成机会。","tone":"陈述","chapter":5,"line_start":310,"line_end":310},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"只有五成？","tone":"疑问","chapter":5,"line_start":312,"line_end":312},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"现在我们若不出手，以后恐怕连一成机会都没有。","tone":"严肃","chapter":5,"line_start":314,"line_end":314},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你已有动手的计划？","tone":"疑问","chapter":5,"line_start":320,"line_end":320},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"每天晚上，子时前后，他都会在他的密室中喝酒，陪着他的爱妾郭玉娘。","tone":"陈述","chapter":5,"line_start":322,"line_end":323},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"门卫有多少人守卫？","tone":"疑问","chapter":5,"line_start":326,"line_end":326},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"也只有一个。","tone":"陈述","chapter":5,"line_start":328,"line_end":328},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"是王桐？","tone":"疑问","chapter":5,"line_start":330,"line_end":330},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"是个叫葛新的家丁。","tone":"陈述","chapter":5,"line_start":332,"line_end":332},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"他是个什么样的人？","tone":"疑问","chapter":5,"line_start":334,"line_end":334},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"是个奴才。","tone":"陈述","chapter":5,"line_start":336,"line_end":336},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":null,"text":"看来这倒真是我们动手的好机会。","tone":"陈述","chapter":5,"line_start":338,"line_end":338},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"这也是唯一的机会。","tone":"陈述","chapter":5,"line_start":340,"line_end":340},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你知道那密室的门户所在？","tone":"疑问","chapter":5,"line_start":342,"line_end":342},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我不但知道，而且还能混进去。","tone":"陈述","chapter":5,"line_start":344,"line_end":344},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你有把握。","tone":"疑问","chapter":5,"line_start":346,"line_end":346},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"有。","tone":"陈述","chapter":5,"line_start":348,"line_end":348},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"我们怎么进去。","tone":"疑问","chapter":5,"line_start":350,"line_end":350},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"后天晚上的子时之前，我先到那密室中去等着，看见窗子里的灯光一暗，你们立刻就冲进去动手。","tone":"陈述","chapter":5,"line_start":352,"line_end":353},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"我们怎么知道是哪扇窗户？","tone":"疑问","chapter":5,"line_start":356,"line_end":356},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我可以把那里的地形门户都画出来给你们看。","tone":"陈述","chapter":5,"line_start":358,"line_end":358},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"灯光一暗，我们就出手！","tone":"陈述","chapter":5,"line_start":360,"line_end":360},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"以我们三人之力合击，也许还不止五成机会。","tone":"陈述","chapter":5,"line_start":362,"line_end":362},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"可是灯光既然已暗了，我们怎能分辨出谁是葛停香？","tone":"疑问","chapter":5,"line_start":364,"line_end":364},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"那天我可以穿一身白衣服去。","tone":"陈述","chapter":5,"line_start":366,"line_end":366},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"屋子里还有个郭玉娘。","tone":"陈述","chapter":5,"line_start":368,"line_end":368},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"郭玉娘是个很香的女人，耳上还戴着珠环，就算瞎子也能分辨得出。","tone":"陈述","chapter":5,"line_start":370,"line_end":371},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":"char_xiao_shao_ying","text":"除了你与郭玉娘之外，还有一个人，就是葛停香？","tone":"疑问","chapter":5,"line_start":374,"line_end":374},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_wang_rui","text":"那秘室中绝没有别人会进去！","tone":"陈述","chapter":5,"line_start":376,"line_end":376},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"王桐呢？","tone":"疑问","chapter":5,"line_start":378,"line_end":378},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"他就算在，到时我也有法子把他支开。","tone":"陈述","chapter":5,"line_start":380,"line_end":380},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"他们相信你？","tone":"疑问","chapter":5,"line_start":382,"line_end":382},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我岂非本来就很象是个卖友求荣的人？","tone":"淡然","chapter":5,"line_start":384,"line_end":384},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你不是？","tone":"疑问","chapter":5,"line_start":386,"line_end":386},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"你看呢？","tone":"疑问","chapter":5,"line_start":388,"line_end":388},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"没有人知道你到这里来找我们？","tone":"疑问","chapter":5,"line_start":390,"line_end":390},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"绝没有。","tone":"陈述","chapter":5,"line_start":392,"line_end":392},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你从天香堂出来的时候，后面有没有人跟踪的。","tone":"疑问","chapter":5,"line_start":394,"line_end":394},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"本来是有的，却已被我甩脱了。","tone":"陈述","chapter":5,"line_start":396,"line_end":396},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"我虽然因此挨了一刀，那位葛二哥回去后，只怕也不会再有好日子过。","tone":"陈述","chapter":5,"line_start":398,"line_end":399}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_ge_ting_xiang_mi_shi","name":"密室","region":"天香堂","one_line":"葛停香每晚子时与郭玉娘独处喝酒的密室。","source_refs":[{"chapter":5,"line_start":322,"line_end":323,"text":"每天晚上，子时前后，他都会在他的密室中喝酒，陪着他的爱妾郭玉娘。"}]}],"items":[]},"entity_updates":[{"id":"char_xiao_shao_ying","updates":{"source_refs":[{"chapter":5,"line_start":322,"line_end":400,"text":"萧少英神情已变得很严肃，道：每天晚上，子时前后..."}],"personality":{"traits":["机智","胆大","隐忍","深思熟虑","善于伪装","不择手段","骄傲"],"speech_style":"时而调侃时而严肃","temperament":"冷静多变"},"alias":"天香堂分堂主"},"relationship_updates":[{"action":"add","target":"char_ge_ting_xiang","type":"合作者","intensity":30,"bond_level":2,"dynamic":"假意投靠"}]},{"id":"char_wang_rui","updates":{"source_refs":[{"chapter":5,"line_start":308,"line_end":376,"text":"我们能杀得了他？...除了你与郭玉娘之外，还有一个人，就是葛停香？"}]},"relationship_updates":[]},{"id":"char_yang_lin","updates":{"source_refs":[{"chapter":5,"line_start":320,"line_end":400,"text":"杨麟也忍不住问：你已有动手的计划？...杨麟道：葛二哥？"}],"personality":{"traits":["多疑","谨慎","剽悍","心狠手辣","不轻信"]}},"relationship_updates":[]}]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"葛二哥？","tone":"疑问","chapter":5,"line_start":402,"line_end":402},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"天香堂用的家丁都姓葛。","tone":"陈述","chapter":5,"line_start":404,"line_end":404},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"天香堂的秘密，你已知道多少？","tone":"疑问","chapter":5,"line_start":406,"line_end":406},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"知道的已够多。","tone":"陈述","chapter":5,"line_start":408,"line_end":408},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"这个角门，就是你们唯一的入路。","tone":"陈述","chapter":5,"line_start":410,"line_end":412},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"你们绝不能越墙而入，一定要想法子撬开这扇窗。","tone":"陈述","chapter":5,"line_start":414,"line_end":414},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"为什么？","tone":"疑问","chapter":5,"line_start":416,"line_end":416},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"因为上面很可能有人守望，撬门进去，别人反而想不到。","tone":"陈述","chapter":5,"line_start":418,"line_end":418},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"然后呢？","tone":"疑问","chapter":5,"line_start":420,"line_end":420},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"然后你们就沿着条碎石路，走到这里，在这棵树上等着。","tone":"陈述","chapter":5,"line_start":422,"line_end":424},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"碎石路和大树都已标明，在这棵树上，就可以看到这扇窗户。","tone":"陈述","chapter":5,"line_start":426,"line_end":426},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"窗里的灯一灭，我们就动手。","tone":"陈述","chapter":5,"line_start":428,"line_end":428},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"葛停香已是个老人，老人的眼力总难免会差些，在黑暗中，他的武功一定要打个很大的折扣。","tone":"陈述","chapter":5,"line_start":430,"line_end":432},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":null,"text":"可是你们这些日子来，一直都是昼伏夜出的，对黑暗想必已比别人习惯，而且你们本来就一直躲在外面的黑暗里，所以灯光虽然灭了，你们还是可以分辨出屋里的人影，屋里的人一直在灯光下，灯光突然熄灭，就未必能看得见你们。","tone":"陈述","chapter":5,"line_start":434,"line_end":436},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你考虑得倒很周到。","tone":"陈述","chapter":5,"line_start":438,"line_end":438},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我不能不考虑得周到些，我也只有一个脑袋。","tone":"微笑","chapter":5,"line_start":440,"line_end":440},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"我们好象一直都看错了你。","tone":"无奈","chapter":5,"line_start":442,"line_end":442},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"葛停香好象也看错了我。","tone":"微笑","chapter":5,"line_start":444,"line_end":444},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"我只希望你没有看错他！也没有看错郭玉娘和葛新。","tone":"严肃","chapter":5,"line_start":446,"line_end":446},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_xin","text":"我又来了。","tone":"陈述","chapter":5,"line_start":456,"line_end":456},{"speaker":"char_ge_xin","speaker_name":"葛新","listener":"char_xiao_shao_ying","text":"是。","tone":"陈述","chapter":5,"line_start":458,"line_end":458},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_xin","text":"你好象很少睡觉。","tone":"陈述","chapter":5,"line_start":460,"line_end":460},{"speaker":"char_ge_xin","speaker_name":"葛新","listener":"char_xiao_shao_ying","text":"是。","tone":"陈述","chapter":5,"line_start":462,"line_end":462},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_xin","text":"除了'是'字外，你已不会说别的？","tone":"调侃","chapter":5,"line_start":464,"line_end":464},{"speaker":"char_ge_xin","speaker_name":"葛新","listener":"char_xiao_shao_ying","text":"是。","tone":"陈述","chapter":5,"line_start":466,"line_end":466},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_xin","text":"前两天我来的时候，你说的话好象还多些。","tone":"陈述","chapter":5,"line_start":468,"line_end":468},{"speaker":"char_ge_xin","speaker_name":"葛新","listener":"char_xiao_shao_ying","text":"是。","tone":"陈述","chapter":5,"line_start":470,"line_end":470},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_xin","text":"这次你为什么变了。","tone":"疑问","chapter":5,"line_start":472,"line_end":472},{"speaker":"char_guo_yu_niang","speaker_name":"郭玉娘","listener":"char_xiao_shao_ying","text":"因为你也变了。","tone":"陈述","chapter":5,"line_start":474,"line_end":474},{"speaker":"char_guo_yu_niang","speaker_name":"郭玉娘","listener":"char_xiao_shao_ying","text":"上次来的时候，你只不过是个穷光蛋，现在你却已是个天香堂的分堂主。","tone":"陈述","chapter":5,"line_start":478,"line_end":480},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_guo_yu_niang","text":"做了天香堂的分堂主，别人就连话都不跟我多说？","tone":"无奈","chapter":5,"line_start":482,"line_end":482},{"speaker":"char_guo_yu_niang","speaker_name":"郭玉娘","listener":"char_xiao_shao_ying","text":"别人多少总要小心些。","tone":"陈述","chapter":5,"line_start":484,"line_end":484},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_guo_yu_niang","text":"看来做这分堂主，也没有什么太大的好处。","tone":"无奈","chapter":5,"line_start":486,"line_end":488},{"speaker":"char_guo_yu_niang","speaker_name":"郭玉娘","listener":"char_xiao_shao_ying","text":"至少有一样好处。至少你可以随便在别人汤碗里撒尿。","tone":"调侃","chapter":5,"line_start":490,"line_end":492}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ge_xin","updates":{"one_line":"天香堂的家丁，沉默寡言，几乎只用\"是\"字回答。","personality":{"traits":["沉默","寡言","忠诚","冷漠","警惕"],"speech_style":"极简，几乎只用是字","temperament":"冷静"},"source_refs":[{"chapter":5,"line_start":456,"line_end":472,"text":"葛新道：是。...萧少英道：这次你为什么变了。"}]},"relationship_updates":[]},{"id":"char_guo_yu_niang","updates":{"one_line":"葛停香的宠妾，聪慧美丽，言语间带着俏皮。","personality":{"traits":["聪慧","俏皮","善解人意","胆大","细心"],"speech_style":"俏皮直率","temperament":"活泼"},"source_refs":[{"chapter":5,"line_start":474,"line_end":492,"text":"因为你也变了。...至少你可以随便在别人汤碗里撒尿。"}]},"relationship_updates":[]},{"id":"char_xiao_shao_ying","updates":{"source_refs":[{"chapter":5,"line_start":456,"line_end":492,"text":"他又微笑着拍了拍葛新的肩，道：我又来了。...看来做这分堂主，也没有什么太大的好处。"}]},"relationship_updates":[{"action":"add","target":"char_ge_xin","type":"主仆","intensity":20,"bond_level":1,"dynamic":"新识"},{"action":"add","target":"char_guo_yu_niang","type":"合作者","intensity":40,"bond_level":2,"dynamic":"博弈"}]}]}
{"segment":6,"line_start":501,"line_end":600,"dialogues":[{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"这身衣裳你是第一天穿？","tone":"疑问","chapter":5,"line_start":502,"line_end":502},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"这套衣服我只准备穿一天。","tone":"陈述","chapter":5,"line_start":504,"line_end":504},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"为什么？","tone":"疑问","chapter":5,"line_start":506,"line_end":506},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"不为什么。","tone":"陈述","chapter":5,"line_start":508,"line_end":508},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"今天你还没有醉？","tone":"疑问","chapter":5,"line_start":510,"line_end":510},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"没有。","tone":"陈述","chapter":5,"line_start":512,"line_end":512},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"你有没有真的醉过？","tone":"疑问","chapter":5,"line_start":514,"line_end":514},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"很少。","tone":"陈述","chapter":5,"line_start":516,"line_end":516},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"至少在有人跟我梢的时候，我绝不会醉。","tone":"陈述","chapter":5,"line_start":518,"line_end":518},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"葛二虎本来也是个很能干的人，可是跟你一比，他简直就象是个猪。","tone":"无奈","chapter":5,"line_start":520,"line_end":522},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"你手里好象总是有杯酒。","tone":"陈述","chapter":5,"line_start":526,"line_end":526},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"这并不算奇怪，","tone":"陈述","chapter":5,"line_start":528,"line_end":528},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"有时酒杯的确也是种很好的武器。","tone":"微笑","chapter":5,"line_start":530,"line_end":530},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"武器？什么武器？","tone":"疑问","chapter":5,"line_start":532,"line_end":532},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"令人疏忽的武器。","tone":"陈述","chapter":5,"line_start":534,"line_end":534},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"哦？","tone":"疑问","chapter":5,"line_start":536,"line_end":536},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"大多数人看到别人手里拿着杯酒时，都会变得比较疏忽。","tone":"陈述","chapter":5,"line_start":538,"line_end":540},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"哦。","tone":"淡然","chapter":5,"line_start":540,"line_end":540},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"因为大家都认为，手里总是拿着杯酒的人，一定比较容易对付。","tone":"陈述","chapter":5,"line_start":542,"line_end":544},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"你的确是个聪明人。","tone":"大笑","chapter":5,"line_start":546,"line_end":546},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"我的确不笨。","tone":"陈述","chapter":5,"line_start":548,"line_end":548},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"只可惜你的记性并不好。","tone":"淡然","chapter":5,"line_start":550,"line_end":550},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"哦？","tone":"疑问","chapter":5,"line_start":552,"line_end":552},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"你好象忘了一件事。","tone":"陈述","chapter":5,"line_start":554,"line_end":554},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"我没有忘。","tone":"陈述","chapter":5,"line_start":556,"line_end":556},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"但你却是空着手来的。","tone":"陈述","chapter":5,"line_start":558,"line_end":558},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"我答应你的是什么时候？","tone":"疑问","chapter":5,"line_start":560,"line_end":560},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"今夜子时！","tone":"陈述","chapter":5,"line_start":562,"line_end":562},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"现在到了子时没有？","tone":"疑问","chapter":5,"line_start":564,"line_end":564},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"还没有。","tone":"陈述","chapter":5,"line_start":566,"line_end":566},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"所以我们现在还可以喝两杯。","tone":"轻笑","chapter":5,"line_start":568,"line_end":568},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"聪明人反而时常会做糊涂事，我只希望你是例外。","tone":"淡然","chapter":5,"line_start":570,"line_end":572},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"我还没有喝醉。","tone":"陈述","chapter":5,"line_start":574,"line_end":574},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"什么时候你才醉？","tone":"疑问","chapter":5,"line_start":576,"line_end":576},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"想醉的时候。","tone":"陈述","chapter":5,"line_start":578,"line_end":578},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"什么时候你才想醉？","tone":"疑问","chapter":5,"line_start":580,"line_end":580},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"快了。","tone":"陈述","chapter":5,"line_start":582,"line_end":582},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":null,"text":"好，拿大杯来，看他到底能喝多少杯？","tone":"大笑","chapter":5,"line_start":584,"line_end":586},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"现在是不是已快了？","tone":"疑问","chapter":5,"line_start":594,"line_end":594},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"快了。","tone":"陈述","chapter":5,"line_start":596,"line_end":596}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ge_ting_xiang","updates":{"one_line":"天香堂主人，推翻双环门的枭雄，精于算计，善于察言观色。","personality":{"traits":["精明","多疑","老谋深算","威严","善变"],"speech_style":"时而大笑时而冷淡","temperament":"深沉"},"source_refs":[{"chapter":5,"line_start":502,"line_end":596,"text":"葛停香看着他，目中带着笑意...葛停香眼睛里闪着光道：现在是不是已快了？"}]},"relationship_updates":[]},{"id":"char_xiao_shao_ying","updates":{"source_refs":[{"chapter":5,"line_start":504,"line_end":596,"text":"萧少英道：这套衣服我只准备穿一天。...萧少英道：快了。"}]},"relationship_updates":[]}]}
{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"你现在是不是已明白？这身衣服我为什么只准备穿一天。","tone":"微笑","chapter":5,"line_start":632,"line_end":634},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"从今以后，无论多贵的衣服，你都可以只穿一天。","tone":"陈述","chapter":5,"line_start":636,"line_end":638},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"这句话我一定会记得。","tone":"陈述","chapter":5,"line_start":640,"line_end":640},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"我知道你的记性很好。","tone":"陈述","chapter":5,"line_start":642,"line_end":642},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"我也没有做糊涂事。","tone":"陈述","chapter":5,"line_start":644,"line_end":644},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"你的确没有醉。","tone":"微笑","chapter":5,"line_start":646,"line_end":646},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"但现在我却已准备醉了。","tone":"无奈","chapter":5,"line_start":648,"line_end":648},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"只要你想醉，你随时都可以醉。","tone":"陈述","chapter":5,"line_start":650,"line_end":650},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"我……","tone":"犹豫","chapter":5,"line_start":652,"line_end":652},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你果然是个卖友求荣的小人，我果然没有看错。","tone":"嘶声","chapter":5,"line_start":666,"line_end":666},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"你看错了。我从来也没有出卖过朋友。","tone":"淡然","chapter":5,"line_start":668,"line_end":668},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你还敢狡辩？","tone":"愤怒","chapter":5,"line_start":670,"line_end":670},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我为什么要狡辩？","tone":"淡然","chapter":5,"line_start":672,"line_end":672},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_xiao_shao_ying","text":"你……难道没有出卖我？","tone":"愤怒","chapter":5,"line_start":674,"line_end":674},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_yang_lin","text":"我当然出卖了你，只因为你从来也不是我的朋友。双环门里，没有一个人是我的朋友。","tone":"淡然","chapter":5,"line_start":676,"line_end":680},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":null,"text":"这不能怪他？","tone":"疑问","chapter":5,"line_start":684,"line_end":686},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":"char_wang_rui","text":"不能怪他？","tone":"愤怒","chapter":5,"line_start":688,"line_end":688},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":null,"text":"这只能怪我们自己，我们本不该信任他的，他本来就是个卑鄙无耻的畜牲！","tone":"愤怒","chapter":5,"line_start":690,"line_end":692},{"speaker":"char_wang_rui","speaker_name":"王锐","listener":null,"text":"我们相信他，岂非也变成了畜牲？","tone":"悲痛","chapter":5,"line_start":694,"line_end":694},{"speaker":"char_yang_lin","speaker_name":"杨麟","listener":null,"text":"不错，我是个畜牲，该死的畜牲。","tone":"狂笑","chapter":5,"line_start":696,"line_end":696},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"我已将他们送给你了。","tone":"淡然","chapter":5,"line_start":700,"line_end":702}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_shao_ying","updates":{"source_refs":[{"chapter":5,"line_start":632,"line_end":702,"text":"萧少英低着头，看着衣服上的血迹，忽然笑了笑，道：你现在是不是已明白？...我已将他们送给你了。"}]},"relationship_updates":[{"action":"add","target":"char_yang_lin","type":"对手","intensity":80,"bond_level":1,"dynamic":"彻底决裂"},{"action":"add","target":"char_wang_rui","type":"对手","intensity":70,"bond_level":1,"dynamic":"彻底决裂"}]},{"id":"char_yang_lin","updates":{"source_refs":[{"chapter":5,"line_start":654,"line_end":700,"text":"死人般躺在地上的杨麟，突然跃起，扑了过去...杨麟突然大笑，疯狂般大笑：不错，我是个畜牲，该死的畜牲。"}]},"relationship_updates":[{"action":"add","target":"char_xiao_shao_ying","type":"宿敌","intensity":90,"bond_level":1,"dynamic":"背叛"},{"action":"add","target":"char_ge_ting_xiang","type":"宿敌","intensity":95,"bond_level":1,"dynamic":"被俘"}]},{"id":"char_wang_rui","updates":{"source_refs":[{"chapter":5,"line_start":630,"line_end":694,"text":"王锐伏在地上，发出了轻微的呻吟...我们相信他，岂非也变成了畜牲？"}]},"relationship_updates":[{"action":"add","target":"char_xiao_shao_ying","type":"宿敌","intensity":85,"bond_level":1,"dynamic":"背叛"},{"action":"add","target":"char_ge_ting_xiang","type":"宿敌","intensity":95,"bond_level":1,"dynamic":"被俘"}]}]}
{"segment":8,"line_start":701,"line_end":752,"dialogues":[{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"不错！","tone":"陈述","chapter":5,"line_start":704,"line_end":704},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"他们现在已是你的人。","tone":"陈述","chapter":5,"line_start":706,"line_end":706},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"不错。","tone":"陈述","chapter":5,"line_start":708,"line_end":708},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"但他们现在却辱骂你的分堂主，你难道就这样听着？难道觉得很好听？","tone":"淡然","chapter":5,"line_start":710,"line_end":712},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"不好听。","tone":"陈述","chapter":5,"line_start":714,"line_end":714},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":null,"text":"葛新！","tone":"陈述","chapter":5,"line_start":716,"line_end":716},{"speaker":"char_ge_xin","speaker_name":"葛新","listener":"char_ge_ting_xiang","text":"在。","tone":"陈述","chapter":5,"line_start":718,"line_end":718},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":null,"text":"带这两人下去，想法子把他们养得肥肥的，越肥越好。","tone":"陈述","chapter":5,"line_start":720,"line_end":720},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"你知不知道我为什么要把他们养肥？","tone":"疑问","chapter":5,"line_start":726,"line_end":728},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"你懂？你说吧。","tone":"陈述","chapter":5,"line_start":732,"line_end":732},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"只有日子过得很舒服的人，才会长肥。","tone":"微笑","chapter":5,"line_start":734,"line_end":734},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"不错。","tone":"陈述","chapter":5,"line_start":736,"line_end":736},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"一个人若是过得很舒服就不想死了。","tone":"陈述","chapter":5,"line_start":738,"line_end":738},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":"char_xiao_shao_ying","text":"不错！","tone":"陈述","chapter":5,"line_start":740,"line_end":740},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"不想死的人，就会说实话。","tone":"陈述","chapter":5,"line_start":742,"line_end":742},{"speaker":"char_xiao_shao_ying","speaker_name":"萧少英","listener":"char_ge_ting_xiang","text":"你只有等到他们肯说话的时候，才能查出来，双环门是不是已被完全消灭。","tone":"陈述","chapter":5,"line_start":744,"line_end":746},{"speaker":"char_ge_ting_xiang","speaker_name":"葛停香","listener":null,"text":"好，说得好，再拿大杯来，今夜我也陪他醉一醉。","tone":"大笑","chapter":5,"line_start":748,"line_end":750},{"speaker":"char_guo_yu_niang","speaker_name":"郭玉娘","listener":null,"text":"现在你们的确都可以醉一醉了。","tone":"微笑","chapter":5,"line_start":752,"line_end":752}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_shao_ying","updates":{"source_refs":[{"chapter":5,"line_start":710,"line_end":752,"text":"萧少英淡淡道：但他们现在却辱骂你的分堂主...你只有等到他们肯说话的时候..."}],"personality":{"traits":["机智","胆大","隐忍","深思熟虑","善于伪装","不择手段","骄傲","心狠手辣"],"speech_style":"时而调侃时而严肃，善于激将","temperament":"冷静多变"}},"relationship_updates":[]},{"id":"char_ge_ting_xiang","updates":{"source_refs":[{"chapter":5,"line_start":714,"line_end":752,"text":"不好听。...好，说得好，再拿大杯来，今夜我也陪他醉一醉。"}]},"relationship_updates":[{"action":"add","target":"char_xiao_shao_ying","type":"合作者","intensity":60,"bond_level":3,"dynamic":"赏识"},{"action":"add","target":"char_wang_rui","type":"对手","intensity":80,"bond_level":2,"dynamic":"囚禁"},{"action":"add","target":"char_yang_lin","type":"对手","intensity":80,"bond_level":2,"dynamic":"囚禁"}]}]}
