{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":"char_ding_ding","speaker_name":"丁丁","listener":null,"text":"因为她知道你的伤一好，立刻就会走的。","tone":"陈述","chapter":6,"line_start":610,"line_end":610},{"speaker":null,"speaker_name":null,"listener":null,"text":"你不该告诉我的。","tone":"陈述","chapter":6,"line_start":622,"line_end":622},{"speaker":"char_ding_ding","speaker_name":"丁丁","listener":null,"text":"为什么？","tone":"陈述","chapter":6,"line_start":624,"line_end":624},{"speaker":"char_xiao_lei","speaker_name":"小雷","listener":null,"text":"因为我不能走。","tone":"陈述","chapter":6,"line_start":626,"line_end":626},{"speaker":null,"speaker_name":null,"listener":null,"text":"为什么？","tone":"惊讶","chapter":6,"line_start":628,"line_end":628},{"speaker":"char_xiao_lei","speaker_name":"小雷","listener":null,"text":"我若走了，她怎么会放过你？","tone":"陈述","chapter":6,"line_start":630,"line_end":630},{"speaker":"char_ding_ding","speaker_name":"丁丁","listener":null,"text":"你……你自己都已经快死了，还在为我想？","tone":"陈述","chapter":6,"line_start":632,"line_end":632},{"speaker":"char_xiao_lei","speaker_name":"小雷","listener":null,"text":"你还是个孩子，我总不能让你为我受苦。","tone":"陈述","chapter":6,"line_start":634,"line_end":634},{"speaker":"char_ding_ding","speaker_name":"丁丁","listener":null,"text":"那么你为什么不带我走？","tone":"陈述","chapter":6,"line_start":636,"line_end":636},{"speaker":"char_xiao_lei","speaker_name":"小雷","listener":null,"text":"带你走？","tone":"陈述","chapter":6,"line_start":638,"line_end":638},{"speaker":"char_xiao_lei","speaker_name":"小雷","listener":null,"text":"但你若跟着我，说不定会饿死。","tone":"陈述","chapter":6,"line_start":644,"line_end":644},{"speaker":"char_ding_ding","speaker_name":"丁丁","listener":null,"text":"我不怕……说不定我还可以赚钱养活你。","tone":"陈述","chapter":6,"line_start":646,"line_end":646},{"speaker":"char_xiao_lei","speaker_name":"小雷","listener":null,"text":"我还是不能带你走。","tone":"陈述","chapter":6,"line_start":648,"line_end":648},{"speaker":"char_ding_ding","speaker_name":"丁丁","listener":null,"text":"为什么？","tone":"陈述","chapter":6,"line_start":650,"li