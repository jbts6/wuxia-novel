{"segment":5,"line_start":67,"line_end":117,"dialogues":[{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":null,"text":"壶里的酒没有毒。","tone":"陈述","chapter":11,"line_start":68,"line_end":68},{"speaker":"char_jue_da_shi","speaker_name":"绝大师","listener":"char_chi_ku_he_shang","text":"毒在哪里？","tone":"疑问","chapter":11,"line_start":70,"line_end":70},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":null,"text":"在他喝的最后一杯酒里。","tone":"陈述","chapter":11,"line_start":72,"line_end":72},{"speaker":"char_jue_da_shi","speaker_name":"绝大师","listener":"char_chi_ku_he_shang","text":"是什么毒？","tone":"疑问","chapter":11,"line_start":74,"line_end":74},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":null,"text":"是用牵机、断肠、销魂，三种毒草炼成的'秋虫散'。","tone":"陈述","chapter":11,"line_start":76,"line_end":76},{"speaker":"char_jue_da_shi","speaker_name":"绝大师","listener":"char_chi_ku_he_shang","text":"你能确定？","tone":"疑问","chapter":11,"line_start":78,"line_end":78},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":null,"text":"这种毒散无色有味，最宜下在酒中，配合酒性，发作更快。","tone":"陈述","chapter":11,"line_start":80,"line_end":80},{"speaker":"char_jue_da_shi","speaker_name":"绝大师","listener":"char_chi_ku_he_shang","text":"多快？","tone":"疑问","chapter":11,"line_start":82,"line_end":82},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":null,"text":"酒一入喉，毒已发作，酒一入肠，命如秋虫。","tone":"陈述","chapter":11,"line_start":84,"line_end":84},{"speaker":"char_jue_da_shi","speaker_name":"绝大师","listener":"char_chi_ku_he_shang","text":"他的毒刚发作。","tone":"陈述","chapter":11,"line_start":86,"line_end":86},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":null,"text":"所以毒必在最后一杯酒中。","tone":"陈述","chapter":11,"line_start":88,"line_end":88},{"speaker":"char_jue_da_shi","speaker_name":"绝大师","listener":"char_chi_ku_he_shang","text":"中毒能解？","tone":"疑问","chapter":11,"line_start":90,"line_end":90},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":null,"text":"秋虫并非必死，只要救得快，就能解。","tone":"陈述","chapter":11,"line_start":92,"line_end":92},{"speaker":"char_jue_da_shi","speaker_name":"绝大师","listener":"char_chi_ku_he_shang","text":"你能解？","tone":"疑问","chapter":11,"line_start":94,"line_end":94},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":"char_yu_dao_ren","text":"我不能，他能。","tone":"陈述","chapter":11,"line_start":96,"line_end":96},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":"char_yu_dao_ren","text":"识毒天下无人及我，解毒我不及你。","tone":"认真","chapter":11,"line_start":98,"line_end":100},{"speaker":"char_yu_dao_ren","speaker_name":"玉道人","listener":"char_chi_ku_he_shang","text":"你怎知道你不及我！","tone":"轻笑","chapter":11,"line_start":102,"line_end":102},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":"char_yu_dao_ren","text":"因为你是个负心人，我不是。","tone":"认真","chapter":11,"line_start":104,"line_end":104},{"speaker":"char_chi_ku_he_shang","speaker_name":"吃苦和尚","listener":null,"text":"如果他不知解毒，现在他早已是个死人。","tone":"陈述","chapter":11,"line_start":112,"line_end":112},{"speaker":"char_jue_da_shi","speaker_name":"绝大师","listener":null,"text":"如果他解不了这秋虫散的毒，还有没有别人能解。","tone":"疑问","chapter":11,"line_start":114,"line_end":114},{"speaker":"char_yu_dao_ren","speaker_name":"玉道人","listener":"char_jue_da_shi","text":"没有。","tone":"陈述","chapter":11,"line_start":116,"line_end":116}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_qiu_chong_san","name":"秋虫散","type":"poison","owner":null,"one_line":"用三种毒草炼成的致命毒药","description":"用牵机、断肠、销魂三种毒草炼成的毒散，无色有味，最宜下在酒中配合酒性发作，酒一入喉毒已发作，酒一入肠命如秋虫。","effects":[{"type":"伤害","description":"酒入喉即发作，入肠致命"}],"origin":"江湖","rarity":"稀世珍品","related_characters":["char_qiu_feng_cheng"],"related_skills":[],"rag_refs":[11],"source_refs":[{"chapter":11,"line_start":76,"line_end":76,"text":"是用牵机、断肠、销魂，三种毒草炼成的'秋虫散'。"}]}]},"entity_updates":[]}
