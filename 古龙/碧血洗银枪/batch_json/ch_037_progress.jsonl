{"segment":1,"line_start":1,"line_end":30,"dialogues":[{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":null,"text":"——马车到哪里去了？","tone":"疑问","chapter":37,"line_start":14,"line_end":14},{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":null,"text":"在下面。","tone":"陈述","chapter":37,"line_start":16,"line_end":16},{"speaker":null,"speaker_name":"旁人","listener":"char_ma_ru_long","text":"什么在下面？","tone":"疑问","chapter":37,"line_start":18,"line_end":18},{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":null,"text":"车马，黄金，人，都在下面。","tone":"陈述","chapter":37,"line_start":20,"line_end":20},{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":null,"text":"他们一定在地下建造了一个规模很大的秘窟。","tone":"陈述","chapter":37,"line_start":20,"line_end":20},{"speaker":"char_yu_liu","speaker_name":"俞六","listener":"char_ma_ru_long","text":"你错了，","tone":"陈述","chapter":37,"line_start":28,"line_end":28},{"speaker":"char_yu_liu","speaker_name":"俞六","listener":"char_ma_ru_long","text":"他们绝不在下面，他们在上面。","tone":"陈述","chapter":37,"line_start":28,"line_end":28},{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":"char_yu_liu","text":"上面？","tone":"疑问","chapter":37,"line_start":30,"line_end":30}],"new_entities":{"characters":[{"id":"char_ma_ru_long","name":"马如龙","alias":[],"identity":"江湖侠士","faction":"无","role":"主角","archetype":"舍身救人的侠义者","rank":"一流","one_line":"追踪马车寻找大婉，面对死谷迷局仍将救人置于黄金之前。","personality":{"traits":["重情重义","临危冷静","敢冒死险","判断敏锐","沉默坚决"],"speech_style":"简短直接，关键时刻少言而决断","temperament":"坚忍沉着"},"relationships":[{"target":"char_da_wan","type":"牵挂","intensity":85,"bond_level":4,"dynamic":"为救大婉进入险局"}],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":37,"line_start":12,"line_end":20,"text":"马如龙关心的不是黄金，是大婉，他相信，只要能找到那辆马车，就能找到大婉。"}]},{"id":"char_da_wan","name":"大婉","alias":[],"identity":"被挟持女子","faction":"无","role":"人质","archetype":"牵动众人行动的被困者","rank":"普通","one_line":"被无十三一方用来要挟马如龙，安危决定马如龙的选择。","personality":{"traits":["处境危险","牵动人心","被动受制","与