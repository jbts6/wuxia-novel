{"segment":3,"line_start":70,"line_end":88,"dialogues":[{"speaker":"char_xie_yu_bao","speaker_name":"谢玉宝","listener":"char_ma_ru_long","text":"我也知道你一定会去的。","tone":"温柔","chapter":37,"line_start":74,"line_end":74},{"speaker":"char_xie_yu_bao","speaker_name":"谢玉宝","listener":"char_ma_ru_long","text":"如果我落在他们手里，你也一定会去。","tone":"温柔","chapter":37,"line_start":74,"line_end":74},{"speaker":"char_xie_yu_bao","speaker_name":"谢玉宝","listener":"char_ma_ru_long","text":"我只希望你明白一件事。","tone":"认真","chapter":37,"line_start":76,"line_end":76},{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":"char_xie_yu_bao","text":"什么事？","tone":"疑问","chapter":37,"line_start":78,"line_end":78},{"speaker":"char_xie_yu_bao","speaker_name":"谢玉宝","listener":"char_ma_ru_long","text":"不管你是死是活，不管你心里喜欢的是谁，我都已是你的人了。","tone":"悲伤","chapter":37,"line_start":80,"line_end":80},{"speaker":"char_xie_yu_bao","speaker_name":"谢玉宝","listener":"char_ma_ru_long","text":"你有没有问过你自己，除了你之外，我还能嫁给谁？","tone":"悲伤","chapter":37,"line_start":82,"line_end":82}],"new_entities":{"characters":[{"id":"char_xie_yu_bao","name":"谢玉宝","alias":[],"identity":"钟情马如龙的女子","faction":"无","role":"同行者","archetype":"痴情而坚忍的女子","rank":"普通","one_line":"在马如龙赴险前表明心迹，明知无法挽留仍以笑面对离别。","personality":{"traits":["痴情执着","外柔内刚","克制悲伤","坦率真切","自尊而脆弱"],"speech_style":"柔中带悲，关键处直接表白","temperament":"悲伤坚忍"},"relationships":[{"target":"char_ma_ru_long","type":"倾慕","intensity":90,"bond_level":4,"dynamic":"临别前确认自己心意"}],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":37,"line_start":72,"line_end":82,"text":"阳光正照在谢玉宝的脸上，阳光如此灿烂，她的脸色却苍白如冷月。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ma_ru_long","updates":{"source_refs":[{"chapter":37,"line_start":86,"line_end":86,"text":"马如龙走了，连一句话也没有再说就走了。"}]},"relationship_updates":[{"action":"add","target":"char_xie_yu_bao","type":"情感牵连","intensity":70,"bond_level":3,"dynamic":"无法回应她的托付与追问"}]}]}
