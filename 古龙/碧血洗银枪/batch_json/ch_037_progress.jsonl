{"segment":2,"line_start":32,"line_end":68,"dialogues":[{"speaker":"char_bo_si_nu","speaker_name":"波斯奴","listener":"char_ma_ru_long","text":"马如龙！","tone":"厉声","chapter":37,"line_start":36,"line_end":36},{"speaker":"char_bo_si_nu","speaker_name":"波斯奴","listener":"char_ma_ru_long","text":"谁是马如龙，你想找大婉，你就跟我来，有别的人跟来，大婉就死。","tone":"冷酷","chapter":37,"line_start":36,"line_end":36},{"speaker":"char_tie_zhen_tian","speaker_name":"铁震天","listener":"char_ma_ru_long","text":"那个人是疯子，","tone":"严肃","chapter":37,"line_start":52,"line_end":52},{"speaker":"char_tie_zhen_tian","speaker_name":"铁震天","listener":"char_ma_ru_long","text":"他杀人从来都用不着找理由的。","tone":"严肃","chapter":37,"line_start":52,"line_end":52},{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":"char_tie_zhen_tian","text":"我知道。","tone":"陈述","chapter":37,"line_start":54,"line_end":54},{"speaker":"char_tie_zhen_tian","speaker_name":"铁震天","listener":"char_ma_ru_long","text":"何况他这次有理由杀你。","tone":"严肃","chapter":37,"line_start":56,"line_end":56},{"speaker":"char_tie_zhen_tian","speaker_name":"铁震天","listener":"char_ma_ru_long","text":"因为你已骗过他一次，这次他绝对不会放过你，他杀了你之后，还是一样可以杀大婉。","tone":"严肃","chapter":37,"line_start":56,"line_end":56},{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":"char_tie_zhen_tian","text":"我知道。","tone":"陈述","chapter":37,"line_start":60,"line_end":60},{"speaker":"char_tie_zhen_tian","speaker_name":"铁震天","listener":"char_ma_ru_long","text":"你还是要去？","tone":"疑问","chapter":37,"line_start":62,"line_end":62},{"speaker":"char_ma_ru_long","speaker_name":"马如龙","listener":"char_tie_zhen_tian","text":"如果你是我，你去不去？","tone":"疑问","chapter":37,"line_start":64,"line_end":64},{"speaker":"char_tie_zhen_tian","speaker_name":"铁震天","listener":"char_ma_ru_long","text":"我也会去，一定会去。","tone":"无奈","chapter":37,"line_start":66,"line_end":66}],"new_entities":{"characters":[{"id":"char_bo_si_nu","name":"波斯奴","alias":[],"identity":"持弯刀的波斯杀手","faction":"无十三一方","role":"诱敌者","archetype":"杀人冷酷的异域刀客","rank":"一流","one_line":"奉命在死谷隘口引马