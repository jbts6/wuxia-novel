{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":null,"speaker_name":"众人","listener":null,"text":"怎样了，有没有消息？","tone":"焦急","chapter":35,"line_start":40,"line_end":40},{"speaker":null,"speaker_name":"其中一人","listener":null,"text":"有没有消息？","tone":"焦急","chapter":35,"line_start":48,"line_end":48},{"speaker":null,"speaker_name":"冰冷声音","listener":null,"text":"走远点！","tone":"冷酷","chapter":35,"line_start":52,"line_end":52},{"speaker":null,"speaker_name":"去探消息者","listener":null,"text":"没有消息。","tone":"陈述","chapter":35,"line_start":56,"line_end":56},{"speaker":"char_bao_xiao_tian","speaker_name":"包晓天","listener":null,"text":"真是倒了霉，竟被差来干这一趟苦差！","tone":"愤怒","chapter":35,"line_start":62,"line_end":62},{"speaker":null,"speaker_name":"众人","listener":"char_bao_xiao_tian","text":"包老大，怎么了，有没有消息？","tone":"疑问","chapter":35,"line_start":66,"line_end":66},{"speaker":"char_bao_xiao_tian","speaker_name":"包晓天","listener":null,"text":"有什么消息！哼，屁也没有，只怕要等上三年五载也说不定，走着瞧吧！我鞋子都换了两双了！","tone":"愤怒","chapter":35,"line_start":70,"line_end":72},{"speaker":null,"speaker_name":"旁人","listener":"char_bao_xiao_tian","text":"倒是真的，包老大鞋破了，还真不好买。","tone":"调侃","chapter":35,"line_start":76,"line_end":76},{"speaker":null,"speaker_name":"小贩","listener":"char_bao_xiao_tian","text":"没关系，小的已为您老准备了好几双红鞋子，大小包管合脚。","tone":"陈述","chapter":35,"line_start":80,"line_end":80},{"speaker":"char_bao_xiao_tian","speaker_name":"包晓天","listener":null,"text":"这小子倒蛮会做生意！","tone":"大笑","chapter":35,"line_start":84,"line_end":84}],"new_entities":{"characters":[{"id":"char_bao_xiao_tian","name":"包晓天","alias":["鸡冠"],"identity":"金鸡帮大头领","faction":"faction_jin_ji_bang","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"金鸡帮大头领，满身红衣，性格急躁狂傲","personality":{"traits":["急躁","狂傲","好胜","豪爽","粗犷"],"speech_style":"大嗓门，直来直去","temperament":"暴躁易怒"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[35],"source_refs":[{"chapter":35,"line_start":60,"line_end":88,"text":"满身红衣，红巾红履，身材高大威猛，步履极为矫健的虬髯大汉"}]},{"id":"char_gu