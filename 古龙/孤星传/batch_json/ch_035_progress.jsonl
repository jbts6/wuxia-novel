":"嘻嘻哈哈","temperament":"开朗"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[35],"source_refs":[{"chapter":35,"line_start":108,"line_end":112,"text":"身躯臃肿，满头大汗，气喘咻咻"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_jin_ji_bang","name":"金鸡帮","type":"帮派","location":"江南","sub_divisions":[],"one_line":"江南帮派，帮主向一啼","source_refs":[{"chapter":35,"line_start":88,"line_end":88,"text":"金鸡帮中仅次于帮主向一啼的大头领"}]},{"id":"faction_fei_ling_bao","name":"飞灵堡","type":"家族","location":"江南","sub_divisions":[],"one_line":"江南名门，东方五剑所在","source_refs":[{"chapter":35,"line_start":16,"line_end":16,"text":"东方五剑兼程返回飞灵堡"}]},{"id":"faction_fei_long_biao_ju","name":"飞龙镖局","type":"帮派","location":"中原","sub_divisions":[],"one_line":"中原镖局，龙形八掌檀明所属","source_refs":[{"chapter":35,"line_start":18,"line_end":18,"text":"飞龙镖局与浪莽山庄"}]},{"id":"faction_lang_mang_shan_zhuang","name":"浪莽山庄","type":"帮派","location":"江南","sub_divisions":[],"one_line":"江南势力，神手战飞为主","source_refs":[{"chapter":35,"line_start":16,"line_end":16,"text":"浪莽山庄"}]},{"id":"faction_qi_qiao_shan_zhuang","name":"七巧山庄","type":"帮派","location":"江南","sub_divisions":[],"one_line":"七巧追魂那飞虹所属","source_refs":[{"chapter":35,"line_start":110,"line_end":110,"text":"七巧追魂那飞虹"}]},{"id":"faction_leng_gu","name":"冷谷","type":"武林门派","location":"冷谷","sub_divisions":[],"one_line":"隐世门派，冷谷双木所在","source_refs":[{"chapter":35,"line_start":118,"line_end":118,"text":"冷谷双木"}]}],"locations":[{"id":"loc_huang_shan","name":"黄山","region":"安徽","one_line":"天下闻名，景色绝美的名山","source_refs":[{"chapter":35,"line_start":30,"line_end":30,"text":"自祁门至黄山"}]},{"id":"loc_qi_men","name":"祁门","region":"安徽","one_line":"黄山附近地名","source_refs":[{"chapter":35,"line_start":30,"line_end":30,"text":"自祁门至黄山"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_leng_han_zhu","speaker_name":"冷寒竹","listener":"char_leng_ku_mu","text":"怎地不避开这些厌物！","tone":"疑问","chapter":35,"line_start":150,"line_end":150},{"speaker":"char_leng_ku_mu","speaker_name":"冷枯木","listener":"char_leng_han_zhu","text":"他们不避我们，难道还要我们避他们么？","tone":"冷笑","chapter":35,"line_start":153,"line_end":154},{"speaker":null,"speaker_name":"众人","listener":"char_bao_xiao_tian","text":"想不到包老大竟有这么俊的马上功夫！","tone":"欣喜","chapter":35,"line_start":162,"line_end":162},{"speaker":"char_jia_bin","speaker_name":"贾斌","listener":"char_bao_xiao_tian","text":"不错不错，关外的马贼也不过如此了。","tone":"嘲讽","chapter":35,"line_start":165,"line_end":166},{"speaker":"char_bao_xiao_tian","speaker_name":"包晓天","listener":null,"text":"上山了。","tone":"陈述","chapter":35,"line_start":170,"line_end":170},{"speaker":"char_guan_er_ye","speaker_name":"管二爷","listener":null,"text":"这一来别的事还小，名山却要遭劫了！","tone":"无奈","chapter":35,"line_start":175,"line_end":176},{"speaker":"char_yu_ping","speaker_name":"于平","listener":"char_guan_er_ye","text":"我们不必一齐上山，只要三两人随之上山便可以了，其余的等在山下亦是一样。","tone":"陈述","chapter":35,"line_start":181,"line_end":184},{"speaker":"char_guan_er_ye","speaker_name":"管二爷","listener":"char_yu_ping","text":"正是正是，于兄高见，果是不凡，那么——是请哪位上山一行？","tone":"欣喜","chapter":35,"line_start":187,"line_end":188},{"speaker":"char_bao_xiao_tian","speaker_name":"包晓天","listener":null,"text":"我宁愿在山下吃酒，倒落得快活些。","tone":"陈述","chapter":35,"line_start":191,"line_end":192},{"speaker":"char_yu_ping","speaker_name":"于平","listener":"char_bao_xiao_tian","text":"这其中只有包兄与贾兄轻功还高，少不得还是要劳动两位一下的。","tone":"微笑","chapter":35,"line_start":195,"line_end":198},{"speaker":"char_bao_xiao_tian","speaker_name":"包晓天","listener":null,"text":"既然如此，我只好再跑一趟了。","tone":"无奈","chapter":35,"line_start":201,"line_end":202}],"new_entities":{"characters":[{"id":"char_leng_han_zhu","name":"冷寒竹","alias":[],"identity":"冷谷双木之一","faction":"faction_leng_gu","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"冷谷双木之一，冷僻孤傲但有赤子之心","personality":{"traits":["冷僻","孤傲","热心","直率","清高"],"speech_style":"冷然","temperament":"冷漠"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[35],"source_refs":[{"chapter":35,"line_start":118,"line_end":118,"text":"冷谷双木一路观赏着风景"}]},{"id":"char_leng_ku_mu","name":"冷枯木","alias":[],"identity":"冷谷双木之一","faction":"faction_leng_gu","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"冷谷双木之一，冷僻孤傲但有赤子之心","personality":{"traits":["冷僻","孤傲","机智","犀利","护短"],"speech_style":"冷笑","temperament":"冷漠"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[35],"source_refs":[{"chapter":35,"line_start":118,"line_end":118,"text":"冷谷双木一路观赏着风景"}]},{"id":"char_pei_jue","name":"裴珏","alias":["裴大先生"],"identity":"江南绿林盟主","faction":null,"role":"protagonist","archetype":"scholar","rank":"初窥门径","one_line":"善良平凡的弱冠少年，被江湖渲染成神秘人物","personality":{"traits":["善良","宽厚","仁慈","好学","坚毅"],"speech_style":"沉思","temperament":"温和"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[35],"source_refs":[{"chapter":35,"line_start":12,"line_end":14,"text":"这少年叫做裴珏"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_pei_jue","updates":{"source_refs":[{"chapter":35,"line_start":120,"line_end":140,"text":"裴珏大半俱在沉思，有时自怀中取出一册书卷"}]},"relationship_updates":[{"action":"add","target":"char_leng_han_zhu","type":"师徒","intensity":70,"bond_level":4,"dynamic":"传授武功"},{"action":"add","target":"char_leng_ku_mu","type":"师徒","intensity":70,"bond_level":4,"dynamic":"传授武功"}]}]}
{"segment":3,"line_start":201,"line_end":262,"dialogues":[{"speaker":"char_jia_bin","speaker_name":"贾斌","listener":null,"text":"我不去！","tone":"冷酷","chapter":35,"line_start":204,"line_end":204},{"speaker":"char_yu_ping","speaker_name":"于平","listener":"char_jia_bin","text":"那么只有我去走一趟了。","tone":"苦笑","chapter":35,"line_start":207,"line_end":208},{"speaker":"char_jia_bin","speaker_name":"贾斌","listener":null,"text":"谁都毋庸去，他们难道住在黄山，不下来了么？","tone":"淡然","chapter":35,"line_start":211,"line_end":212},{"speaker":"char_bao_xiao_tian","speaker_name":"包晓天","listener":"char_jia_bin","text":"极是极是，他们一定要下来的——但是难道他们非常喜欢我们跟在后面？他们不会偷偷溜走么？","tone":"冷笑","chapter":35,"line_start":215,"line_end":218},{"speaker":"char_jia_bin","speaker_name":"贾斌","listener":"char_bao_xiao_tian","text":"极是极是，他们会悄悄溜走的——他们若是不想我们跟着，早有十万个机会可以溜走了，以'冷谷双木'的脚程，有谁追得到？他们以前既未溜走，难道今日会溜走么？","tone":"嘲讽","chapter":35,"line_start":221,"line_end":226},{"speaker":"char_jia_bin","speaker_name":"贾斌","listener":"char_guan_er_ye","text":"管二爷，你我不妨来快活快活。","tone":"陈述","chapter":35,"line_start":234,"line_end":234},{"speaker":"char_jia_bin","speaker_name":"贾斌","listener":null,"text":"贾儿，有些人真的没有你聪明，你知道么？这么热的天，一定要跑上山去，你看，我们在这里多舒服，多凉快。","tone":"调侃","chapter":35,"line_start":238,"line_end":240},{"speaker":"char_bao_xiao_tian","speaker_name":"包晓天","listener":null,"text":"谁说我要上山？我本来就要留在山下的！","tone":"愤怒","chapter":35,"line_start":246,"line_end":246}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_hei_lv","name":"黑驴","type":"special","owner":"char_jia_bin","one_line":"贾斌的坐骑，干枯瘦小，通人性","description":"贾斌的黑色毛驴，干枯瘦小，与主人形影不离，似乎通晓人意，常与贾斌一同行动进食。","effects":["日行千里"],"origin":"关外","rarity":"寻常凡品","related_characters":["char_jia_bin"],"related_skills":[],"rag_refs":[35],"source_refs":[{"chapter":35,"line_start":100,"line_end":100,"text":"一人一驴，恰好相互辉映"}]}]},"entity_updates":[{"id":"char_bao_xiao_tian","updates":{},"relationship_updates":[{"action":"add","target":"char_jia_bin","type":"对手","intensity":60,"bond_level":3,"dynamic":"互相嘲讽"}]},{"id":"char_jia_bin","updates":{},"relationship_updates":[{"action":"add","target":"char_bao_xiao_tian","type":"对手","intensity":60,"bond_level":3,"dynamic":"互相嘲讽"}]}]}
