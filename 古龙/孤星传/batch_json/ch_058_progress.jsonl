:[],"identity":"檀明手下","faction":"飞龙镖局","role":"villain","archetype":"assassin","rank":"出神入化","one_line":"檀明手下的剺悍杀手","personality":{"traits":["剺悍","忠诚","冷酷","果断","勇猛"],"speech_style":"冷酷","temperament":"冷酷"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":58,"line_start":98,"line_end":98,"text":"苒豹冷冷一笑"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_miao_bao","speaker_name":"苒豹","listener":null,"text":"哪里去！","tone":"厉声","chapter":58,"line_start":104,"line_end":104},{"speaker":"char_liu_hui","speaker_name":"柳辉","listener":"char_miao_bao","text":"苒兄，你这……这是要做什么？嘿嘿，老兄弟好久不见，我请你——","tone":"恐惧","chapter":58,"line_start":108,"line_end":110},{"speaker":"char_miao_bao","speaker_name":"苒豹","listener":null,"text":"谁是你的老兄弟？我正是来要你的狗命！","tone":"冷酷","chapter":58,"line_start":112,"line_end":114},{"speaker":"char_bian_shao_yan","speaker_name":"边少衍","listener":null,"text":"你说来要命，我却看你是来送死的！","tone":"冷笑","chapter":58,"line_start":120,"line_end":122},{"speaker":"char_pei_jue","speaker_name":"裴玺","listener":null,"text":"经过这么多天的劳累，我们都该早些睡了。","tone":"陈述","chapter":58,"line_start":174,"line_end":176}],"new_entities":{"characters":[{"id":"char_pei_jue","name":"裴玺","alias":[],"identity":"武林明星","faction":"江南同盟","role":"protagonist","archetype":"warrior","rank":"出神入化","one_line":"武林中新崛的明星","personality":{"traits":["坚韧","善良","正直","勇敢","重情义"],"speech_style":"正直","temperament":"热血"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":58,"line_start":170,"line_end":176,"text":"裴玺孤独而冷清地将自己锁在一间房里"}]},{"id":"char_wu_ming_shi","name":"吴鸣世","alias":[],"identity":"裴玺的友人","faction":null,"role":"companion","archetype":"scholar","rank":"登堂入室","one_line":"裴玺的好友","personality":{"traits":["热情","卓越","智慧","忠诚","细心"],"speech_style":"文雅","temperament":"温和"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":58,"line_start":174,"line_end":174,"text":"吴鸣世说话的声音"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":298,"dialogues":[{"speaker":"char_sun_bin","speaker_name":"孙斌","listener":"char_tan_ming","text":"美人多是祸水，奇珍更多不祥，唉……为了这一只‘碧玉蟻蝉’，弄得我浪落江湖半生，至今一身残废，连……唉，连锦平都……","tone":"悲痛","chapter":58,"line_start":250,"line_end":252},{"speaker":"char_tan_ming","speaker_name":"檀明","listener":"char_sun_bin","text":"造化弄人，每多如此，孙兄，你……你……","tone":"悲痛","chapter":58,"line_start":258,"line_end":260},{"speaker":"char_sun_bin","speaker_name":"孙斌","listener":"char_tan_ming","text":"但我自思自想，如今落得这种地步，也是罪有应得，只是檀兄，你……你为什么不将事实的真相说出来？","tone":"疑问","chapter":58,"line_start":264,"line_end":268},{"speaker":"char_sun_bin","speaker_name":"孙斌","listener":"char_tan_ming","text":"我失去了这‘碧玉蟻蝉’后，便一心以为它是被‘淮阳三焢’盗去，竟没有去追查事实的真相！唉……只可怫‘淮阳三焢’兄弟三人都被我……唉，他们虽然为恶甚多，但又何尚得罪了我！反是我错怪了他们，我……我这不是罪有应得么？","tone":"悲痛","chapter":58,"line_start":274,"line_end":280},{"speaker":"char_tan_ming","speaker_name":"檀明","listener":"char_sun_bin","text":"天网恢恢，疏而不漏，善恶之报，最是令人难测，‘淮阳三焢’作恶多端，没有被仇家杀死，却死在你手里，你心里自然难受，但你若仔细一想，又何尝不会是苍天假你之手，来将他们除去呢？","tone":"陈述","chapter":58,"line_start":282,"line_end":286},{"speaker":"char_sun_bin","speaker_name":"孙斌","listener":"char_tan_ming","text":"我无心铸下了这般大错，也受到了应得的报应，这样我死了之后，在九泉下也会安心些，只是檀兄，你……你为什么……","tone":"悲痛","chapter":58,"line_start":288,"line_end":290},{"speaker":"char_tan_ming","speaker_name":"檀明","listener":null,"text":"我如今受到这样的冤屈、侥辱，实在也是罪有应得，我本想将这‘碧玉蟻蝉’物归原主后，就远远一走，让所有的罪孽都算在我身上，让这一段武林中的隐密，永远埋藏，但……但我满腔积郁不吐，实是死难瞪目。","tone":"无奈","chapter":58,"line_start":292,"line_end":296}],"new_entities":{"characters":[{"id":"char_tan_ming","name":"檀明","alias":["龙形八掌"],"identity":"武林宝藏","faction":"飞龙镖局","role":"villain","archetype":"warrior","rank":"出神入化","one_line":"飞龙镖局局主，武林系宝","personality":{"traits":["深沉","城底","复杂","阴险","自私"],"speech_style":"深沉","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":58,"line_start":240,"line_end":240,"text":"龙形八掌檀明"}]},{"id":"char_sun_bin","name":"孙斌","alias":["断魂刀","孙老爷"],"identity":"江湖老前辈","faction":null,"role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"孙锦平之父，断魂刀孙斌","personality":{"traits":["正直","勇敢","重情义","自责","悲伤"],"speech_style":"正直","temperament":"悲伤"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":58,"line_start":242,"line_end":242,"text":"断魂刀孙斌"}]},{"id":"char_sun_jin_ping","name":"孙锦平","alias":[],"identity":"孙斌之女","faction":null,"role":"npc","archetype":"healer","rank":"登堂入室","one_line":"孙斌的女儿，裴玺的旧知","personality":{"traits":["温柔","善良","坚强","陈静","美丽"],"speech_style":"柔声","temperament":"温柔"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":58,"line_start":232,"line_end":234,"text":"孙锦平，白月而美丽的女子"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_bi_yu_chan_chu","name":"碧玉蟻蝉","type":"special","owner":"char_sun_bin","one_line":"引起武林纠著的奇珍","description":"一只碧绿色的蟻蝉形珍宝，质地玉洁，工艺精湛，为江湖上下万人争夺的奇异宝物。","effects":[],"origin":"传说中的宝藏","rarity":"稀世珍品","related_characters":["char_sun_bin"],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":58,"line_start":248,"line_end":248,"text":"赫然竟是一只‘碧玉蟻蝉’"}]}]},"entity_updates":[]}
