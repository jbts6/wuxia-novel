{"segment":2,"line_start":61,"line_end":129,"dialogues":[{"speaker":"char_ai_qing","speaker_name":"艾青","listener":null,"text":"喂！你睡着了吗？","tone":"疑问","chapter":5,"line_start":60,"line_end":60},{"speaker":null,"speaker_name":null,"listener":"char_pei_jue","text":"想不到我来了吧？","tone":"嘲讽","chapter":5,"line_start":68,"line_end":69},{"speaker":null,"speaker_name":null,"listener":"char_ai_qing","text":"更想不到的，总算让我抓着了你。你还有什么话说？","tone":"冷笑","chapter":5,"line_start":72,"line_end":73},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"你是谁？","tone":"疑问","chapter":5,"line_start":84,"line_end":85},{"speaker":null,"speaker_name":null,"listener":"char_pei_jue","text":"你是谁？","tone":"冷笑","chapter":5,"line_start":88,"line_end":88},{"speaker":null,"speaker_name":null,"listener":"char_pei_jue","text":"艾青呢？","tone":"疑问","chapter":5,"line_start":90,"line_end":90},{"speaker":null,"speaker_name":null,"listener":"char_pei_jue","text":"艾青呢？","tone":"疑问","chapter":5,"line_start":92,"line_end":93},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"她出去了。","tone":"陈述","chapter":5,"line_start":96,"line_end":96},{"speaker":null,"speaker_name":null,"listener":null,"text":"怪不得我找不着她，原来她找着了汉子。","tone":"喃喃","chapter":5,"line_start":98,"line_end":99},{"speaker":null,"speaker_name":null,"listener":"char_pei_jue","text":"想不到她竟看上了你这男不男、女不女的兔崽子。","tone":"嘲讽","chapter":5,"line_start":100,"line_end":101},{"speaker":null,"speaker_name":null,"listener":null,"text":"原来是他的独门点穴。","tone":"惊讶","chapter":5,"line_start":114,"line_end":114},{"speaker":null,"speaker_name":null,"listener":"char_pei_jue","text":"这厮的手段，果然狠毒已到极处。","tone":"陈述","chapter":5,"line_start":126,"line_end":126},{"speaker":null,"speaker_name":null,"listener":"char_pei_jue","text":"只能怪你没出息。","tone":"轻蔑","chapter":5,"line_start":127,"line_end":127}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":130,"line_end":170,"dialogues":[{"speaker":null,"speaker_name":"店伙","listener":null,"text":"客官，天亮了，要赶路的该起来了。","tone":"陈述","chapter":5,"line_start":148,"line_end":148},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"天亮了，我该走了，但我走到哪里去呢？","tone":"悲伤","chapter":5,"line_start":150,"line_end":150},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"男子汉大丈夫，宁可流血，也不能流泪的。","tone":"认真","chapter":5,"line_start":154,"line_end":154},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"别人的东西，我能拿吗？","tone":"疑问","chapter":5,"line_start":156,"line_end":156},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"但是我住了店，该付店钱的。","tone":"陈述","chapter":5,"line_start":157,"line_end":157},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"多的你拿去吧！","tone":"陈述","chapter":5,"line_start":164,"line_end":165},{"speaker":"char_dian_huo","speaker_name":"店伙","listener":null,"text":"客官多光顾。","tone":"陈述","chapter":5,"line_start":168,"line_end":168},{"speaker":null,"speaker_name":"店伙","listener":null,"text":"住店不给钱，还要铁青着脸充大爷，看你这样子，八成是个兔二爷。","tone":"嘲讽","chapter":5,"line_start":170,"line_end":170},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"有了马，我就可以到处跑了。","tone":"欣喜","chapter":5,"line_start":174,"line_end":174}],"new_entities":{"characters":[{"id":"char_dian_huo","name":"店伙","alias":[],"identity":"客栈伙计","faction":null,"role":"npc","archetype":null,"rank":null,"one_line":"客栈伙计，见风使舵，背后暗骂客人","personality":{"traits":["势利","圆滑","精明","势利眼","世故"],"speech_style":"市井口吻","temperament":"势利"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":148,"line_end":170,"text":"店伙的叫声及内心独白"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":171,"line_end":232,"dialogues":[{"speaker":null,"speaker_name":"公差","listener":"char_pei_jue","text":"你这匹马是哪里偷来的？","tone":"疑问","chapter":5,"line_start":178,"line_end":179},{"speaker":null,"speaker_name":"公差","listener":"char_pei_jue","text":"快跟太爷到衙门里去！","tone":"厉声","chapter":5,"line_start":182,"line_end":182},{"speaker":null,"speaker_name":"公差","listener":null,"text":"这一个是贼，你看他穿得这个样子，手里却牵着这么一匹好马。","tone":"陈述","chapter":5,"line_start":184,"line_end":184},{"speaker":null,"speaker_name":"公差","listener":"char_pei_jue","text":"妈那个巴子，你这个小贼还耍赖。","tone":"愤怒","chapter":5,"line_start":188,"line_end":188},{"speaker":null,"speaker_name":"公差","listener":"char_pei_jue","text":"小贼还敢还手！","tone":"愤怒","chapter":5,"line_start":192,"line_end":192},{"speaker":null,"speaker_name":"瘦子公差","listener":null,"text":"老张，算了，把赃物带回去就算了，这小贼怪可怜的，就马马虎虎放了他吧！","tone":"陈述","chapter":5,"line_start":196,"line_end":197},{"speaker":null,"speaker_name":"瘦子公差","listener":null,"text":"这小贼身上的那个包袱，说不定还有什么赃物，你拿来看看。","tone":"陈述","chapter":5,"line_start":200,"line_end":201},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"为什么这些人要欺负我，难道我生成就是该受人家的欺凌与侮辱的吗？","tone":"愤怒","chapter":5,"line_start":208,"line_end":208},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"为什么在有光的地方才有灰尘呢？","tone":"疑问","chapter":5,"line_start":136,"line_end":137},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"原来是光线将灰尘照出来，没有光的地方也有灰尘，只是我们看不到罢了。","tone":"陈述","chapter":5,"line_start":140,"line_end":140},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"这世界多么不公平！光线为什么不把所有的灰尘都照出来呢？为什么让那些灰尘躲在黑暗里呢？","tone":"悲伤","chapter":5,"line_start":142,"line_end":146},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"你有三颗金牙，耳朵上有一粒痣。","tone":"认真","chapter":5,"line_start":216,"line_end":216},{"speaker":"char_pei_jue","speaker_name":"裴珏","listener":null,"text":"我不会忘记你，总有一天我会报答你的。","tone":"认真","chapter":5,"line_start":218,"line_end":218}],"new_entities":{"characters":[{"id":"char_gong_chai_lao_zhang","name":"老张","alias":["公差"],"identity":"衙门公差","faction":null,"role":"npc","archetype":null,"rank":null,"one_line":"衙门里吃闲饭的公差，赌输后出来敲诈勒索","personality":{"traits":["贪婪","欺软怕硬","粗鲁","无赖","势利"],"speech_style":"市井粗口","temperament":"暴躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":178,"line_end":204,"text":"公差老张抢马抢包袱"}]},{"id":"char_gong_chai_shou_zi","name":"瘦子","alias":["瘦子公差"],"identity":"衙门公差","faction":null,"role":"npc","archetype":null,"rank":null,"one_line":"与老张同行的瘦子公差，假意劝解实则趁火打劫","personality":{"traits":["阴险","狡猾","贪婪","虚伪","冷漠"],"speech_style":"市井口吻","temperament":"阴沉"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":196,"line_end":201,"text":"瘦子公差劝解并索要包袱"}]},{"id":"char_mai_shao_bing_pang_zi","name":"卖烧饼胖子","alias":["胖子"],"identity":"街头小贩","faction":null,"role":"npc","archetype":null,"rank":null,"one_line":"卖烧饼的胖子，心地善良赠饼给裴珏","personality":{"traits":["善良","朴实","热心","慷慨","厚道"],"speech_style":"无对白","temperament":"温和"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":216,"line_end":228,"text":"卖烧饼胖子赠饼给裴珏"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_liang_ben_bao_shu","name":"两本薄书","type":"special","owner":"char_pei_jue","one_line":"裴珏包袱中发现的两本薄书，黑桑皮纸封面","description":"两本薄薄的书，用黑桑皮纸做封面，上面没有写字，藏在艾青留给裴珏的包袱中，来历不明。","effects":[],"origin":"艾青的包袱","rarity":"寻常凡品","related_characters":["char_pei_jue","char_ai_qing"],"related_skills":[],"rag_refs":[5],"source_refs":[{"chapter":5,"line_start":212,"line_end":222,"text":"包袱里所剩只有两本薄薄的书"}]}]},"entity_updates":[]}
