  {
    "id": "faction_fei_long_biao_ju",
    "name": "飞龙镖局",
    "type": "帮派",
    "location": "北京",
    "sub_divisions": [],
    "one_line": "北京城最大镖局，总镖头龙形八掌檀明",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 276,
        "line_end": 282,
        "text": "河北京城里的'飞龙镖局'"
      },
      {
        "chapter": 2,
        "line_start": 8,
        "line_end": 8,
        "text": "飞龙镖局不但在两河首屈一指，远至江南，塞外，都设有分号"
      },
      {
        "chapter": 8,
        "line_start": 128,
