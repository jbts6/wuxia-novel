{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"我……我今年已经十八了。","tone":"陈述","chapter":13,"line_start":406,"line_end":406},{"speaker":null,"speaker_name":null,"listener":null,"text":"却不知你看上的人是谁？","tone":"陈述","chapter":13,"line_start":420,"line_end":420},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"当然是你。","tone":"陈述","chapter":13,"line_start":422,"line_end":422},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"那倒不一定。","tone":"陈述","chapter":13,"line_start":424,"line_end":424},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"为什么？","tone":"陈述","chapter":13,"line_start":436,"line_end":436},{"speaker":"char_suan_mei_tang","speaker_name":"酸梅汤","listener":null,"text":"因为现在还没有到时候。","tone":"陈述","chapter":13,"line_start":438,"line_end":438},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"几时才到时候？","tone":"陈述","chapter":13,"line_start":440,"line_end":440},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你现在还看不出？","tone":"陈述","chapter":13,"line_start":446,"line_end":446},{"speaker":"char_suan_mei_tang","speaker_name":"酸梅汤","listener":null,"text":"我……我还想再等等，再看看。","tone":"陈述","chapter":13,"line_start":448,"line_end":448},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"我看你还是快点看吧，有人已经快急死了。","tone":"陈述","chapter":13,"line_start":450,"line_end":450},{"speaker":"char_suan_mei_tang","speaker_name":"酸梅汤","listener":null,"text":"我看出来之后，一定第一个告诉你。","tone":"陈述","chapter":13,"line_start":456,"line_end":456},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你为什么要走呢？大家一齐聊聊天不好吗？","tone":"陈述","chapter":13,"line_start":460,"line_end":460},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"有什么好聊的？","tone":"陈述","chapter":13,"line_start":462,"line_end":462},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你难道没有话说？","tone":"陈述","chapter":13,"line_start":464,"line_end":464},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"我只有一句话说。","tone":"陈述","chapter":13,"line_start":466,"line_end":466},{"speaker":"char_suan_mei_tang","speaker_name":"酸梅汤","listener":null,"text":"我不姓酸，我姓梅。","tone":"陈述","chapter":13,"line_start":476,"line_end":476},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"梅花的梅？","tone":"陈述","chapter":13,"line_start":478,"line_end":478},{"speaker":"char_suan_mei_tang","speaker_name":"酸梅汤","listener":null,"text":"我叫梅汝男。","tone":"陈述","chapter":13,"line_start":480,"line_end":480},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"又是梅花，又是兰花，简直可以开花店了。","tone":"陈述","chapter":13,"line_start":482,"line_end":482},{"speaker":"char_suan_mei_tang","speaker_name":"酸梅汤","listener":null,"text":"不是兰花的兰，是男人的男。","tone":"陈述","chapter":13,"line_start":484,"line_end":484},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"梅汝男，这名字倒有点怪。","tone":"陈述","chapter":13,"line_start":486,"line_end":486},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"令尊九泉之下有灵，一定会觉得很高兴。","tone":"陈述","chapter":13,"line_start":492,"line_end":492},{"speaker":"char_suan_mei_tang","speaker_name":"酸梅汤","listener":null,"text":"为什么？","tone":"陈述","chapter":13,"line_start":494,"line_end":494},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"因为你的确没有辜负他的期望。","tone":"陈述","chapter":13,"line_start":496,"line_end":496},{"speaker":"char_suan_mei_tang","speaker_name":"酸梅汤","listener":null,"text":"你……你认为我做事真的很像男人？","tone":"陈述","chapter":13,"line_start":498,"line_end":498},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"你是女人？","tone":"陈述","chapter":13,"line_start":500,"line_end":500}],"new_entities":{"characters":[{"id":"char_guo_da_lu","name":"郭大路","alias":[],"identity":"江湖浪子","faction":"无","role":"protagonist","archetype":"warrior","rank":"登堂入室","one_line":"豪爽直率的江湖人，饿了就想到吃饭","personality":{"traits":