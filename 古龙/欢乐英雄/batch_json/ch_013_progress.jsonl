{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"这是被刀割断的。","tone":"陈述","chapter":13,"line_start":14,"line_end":14},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"而且是把快刀。","tone":"陈述","chapter":13,"line_start":16,"line_end":16},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我实在想不到连这种人也会有朋友。","tone":"陈述","chapter":13,"line_start":24,"line_end":24},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"会不会是那两个小鬼？","tone":"陈述","chapter":13,"line_start":26,"line_end":26},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"不会，他们既没有这么大本事，也没有这么大胆子，而且……","tone":"陈述","chapter":13,"line_start":28,"line_end":28},{"speaker":null,"speaker_name":null,"listener":null,"text":"小孩有的地方，就跟女人一样。","tone":"陈述","chapter":13,"line_start":30,"line_end":30},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"哪点？","tone":"陈述","chapter":13,"line_start":32,"line_end":32},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"小孩子都不会很讲义气……他们根本不懂。","tone":"陈述","chapter":13,"line_start":34,"line_end":34},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"会不会是金毛狮子狗？","tone":"陈述","chapter":13,"line_start":36,"line_end":36},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你怎么想起他的？","tone":"陈述","chapter":13,"line_start":38,"line_end":38},{"speaker":"char_lin_tai_ping","speaker_name":"林太平","listener":null,"text":"哪一件事？","tone":"陈述","chapter":13,"line_start":48,"line_end":48},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"他绝不会留着别人跟他分赃。","tone":"陈述","chapter":13,"line_start":50,"line_end":50},{"speaker":"char_lin_tai_ping","speaker_name":"林太平","listener":null,"text":"你认为棍子和金毛狮子狗都已被他杀了？","tone":"陈述","chapter":13,"line_start":56,"line_end":56},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我饿了。","tone":"陈述","chapter":13,"line_start":58,"line_end":58},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"你说到什么的时候，就会想到什么？","tone":"陈述","chapter":13,"line_start":70,"line_end":70},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"好像是的。","tone":"陈述","chapter":13,"line_start":72,"line_end":72},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"你说到狗屎的时候，难道就会想到……","tone":"陈述","chapter":13,"line_start":74,"line_end":74},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"这人实在是个天才。","tone":"陈述","chapter":13,"line_start":82,"line_end":82},{"speaker":"char_lin_tai_ping","speaker_name":"林太平","listener":null,"text":"这样的天才世上也许还不多。","tone":"陈述","chapter":13,"line_start":84,"line_end":84},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"非但不多，恐怕只有这么一个。","tone":"陈述","chapter":13,"line_start":86,"line_end":86}],"new_entities":{"characters":[{"id":"char_guo_da_lu","name":"郭大路","alias":[],"identity":"江湖浪子","faction":"无","role":"protagonist","archetype":"warrior","rank":"登堂入室","one_line":"豪爽直率的江湖人，饿了就想到吃饭","personality":{"traits":["豪爽","直率","幽默","乐观","重义气"],"speech_style":"大大咧咧","temperament":"开朗"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[13],"source_refs":[{"chapter":13,"line_start":14,"line_end":14,"text":"郭大路发了半天怔"}]},{"id":"char_yan_qi","name":"燕七","alias":[],"identity":"江湖人","faction":"无","role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"性格有些古怪的江湖人，会无缘无故发脾气","personality":{"traits":["聪明","敏感","有些小气","重感情","口是心非"],"speech_style":"冷冷的","temperament":"易怒"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[13],"source_refs":[{"chapter":13,"line_start":16,"line_end":16,"text":"燕七道"}]},{"id":"char_lin_tai_ping","name":"林太平","alias":[],"identity":"江湖人","faction":"无","role":"companion","archetype":"scholar","rank":"登堂入室","one_line":"善于思考的江湖人","personality":{"traits":["冷静","善于分析","沉稳","细心","有洞察力"],"speech_style":"认真","temperament":"冷静"},"relationships