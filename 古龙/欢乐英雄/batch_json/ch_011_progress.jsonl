{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你这倒好像是经验之谈。","tone":"陈述","chapter":11,"line_start":108,"line_end":108},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你莫忘了，我虽然没有杀过人，至少被人杀过。","tone":"陈述","chapter":11,"line_start":110,"line_end":110},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"既然不怕，就索性打开棺材，让他出来吧。","tone":"陈述","chapter":11,"line_start":142,"line_end":142},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我当然不怕，只不过……只不过……","tone":"陈述","chapter":11,"line_start":150,"line_end":150},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你不能去，还是让我来。","tone":"陈述","chapter":11,"line_start":158,"line_end":158},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"谁说我不怕的？","tone":"陈述","chapter":11,"line_start":168,"line_end":168},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"他绝不是白痴，也绝不是在开玩笑。","tone":"轻笑","chapter":11,"line_start":182,"line_end":182},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"不是开玩笑，是什么？","tone":"轻笑","chapter":11,"line_start":184,"line_end":184},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你认为他一定还要做些别的事？","tone":"陈述","chapter":11,"line_start":196,"line_end":196}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_nan_gong_chou_zhi_guan","name":"南宫丑之棺","type":"special","owner":null,"one_line":"装有黑狗的崭新棺材，棺头刻字","description":"一口崭新的棺材，棺头上刻着\"南宫丑之枢\"，里面装的却是一条活生生的黑狗，是神秘人用来试探和警告的道具。","effects":["心理震慑"],"origin":"神秘人放置","rarity":"寻常凡品","related_characters":["char_nan_gong_chou"],"related_skills":[],"rag_refs":[11],"source_refs":[{"chapter":11,"line_start":80,"line_end":84,"text":"他看着的赫然是口棺材。崭新的棺材。棺头上仿佛刻着一行字"}]}]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你的眼睛只有在看到女人时，才会有毛病。","tone":"陈述","chapter":11,"line_start":257,"line_end":257},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"是公的。","tone":"陈述","chapter":11,"line_start":261,"line_end":261},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你怎么知道？","tone":"陈述","chapter":11,"line_start":263,"line_end":263},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"因为他看来并不喜欢你。","tone":"陈述","chapter":11,"line_start":265,"line_end":265},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"母猫都喜欢懒猫。","tone":"陈述","chapter":11,"line_start":273,"line_end":273},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"因为它会做饭。","tone":"陈述","chapter":11,"line_start":279,"line_end":279},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"包子也是热的。","tone":"陈述","chapter":11,"line_start":285,"line_end":285},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"看来这些东西送来还不久。","tone":"陈述","chapter":11,"line_start":287,"line_end":287},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"答对了。","tone":"陈述","chapter":11,"line_start":289,"line_end":289},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"又答对了。","tone":"陈述","chapter":11,"line_start":295,"line_end":295},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"他为什么要这样拍我们的马屁，难道真是我干儿子？","tone":"陈述","chapter":11,"line_start":297,"line_end":297},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"咪咪……咪咪……","tone":"陈述","chapter":11,"line_start":299,"line_end":299}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_black_cat","name":"黑猫","type":"special","owner":"char_he_ya_feng","one_line":"被绳子吊铃铛的黑猫，用来叫人吃早饭","description":"一只黑猫，脚上绑着绳子连接花架下的铃铛，不停跳动使铃铛响动，用来叫醒众人吃早饭。是神秘人安排的巧妙机关。","effects":["叫醒服务"],"origin":"神秘人安排","rarity":"寻常凡品","related_characters":["char_he_ya_feng"],"related_skills":[],"rag_refs":[11],"source_refs":[{"chapter":11,"line_start":243,"line_end":249,"text":"他只不过站在那里发怔，摇铃的是条猫。黑猫。一个铃铛用绳子吊在花架下"}]},{"id":"item_feng_sheng_zao_can","name":"丰盛早餐","type":"special","owner":"char_he_ya_feng","one_line":"神秘人送来的丰盛早餐","description":"一大桌热腾腾的早餐，包括鸡鸭包子馒头和一大坛酒，由黑猫摇铃通知众人来享用，是神秘人暗中照料的又一证据。","effects":["提供饮食"],"origin":"神秘人赠送","rarity":"寻常凡品","related_characters":["char_he_ya_feng"],"related_skills":[],"rag_refs":[11],"source_refs":[{"chapter":11,"line_start":251,"line_end":251,"text":"花厅中的桌子上摆着一大桌的东西，都是吃的东西"}]}]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你几乎变成一条猫了，我可听不懂猫说的话。","tone":"陈述","chapter":11,"line_start":301,"line_end":301},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你怎么知道？","tone":"陈述","chapter":11,"line_start":331,"line_end":331},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"只有女人才会做这疯疯癫癫的事。","tone":"陈述","chapter":11,"line_start":333,"line_end":333},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"都不是。","tone":"陈述","chapter":11,"line_start":341,"line_end":341},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"是因为什么呢？","tone":"陈述","chapter":11,"line_start":343,"line_end":343},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"不是一个，是三个。","tone":"陈述","chapter":11,"line_start":379,"line_end":379},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你怎么知道？","tone":"陈述","chapter":11,"line_start":381,"line_end":381}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"这里的主人好客，却有点病。","tone":"陈述","chapter":11,"line_start":429,"line_end":429},{"speaker":"char_diao_shi","speaker_name":"钓诗","listener":null,"text":"你酒量若真的好，为什么不敢跟我们公子喝酒去？","tone":"陈述","chapter":11,"line_start":479,"line_end":479}],"new_entities":{"characters":[{"id":"char_he_ya_feng","name":"何雅风","alias":["何公子"],"identity":"神秘书生","faction":"无","role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"来路不明的文雅书生，暗中关注主角团","personality":{"traits":["文雅","神秘","大方","风趣","谨慎","豪爽"],"speech_style":"文绉绉，好引经据典","temperament":"温和从容"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[11],"source_refs":[{"chapter":11,"line_start":415,"line_end":416,"text":"他们的主人是个文质彬彬的书生，年纪并不太大，长得非常英俊"}]},{"id":"char_diao_shi","name":"钓诗","alias":[],"identity":"何雅风书童","faction":"无","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"何雅风的书童，口齿伶俐，爱喝酒","personality":{"traits":["伶俐","健谈","活泼","直率","爱喝酒","有学问"],"speech_style":"话多，爱炫耀知识","temperament":"天真活泼"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[11],"source_refs":[{"chapter":11,"line_start":445,"line_end":455,"text":"这孩子大眼睛眨眨，道：\"不太重，只不过是些酒瓶子\""}]},{"id":"char_sao_su","name":"扫俗","alias":[],"identity":"何雅风书童","faction":"无","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"何雅风的另一书童，性格较安静","personality":{"traits":["安静","勤快","忠诚","沉默","细心"],"speech_style":"话少","temperament":"沉稳内敛"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[11],"source_refs":[{"chapter":11,"line_start":451,"line_end":452,"text":"我叫钓诗，他叫扫俗"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_he_ya_feng","updates":{},"relationship_updates":[{"action":"add","target":"char_guo_da_lu","type":"合作者","intensity":50,"bond_level":2,"dynamic":"暗中关注"},{"action":"add","target":"char_wang_dong","type":"合作者","intensity":50,"bond_level":2,"dynamic":"暗中关注"}]}]}
{"segment":6,"line_start":501,"line_end":600,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"看来他倒是个很风雅的人，而且据说还很能喝酒。","tone":"陈述","chapter":11,"line_start":503,"line_end":503},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你想他会不会就是那……","tone":"陈述","chapter":11,"line_start":505,"line_end":505},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"嗯，我本来没有想到这点，现在越想越有可能。","tone":"陈述","chapter":11,"line_start":511,"line_end":511},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"世上凑巧的事本来很多，但这件事的确太巧些了。","tone":"陈述","chapter":11,"line_start":517,"line_end":517},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你以前有没有见过他？","tone":"陈述","chapter":11,"line_start":519,"line_end":519},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"没有。","tone":"陈述","chapter":11,"line_start":521,"line_end":521},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你再想想。","tone":"陈述","chapter":11,"line_start":523,"line_end":523},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"用不着再想，这样的人我若见过，一定不会忘记。","tone":"陈述","chapter":11,"line_start":525,"line_end":525},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"他叫什么名字？","tone":"陈述","chapter":11,"line_start":531,"line_end":531},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"他为什么要用假名字？难道你认为他对我们有恶意？","tone":"陈述","chapter":11,"line_start":535,"line_end":535},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"到目前为止，倒看不出有什么恶意。","tone":"陈述","chapter":11,"line_start":537,"line_end":537},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你笑什么？","tone":"轻笑","chapter":11,"line_start":549,"line_end":549},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"为什么？","tone":"陈述","chapter":11,"line_start":557,"line_end":557},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你并没有醉。","tone":"陈述","chapter":11,"line_start":567,"line_end":567},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"快醉了——我现在就打算进去把他灌醉。","tone":"陈述","chapter":11,"line_start":569,"line_end":569},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你笑什么？","tone":"轻笑","chapter":11,"line_start":575,"line_end":575},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"我在想，你这人至少还有样别人比不上的长处。","tone":"陈述","chapter":11,"line_start":577,"line_end":577},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我的长处至少有三百多种，却不知你说的是哪一种？","tone":"陈述","chapter":11,"line_start":579,"line_end":579},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你随时随地都能把握住机会。","tone":"陈述","chapter":11,"line_start":581,"line_end":581},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"什么机会？","tone":"陈述","chapter":11,"line_start":583,"line_end":583},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"喝酒的机会！","tone":"陈述","chapter":11,"line_start":585,"line_end":585}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":601,"line_end":721,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我醉？你看，我有没有一点喝醉的样子？","tone":"陈述","chapter":11,"line_start":615,"line_end":615},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"没有一点，有八九点。","tone":"陈述","chapter":11,"line_start":617,"line_end":617},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你错了，我现在清醒得简直就像孔夫子一样。","tone":"陈述","chapter":11,"line_start":619,"line_end":619},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你笑得却像是土狗。","tone":"轻笑","chapter":11,"line_start":621,"line_end":621},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我只不过笑他，还没开始，他已经被我灌醉了。","tone":"轻笑","chapter":11,"line_start":623,"line_end":623},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你记不记得为什么要灌他酒？","tone":"陈述","chapter":11,"line_start":625,"line_end":625},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"当然记得，我本来是想要叫他说实话的。","tone":"陈述","chapter":11,"line_start":627,"line_end":627},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"他说了吗？","tone":"陈述","chapter":11,"line_start":629,"line_end":629},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"说了。","tone":"陈述","chapter":11,"line_start":631,"line_end":631},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"说了？说了什么？","tone":"陈述","chapter":11,"line_start":633,"line_end":633},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"你看我干什么？","tone":"陈述","chapter":11,"line_start":645,"line_end":645},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"你要我说什么？","tone":"陈述","chapter":11,"line_start":651,"line_end":651},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"说我清醒的时候也醉，醉的时候反而清醒。","tone":"陈述","chapter":11,"line_start":653,"line_end":653},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我答对了么？","tone":"陈述","chapter":11,"line_start":657,"line_end":657},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"我只想他这一觉能睡到明天天亮。","tone":"陈述","chapter":11,"line_start":671,"line_end":671},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"为什么？","tone":"陈述","chapter":11,"line_start":673,"line_end":673},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"为什么要当东西？","tone":"陈述","chapter":11,"line_start":677,"line_end":677},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"请客人吃晚饭。","tone":"陈述","chapter":11,"line_start":679,"line_end":679},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你认为晚饭还会有人送来？","tone":"陈述","chapter":11,"line_start":683,"line_end":683},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"嗯。","tone":"陈述","chapter":11,"line_start":685,"line_end":685}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
