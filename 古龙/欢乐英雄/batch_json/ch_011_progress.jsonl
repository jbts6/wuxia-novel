{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"仙子说不定是来找我的，我也是个孝子。","tone":"陈述","chapter":11,"line_start":32,"line_end":32},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你是个傻子。","tone":"陈述","chapter":11,"line_start":34,"line_end":34},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你知不知道这些东西是谁送来的？","tone":"陈述","chapter":11,"line_start":50,"line_end":50},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"不知道。我只知道累了就要睡觉。","tone":"陈述","chapter":11,"line_start":52,"line_end":52},{"speaker":"char_lin_tai_ping","speaker_name":"林太平","listener":null,"text":"就……就在外面。","tone":"陈述","chapter":11,"line_start":90,"line_end":90},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"什么地方外面？","tone":"陈述","chapter":11,"line_start":92,"line_end":92},{"speaker":"char_lin_tai_ping","speaker_name":"林太平","listener":null,"text":"他住的屋子外面。","tone":"陈述","chapter":11,"line_start":94,"line_end":94},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你杀丁他后，有没有把他的尸体埋起来？","tone":"陈述","chapter":11,"line_start":96,"line_end":96}],"new_entities":{"characters":[{"id":"char_guo_da_lu","name":"郭大路","alias":[],"identity":"江湖游侠","faction":"无","role":"protagonist","archetype":"warrior","rank":"登堂入室","one_line":"豪爽直率的江湖游侠，嗜酒如命，重情重义","personality":{"traits":["豪爽","重义","嗜酒","幽默","胆大","乐观"],"speech_style":"直来直去，爱开玩笑","temperament":"开朗豪迈"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[11],"source_refs":[{"chapter":11,"line_start":18,"line_end":20,"text":"郭大路站在门口，看得眼珠子都快掉了下来"}]},{"id":"char_yan_qi","name":"燕七","alias":[],"identity":"江湖人士","faction":"无","role":"protagonist","archetype":"warrior","rank":"登堂入室","one_line":"细心谨慎的江湖人，外表邋遢内心精明","personality":{"traits":["细心","谨慎","毒舌","机敏","外冷内热","爱整洁"],"speech_style":"犀利直接，常带嘲讽","temperament":"沉稳冷静"},"relationships":[],"known_skills":[],"related_skills":[],"ra