    },
    {
      "speaker": "char_cui_ming_fu",
      "speaker_name": "催命符",
      "listener": "char_chi_lian_she",
      "text": "每个地方都看过了。",
      "tone": "陈述",
      "chapter": 25,
      "line_start": 194,
      "line_end": 194
    },
    {
      "speaker": "char_hong_niang_zi",
      "speaker_name": "红娘子",
      "listener": "char_wang_dong",
      "text": "连厕所里都看过了，奇怪的是，那里居然不太臭。",
