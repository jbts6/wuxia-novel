    },
    {
      "speaker": "char_hong_niang_zi",
      "speaker_name": "红娘子",
      "listener": "char_wang_dong",
      "text": "我还知道那人一定不是你。",
      "tone": "微笑",
      "chapter": 25,
      "line_start": 206,
