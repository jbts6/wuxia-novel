      "chapter": 25,
      "line_start": 216,
      "line_end": 216
    },
    {
      "speaker": "char_chi_lian_she",
      "speaker_name": "赤练蛇",
      "listener": "char_cui_ming_fu",
      "text": "这屋子里已没有别的人？",
      "tone": "疑问",
      "chapter": 25,
      "line_start": 220,
      "line_end": 222
    },
    {
      "speaker": "char_cui_ming_fu",
      "speaker_name": "催命符",
      "listener": "char_chi_lian_she",
      "text": "只有这两个稻草人。",
      "tone": "陈述",
      "chapter": 25,
      "line_start": 224,
