{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"好，有种。","tone":"冷笑","chapter":6,"line_start":24,"line_end":24},{"speaker":null,"speaker_name":null,"listener":null,"text":"你不是凤栖梧？","tone":"陈述","chapter":6,"line_start":36,"line_end":36},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"我谁都不是，只不过是这城里一个卖杂货的小商人。","tone":"陈述","chapter":6,"line_start":46,"line_end":46},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"放了我？你会放了我？","tone":"陈述","chapter":6,"line_start":60,"line_end":60},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"我姓韩，叫一阵风。","tone":"陈述","chapter":6,"line_start":66,"line_end":66},{"speaker":"char_yi_zhen_feng","speaker_name":"一阵风","listener":null,"text":"你说过，只要我不是凤栖梧别的事你都不管。","tone":"陈述","chapter":6,"line_start":72,"line_end":72},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"我当然不管。但我又怎知你就是一阵风，不是凤栖梧？","tone":"陈述","chapter":6,"line_start":74,"line_end":74},{"speaker":"char_yi_zhen_feng","speaker_name":"一阵风","listener":null,"text":"我身上刺着花……","tone":"陈述","chapter":6,"line_start":76,"line_end":76},{"speaker":"char_yi_zhen_feng","speaker_name":"一阵风","listener":null,"text":"哧","tone":"陈述","chapter":6,"line_start":78,"line_end":78},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"听说，黄员外是被人一剑刺死的。","tone":"陈述","chapter":6,"line_start":86,"line_end":86},{"speaker":"char_yi_zhen_feng","speaker_name":"一阵风","listener":null,"text":"不是，我从来不使剑。","tone":"陈述","chapter":6,"line_start":88,"line_end":88},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"他是怎么死的呢？","tone":"陈述","chapter":6,"line_start":90,"line_end":90},{"speaker":"char_yi_zhen_feng","speaker_name":"一阵风","listener":null,"text":"我用药先毒死了他，再将他抛到井里去。","tone":"陈述","chapter":6,"line_start":92,"line_end":92},{"speaker":"char_yi_zhen_feng","speaker_name":"一阵风","listener":null,"text":"这么说来，你的确是一阵风了。","tone":"陈述","chapter":6,"line_start":94,"line_end":94},{"speaker":"char_yi_zhen_feng","speaker_name":"一阵风","listener":null,"text":"我本来就是。","tone":"陈述","chapter":6,"line_start":96,"line_end":96},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"好，很好……","tone":"陈述","chapter":6,"line_start":98,"line_end":98}],"new_entities":{"characters":[{"id":"char_han_yi_zhen_feng","name":"韩一阵风","alias":["一阵风"],"identity":"逃犯/杀人犯","faction":null,"role":"npc","archetype":"assassin","rank":null,"one_line":"在张家口杀害黄员外一家的逃犯，被棍子追捕","personality":{"traits":["凶残","狡猾","狠毒","多疑","自保心强"],"speech_style":"简短直接","temperament":"阴险"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[6],"source_refs":[{"chapter":6,"line_start":66,"line_end":66,"text":"我姓韩，叫一阵风"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"原来他杀人的时候，你也只不过在旁边瞧着的。","tone":"陈述","chapter":6,"line_start":120,"line_end":120},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"但我还是要看下去。","tone":"无奈","chapter":6,"line_start":124,"line_end":124},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你喜欢看他杀人？","tone":"陈述","chapter":6,"line_start":126,"line_end":126},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我要等着看他杀错一个人。","tone":"陈述","chapter":6,"line_start":128,"line_end":128},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"为什么？","tone":"陈述","chapter":6,"line_start":130,"line_end":130},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"那时我才有理由杀他。","tone":"陈述","chapter":6,"line_start":132,"line_end":132},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你想杀他？","tone":"陈述","chapter":6,"line_start":134,"line_end":134},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"一阵风虽该死，但他却更该死。","tone":"陈述","chapter":6,"line_start":136,"line_end":136},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你认为他做错了事？","tone":"陈述","chapter":6,"line_start":138,"line_end":138},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"他若永远不杀错人呢？","tone":"陈述","chapter":6,"line_start":144,"line_end":144},{"speaker":null,"speaker_name":null,"listener":null,"text":"你以为他这种人就没有人能对付得了？","tone":"陈述","chapter":6,"line_start":154,"line_end":154},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"谁能对付他？你？","tone":"陈述","chapter":6,"line_start":156,"line_end":156},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"你。","tone":"陈述","chapter":6,"line_start":174,"line_end":174},{"speaker":"char_jin_mao_shi","speaker_name":"金毛狮","listener":null,"text":"下一家是谁？","tone":"陈述","chapter":6,"line_start":182,"line_end":182},{"speaker":"char_jin_mao_shi","speaker_name":"金毛狮","listener":null,"text":"利源当铺","tone":"陈述","chapter":6,"line_start":186,"line_end":186},{"speaker":null,"speaker_name":null,"listener":null,"text":"不能动。","tone":"陈述","chapter":6,"line_start":192,"line_end":192},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我又不是王动，为什么不能动？","tone":"陈述","chapter":6,"line_start":194,"line_end":194},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"现在若动，一动就有麻烦。","tone":"陈述","chapter":6,"line_start":196,"line_end":196},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你几时怕过麻烦了？","tone":"陈述","chapter":6,"line_start":198,"line_end":198},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"就是现在，而且怕的就是这种麻烦。","tone":"陈述","chapter":6,"line_start":200,"line_end":200}],"new_entities":{"characters":[{"id":"char_jin_mao_shi","name":"金毛狮","alias":[],"identity":"六扇门捕快","faction":"六扇门","role":"npc","archetype":"warrior","rank":null,"one_line":"六扇门捕快，与棍子搭档办案，较为圆滑","personality":{"traits":["圆滑","老练","善于周旋","表面和善","精明"],"speech_style":"客气有礼","temperament":"平和"},"relationships":[{"target":"char_gun_zi","type":"合作者","intensity":50,"bond_level":3,"dynamic":"搭档"}],"known_skills":[],"related_skills":[],"rag_refs":[6],"source_refs":[{"chapter":6,"line_start":170,"line_end":170,"text":"金毛狮正拍着棍子的肩"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_li_yuan_dang_pu","name":"利源当铺","region":"城内","one_line":"城中当铺，老板虽精明却常分利给人","source_refs":[{"chapter":6,"line_start":186,"line_end":186,"text":"黑底的招牌，金字：\"利源当铺\""}]}],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"没有娘舅无妨，没有祖宗才麻烦。","tone":"陈述","chapter":6,"line_start":206,"line_end":206},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"没有祖宗？","tone":"陈述","chapter":6,"line_start":208,"line_end":208},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你用不着去，我去！","tone":"陈述","chapter":6,"line_start":214,"line_end":214},{"speaker":null,"speaker_name":null,"listener":null,"text":"二位要走了么，不送不送。","tone":"陈述","chapter":6,"line_start":246,"line_end":246},{"speaker":"char_bo_pi_lao_ban","speaker_name":"剥皮老板","listener":null,"text":"不用客气，请留步。","tone":"陈述","chapter":6,"line_start":248,"line_end":248},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"这剥皮老板又是谁？凭什么能令他们如此客气？","tone":"陈述","chapter":6,"line_start":258,"line_end":258},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"也许就因为他谁都不是，所以人家才对他客气？","tone":"陈述","chapter":6,"line_start":260,"line_end":260},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我当然不但心，但却不是为了你这原因。","tone":"陈述","chapter":6,"line_start":274,"line_end":274},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你为的是什么？","tone":"陈述","chapter":6,"line_start":276,"line_end":276},{"speaker":"char_wang_dong","speaker_name":"王动","listener":null,"text":"吃屁。","tone":"陈述","chapter":6,"line_start":282,"line_end":282},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"这锭金子是哪里来的？说！","tone":"疑问","chapter":6,"line_start":288,"line_end":288},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"金子","tone":"陈述","chapter":6,"line_start":290,"line_end":290},{"speaker":"char_gun_zi","speaker_name":"棍子","listener":null,"text":"你说不说？金子是哪里来的？","tone":"厉声","chapter":6,"line_start":300,"line_end":300}],"new_entities":{"characters":[{"id":"char_jin_mao_shi","name":"金毛狮","alias":[],"identity":"六扇门捕快"