{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"在点头的时候？","tone":"陈述","chapter":38,"line_start":302,"line_end":302},{"speaker":null,"speaker_name":"才缓缓地","listener":null,"text":"你一直没有睡？","tone":"陈述","chapter":38,"line_start":310,"line_end":310},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我若睡了，你还能睡么？","tone":"陈述","chapter":38,"line_start":312,"line_end":312},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你为什么让我站在你背后？","tone":"陈述","chapter":38,"line_start":320,"line_end":320},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":null,"text":"因为我不愿被你诱惑。","tone":"陈述","chapter":38,"line_start":322,"line_end":322},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"诱惑？","tone":"陈述","chapter":38,"line_start":324,"line_end":324},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":null,"text":"我若站在你背后，看到你再点头时，手会痒的。","tone":"陈述","chapter":38,"line_start":326,"line_end":326},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"你手痒的时候就要杀人？","tone":"陈述","chapter":38,"line_start":328,"line_end":328},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":null,"text":"只有一次是例外。","tone":"陈述","chapter":38,"line_start":330,"line_end":330},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"哪一次？","tone":"陈述","chapter":38,"line_start":332,"line_end":332},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":null,"text":"刚才那一次。","tone":"陈述","chapter":38,"line_start":334,"line_end":334},{"speaker":null,"speaker_name":"忽然","listener":null,"text":"等一等。","tone":"陈述","chapter":38,"line_start":338,"line_end":338},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":null,"text":"你还有什么话要说？该说的似已全都说完了。","tone":"陈述","chapter":38,"line_start":340,"line_end":340},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我只有一句话要问你。","tone":"疑问","chapter":3