{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"难道她每次都能得手？","tone":"陈述","chapter":38,"line_start":206,"line_end":206},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"难道就没有人管管她？","tone":"陈述","chapter":38,"line_start":212,"line_end":212},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"答对了。","tone":"陈述","chapter":38,"line_start":230,"line_end":230},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"答对了。","tone":"陈述","chapter":38,"line_start":236,"line_end":236},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"但南宫丑若不是真的很该死，她也不会来找他的？","tone":"陈述","chapter":38,"line_start":238,"line_end":238},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"不错，她以前从来也没有找错过人。","tone":"陈述","chapter":38,"line_start":240,"line_end":240},{"speaker":null,"speaker_name":"苦笑","listener":null,"text":"所以错的并不是她，是我。","tone":"轻笑","chapter":38,"line_start":242,"line_end":242},{"speaker":null,"speaker_name":"苦","listener":null,"text":"所以错的并不是她，是我。","tone":"轻笑","chapter":38,"line_start":242,"line_end":242},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"你也没有错。","tone":"陈述","chapter":38,"line_start":244,"line_end":244},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"只有一个会。","tone":"陈述","chapter":38,"line_start":250,"line_end":250},{"speaker":"char_yan_qi","speaker_name":"燕七","listener":null,"text":"谁？","tone":"陈述","chapter":38,"line_start":252,"line_end":252},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"我自己。","tone":"陈述","chapter":38,"line_start":254,"line_end":254},{"speaker":"char_guo_da_lu","speaker_name":"郭大路","listener":null,"text":"为什么？","tone":"陈述","chapter":38,"line_start":272,"line_end":272},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":null,"text":"因为从来没有像你这样的人，替我在门外看守过。","tone":"陈述","chapter":38,"line_start":274,"line_en