{"segment":1,"line_start":1,"line_end":101,"dialogues":[{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_a_fei","text":"原来是阿飞兄，久违久违。","tone":"微笑","chapter":57,"line_start":32,"line_end":32},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_a_fei","text":"兄台竟真的能追踪到这里，佩服佩服。","tone":"陈述","chapter":57,"line_start":36,"line_end":36},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_a_fei","text":"兄台追踪的手段虽高，只可惜却也被这位荆先生发觉了。","tone":"微笑","chapter":57,"line_start":42,"line_end":44},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_a_fei","text":"荆先生虽已发觉了你，却一直没有说出来，你可道是为了什么？","tone":"陈述","chapter":57,"line_start":56,"line_end":58},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_a_fei","text":"因为荆先生本就希望你来。","tone":"淡然","chapter":57,"line_start":62,"line_end":62},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"荆先生，在下猜得不错吧。","tone":"微笑","chapter":57,"line_start":64,"line_end":64},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_a_fei","text":"荆先生希望你来，只有一个原因，因为他要杀你！","tone":"大笑","chapter":57,"line_start":68,"line_end":70},{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_a_fei","text":"荆先生要杀的人，至今还没有一个人能活着的！","tone":"陈述","chapter":57,"line_start":72,"line_end":74}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":102,"line_end":201,"dialogues":[{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你已看出我的剑是击暗器，而非刺你？","tone":"陈述","chapter":57,"line_start":168,"line_end":170},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"是。","tone":"陈述","chapter":57,"line_start":172,"line_end":172},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你还是很镇定！","tone":"陈述","chapter":57,"line_start":174,"line_end":174},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"但你反应已慢了……","tone":"陈述","chapter":57,"line_start":178,"line_end":178},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"是！","tone":"悲伤","chapter":57,"line_start":180,"line_end":180},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"我能杀你！","tone":"陈述","chapter":57,"line_start":182,"line_end":182},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"是！","tone":"冷酷","chapter":57,"line_start":184,"line_end":184},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"但我不杀你！","tone":"陈述","chapter":57,"line_start":188,"line_end":188},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"你不杀我？","tone":"疑问","chapter":57,"line_start":192,"line_end":194},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"我不杀你，只因你是阿飞！","tone":"陈述","chapter":57,"line_start":196,"line_end":196}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":202,"line_end":301,"dialogues":[{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"我若是你，今日你就能杀我。","tone":"陈述","chapter":57,"line_start":204,"line_end":204},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你可以走了。","tone":"陈述","chapter":57,"line_start":220,"line_end":220},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"我不走。","tone":"冷酷","chapter":57,"line_start":222,"line_end":222},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你不走？要我杀你？","tone":"陈述","chapter":57,"line_start":224,"line_end":224},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"是！","tone":"陈述","chapter":57,"line_start":226,"line_end":226},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你为的是李寻欢？","tone":"淡然","chapter":57,"line_start":228,"line_end":228},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"是，只要我活着，就不能让他死在你手里。","tone":"陈述","chapter":57,"line_start":230,"line_end":230},{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_a_fei","text":"林仙儿呢？你难道忍心让她为你痛苦？","tone":"疑问","chapter":57,"line_start":232,"line_end":232},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"我喜欢杀人，我喜欢自己杀，你明白么？","tone":"沉声","chapter":57,"line_start":236,"line_end":238},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"我明白。","tone":"苦笑","chapter":57,"line_start":240,"line_end":240},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"你最好明白，否则我就杀你。","tone":"陈述","chapter":57,"line_start":242,"line_end":242},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"李寻欢在哪里？带我去！","tone":"陈述","chapter":57,"line_start":244,"line_end":244},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"可是他……","tone":"陈述","chapter":57,"line_start":246,"line_end":246},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"我随时都可杀他！","tone":"淡然","chapter":57,"line_start":248,"line_end":248},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"这就是李寻欢？","tone":"陈述","chapter":57,"line_start":286,"line_end":286},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"是！","tone":"陈述","chapter":57,"line_start":288,"line_end":288},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"这就是小李探花？","tone":"疑问","chapter":57,"line_start":290,"line_end":292},{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_jing_wu_ming","text":"就算是雄狮猛虎，被饿了十几天，也会变成这样子的。","tone":"微笑","chapter":57,"line_start":294,"line_end":296},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"我本不愿这样对他，可是……人无伤虎心，虎有伤人意，经过上次的教训，我不愿再有任何意外。","tone":"无奈","chapter":57,"line_start":298,"line_end":300}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":302,"line_end":401,"dialogues":[{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"他的刀呢？","tone":"陈述","chapter":57,"line_start":302,"line_end":302},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"荆先生是不是想看看他的刀？","tone":"陈述","chapter":57,"line_start":304,"line_end":304},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"其实，这不过是柄很普通的刀，并不能算是利器。","tone":"微笑","chapter":57,"line_start":314,"line_end":314},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"利器？……凭你这种人也配谈论利器？","tone":"陈述","chapter":57,"line_start":316,"line_end":316},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"你可知道什么是利器？","tone":"淡然","chapter":57,"line_start":318,"line_end":318},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"请指教。","tone":"苦笑","chapter":57,"line_start":322,"line_end":322},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"能杀人的，就是利器，否则，纵是干将莫邪，到了你这种人手上，也就算不得利器了。","tone":"淡然","chapter":57,"line_start":324,"line_end":326},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"是是是，荆先生见解的确精辟，令人……","tone":"苦笑","chapter":57,"line_start":328,"line_end":328},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"你可知道至今已有多少人死在这种刀下？","tone":"陈述","chapter":57,"line_start":330,"line_end":332},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"这……只怕已数不清了。","tone":"陈述","chapter":57,"line_start":334,"line_end":334},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"数得清。","tone":"陈述","chapter":57,"line_start":336,"line_end":336},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"真的数得清？有多少人？","tone":"疑问","chapter":57,"line_start":350,"line_end":350},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"七十六。","tone":"陈述","chapter":57,"line_start":352,"line_end":352},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"这七十六人中，没有一人的武功比你差。","tone":"淡然","chapter":57,"line_start":354,"line_end":354},{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_jing_wu_ming","text":"李寻欢自己若也死在这种刀下，那才真的大快人心。","tone":"微笑","chapter":57,"line_start":360,"line_end":362},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"解开他的穴道！","tone":"陈述","chapter":57,"line_start":372,"line_end":372},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"可是……","tone":"陈述","chapter":57,"line_start":374,"line_end":374},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"我说解开他的穴道！","tone":"厉声","chapter":57,"line_start":376,"line_end":376},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"上官帮主要的只是李寻欢，并不在乎他是死的，还是活的。","tone":"陈述","chapter":57,"line_start":380,"line_end":382},{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_jing_wu_ming","text":"上官老伯自己滴酒不沾，自然也很讨厌酒鬼，真正的酒鬼只有死才能不喝酒，才会令人看得顺眼些。","tone":"陈述","chapter":57,"line_start":384,"line_end":386},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"何况，带个死人回去，总比带活人方便得多，也绝不会再有任何意外。","tone":"陈述","chapter":57,"line_start":388,"line_end":390},{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_jing_wu_ming","text":"但荆先生自然不会向一个全无反抗之力的人出手，所以……","tone":"陈述","chapter":57,"line_start":392,"line_end":392},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_long_xiao_yun_father","text":"你们的话太多了。","tone":"厉声","chapter":57,"line_start":394,"line_end":394},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_jing_wu_ming","text":"是是是，在下这就去解开他的穴道。","tone":"微笑","chapter":57,"line_start":396,"line_end":396},{"speaker":"char_long_xiao_yun_father","speaker_name":"龙啸云","listener":"char_li_xun_huan","text":"兄弟，看来荆先生是想和你一较高下，荆先生剑法高绝天下，兄弟你出手可千万不能大意。","tone":"柔声","chapter":57,"line_start":400,"line_end":401}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":402,"line_end":501,"dialogues":[{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_li_xun_huan","text":"小李飞刀，例不虚发，这一次不知道还灵不灵？","tone":"嘲讽","chapter":57,"line_start":426,"line_end":428},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_li_xun_huan","text":"我要杀人，一定先给人一个机会，这就是你最后的机会，你明白么？","tone":"冷酷","chapter":57,"line_start":432,"line_end":434},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_li_xun_huan","text":"好，你站起来吧！","tone":"陈述","chapter":57,"line_start":438,"line_end":438},{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_li_xun_huan","text":"李大叔若已站不起，小侄可以扶你一把。","tone":"柔声","chapter":57,"line_start":442,"line_end":442},{"speaker":"char_long_xiao_yun_son","speaker_name":"龙小云","listener":"char_li_xun_huan","text":"但我看这根本是用不着的，据说李大叔的飞刀不但能坐着发，就连躺着时发出来也同样准。","tone":"嘲讽","chapter":57,"line_start":444,"line_end":446},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你还不死心？","tone":"陈述","chapter":57,"line_start":460,"line_end":460},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"要杀他，就得先杀我！","tone":"严肃","chapter":57,"line_start":464,"line_end":466},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你已不再关心她？","tone":"陈述","chapter":57,"line_start":472,"line_end":474},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"我死了，她还是能活下去。","tone":"陈述","chapter":57,"line_start":476,"line_end":476},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你不怕她伤心？","tone":"淡然","chapter":57,"line_start":482,"line_end":484},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"活着不安，就不如死，我若不死，她更伤心。","tone":"陈述","chapter":57,"line_start":486,"line_end":486},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"你认为她是这种人？","tone":"陈述","chapter":57,"line_start":488,"line_end":488},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"当然！","tone":"陈述","chapter":57,"line_start":490,"line_end":490}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":502,"line_end":524,"dialogues":[{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"你不必笑，你虽有八成机会杀我，但也有两成死在我剑下。","tone":"淡然","chapter":57,"line_start":504,"line_end":506},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"我说过不杀你，就一定会留下你的命！","tone":"陈述","chapter":57,"line_start":508,"line_end":510},{"speaker":"char_a_fei","speaker_name":"阿飞","listener":"char_jing_wu_ming","text":"不必。","tone":"陈述","chapter":57,"line_start":512,"line_end":512},{"speaker":"char_jing_wu_ming","speaker_name":"荆无命","listener":"char_a_fei","text":"我要你活着，看着……","tone":"陈述","chapter":57,"line_start":514,"line_end":514}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
