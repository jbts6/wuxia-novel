    {
      "speaker": "char_shao_nian",
      "speaker_name": "少年",
      "listener": "char_bai_she",
      "text": "千金太多了，我只要五十两。",
      "tone": "陈述",
      "chapter": 1,
      "line_start": 368,
      "line_end": 368
    },
    {
      "speaker": "char_bai_she",
      "speaker_name": "白蛇",
      "listener": "char_shao_nian",
      "text": "好，只要你能照这样做一遍，我就给五十两。",
