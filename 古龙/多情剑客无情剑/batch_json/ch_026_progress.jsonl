{"segment":3,"line_start":198,"line_end":229,"dialogues":[{"speaker":"char_sun_tuo_zi","speaker_name":"孙驼子","listener":null,"text":"原来有时候赚钱也容易得很……","tone":"喃喃","chapter":26,"line_start":199,"line_end":199},{"speaker":"char_sun_tuo_zi","speaker_name":"孙驼子","listener":"char_li_xun_huan","text":"你今天倒早。","tone":"轻笑","chapter":26,"line_start":203,"line_end":203},{"speaker":"char_li_xun_huan","speaker_name":"酒鬼","listener":"char_sun_tuo_zi","text":"昨天晚上我喝得快，今天一早就断粮了。","tone":"轻笑","chapter":26,"line_start":205,"line_end":207},{"speaker":"char_li_xun_huan","speaker_name":"酒鬼","listener":"char_sun_tuo_zi","text":"今天是什么日子了？","tone":"疑问","chapter":26,"line_start":209,"line_end":209},{"speaker":"char_sun_tuo_zi","speaker_name":"孙驼子","listener":"char_li_xun_huan","text":"九月十四。","tone":"陈述","chapter":26,"line_start":211,"line_end":211},{"speaker":"char_li_xun_huan","speaker_name":"酒鬼","listener":"char_sun_tuo_zi","text":"明天就是九月十五了么？","tone":"沉声","chapter":26,"line_start":213,"line_end":215},{"speaker":"char_sun_tuo_zi","speaker_name":"孙驼子","listener":"char_li_xun_huan","text":"过了十四，自然是十五。","tone":"轻笑","chapter":26,"line_start":217,"line_end":219},{"speaker":"char_sun_tuo_zi","speaker_name":"孙驼子","listener":"char_li_xun_huan","text":"若是人人都像你这么样喝酒，卖酒的也早就都发财了。","tone":"无奈","chapter":26,"line_start":223,"line_end":225}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
