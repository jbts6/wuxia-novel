    "one_line": "龙啸云一脉家族",
    "description": "与林家婚姻、李寻欢旧怨紧密相关的家族势力，龙啸云为其代表人物。",
    "leader": "char_long_xiao_yun",
    "members": [
      "char_long_xiao_yun"
    ],
    "headquarters": null,
    "power_rank": "炉火纯青",
