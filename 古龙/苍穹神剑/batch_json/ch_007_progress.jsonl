{"segment":20,"line_start":759,"line_end":806,"dialogues":[{"speaker":"char_bian_hao","speaker_name":"边浩","listener":null,"text":"阁下何人？为何发笑？","tone":"轻笑","chapter":7,"line_start":774,"line_end":774},{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"我笑你的剑今日只怕真要过瘾了。","tone":"轻笑","chapter":7,"line_start":776,"line_end":776},{"speaker":"char_bian_hao","speaker_name":"边浩","listener":null,"text":"你是什么东西，也配向我叫阵？","tone":"厉声","chapter":7,"line_start":778,"line_end":778},{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"我正要问你是什么东西，也配向我大哥叫阵？","tone":"疑问","chapter":7,"line_start":780,"line_end":780},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"贤弟不要包揽，这人是我的，不管你的事。","tone":"陈述","chapter":7,"line_start":786,"line_end":786},{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"只怕今日是谁教训谁还不一定呢！","tone":"慌张","chapter":7,"line_start":792,"line_end":792},{"speaker":"char_bian_hao","speaker_name":"边浩","listener":null,"text":"我先教训教训你。","tone":"厉声","chapter":7,"line_start":794,"line_end":794},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"你两人都不能动手。","tone":"陈述","chapter":7,"line_start":804,"line_end":804},{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"为什么？","tone":"疑问","chapter":7,"line_start":806,"line_end":806}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":21,"line_start":807,"line_end":858,"dialogues":[{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"你认得此人吗？","tone":"疑问","chapter":7,"line_start":808,"line_end":808},{"speaker":"char_bian_hao","speaker_name":"边浩","listener":null,"text":"你又知道他是什么人吗？","tone":"疑问","chapter":7,"line_start":812,"line_end":812},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"就好了，你两人既然互不相识，怎能随便动手？","tone":"轻笑","chapter":7,"line_start":816,"line_end":816},{"speaker":"char_bian_hao","speaker_name":"边浩","listener":null,"text":"你也知道？","tone":"疑问","chapter":7,"line_start":828,"line_end":828},{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"当然，当然。","tone":"陈述","chapter":7,"line_start":830,"line_end":830},{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"岂敢，岂敢，正是区区在下。","tone":"陈述","chapter":7,"line_start":838,"line_end":838}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
