{"segment":14,"line_start":568,"line_end":605,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"这熊倜果然厉害，竟已知道了。","tone":"陈述","chapter":6,"line_start":581,"line_end":581},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"夏姑娘真是快人快语，那么就请姑娘跟着我来吧。","tone":"焦急","chapter":6,"line_start":597,"line_end":597}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":15,"line_start":606,"line_end":649,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"收拾你这种黄毛丫头，还用得着别人费事？","tone":"厉声","chapter":6,"line_start":629,"line_end":629},{"speaker":"char_dong_fang_ling","speaker_name":"东方灵","listener":null,"text":"王兄且慢动手，我还有几句问她。","tone":"疑问","chapter":6,"line_start":633,"line_end":633},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"什么事？","tone":"疑问","chapter":6,"line_start":639,"line_end":639}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":16,"line_start":650,"line_end":691,"dialogues":[{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"谁要你让，你若不动手，我也不动手。","tone":"厉声","chapter":6,"line_start":681,"line_end":681},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"那么小心了。","tone":"厉声","chapter":6,"line_start":683,"line_end":683},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"你是宝马神鞭萨天骥的什么人？","tone":"厉声","chapter":6,"line_start":687,"line_end":687},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"谁认识萨天骥！","tone":"陈述","chapter":6,"line_start":689,"line_end":689}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":17,"line_start":692,"line_end":725,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"我是教训教训你，让你知道人外有人，不要卖狂。","tone":"陈述","chapter":6,"line_start":721,"line_end":721},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"你少哕嗦。","tone":"厉声","chapter":6,"line_start":723,"line_end":723}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":18,"line_start":726,"line_end":761,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"像你这样的脾气，早晚要吃大亏……","tone":"陈述","chapter":6,"line_start":743,"line_end":743},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"这位姑娘应该怎么发落？","tone":"疑问","chapter":6,"line_start":755,"line_end":755}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":19,"line_start":762,"line_end":801,"dialogues":[{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"我就是死了，也不跟你们一起去。","tone":"陈述","chapter":6,"line_start":781,"line_end":781},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"各位就饶了她吧。","tone":"陈述","chapter":6,"line_start":783,"line_end":783},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"看他的身法影子，我想一定是熊倜。","tone":"陈述","chapter":6,"line_start":797,"line_end":797},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"熊倜，熊倜……","tone":"陈述","chapter":6,"line_start":799,"line_end":799}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
