{"segment":21,"line_start":844,"line_end":891,"dialogues":[{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"他不是曾经给你一枚古钱为记吗？","tone":"疑问","chapter":6,"line_start":881,"line_end":881},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"不错。","tone":"陈述","chapter":6,"line_start":883,"line_end":883}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
