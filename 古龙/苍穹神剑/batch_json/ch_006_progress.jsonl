{"segment":1,"line_start":1,"line_end":42,"dialogues":[{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"喂，我说你换件衣服好不好，不要老是这样嘛。","tone":"陈述","chapter":6,"line_start":14,"line_end":14},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"人家上了门，我们不会去敲他他们的门吗？","tone":"疑问","chapter":6,"line_start":20,"line_end":20},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"我们想买几件衣服，要特别好的。","tone":"陈述","chapter":6,"line_start":24,"line_end":24},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"不卖也得卖，我出双倍的价钱，还不行吗？","tone":"疑问","chapter":6,"line_start":30,"line_end":30}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":43,"line_end":88,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"这胖子莫非是长江渡头那两个诡异客商的兄弟……","tone":"轻笑","chapter":6,"line_start":70,"line_end":70},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"这位掌柜的，可是姓叶？","tone":"疑问","chapter":6,"line_start":72,"line_end":72}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":89,"line_end":132,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"你怎么会认识这样的人？","tone":"疑问","chapter":6,"line_start":96,"line_end":96},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"什么事呀？","tone":"疑问","chapter":6,"line_start":102,"line_end":102},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"这样也好。","tone":"陈述","chapter":6,"line_start":124,"line_end":124}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":133,"line_end":186,"dialogues":[{"speaker":"char_ubldp_ubrgr_chang","speaker_name":"我爹常","listener":null,"text":"她说着眼圈都红了，又说：","tone":"陈述","chapter":6,"line_start":146,"line_end":146},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"我也不知道为什么，把什么话都告诉你了。","tone":"陈述","chapter":6,"line_start":160,"line_end":160}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":187,"line_end":214,"dialogues":[],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":215,"line_end":256,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"我爹爹说当年他也是保镖的呢。","tone":"陈述","chapter":6,"line_start":224,"line_end":224},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"看看有什么关系？","tone":"疑问","chapter":6,"line_start":236,"line_end":236},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"什么东西都可以看，就是这镖旗，却随便看不得。","tone":"陈述","chapter":6,"line_start":238,"line_end":238},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"我偏看不可！","tone":"陈述","chapter":6,"line_start":240,"line_end":240},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"你不要拉我，我一定要教训教训那家伙。","tone":"低语","chapter":6,"line_start":248,"line_end":248},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"算了，算了，我们又何必跟那种人一般见识。","tone":"陈述","chapter":6,"line_start":250,"line_end":250}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":257,"line_end":306,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"没有什么，只是一点小事罢了。","tone":"陈述","chapter":6,"line_start":262,"line_end":262}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":307,"line_end":356,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"这些都是些什么人？","tone":"疑问","chapter":6,"line_start":310,"line_end":310},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"这些人都是近年来在武林中赫赫一时的人物，'一异'就是天阴教主焦异行夫妇，'双绝'是峨嵋的孤峰一剑边浩和江苏虎丘的出尘剑客，飞灵堡主东方灵……","tone":"陈述","chapter":6,"line_start":312,"line_end":312},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"难道这位便是雪地飘风吗？","tone":"疑问","chapter":6,"line_start":340,"line_end":340},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"小弟还有些事情，少陪了。","tone":"轻笑","chapter":6,"line_start":342,"line_end":342}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":357,"line_end":409,"dialogues":[{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"你别骗我，下次我再也不受你的骗了。","tone":"陈述","chapter":6,"line_start":364,"line_end":364},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"真的吗？","tone":"疑问","chapter":6,"line_start":370,"line_end":370},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"当然啦。","tone":"轻笑","chapter":6,"line_start":372,"line_end":372},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"你不怪我啦？","tone":"疑问","chapter":6,"line_start":386,"line_end":386},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"真的吗？","tone":"疑问","chapter":6,"line_start":395,"line_end":395},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"熊兄别开玩笑了，熊兄若不知道，还有谁人知道？","tone":"轻笑","chapter":6,"line_start":397,"line_end":397},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"史兄这话却怎的讲法？","tone":"疑问","chapter":6,"line_start":399,"line_end":399},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"这可真吓死我了。","tone":"陈述","chapter":6,"line_start":409,"line_end":409}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":10,"line_start":410,"line_end":443,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"那真太好了，我先谢谢姑娘。","tone":"陈述","chapter":6,"line_start":429,"line_end":429},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"人家既然已经来赔话了，你就还给人家吧。","tone":"陈述","chapter":6,"line_start":437,"line_end":437}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":11,"line_start":444,"line_end":499,"dialogues":[{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"你别拦着我。","tone":"陈述","chapter":6,"line_start":451,"line_end":451},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"你也是的，人家……","tone":"陈述","chapter":6,"line_start":453,"line_end":453},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"你走，你走，我永远不要听你说话。","tone":"陈述","chapter":6,"line_start":481,"line_end":481}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":12,"line_start":500,"line_end":539,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"这个只有到时候再说了。","tone":"陈述","chapter":6,"line_start":515,"line_end":515},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"便是这家了。","tone":"陈述","chapter":6,"line_start":523,"line_end":523},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"还敲什么门，大家一起越墙而入好了。","tone":"陈述","chapter":6,"line_start":529,"line_end":529}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
