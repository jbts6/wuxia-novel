{"segment":29,"line_start":1029,"line_end":1068,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"你别看着我，有什么事尽管说好了。","tone":"陈述","chapter":5,"line_start":1046,"line_end":1046},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"你不认识我了，可是我却认识你呢。","tone":"轻笑","chapter":5,"line_start":1048,"line_end":1048},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"那么你大年初一的清早，不也跑到这里来了吗！","tone":"轻笑","chapter":5,"line_start":1060,"line_end":1060}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":30,"line_start":1069,"line_end":1124,"dialogues":[{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"只是……只是你穿得这么少，岂不要冻坏了。","tone":"陈述","chapter":5,"line_start":1076,"line_end":1076},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"我一点也不冷呀。","tone":"惊讶","chapter":5,"line_start":1078,"line_end":1078},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"有时我真恨你，那时我叫你陪着我，你为什么不肯？","tone":"疑问","chapter":5,"line_start":1098,"line_end":1098},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"要是我呀，我就去抢了。","tone":"惊讶","chapter":5,"line_start":1112,"line_end":1112},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"我自若馨死后，本来已觉得心如死灰了，可是不知怎么回事，我看到了她只觉得高兴得很，只想跟她在一块儿，别的事全想不起了……","tone":"轻笑","chapter":5,"line_start":1124,"line_end":1124}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":31,"line_start":1125,"line_end":1171,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"我在想着你，我看到了你，心里就高兴得很。","tone":"陈述","chapter":5,"line_start":1130,"line_end":1130},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"真的吗？","tone":"疑问","chapter":5,"line_start":1132,"line_end":1132},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"你也喜欢它吗？","tone":"疑问","chapter":5,"line_start":1154,"line_end":1154},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"当然喜欢。","tone":"陈述","chapter":5,"line_start":1156,"line_end":1156},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"你有马场？","tone":"疑问","chapter":5,"line_start":1162,"line_end":1162},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"只要你喜欢的，我都会喜欢。","tone":"陈述","chapter":5,"line_start":1168,"line_end":1168}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
