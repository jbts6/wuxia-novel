{"segment":23,"line_start":835,"line_end":866,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"这位姑娘请了，在下和姑娘素昧生平，姑娘竟插手相助，在下确是感激……","tone":"陈述","chapter":5,"line_start":842,"line_end":842},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"看这小子愣头愣脑，却不料他竟有如此佳人相伴……","tone":"轻笑","chapter":5,"line_start":864,"line_end":864}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":24,"line_start":867,"line_end":894,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"好，好，想不到今日竟然有向我孤峰一剑边某人叫阵的人，而且居然是个女子，我边浩行走江湖多年，真还没有和女子交过手，可是，今日么……","tone":"厉声","chapter":5,"line_start":876,"line_end":876}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":25,"line_start":895,"line_end":950,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"小生熊倜。","tone":"陈述","chapter":5,"line_start":902,"line_end":902},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"好，好！","tone":"陈述","chapter":5,"line_start":924,"line_end":924},{"speaker":"char_xia_yun","speaker_name":"夏芸","listener":null,"text":"好，我知道你不告诉我。","tone":"娇声","chapter":5,"line_start":932,"line_end":932}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":26,"line_start":951,"line_end":980,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"我刚才放在桌上的两个包袱，你可见到？","tone":"疑问","chapter":5,"line_start":964,"line_end":964},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"没有，没有。","tone":"慌张","chapter":5,"line_start":966,"line_end":966}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
