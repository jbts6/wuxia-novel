{"segment":20,"line_start":721,"line_end":776,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"别走，你过来，我问你几句话。","tone":"疑问","chapter":5,"line_start":726,"line_end":726},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"你过来不过来？","tone":"厉声","chapter":5,"line_start":732,"line_end":732},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"狂又怎地？","tone":"疑问","chapter":5,"line_start":750,"line_end":750},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"舵主，这个就是叫熊倜的小子。","tone":"陈述","chapter":5,"line_start":766,"line_end":766}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
