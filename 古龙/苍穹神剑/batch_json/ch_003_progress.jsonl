{"segment":6,"line_start":131,"line_end":156,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"此人年纪太轻，最多只有十六七岁，只怕不太好……","tone":"慌张","chapter":3,"line_start":150,"line_end":150}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":157,"line_end":194,"dialogues":[{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"自古英雄惜英雄，此话果真不假，两位都是武林中千百年难见的奇才俊彦，日后真该多亲近……","tone":"大笑","chapter":3,"line_start":190,"line_end":190}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":195,"line_end":219,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"此趟镖关系着鸣远镖局的前途，以及愚兄的身家性命，这些都全靠贤弟，这趟镖我就交给两位贤弟了，愚兄神思已乱，去了也是无益，再者镖局中尚有许多事……","tone":"陈述","chapter":3,"line_start":219,"line_end":219}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":220,"line_end":247,"dialogues":[{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"您不去怎么行，路上的一切，非您不可呀。","tone":"惊讶","chapter":3,"line_start":221,"line_end":221},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"鸣远……扬威……","tone":"疑问","chapter":3,"line_start":235,"line_end":235}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
