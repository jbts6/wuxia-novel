{"segment":2,"line_start":31,"line_end":72,"dialogues":[{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"怎么？","tone":"疑问","chapter":8,"line_start":36,"line_end":36},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"方才我慌忙中蹿进这山谷……","tone":"慌张","chapter":8,"line_start":38,"line_end":38},{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"大哥，你有没有看到谷口的石碑？","tone":"疑问","chapter":8,"line_start":40,"line_end":40},{"speaker":"char_xiong_ti","speaker_name":"熊倜","listener":null,"text":"谷口还有个石碑？","tone":"疑问","chapter":8,"line_start":42,"line_end":42},{"speaker":"char_shang_wei_ming","speaker_name":"尚未明","listener":null,"text":"快朝来路退。","tone":"焦急","chapter":8,"line_start":44,"line_end":44},{"speaker":null,"speaker_name":"未明说话人","listener":null,"text":"两个娃娃跑到我这甜甜谷来，还想出去吗？","tone":"疑问","chapter":8,"line_start":52,"line_end":52}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
