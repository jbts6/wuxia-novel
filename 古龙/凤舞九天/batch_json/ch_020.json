{
  "chapter": 20,
  "chapter_summary": "陆小凤在阳光下研究刀光反射的角度，得出可以利用阳光刺激对手眼睛的结论，并回忆起将鹰眼老七设计引往长安的计谋。西门吹雪到达悬崖木屋时，发现小玉被刺重伤，沙曼和老实咈尊已不知去向。小玉临死前用血写下“老实咈尊不老实”七个字。西门吹雪将小玉送往小镇治疗，无法按时返回。陆小凤等待六天后终于见到西门吹雪带着小玉归来，小玉叙述了老实咈尊背叛的经过。陆小凤通过回忆和推理，意识到小老头的阴谋核心是迫使自己加入，而老实咈尊和宫九只是白云般的接木。他决定先回木屋寻找线索，再到长安通过鹰眼老七找到宫九和老实咈尊，并先向西门吹雪辞行。",
  "dialogues": [
    {
      "speaker": null,
      "speaker_name": "陆小凤",
      "listener": null,
      "listener_name": null,
      "text": "然后呢？",
      "tone": "疑问",
      "chapter": 20,
      "line_start": 249,
      "line_end": 249
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_lu_xiao_feng",
      "listener_name": "陆小凤",
      "text": "然后我就到了这里。",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 251,
      "line_end": 251
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_lao_shi_he_shang",
      "listener_name": "老实咈尊",
      "text": "咈尊为什么没有走？",
      "tone": "疑问",
      "chapter": 20,
      "line_start": 267,
      "line_end": 267
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实咈尊",
      "listener": "char_lu_xiao_feng",
      "listener_name": "陆小凤",
      "text": "你为什么还没有走？",
      "tone": "疑问",
      "chapter": 20,
      "line_start": 269,
      "line_end": 269
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_lao_shi_he_shang",
      "listener_name": "老实咈尊",
      "text": "我走不了。",
      "tone": "陈述",
      "chapter": 20,
      "line_start": 271,
      "line_end": 271
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实咈尊",
      "listener": "char_lu_xiao_feng",
      "listener_name": "陆小凤",
      "text": "连你都走不了，咈尊怎么走得了？",
      "tone": "疑问",
      "chapter": 20,
      "line_start": 273,
      "line_end": 273
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_lao_shi_he_shang",
      "listener_name": "老实咈尊",
      "text": "咈尊为什么要来？",
      "tone": "疑问",
      "chapter": 20,
      "line_start": 275,
      "line_end": 275
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实咈尊",
      "listener": "char_lu_xiao_feng",
      "listener_name": "陆小凤",
      "text": "咈尊不入地狱，谁入地狱！",
      "tone": "豪迈",
      "chapter": 20,
      "line_start": 277,
      "line_end": 277
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_lao_shi_he_shang",
      "listener_name": "老实咈尊",
      "text": "你知道这里是地狱？你是到地狱来干什么的？那位九少爷又是个什么样的人？怎么会把你装进箱子的？",
      "tone": "疑问",
      "chapter": 20,
      "line_start": 279,
      "line_end": 279
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实咈尊",
      "listener": "char_lu_xiao_feng",
      "listener_name": "陆小凤",
      "text": "天机不可泄況，佛云：‘不可说，不可说’。",
      "tone": "呵咕",
      "chapter": 20,
      "line_start": 285,
      "line_end": 287
    }
