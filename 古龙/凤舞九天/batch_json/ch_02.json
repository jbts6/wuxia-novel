  "entity_updates": [
    {
      "id": "char_lu_xiao_feng",
      "updates": {
        "source_refs": [
          {
            "chapter": 1,
            "line_start": 192,
            "line_end": 194,
            "text": "就是那个有四条眉毛的陆小凤？...假如世上还有人能替我们找出那凶手来，一定就是陆小凤。"
          },
          {
            "chapter": 2,
            "line_start": 2,
            "line_end": 4,
            "text": "陆小凤还没有出海，他怕晕船，他选了条最大最稳的海船"
