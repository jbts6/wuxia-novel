      "chapter": 13
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实和尚",
      "listener": "char_lu_xiao_feng",
      "text": "酒肉穿肠过，佛在心头坐，和尚吃点牛肉汤，其实也没太大关系。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": null,
      "text": "的确没关系。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实和尚",
      "listener": "char_lu_xiao_feng",
      "text": "有关系。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": null,
      "text": "有什么关系？",
      "tone": "疑问",
      "chapter": 13
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实和尚",
      "listener": "char_lu_xiao_feng",
      "text": "大得要命的关系，和尚……",
      "tone": "犹豫",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": null,
      "text": "这碗汤里下了药。",
