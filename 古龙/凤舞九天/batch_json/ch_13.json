    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_lu_xiao_feng",
      "text": "你能不能不要去陪母狗？能不能去陪公狗？",
      "tone": "疑问",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_xiao_yu",
      "text": "不能。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_lu_xiao_feng",
      "text": "为什么？",
      "tone": "疑问",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_xiao_yu",
      "text": "因为我要陪你。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实和尚",
      "listener": "char_lu_xiao_feng",
      "text": "你为什么一定不让他去陪母狗？",
