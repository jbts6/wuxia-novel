    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_xiao_yu",
      "text": "所以他们想不到是你。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_lu_xiao_feng",
      "text": "连做梦都想不到。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": null,
      "text": "人不可貌相",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实和尚",
      "listener": "char_xiao_yu",
      "text": "这有什么好笑，和尚也是人，肚子饿了也会叫。",
