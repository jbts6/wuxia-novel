      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_xiao_yu",
      "text": "是你把沙曼送来的？",
      "tone": "疑问",
      "chapter": 13
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_lu_xiao_feng",
      "text": "当然是我。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_xiao_yu",
      "text": "把这和尚吊起来的也是你？",
      "tone": "疑问",
      "chapter": 13
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_lu_xiao_feng",
      "text": "把他放下来的也是我。",
