      "chapter": 13
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": null,
      "text": "是谁下的药？",
      "tone": "疑问",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": null,
      "text": "我正想问你。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": null,
      "text": "这件事不是我做的，不是我……",
      "tone": "犹豫",
      "chapter": 13
    },
    {
