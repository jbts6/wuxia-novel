      "chapter": 13
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_lu_xiao_feng",
      "text": "只有一个人。",
      "tone": "平静",
      "chapter": 13
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_xiao_yu",
      "text": "谁？",
      "tone": "疑问",
      "chapter": 13
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
