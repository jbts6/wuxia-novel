{"segment":3,"line_start":201,"line_end":250,"dialogues":[{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"哪里的粽子做得最好，我就到哪里去找。","tone":"陈述","chapter":1,"line_start":202,"line_end":202},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"我正准备到那里去。","tone":"陈述","chapter":1,"line_start":210,"line_end":210},{"speaker":"char_wo_yun_lou_zhu_ren","speaker_name":"卧云楼主人","listener":"char_ying_yan_lao_qi","text":"陆小凤来过，几乎每年端午前后他都要来住几天。","tone":"陈述","chapter":1,"line_start":218,"line_end":218},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":"char_wo_yun_lou_zhu_ren","text":"现在他的人呢？","tone":"疑问","chapter":1,"line_start":222,"line_end":222},{"speaker":"char_wo_yun_lou_zhu_ren","speaker_name":"卧云楼主人","listener":null,"text":"今年他的兴致好像不如往年，总显得有点心事重重，连这坛酒都没有喝完，就一定要走，连我都留不住！","tone":"无奈","chapter":1,"line_start":224,"line_end":224},{"speaker":"char_wo_yun_lou_zhu_ren","speaker_name":"卧云楼主人","listener":null,"text":"他太喜欢管闲事，什么事都管，不该管的也要管，却忘了替自己打算打算，一个人到了三十岁还没有成家，心情怎么会好得起来？","tone":"担心","chapter":1,"line_start":228,"line_end":228},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":"char_wo_yun_lou_zhu_ren","text":"你知不知道他会到什么地方去？","tone":"疑问","chapter":1,"line_start":230,"line_end":230},{"speaker":"char_wo_yun_lou_zhu_ren","speaker_name":"卧云楼主人","listener":null,"text":"我好像听他说过，他要到海外去散散心。","tone":"陈述","chapter":1,"line_start":232,"line_end":232},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":"char_wo_yun_lou_zhu_ren","text":"你是说他要出海去？","tone":"惊讶","chapter":1,"line_start":234,"line_end":234},{"speaker":"char_wo_yun_lou_zhu_ren","speaker_name":"卧云楼主人","listener":null,"text":"现在他想必已到了海上。","tone":"陈述","chapter":1,"line_start":236,"line_end":236},{"speaker":"char_wo_yun_lou_zhu_ren","speaker_name":"卧云楼主人","listener":"char_ying_yan_lao_qi","text":"他秋深的时候就会回来的，一定还会到我这里吃月饼，你有什么事，我可以转告他。","tone":"认真","chapter":1,"line_start":240,"line_end":240},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"到了那时候，我只有一件事找他做了。","tone":"严肃","chapter":1,"line_start":242,"line_end":242},{"speaker":"char_wo_yun_lou_zhu_ren","speaker_name":"卧云楼主人","listener":"char_ying_yan_lao_qi","text":"什么事？","tone":"疑问","chapter":1,"line_start":244,"line_end":244},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"找他去抬棺材。","tone":"悲伤","chapter":1,"line_start":246,"line_end":246},{"speaker":"char_wo_yun_lou_zhu_ren","speaker_name":"卧云楼主人","listener":"char_ying_yan_lao_qi","text":"谁的？","tone":"疑问","chapter":1,"line_start":248,"line_end":248},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"我的。","tone":"绝望","chapter":1,"line_start":250,"line_end":250}],"new_entities":{"characters":[{"id":"char_wo_yun_lou_zhu_ren","name":"卧云楼主人","alias":[],"identity":"卧云楼主","faction":null,"role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"江湖闻名的美男子，陆小凤好友","personality":{"traits":["好客","风趣","细心","豁达","健谈"],"speech_style":"豪迈","temperament":"热情"},"relationships":[{"target":"char_lu_xiao_feng","type":"挚友","intensity":70,"bond_level":4,"dynamic":"深厚"}],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":1,"line_start":214,"line_end":214,"text":"卧云楼主昔年本是江湖闻名的美男子"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_wo_yun_lou","name":"卧云楼","type":"帮派","location":"湖州","sub_divisions":[],"one_line":"名动公卿的酒楼","source_refs":[{"chapter":1,"line_start":208,"line_end":208,"text":"卧云楼主人"}]}],"locations":[],"items":[]},"entity_updates":[]}
