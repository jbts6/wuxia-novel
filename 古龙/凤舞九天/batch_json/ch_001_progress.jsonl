:"十二连环坞第三寨寨主","faction":"char_shi_er_lian_huan_wu","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"十二连环坞第三寨寨主，老成持重","personality":{"traits":["老成","持重","细心","忠诚","稳重"],"speech_style":"平和","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":1,"line_start":44,"line_end":44,"text":"程中和萧红珠都是鹰眼老七最亲信的人"}]},{"id":"char_tai_ping_wang_shi_zi","name":"太平王世子","alias":[],"identity":"太平王世子","faction":"char_tai_ping_wang_fu","role":"npc","archetype":"scholar","rank":"初窥门径","one_line":"本案委托人代表，给予四十天期限","personality":{"traits":["傲慢","冷静","讲理","威严","深沉"],"speech_style":"冷淡","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":1,"line_start":70,"line_end":70,"text":"太平王的世子冷笑道"}]},{"id":"char_si_tu_gang","name":"司徒刚","alias":[],"identity":"群英镖局总镖头","faction":"char_qun_ying_biao_ju","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"群英镖局总镖头","personality":{"traits":["精明","干练","有魄力","稳重","有名望"],"speech_style":"威严","temperament":"稳重"},"relationships":[{"target":"char_xiong_tian_jian","type":"亲属","intensity":80,"bond_level":4,"dynamic":"舅侄"}],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":1,"line_start":26,"line_end":26,"text":"群英镖局总镖头司徒刚"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_qun_ying_biao_ju","name":"群英镖局","type":"帮派","location":"中原","sub_divisions":[],"one_line":"中原十三家最大镖局之一","source_refs":[{"chapter":1,"line_start":14,"line_end":14,"text":"群英镖局"}]},{"id":"faction_shi_er_lian_huan_wu","name":"十二连环坞","type":"帮派","location":"塞外","sub_divisions":["第一寨","第二寨","第三寨"],"one_line":"势力远及塞外的庞大组织","source_refs":[{"chapter":1,"line_start":30,"line_end":30,"text":"十二连环坞的总瓢把子"}]},{"id":"faction_tai_ping_wang_fu","name":"太平王府","type":"家族","location":"京师","sub_divisions":[],"one_line":"本案的委托方","source_refs":[{"chapter":1,"line_start":34,"line_end":34,"text":"太平王府"}]},{"id":"faction_shao_lin","name":"少林","type":"武林门派","location":"嵩山","sub_divisions":[],"one_line":"天下武学正宗","source_refs":[{"chapter":1,"line_start":28,"line_end":28,"text":"少林铁肩大师"}]}],"locations":[{"id":"loc_tai_hang_shan","name":"太行山","region":"中原","one_line":"镖银失踪案发生地","source_refs":[{"chapter":1,"line_start":16,"line_end":16,"text":"太行山"}]},{"id":"loc_ying_yan","name":"鹰眼","region":"中原","one_line":"十二连环坞总寨密室所在","source_refs":[{"chapter":1,"line_start":62,"line_end":62,"text":"就叫做“鹰眼”"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_ye_xing_shi","speaker_name":"叶星士","listener":null,"text":"上个月底长江水上飞，在作每日例行的巡查时，忽然暴毙在水中，我也曾被他们帮中的子弟请去鉴定他的死因。","tone":"陈述","chapter":1,"line_start":136,"line_end":136},{"speaker":"char_xiong_tian_jian","speaker_name":"熊天健","listener":"char_ye_xing_shi","text":"他的死因也跟崔诚一样？","tone":"疑问","chapter":1,"line_start":138,"line_end":138},{"speaker":"char_ye_xing_shi","speaker_name":"叶星士","listener":null,"text":"他身上也完全没有伤痕血迹，我整整花了三天功夫，才查出他内腑肺叶下的刀伤，也同样是一刀就已致命！","tone":"认真","chapter":1,"line_start":140,"line_end":140},{"speaker":"char_xiong_tian_jian","speaker_name":"熊天健","listener":"char_ye_xing_shi","text":"他是在水中被刺的了？","tone":"疑问","chapter":1,"line_start":142,"line_end":142},{"speaker":"char_ye_xing_shi","speaker_name":"叶星士","listener":null,"text":"不错。","tone":"陈述","chapter":1,"line_start":144,"line_end":144},{"speaker":"char_wang_yi","speaker_name":"王毅","listener":"char_xiong_tian_jian","text":"什么事？","tone":"疑问","chapter":1,"line_start":152,"line_end":152},{"speaker":"char_xiong_tian_jian","speaker_name":"熊天健","listener":null,"text":"今年年初，嵩阳“铁剑山庄”的老庄主在他的藏剑阁中练剑时，忽然暴毙，至今还没有人知道他的死因。","tone":"沉声","chapter":1,"line_start":154,"line_end":156},{"speaker":"char_ye_xing_shi","speaker_name":"叶星士","listener":"char_xiong_tian_jian","text":"他当真是在练剑时被刺的，这刺客的刀就未免太可怕了。","tone":"惊讶","chapter":1,"line_start":164,"line_end":164},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"那么我们是不是就应该坐在这里，等着他来将我们一个个杀光！","tone":"冷笑","chapter":1,"line_start":166,"line_end":166},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"就算这刺客真的有三头六臂，真的会隐形，我也要把他找出来！","tone":"愤怒","chapter":1,"line_start":170,"line_end":170},{"speaker":null,"speaker_name":"有人","listener":"char_ying_yan_lao_qi","text":"你准备到哪里去？","tone":"疑问","chapter":1,"line_start":188,"line_end":188},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"我去找陆小凤。","tone":"认真","chapter":1,"line_start":190,"line_end":190},{"speaker":null,"speaker_name":"有人","listener":"char_ying_yan_lao_qi","text":"就是那个有四条眉毛的陆小凤？","tone":"惊讶","chapter":1,"line_start":192,"line_end":192},{"speaker":"char_ying_yan_lao_qi","speaker_name":"鹰眼老七","listener":null,"text":"假如世上还有人能替我们找出那凶手来，一定就是陆小凤。","tone":"认真","chapter":1,"line_start":194,"line_end":194},{"speaker":null,"speaker_name":"有人","listener":"char_ying_yan_lao_qi","text":"据说这个人是个浪子，浪迹天涯，四海为家，你准备到哪里去找他？","tone":"疑问","chapter":1,"line_start":200,"line_end":200}],"new_entities":{"characters":[{"id":"char_wang_yi","name":"王毅","alias":[],"identity":"淮南武林世家长公子","faction":"faction_huai_nan_wu_lin_shi_jia","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"以鹰爪力著称","personality":{"traits":["急躁","好胜","果断","热情","忠诚"],"speech_style":"急促","temperament":"急躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":1,"line_start":150,"line_end":150,"text":"淮南武林世家长公子王毅"}]},{"id":"char_shui_shang_fei","name":"水上飞","alias":[],"identity":"长江水帮高手","faction":null,"role":"npc","archetype":"warrior","rank":"出神入化","one_line":"水性号称天下第一，被神秘刺客杀害","personality":{"traits":["水性精纯","谨慎","有名望","低调","坚毅"],"speech_style":"沉稳","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":1,"line_start":136,"line_end":136,"text":"长江水上飞"}]},{"id":"char_guo_lao_zhuang_zhu","name":"郭老庄主","alias":[],"identity":"铁剑山庄老庄主","faction":"faction_tie_jian_shan_zhuang","role":"npc","archetype":"warrior","rank":"登峰造极","one_line":"剑法极高，在练剑时被杀害","personality":{"traits":["孤僻","严谨","高傲","坚毅","专注"],"speech_style":"冷淡","temperament":"孤傲"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":1,"line_start":154,"line_end":154,"text":"铁剑山庄的老庄主"}]},{"id":"char_tie_jian_da_shi","name":"铁肩大师","alias":[],"identity":"少林高僧","faction":"faction_shao_lin","role":"npc","archetype":"monk","rank":"返璞归真","one_line":"叶星士的师父","personality":{"traits":["