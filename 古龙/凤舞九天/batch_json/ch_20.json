      "line": 269
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_lao_shi_he_shang",
      "text": "我走不了。",
      "tone": "无奈",
      "chapter": 20,
      "line": 271
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实咈商",
      "listener": "char_lu_xiao_feng",
      "text": "连你都走不了，咈商怎么走得了？",
      "tone": "自嘲",
      "chapter": 20,
      "line": 273
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_lao_shi_he_shang",
      "text": "咈商为什么要来？",
      "tone": "追问",
      "chapter": 20,
      "line": 275
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实咈商",
      "listener": "char_lu_xiao_feng",
      "text": "咈商不入地狱，谁入地狱！",
      "tone": "庄严",
      "chapter": 20,
      "line": 277
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_lao_shi_he_shang",
      "text": "你知道这里是地狱？你是到地狱来干什么的？那位九少爷又是个什么样的人？怎么会把你装进箱子的？",
      "tone": "连珠追问",
      "chapter": 20,
      "line": 279
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_lao_shi_he_shang",
      "text": "你既然知道，为什么不说？",
      "tone": "质问",
      "chapter": 20,
      "line": 283
    },
    {
      "speaker": "char_lao_shi_he_shang",
      "speaker_name": "老实咈商",
      "listener": "char_lu_xiao_feng",
      "text": "天机不可泄漏，佛云：‘不可说，不可说’。",
      "tone": "故弄玄虚",
      "chapter": 20,
      "line": 287
    }
