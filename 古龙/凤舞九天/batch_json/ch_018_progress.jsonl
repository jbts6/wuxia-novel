{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"真笨！","tone":"陈述","chapter":18,"line_start":312,"line_end":312},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"衙门的陆爷请用早饭。","tone":"陈述","chapter":18,"line_start":378,"line_end":378},{"speaker":null,"speaker_name":null,"listener":null,"text":"我不是衙门的陆爷！","tone":"陈述","chapter":18,"line_start":382,"line_end":382},{"speaker":null,"speaker_name":null,"listener":null,"text":"是的，那么请陆小凤陆爷用早饭。","tone":"陈述","chapter":18,"line_start":386,"line_end":386},{"speaker":null,"speaker_name":null,"listener":null,"text":"我不要吃！","tone":"陈述","chapter":18,"line_start":390,"line_end":390},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"我看你还是吃了比较好。","tone":"陈述","chapter":18,"line_start":392,"line_end":392},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我为什么要吃？","tone":"陈述","chapter":18,"line_start":394,"line_end":394},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"因为九哥说，他可不愿意再到你用早饭的店里付钱给你。","tone":"陈述","chapter":18,"line_start":396,"line_end":396},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"他偷了那么多钱，多花一点又有什么大不了？","tone":"陈述","chapter":18,"line_start":398,"line_end":398},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"难道你不知道一件事吗？","tone":"陈述","chapter":18,"line_start":400,"line_end":400}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"什么事？","tone":"疑问","chapter":18,"line_start":402,"line_end":402},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"愈是富有的，愈舍不得花钱。","tone":"陈述","chapter":18,"line_start":404,"line_end":404},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"他不是花了很多钱用来跟踪我吗？","tone":"疑问","chapter":18,"line_start":406,"line_end":406},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"那是不得已的，那是非花不可的。","tone":"陈述","chapter":18,"line_start":408,"line_end":408},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"那我只有一句话。","tone":"陈述","chapter":18,"line_start":410,"line_end":410},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"什么话？","tone":"疑问","chapter":18,"line_start":412,"line_end":412},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"这早饭，我是非吃不可的。","tone":"陈述","chapter":18,"line_start":414,"line_end":414},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我想请你做一件事。","tone":"陈述","chapter":18,"line_start":416,"line_end":416},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"你还要来一碗牛肉汤？","tone":"疑问","chapter":18,"line_start":418,"line_end":418},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"不是。","tone":"陈述","chapter":18,"line_start":420,"line_end":420},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"那我能为你做什么？","tone":"疑问","chapter":18,"line_start":422,"line_end":422},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"带我去见宫九。","tone":"陈述","chapter":18,"line_start":424,"line_end":424},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"有什么话，你可以对我说。","tone":"犹豫","chapter":18,"line_start":426,"line_end":426},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我的话，必须当面对宫九说。","tone":"陈述","chapter":18,"line_start":428,"line_end":428},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"为什么？","tone":"疑问","chapter":18,"line_start":430,"line_end":430},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"因为那样我才有点人生乐趣。","tone":"陈述","chapter":18,"line_start":432,"line_end":432},{"speaker":"char_niu_rou_tang","speaker_name":"牛肉汤","listener":null,"text":"他有话对你说。","tone":"陈述","chapter":18,"line_start":460,"line_end":460},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我有话要当面对你说。","tone":"陈述","chapter":18,"line_start":466,"line_end":466},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"我知道。","tone":"陈述","chapter":18,"line_start":468,"line_end":468},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你知道？","tone":"疑问","chapter":18,"line_start":470,"line_end":470},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"牛肉汤刚刚说的。","tone":"陈述","chapter":18,"line_start":472,"line_end":472},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你不问我要说什么？","tone":"疑问","chapter":18,"line_start":474,"line_end":474},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"我不必问。","tone":"陈述","chapter":18,"line_start":476,"line_end":476},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"为什么？","tone":"疑问","chapter":18,"line_start":478,"line_end":478},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你来了，你就会说。","tone":"陈述","chapter":18,"line_start":480,"line_end":480},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我要说的话，就是要你把你的车夫打发走。","tone":"陈述","chapter":18,"line_start":482,"line_end":482},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"为什么？","tone":"疑问","chapter":18,"line_start":484,"line_end":484},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你不必再用车夫了。","tone":"陈述","chapter":18,"line_start":486,"line_end":486},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"不用车夫，谁来赶车？","tone":"疑问","chapter":18,"line_start":488,"line_end":488},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我。","tone":"陈述","chapter":18,"line_start":490,"line_end":490},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你？","tone":"惊讶","chapter":18,"line_start":492,"line_end":492},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我。","tone":"陈述","chapter":18,"line_start":494,"line_end":494},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你为什么要替我赶车？","tone":"疑问","chapter":18,"line_start":496,"line_end":496},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"因为我要摆脱你的追踪。","tone":"陈述","chapter":18,"line_start":498,"line_end":498},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"可是……","tone":"陈述","chapter":18,"line_start":500,"line_end":500}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":501,"line_end":600,"dialogues":[{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我做你的车夫，就表示不是你跟踪我，而是我带你走。","tone":"陈述","chapter":18,"line_start":502,"line_end":502},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你要带我去哪里？","tone":"疑问","chapter":18,"line_start":504,"line_end":504},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我也不知道。","tone":"陈述","chapter":18,"line_start":506,"line_end":506},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你不知道？","tone":"疑问","chapter":18,"line_start":508,"line_end":508},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"也许在路上我会想到一个地方。","tone":"陈述","chapter":18,"line_start":510,"line_end":510},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"什么地方？","tone":"疑问","chapter":18,"line_start":512,"line_end":512},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"假如你想知道是什么地方，你就必须让我赶车，在路上我想到了，我就告诉你。","tone":"陈述","chapter":18,"line_start":514,"line_end":514},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你在赶路？","tone":"疑问","chapter":18,"line_start":534,"line_end":534},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"是的。","tone":"陈述","chapter":18,"line_start":536,"line_end":536},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"为什么要赶路？","tone":"疑问","chapter":18,"line_start":538,"line_end":538},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"因为我要去见一个人。","tone":"陈述","chapter":18,"line_start":540,"line_end":540},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你急着要见他？","tone":"疑问","chapter":18,"line_start":542,"line_end":542},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"不急。","tone":"陈述","chapter":18,"line_start":544,"line_end":544},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"不急，为什么要赶路？","tone":"疑问","chapter":18,"line_start":546,"line_end":546},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"因为我必须在黄昏以前赶到他住的地方。","tone":"陈述","chapter":18,"line_start":548,"line_end":548},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"那你还说不急？","tone":"疑问","chapter":18,"line_start":550,"line_end":550},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我是不急，是他急。","tone":"陈述","chapter":18,"line_start":552,"line_end":552},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"他急？","tone":"疑问","chapter":18,"line_start":554,"line_end":554},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"因为他有个习惯，天一黑，他就不见客了。","tone":"陈述","chapter":18,"line_start":556,"line_end":556},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"连你也不见？","tone":"疑问","chapter":18,"line_start":558,"line_end":558},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"连天王老子也不见。","tone":"陈述","chapter":18,"line_start":560,"line_end":560},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"所以你一定要在天黑前赶到？","tone":"疑问","chapter":18,"line_start":562,"line_end":562},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"是的。","tone":"陈述","chapter":18,"line_start":564,"line_end":564},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"那急的还是你。","tone":"陈述","chapter":18,"line_start":566,"line_end":566},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"不对，因为规矩是他定出来的，所以急着要在天黑前见客的，是他，不是我。","tone":"陈述","chapter":18,"line_start":568,"line_end":568},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你要见的人喜欢花？","tone":"疑问","chapter":18,"line_start":578,"line_end":578},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"喜欢极了。","tone":"陈述","chapter":18,"line_start":580,"line_end":580},{"speaker":"char_gong_jiu","speaker_name":"宫九","lis