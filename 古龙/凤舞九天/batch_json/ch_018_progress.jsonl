{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你要请他帮你忙？","tone":"疑问","chapter":18,"line_start":602,"line_end":602},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"也许。","tone":"陈述","chapter":18,"line_start":604,"line_end":604},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你要他去通知沙曼？","tone":"疑问","chapter":18,"line_start":606,"line_end":606},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你想进去吗？","tone":"疑问","chapter":18,"line_start":612,"line_end":612},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"既然他不喜欢陌生人，我又何必进去？而且，这里花香四溢，我在这里享受一下黄昏的美景，岂不更愉快？","tone":"陈述","chapter":18,"line_start":614,"line_end":614},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你果然是个聪明人。","tone":"陈述","chapter":18,"line_start":616,"line_end":616},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"过奖。","tone":"陈述","chapter":18,"line_start":618,"line_end":618},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你既然承认你是个聪明人，你猜我要向你借一样什么东西吗？","tone":"疑问","chapter":18,"line_start":620,"line_end":620},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我要向你借一把刮胡刀。","tone":"陈述","chapter":18,"line_start":628,"line_end":628},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"送给你。","tone":"淡然","chapter":18,"line_start":632,"line_end":632},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你不是说西门吹雪在天黑后就不见客吗？","tone":"疑问","chapter":18,"line_start":636,"line_end":636},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"是呀。","tone":"陈述","chapter":18,"line_start":638,"line_end":638},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你还那么悠哉悠哉的刮胡子？","tone":"疑问","chapter":18,"line_start":640,"line_end":640},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我一生难得刮几次胡子，一定要舒舒服服的刮，才能对得起胡子，而且，你放心，太阳还未下山，我保证一定就刮好。","tone":"陈述","chapter":18,"line_start":642,"line_end":642},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"我想劝你一句话。","tone":"陈述","chapter":18,"line_start":644,"line_end":644},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"什么话？","tone":"疑问","chapter":18,"line_start":646,"line_end":646},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"我认为你四条眉毛比较好看，所以我劝你别把胡子剃掉。","tone":"陈述","chapter":18,"line_start":648,"line_end":648},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我必须刮。","tone":"陈述","chapter":18,"line_start":650,"line_end":650},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"为什么？","tone":"疑问","chapter":18,"line_start":652,"line_end":652},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"因为我必须见到西门吹雪。","tone":"陈述","chapter":18,"line_start":654,"line_end":654},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你一定要见到他？","tone":"疑问","chapter":18,"line_start":656,"line_end":656},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"不见他，我就见不到沙曼。","tone":"陈述","chapter":18,"line_start":658,"line_end":658},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"不见他，你还是可以见到沙曼的。","tone":"陈述","chapter":18,"line_start":660,"line_end":660},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"哦？","tone":"疑问","chapter":18,"line_start":662,"line_end":662},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你不信？","tone":"疑问","chapter":18,"line_start":664,"line_end":664},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我信，只是我不敢。","tone":"陈述","chapter":18,"line_start":666,"line_end":666},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你不敢？","tone":"疑问","chapter":18,"line_start":668,"line_end":668},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我怕我是见沙曼最后一面，或者……","tone":"陈述","chapter":18,"line_start":670,"line_end":670},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"或者什么？","tone":"疑问","chapter":18,"line_start":672,"line_end":672},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"或者她见我最后一面。","tone":"陈述","chapter":18,"line_start":674,"line_end":674},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"我可以不杀你们。","tone":"陈述","chapter":18,"line_start":678,"line_end":678},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你会吗？","tone":"疑问","chapter":18,"line_start":680,"line_end":680},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"我会的。","tone":"陈述","chapter":18,"line_start":682,"line_end":682},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"条件呢？","tone":"疑问","chapter":18,"line_start":684,"line_end":684},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你很聪明。","tone":"陈述","chapter":18,"line_start":686,"line_end":686},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"所以我还活着。","tone":"陈述","chapter":18,"line_start":688,"line_end":688},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"只要你加入我们。","tone":"陈述","chapter":18,"line_start":690,"line_end":690},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"这是你本人的意思？","tone":"疑问","chapter":18,"line_start":692,"line_end":692},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"不。","tone":"陈述","chapter":18,"line_start":694,"line_end":694},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"是小老头的意思？","tone":"疑问","chapter":18,"line_start":696,"line_end":696},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"对。","tone":"陈述","chapter":18,"line_start":698,"line_end":698},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你看我这样子不也是挺潇洒的吗？","tone":"陈述","chapter":18,"line_start":700,"line_end":700}],"new_entities":{"characters":[{"id":"char_sha_man","name":"沙曼","alias":[],"identity":"陆小凤的爱人","faction":null,"role":"companion","archetype":"healer","rank":"略有小成","one_line":"陆小凤的爱人，被宫九控制","personality":{"traits":["美丽","温柔","坚韧","深情","聪慧"],"speech_style":"温柔","temperament":"冷静"},"relationships":[{"target":"char_lu_xiao_feng","type":"恋人","intensity":90,"bond_level":5,"dynamic":"深爱彼此"}],"known_skills":[],"related_skills":[],"rag_refs":[18],"source_refs":[{"chapter":18,"line_start":658,"line_end":660,"text":"陆小凤道：\"不见他，我就见不到沙曼。\"宫九道：\"不见他，你还是可以见到沙曼的。\""}]},{"id":"char_xiao_lao_tou","name":"小老头","alias":[],"identity":"幕后主使","faction":null,"role":"villain","archetype":"scholar","rank":"登峰造极","one_line":"宫九的幕后主使，真实身份未知","personality":{"traits":["神秘","阴险","狡猾","聪明","残忍"],"speech_style":"深沉","temperament":"阴沉"},"relationships":[{"target":"char_gong_jiu","type":"主仆","intensity":80,"bond_level":4,"dynamic":"控制与服从"}],"known_skills":[],"related_skills":[],"rag_refs":[18],"source_refs":[{"chapter":18,"line_start":696,"line_end":698,"text":"陆小凤道：\"是小老头的意思？\"宫九道：\"对。\""}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":701,"line_end":800,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"牛肉汤。","tone":"陈述","chapter":18,"line_start":706,"line_end":706},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我这样子是不是比以前更好看？","tone":"陈述","chapter":18,"line_start":710,"line_end":710},{"speaker":null,"speaker_name":null,"listener":null,"text":"你们一定是被我英俊的仪表吓坏了，所以都不说话了，既然我潇洒依旧，我想我还是去见西门吹雪比较好。","tone":"陈述","chapter":18,"line_start":716,"line_end":716},{"speaker":null,"speaker_name":null,"listener":null,"text":"这么美好的日子，我们为什么要勾心斗角，非置对方于死地不可呢？","tone":"陈述","chapter":18,"line_start":722,"line_end":722},{"speaker":null,"speaker_name":null,"listener":null,"text":"人生美好，你为什么要苦苦逼我到绝境？你为什么不和牛肉汤好好携手在花旁，享受一下人生？","tone":"陈述","chapter":18,"line_start":728,"line_end":728},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"天要黑了。","tone":"陈述","chapter":18,"line_start":730,"line_end":730},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我知道。","tone":"陈述","chapter":18,"line_start":732,"line_end":732},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"西门吹雪为什么不出来迎接你？","tone":"陈述","chapter":18,"line_start":734,"line_end":734},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"也许他正在做几个精美小菜来欢迎我吧！","tone":"陈述","chapter":18,"line_start":736,"line_end":736},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你要在里面吃晚饭？","tone":"陈述","chapter":18,"line_start":738,"line_end":738},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我还要在里面睡觉。","tone":"陈述","chapter":18,"line_start":740,"line_end":740},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"那你快请吧。","tone":"陈述","chapter":18,"line_start":742,"line_end":742},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我进去以前，也要奉劝你一句话。","tone":"陈述","chapter":18,"line_start":744,"line_end":744},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"你说。","tone":"陈述","chapter":18,"line_start":746,"line_end":746},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"赶快生火烧饭，免得待会闻到香味，你就受不了啦。","tone":"陈述","chapter":18,"line_start":748,"line_end":748},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"我不是个馋嘴的人，你也不必激我，你好好的吃，好好的睡，明天准备走路吧。","tone":"陈述","chapter":18,"line_start":750,"line_end":750},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"为什么我要走路？","tone":"陈述","chapter":18,"line_start":752,"line_end":752},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"因为我决定不再用你这个车夫了。","tone":"陈述","chapter":18,"line_start":754,"line_end":754},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"其实，明天我也不会做你的车夫了。","tone":"陈述","chapter":18,"line_start":756,"line_end":756},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"哦？","tone":"陈述","chapter":18,"line_start":758,"line_end":758},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"明天你就会发现，我绝对是一个自自由由的人，不会再有猫爪的阴影在我身旁。","tone":"陈述","chapter":18,"line_start":760,"line_end":760},{"speaker":"char_gong_jiu","speaker_name":"宫九","listener":null,"text":"那你就明天再瞧吧。","tone":"陈述","chapter":18,"line_start":762,"line_end":762},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"明天，多么充满希望的字眼！","tone":"陈述","chapter":18,"line_start":764,"line_end":764},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你这人一生中，有没有真的烦恼过？","tone":"陈述","chapter":18,"line_start":774,"line_end":774},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"你以前问过我这个问题。","tone":"疑问","chapter":18,"line_start":776,"line_end":776},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你以前的答案是没有。","tone":"陈述","chapter":18,"line_start":778,"line_end":778},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"你记性很好。","tone":"陈述","chapter":18,"line_start":780,"line_end":780},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"现在呢？","tone":"陈述","chapter":18,"line_start":782,"line_end":782},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"有。","tone":"陈述","chapter":18,"line_start":784,"line_end":784},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"什么烦恼？","tone":"陈述","chapter":18,"line_start":786,"line_end":786},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"胡子的烦恼。","tone":"陈述","chapter":18,"line_start":788,"line_end":788},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你为了你没有胡子而烦恼？","tone":"陈述","chapter":18,"line_start":790,"line_end":790},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"不是。","tone":"陈述","chapter":18,"line_start":792,"line_end":792},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"不是？","tone":"陈述","chapter":18,"line_start":794,"line_end":794},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"我是为了你没有胡子而烦恼。","tone":"陈述","chapter":18,"line_start":796,"line_end":796},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"哦？为什么？","tone":"陈述","chapter":18,"line_start":798,"line_end":798},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"因为你上次求我帮你忙，我说除非你把胡子刮干净，随便你要去干什么，我都跟你去。","tone":"陈述","chapter":18,"line_start":800,"line_end":800}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":801,"line_end":908,"dialogues":[{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我记得，那是我第一次为了别人刮胡子。","tone":"陈述","chapter":18,"line_start":802,"line_end":802},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"现在你又刮干净了胡子，所以我知道，我的烦恼又来了。","tone":"陈述","chapter":18,"line_start":804,"line_end":804},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"这酒适合慢慢品尝。","tone":"陈述","chapter":18,"line_start":808,"line_end":808},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"我知道。","tone":"陈述","chapter":18,"line_start":810,"line_end":810},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"那你为什么一口喝光？","tone":"疑问","chapter":18,"line_start":812,"line_end":812},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"因为我在等你。","tone":"陈述","chapter":18,"line_start":814,"line_end":814},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"等我，等我什么？","tone":"疑问","chapter":18,"line_start":816,"line_end":816},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"等你一句话。","tone":"陈述","chapter":18,"line_start":818,"line_end":818},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"什么话？","tone":"疑问","chapter":18,"line_start":820,"line_end":820},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"解除我烦恼的话。","tone":"陈述","chapter":18,"line_start":822,"line_end":822},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"你要去干什么，我都跟你去。","tone":"陈述","chapter":18,"line_start":824,"line_end":824},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"现在你可以再倒两杯酒，我们可以慢慢品尝了。","tone":"陈述","chapter":18,"line_start":826,"line_end":826},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"为你的一句话。","tone":"陈述","chapter":18,"line_start":828,"line_end":828},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"为你的胡子。","tone":"陈述","chapter":18,"line_start":830,"line_end":830},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你的喜好变了？","tone":"疑问","chapter":18,"line_start":838,"line_end":838},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"没有。","tone":"陈述","chapter":18,"line_start":840,"line_end":840},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"那为什么换了古琴？","tone":"疑问","chapter":18,"line_start":842,"line_end":842},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"笛声悠扬，清涤作用却没有古琴的琴音大。","tone":"陈述","chapter":18,"line_start":844,"line_end":844},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"清涤作用？清涤什么？","tone":"疑问","chapter":18,"line_start":846,"line_end":846},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"杀气。","tone":"陈述","chapter":18,"line_start":848,"line_end":848},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"清涤杀气？","tone":"疑问","chapter":18,"line_start":850,"line_end":850},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"清涤谁的杀气？","tone":"疑问","chapter":18,"line_start":854,"line_end":854},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"马车上的人。","tone":"陈述","chapter":18,"line_start":856,"line_end":856},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你感觉得到他的杀气？","tone":"疑问","chapter":18,"line_start":858,"line_end":858},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"很浓的杀气。","tone":"陈述","chapter":18,"line_start":860,"line_end":860},{"speaker":"char_lu_xiao_feng","speaker_name":"陆小凤","listener":null,"text":"你知道他要杀谁吗？","tone":"疑问","chapter":18,"line_start":862,"line_end":862},{"speaker":"char_xi_men_chui_xue","speaker_name":"西门吹雪","listener":null,"text":"绝不是我。","tone":"陈述","chapter":18,"line_