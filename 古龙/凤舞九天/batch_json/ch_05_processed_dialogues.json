    "chapter": 5,
    "line_num": 40
  },
  {
    "speaker": "char_lu_xiao_feng",
    "speaker_name": "陆小凤",
    "listener": null,
    "text": "特别极了。",
    "tone": "普通",
    "chapter": 5,
    "line_num": 42
  },
  {
    "speaker": "char_zhuang_jia",
    "speaker_name": "庄家",
    "listener": null,
    "text": "有什么特别？",
    "tone": "普通",
    "chapter": 5,
    "line_num": 44
  },
  {
    "speaker": "char_lu_xiao_feng",
    "speaker_name": "陆小凤",
    "listener": "char_wu_ming",
    "text": "这把刀是用夜壶改成的。",
