    "chapter": 5,
    "line_num": 156
  },
  {
    "speaker": "char_wu_ming",
    "speaker_name": "小老头",
    "listener": "char_lu_xiao_feng",
    "text": "若是输了呢？",
    "tone": "普通",
    "chapter": 5,
    "line_num": 158
  },
  {
    "speaker": "char_lu_xiao_feng",
    "speaker_name": "陆小凤",
    "listener": "char_wu_ming",
    "text": "输了我赔。",
    "tone": "普通",
    "chapter": 5,
    "line_num": 160
  },
  {
    "speaker": "char_wu_ming",
    "speaker_name": "小老头",
    "listener": "char_lu_xiao_feng",
    "text": "怎么赔？用你那把天下无双的夜壶刀来赔？只可惜夜壶刀现在也已不是你的了。",
    "tone": "普通",
    "chapter": 5,
    "line_num": 162
  },
  {
    "speaker": "char_lu_xiao_feng",
    "speaker_name": "陆小凤",
    "listener": "char_wu_ming",
    "text": "不管怎么样，我反正一定不会输的，你借给我一万两，这场赌散了之后，我一定还你一万五千两。",
    "tone": "普通",
    "chapter": 5,
    "line_num": 164
  },
  {
    "speaker": "char_迟疑着",
    "speaker_name": "迟疑着",
    "listener": null,
    "text": "万一你还不出怎么办？",
