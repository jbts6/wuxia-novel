[
  {
    "speaker": null,
    "speaker_name": "未知",
    "listener": null,
    "text": "快下注，下得越大越好。",
    "tone": "普通",
    "chapter": 5,
    "line_num": 18
  },
  {
    "speaker": "char_lu_xiao_feng",
    "speaker_name": "陆小凤",
    "listener": "char_wu_ming",
