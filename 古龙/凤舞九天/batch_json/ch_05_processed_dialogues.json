    "speaker_name": "沙曼",
    "listener": "char_lu_xiao_feng",
    "text": "你好像又替我带来了运气。",
    "tone": "普通",
    "chapter": 5,
    "line_num": 196
  },
  {
    "speaker": "char_lu_xiao_feng",
    "speaker_name": "陆小凤",
    "listener": "char_sha_man",
    "text": "我带给你的好运气，你能不能借给我一点？",
    "tone": "普通",
    "chapter": 5,
    "line_num": 198
  },
  {
    "speaker": "char_她立刻",
    "speaker_name": "她立刻",
    "listener": null,
    "text": "我的手又不是骰子，你拉住我干什么？",
