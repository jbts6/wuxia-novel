  },
  {
    "speaker": "char_wu_ming",
    "speaker_name": "小老头",
    "listener": "char_lu_xiao_feng",
    "text": "我只怕你自己会后悔。",
    "tone": "普通",
    "chapter": 5,
    "line_num": 178
  },
  {
    "speaker": "char_lu_xiao_feng",
    "speaker_name": "陆小凤",
    "listener": "char_sha_man",
    "text": "老头子借了赌本给你？他信得过你？",
