  },
  {
    "speaker": "char_sha_man",
    "speaker_name": "沙曼",
    "listener": "char_lu_xiao_feng",
    "text": "总算有人识货的。",
    "tone": "普通",
    "chapter": 5,
    "line_num": 62
  },
  {
    "speaker": "char_sha_man",
    "speaker_name": "沙曼",
    "listener": "char_lu_xiao_feng",
    "text": "我若识货，就不会借这五百两给你了。",
