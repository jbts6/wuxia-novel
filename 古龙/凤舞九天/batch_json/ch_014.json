      "chapter": 14,
      "line_start": 183,
      "line_end": 184
    },
    {
      "speaker": "char_gong_jiu",
      "speaker_name": "宫九",
      "listener": "char_lu_xiao_feng",
      "text": "我就是宫九。",
      "tone": "冷静",
      "chapter": 14,
      "line_start": 209,
      "line_end": 209
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_gong_jiu",
      "text": "我知道！",
      "tone": "淡然",
      "chapter": 14,
      "line_start": 211,
      "line_end": 211
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_gong_jiu",
      "text": "你就是宫九？",
      "tone": "疑问",
      "chapter": 14,
      "line_start": 227,
      "line_end": 227
    },
    {
      "speaker": "char_gong_jiu",
      "speaker_name": "宫九",
      "listener": "char_lu_xiao_feng",
      "text": "我就是。",
      "tone": "陈述",
      "chapter": 14,
      "line_start": 229,
      "line_end": 229
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_gong_jiu",
      "text": "你一定想不到我会来找你？",
      "tone": "疑问",
      "chapter": 14,
      "line_start": 231,
      "line_end": 231
    },
    {
      "speaker": "char_gong_jiu",
      "speaker_name": "宫九",
      "listener": "char_lu_xiao_feng",
      "text": "世上不怕死的人很多，并不止你一个。",
      "tone": "冷酷",
      "chapter": 14,
      "line_start": 233,
      "line_end": 233
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_gong_jiu",
      "text": "我怕死。",
      "tone": "陈述",
      "chapter": 14,
      "line_start": 235,
      "line_end": 235
    },
    {
      "speaker": "char_gong_jiu",
      "speaker_name": "宫九",
      "listener": "char_lu_xiao_feng",
      "text": "所以你现在一定很后悔。",
      "tone": "冷笑",
      "chapter": 14,
      "line_start": 237,
      "line_end": 237
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_gong_jiu",
