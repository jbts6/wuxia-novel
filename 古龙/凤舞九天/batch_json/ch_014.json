      "speaker_name": "小玉",
      "listener": "char_sha_man",
      "text": "当然不能说我不喜欢他，可是……",
      "tone": "犹豫",
      "chapter": 14,
      "line_start": 52,
      "line_end": 52
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_sha_man",
      "text": "可是我这样做并不是为了他。",
      "tone": "认真",
      "chapter": 14,
      "line_start": 54,
      "line_end": 54
    },
    {
      "speaker": "char_sha_man",
      "speaker_name": "沙曼",
      "listener": "char_xiao_yu",
      "text": "不是？",
      "tone": "惊讶",
