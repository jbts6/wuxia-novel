      "speaker_name": "小玉",
      "listener": "char_sha_man",
      "text": "我是为了我自己。",
      "tone": "认真",
      "chapter": 14,
      "line_start": 66,
      "line_end": 66
    },
    {
      "speaker": "char_sha_man",
      "speaker_name": "沙曼",
      "listener": "char_xiao_yu",
      "text": "可是你并不需要来冒这种险的？",
