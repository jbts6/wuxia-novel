      "line_start": 287,
      "line_end": 287
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_gong_jiu",
      "text": "在箱子里面。",
      "tone": "平静",
      "chapter": 14,
      "line_start": 293,
      "line_end": 293
    },
    {
      "speaker": "char_gong_jiu",
      "speaker_name": "宫九",
      "listener": "char_lu_xiao_feng",
      "text": "你知道我问的是谁？",
      "tone": "疑问",
      "chapter": 14,
      "line_start": 295,
      "line_end": 295
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_gong_jiu",
      "text": "我知道。",
      "tone": "陈述",
      "chapter": 14,
      "line_start": 297,
      "line_end": 297
    },
    {
