      "chapter": 14,
      "line_start": 239,
      "line_end": 239
    },
    {
      "speaker": "char_gong_jiu",
      "speaker_name": "宫九",
      "listener": "char_lu_xiao_feng",
      "text": "后悔刚才为什么不杀了我。",
      "tone": "冷笑",
      "chapter": 14,
      "line_start": 241,
      "line_end": 241
    },
    {
      "speaker": "char_lu_xiao_feng",
      "speaker_name": "陆小凤",
      "listener": "char_gong_jiu",
      "text": "刚才我的确有机会杀了你的。",
