      "chapter": 14,
      "line_start": 68,
      "line_end": 68
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_sha_man",
      "text": "我有原因。",
      "tone": "平静",
      "chapter": 14,
      "line_start": 70,
      "line_end": 70
    },
    {
      "speaker": "char_sha_man",
      "speaker_name": "沙曼",
      "listener": "char_xiao_yu",
      "text": "你能不能告诉我？",
      "tone": "疑问",
      "chapter": 14,
      "line_start": 72,
      "line_end": 72
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_sha_man",
      "text": "现在还不能。",
      "tone": "平静",
      "chapter": 14,
      "line_start": 74,
      "line_end": 74
    },
    {
      "speaker": "char_xiao_yu",
      "speaker_name": "小玉",
      "listener": "char_sha_man",
      "text": "只要陆小凤能活着回来，我一定会告诉你的，就算你们不想听都不行。",
      "tone": "认真",
      "chapter": 14,
      "line_start": 78,
      "line_end": 78
    },
    {
      "speaker": "char_gong_jiu",
