    "techniques": [
      {
        "id": "tech_hua_gu_mian_zhang_ji",
        "name": "化骨绵掌击",
        "type": "attack",
        "description": "一掌打在人身上，被打的人浑如不觉，两个时辰后掌力发作，全身骨骼变得其软如绵"
      }
    ],
    "progression": [
      {
        "level": 1,
        "unlock": "初练掌力"
      },
