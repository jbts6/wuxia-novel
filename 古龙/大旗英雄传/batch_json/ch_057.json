      "speaker_name": "易明",
      "listener": null,
      "text": "但……但……",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 111,
      "line_end": 111
    },
    {
      "speaker": "char_yun_yi",
      "speaker_name": "云翼",
      "listener": null,
      "text": "莫要多说，快快走吧！",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 113,
      "line_end": 113
    },
    {
      "speaker": "char_yun_yi",
      "speaker_name": "云翼",
      "listener": null,
      "text": "他人之事，难道比本门血仇还要重要？",
