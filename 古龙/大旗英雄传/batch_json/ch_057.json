      "speaker_name": "云翼",
      "listener": null,
      "text": "快说！",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 137,
      "line_end": 137
    },
    {
      "speaker": "char_yi_ming",
      "speaker_name": "易明",
      "listener": null,
      "text": "你要我走，莫非怕我勾引你家弟子？",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 139,
      "line_end": 139
    },
    {
      "speaker": "char_yun_yi",
      "speaker_name": "云翼",
      "listener": null,
      "text": "这……",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 143,
      "line_end": 143
    },
    {
      "speaker": "char_yun_yi",
      "speaker_name": "云翼",
      "listener": null,
      "text": "住口！",
      "tone": "陈述",
