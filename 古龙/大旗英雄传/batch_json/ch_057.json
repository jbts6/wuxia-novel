    },
    {
      "speaker": "char_hei_xing_tian",
      "speaker_name": "黑星天",
      "listener": null,
      "text": "当真是巧遇……巧遇……",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 447,
      "line_end": 447
    },
    {
      "speaker": "char_yun_yi",
      "speaker_name": "云翼",
      "listener": null,
      "text": "站住！",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 451,
      "line_end": 451
    },
    {
      "speaker": "char_yun_yi",
      "speaker_name": "云翼",
      "listener": null,
      "text": "既然如此，且转过身来，与我决一死战。",
