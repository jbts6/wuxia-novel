      "line_start": 457,
      "line_end": 457
    },
    {
      "speaker": "char_si_tu_xiao",
      "speaker_name": "司徒笑",
      "listener": null,
      "text": "我早想宰了他了。",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 467,
      "line_end": 467
    },
    {
      "speaker": "char_yun_yi",
      "speaker_name": "云翼",
      "listener": null,
      "text": "你还不回身？",
      "tone": "陈述",
