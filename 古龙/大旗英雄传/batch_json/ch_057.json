      "speaker_name": "易明",
      "listener": null,
      "text": "我……我知道。",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 107,
      "line_end": 107
    },
    {
      "speaker": "char_yun_yi",
      "speaker_name": "云翼",
      "listener": null,
      "text": "你既知道，还不快走？",
