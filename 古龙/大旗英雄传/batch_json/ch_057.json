    },
    {
      "speaker": "char_sun_xiao_jiao",
      "speaker_name": "孙小娇",
      "listener": null,
      "text": "是该闭起了，只还有一句话要说。",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 425,
      "line_end": 425
    },
    {
      "speaker": "char_si_tu_xiao",
      "speaker_name": "司徒笑",
      "listener": null,
      "text": "什么话？",
      "tone": "陈述",
      "chapter": 57,
      "line_start": 427,
      "line_end": 427
    },
    {
      "speaker": "char_si_tu_xiao",
      "speaker_name": "司徒笑",
      "listener": null,
      "text": "咱们不会回头的，你也逃不了……",
      "tone": "豪迈",
      "chapter": 57,
      "line_start": 437,
