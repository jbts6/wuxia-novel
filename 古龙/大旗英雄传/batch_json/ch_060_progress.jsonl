_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":36,"line_end":36,"text":"只有白星武"}]},{"id":"char_yun_ting_ting","name":"云婷婷","alias":[],"identity":"大旗门弟子","faction":"大旗门","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"大旗门年轻弟子，云翼之女","personality":{"traits":["勇敢","刚毅","初生牛犊","孝顺","坚韧"],"speech_style":"直率","temperament":"刚烈"},"relationships":[{"target":"char_yun_yi","type":"亲属","intensity":85,"bond_level":4,"dynamic":"父女"},{"target":"char_tie_qing_shu","type":"挚友","intensity":75,"bond_level":3,"dynamic":"并肩作战"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":38,"line_end":38,"text":"云婷婷、铁青树竟是初生之犊不怕虎"}]},{"id":"char_tie_qing_shu","name":"铁青树","alias":[],"identity":"大旗门弟子","faction":"大旗门","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"大旗门年轻弟子，勇猛好斗","personality":{"traits":["勇猛","刚毅","不畏强敌","强悍","忠诚"],"speech_style":"豪爽","temperament":"刚烈"},"relationships":[{"target":"char_yun_ting_ting","type":"挚友","intensity":75,"bond_level":3,"dynamic":"并肩作战"},{"target":"char_yi_ming","type":"恋人","intensity":80,"bond_level":4,"dynamic":"深情关注"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":38,"line_end":38,"text":"云婷婷、铁青树竟是初生之犊不怕虎"}]},{"id":"char_feng_jiu_you","name":"风九幽","alias":[],"identity":"武林高手","faction":null,"role":"villain","archetype":"assassin","rank":"登峰造极","one_line":"武林枭雄，精通催眠之术，最终死于赤足汉斧下","personality":{"traits":["诡诈","残忍","得意忘形","阴险","变态"],"speech_style":"阴柔","temperament":"疯狂"},"relationships":[{"target":"char_xiu_du_da_shi","type":"主仆","intensity":90,"bond_level":4,"dynamic":"精神控制"},{"target":"char_zhuo_san_niang","type":"合作者","intensity":40,"bond_level":2,"dynamic":"互相利用"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":62,"line_end":62,"text":"风九幽，突然长身而起"}]},{"id":"char_sun_xiao_jiao","name":"孙小娇","alias":[],"identity":"江湖中人","faction":null,"role":"npc","archetype":"assassin","rank":"初窥门径","one_line":"乘乱抱着沈杏白溜走的女子","personality":{"traits":["狡猾","贪生怕死","见风使舵","自私","机灵"],"speech_style":"圆滑","temperament":"机敏"},"relationships":[{"target":"char_shen_xing_bai","type":"合作者","intensity":50,"bond_level":2,"dynamic":"同逃"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":60,"line_end":60,"text":"孙小娇竟抱着沈杏白"}]},{"id":"char_shen_xing_bai","name":"沈杏白","alias":[],"identity":"江湖中人","faction":null,"role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"被孙小娇抱着逃走之人","personality":{"traits":["懦弱","依附","无主见","被动","沉默"],"speech_style":"沉默","temperament":"懦弱"},"relationships":[{"target":"char_sun_xiao_jiao","type":"合作者","intensity":50,"bond_level":2,"dynamic":"同逃"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":60,"line_end":60,"text":"孙小娇竟抱着沈杏白"}]},{"id":"char_xiu_du_da_shi","name":"飧毒大师","alias":["冷一枫"],"identity":"毒门之主","faction":"毒门","role":"villain","archetype":"assassin","rank":"出神入化","one_line":"毒门之主，被风九幽催眠控制，最终与毒神同归于尽","personality":{"traits":["阴毒","用毒如神","心机深沉","疯狂","悲凉"],"speech_style":"阴沉","temperament":"疯狂"},"relationships":[{"target":"char_feng_jiu_you","type":"主仆","intensity":90,"bond_level":4,"dynamic":"精神控制"},{"target":"char_du_shen","type":"主仆","intensity":80,"bond_level":4,"dynamic":"操控"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":74,"line_end":74,"text":"风九幽走到飧毒面前"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_da_qi_men","name":"大旗门","type":"武林门派","location":"草原","sub_divisions":[],"one_line":"武林正派门派，与五福联盟世代为敌","source_refs":[{"chapter":60,"line_start":14,"line_end":14,"text":"便也不许有人相助大旗门"}]},{"id":"faction_wu_fu_lian_meng","name":"五福联盟","type":"帮派","location":"中原","sub_divisions":[],"one_line":"由盛、冷等六姓子弟组成的联盟，与大旗门世代为敌","source_refs":[{"chapter":60,"line_start":14,"line_end":14,"text":"既不许别人为'五福联盟'帮拳"}]},{"id":"faction_du_men","name":"毒门","type":"武林门派","location":null,"sub_divisions":[],"one_line":"以用毒闻名的门派，由飧毒大师统领","source_refs":[{"chapter":60,"line_start":148,"line_end":148,"text":"本门毒神何在"}]}],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":111,"line_end":220,"dialogues":[{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_xiu_du_da_shi","text":"如今在世上你已只有一个主子，无论他说什么，你都不能违抗……你的主子是谁？你可知道么？","tone":"柔声","chapter":60,"line_start":116,"line_end":118},{"speaker":"char_xiu_du_da_shi","speaker_name":"飧毒大师","listener":"char_feng_jiu_you","text":"主子是你。","tone":"陈述","chapter":60,"line_start":120,"line_end":120},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_xiu_du_da_shi","text":"你若违抗了主子，又当如何？","tone":"沉声","chapter":60,"line_start":122,"line_end":122},{"speaker":"char_xiu_du_da_shi","speaker_name":"飧毒大师","listener":"char_feng_jiu_you","text":"悉听主子惩罚。","tone":"陈述","chapter":60,"line_start":124,"line_end":124},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_xiu_du_da_shi","text":"你体内所中之毒，已被我神力阻住，绝对不致发作。要知古之'慑心之术'，便乃今日'催眠之术'，其术本有治病之力，今之医家，遇着无救之症，若施此术，每奏奇效。","tone":"柔声","chapter":60,"line_start":126,"line_end":130},{"speaker":"char_xiu_du_da_shi","speaker_name":"飧毒大师","listener":"char_feng_jiu_you","text":"多谢。","tone":"陈述","chapter":60,"line_start":132,"line_end":132},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_xiu_du_da_shi","text":"但你若违抗主子之命，这毒性立刻便将发作，那时世上再也没有人能救得了你了，知道么？","tone":"沉声","chapter":60,"line_start":134,"line_end":136},{"speaker":"char_xiu_du_da_shi","speaker_name":"飧毒大师","listener":"char_feng_jiu_you","text":"知道。","tone":"陈述","chapter":60,"line_start":138,"line_end":138},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_xiu_du_da_shi","text":"好，如今你已可叫你的毒神回来，告诉他谁是大旗子弟，令他将大旗子弟，个个斩尽，人人诛绝。","tone":"得意","chapter":60,"line_start":140,"line_end":142},{"speaker":"char_xiu_du_da_shi","speaker_name":"飧毒大师","listener":"char_feng_jiu_you","text":"遵命。","tone":"陈述","chapter":60,"line_start":144,"line_end":144},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_chi_zu_han","text":"神斧力士何在？","tone":"厉声","chapter":60,"line_start":146,"line_end":146},{"speaker":"char_xiu_du_da_shi","speaker_name":"飧毒大师","listener":"char_du_shen","text":"本门毒神何在？","tone":"厉声","chapter":60,"line_start":148,"line_end":148},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_chi_zu_han","text":"赤足汉，你本乃大旗子弟，知道么？","tone":"沉声","chapter":60,"line_start":158,"line_end":160},{"speaker":"char_chi_zu_han","speaker_name":"赤足汉","listener":"char_feng_jiu_you","text":"是。","tone":"陈述","chapter":60,"line_start":162,"line_end":162},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_chi_zu_han","text":"我手指的这三人，便是你不共戴天的仇人，你此刻快快前去取了他三人性命，不得有误。","tone":"厉声","chapter":60,"line_start":164,"line_end":166},{"speaker":"char_chi_zu_han","speaker_name":"赤足汉","listener":"char_feng_jiu_you","text":"是。","tone":"陈述","chapter":60,"line_start":168,"line_end":168},{"speaker":"char_yun_jiu_xiao","speaker_name":"云九霄","listener":"char_yun_yi","text":"大哥小心。","tone":"焦急","chapter":60,"line_start":172,"line_end":172},{"speaker":"char_yun_jiu_xiao","speaker_name":"云九霄","listener":"char_tie_qing_shu","text":"青树、婷婷，住手，快退！","tone":"焦急","chapter":60,"line_start":176,"line_end":178},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":null,"text":"好玩好玩，妙极妙极。","tone":"大笑","chapter":60,"line_start":190,"line_end":190},{"speaker":"char_si_tu_xiao","speaker_name":"司徒笑","listener":"char_feng_jiu_you","text":"风老前辈，你……你怎的……","tone":"惊讶","chapter":60,"line_start":192,"line_end":192},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_si_tu_xiao","text":"赤足汉本是大旗子弟，自然要找你们算账，你唤我则甚？","tone":"大笑","chapter":60,"line_start":194,"line_end":196},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_zhuo_san_niang","text":"卓……卓老前辈，你怎地……","tone":"惊讶","chapter":60,"line_start":198,"line_end":198},{"speaker":"char_zhuo_san_niang","speaker_name":"卓三娘","listener":"char_yi_ming","text":"冷一枫本是五福联盟中人，自然要找大旗子弟，你唤我作甚？你瞧，此刻动手的，有哪一个不是他们这纠缠恩怨的当事人？有哪一个外人插了手？你三娘做事，是否公正得很？","tone":"大笑","chapter":60,"line_start":200,"line_end":204},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_zhuo_san_niang","text":"你好狠！你们好狠！你们非但要大旗门全军覆没，也要叫五福联盟死个干净，你们如此做法，为的是什么？","tone":"愤怒","chapter":60,"line_start":206,"line_end":208},{"speaker":"char_zhuo_san_niang","speaker_name":"卓三娘","listener":"char_yi_ming","text":"他们都死干净了，天下岂非就太平得很？","tone":"微笑","chapter":60,"line_start":210,"line_end":210},{"speaker":null,"speaker_name":"殿堂外之人","listener":null,"text":"这是干什么？造反了么？全都给我住手。","tone":"厉声","chapter":60,"line_start":214,"line_end":216},{"speaker":"char_zhuo_san_niang","speaker_name":"卓三娘","listener":"char_hua_shuang_shuang","text":"花二娘，不准你多事，过来。","tone":"厉声","chapter":60,"line_start":220,"line_end":220}],"new_entities":{"characters":[{"id":"char_du_shen","name":"毒神","alias":["冷一枫"],"identity":"被控制的毒门傀儡","faction":"毒门","role":"villain","archetype":"assassin","rank":"登峰造极","one_line":"被毒门控制的恐怖傀儡，最终与飧毒大师同归于尽","personality":{"traits":["恐怖","无情","嗜杀","机械","悲哀"],"speech_style":"无","temperament":"疯狂"},"relationships":[{"target":"char_xiu_du_da_shi","type":"主仆","intensity":80,"bond_level":4,"dynamic":"被操控"},{"target":"char_yun_yi","type":"宿敌","intensity":100,"bond_level":5,"dynamic":"同归于尽"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":150,"line_end":150,"text":"毒神如御急风，掠至飧毒身侧"}]},{"id":"char_chi_zu_han","name":"赤足汉","alias":[],"identity":"大旗子弟（失忆）","faction":"大旗门","role":"villain","archetype":"warrior","rank":"出神入化","one_line":"被风九幽控制的大旗子弟，手持巨斧斩杀五福联盟众人","personality":{"traits":["勇猛","忠义","被操控","悲剧","强悍"],"speech_style":"沉默","temperament":"机械"},"relationships":[{"target":"char_feng_jiu_you","type":"主仆","intensity":90,"bond_level":4,"dynamic":"精神控制"},{"target":"char_bai_xing_wu","type":"宿敌","intensity":100,"bond_level":5,"dynamic":"复仇"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":150,"line_end":150,"text":"赤足汉亦自大步奔到风九幽面前"}]},{"id":"char_hua_shuang_shuang","name":"花双霜","alias":["花二娘"],"identity":"武林绝顶高手","faction":null,"role":"npc","archetype":"warrior","rank":"登峰造极","one_line":"武林绝顶高手，烟雨花双霜，花灵铃之母","personality":{"traits":["强势","护女","精明","冷傲","深情"],"speech_style":"冷傲","temperament":"冷傲"},"relationships":[{"target":"char_hua_ling_ling","type":"亲属","intensity":100,"bond_level":5,"dynamic":"母女重逢"},{"target":"char_zhuo_san_niang","type":"合作者","intensity":40,"bond_level":2,"dynamic":"表面和睦"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":218,"line_end":218,"text":"一条人影，翩然掠来，正是花双霜"}]},{"id":"char_shui_ling_guang","name":"水灵光","alias":[],"identity":"夜帝之女","faction":null,"role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"夜帝之女，被卓三娘抢走作为人质","personality":{"traits":["纯真","深情","柔弱","坚贞","痴情"],"speech_style":"温柔","temperament":"温柔"},"relationships":[{"target":"char_tie_zhong_tang","type":"恋人","intensity":100,"bond_level":5,"dynamic":"生死相许"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":222,"line_end":222,"text":"怀中的水灵光，已被卓三娘抢了过去"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":221,"line_end":330,"dialogues":[{"speaker":"char_hua_shuang_shuang","speaker_name":"花双霜","listener":"char_zhuo_san_niang","text":"三丫头，是你，你什么时候变得可以命令我了？","tone":"冷笑","chapter":60,"line_start":224,"line_end":226},{"speaker":"char_zhuo_san_niang","speaker_name":"卓三娘","listener":"char_hua_shuang_shuang","text":"二姐你好，你瞧瞧这是谁？","tone":"微笑","chapter":60,"line_start":228,"line_end":228},{"speaker":"char_hua_shuang_shuang","speaker_name":"花双霜","listener":"char_zhuo_san_niang","text":"我的女儿……还我，我的女儿……","tone":"焦急","chapter":60,"line_start":230,"line_end":230},{"speaker":"char_zhuo_san_niang","speaker_name":"卓三娘","listener":"char_hua_shuang_shuang","text":"只要二姐不多事，小妹自当将她双手奉回。","tone":"微笑","chapter":60,"line_start":232,"line_end":234},{"speaker":"char_hua_shuang_shuang","speaker_name":"花双霜","listener":"char_zhuo_san_niang","text":"好，三丫头，我听你的，你可不能伤了我女儿一根毫发。","tone":"无奈","chapter":60,"line_start":236,"line_end":238},{"speaker":"char_zhuo_san_niang","speaker_name":"卓三娘","listener":"char_hua_shuang_shuang","text":"这小宝贝儿我爱都惟恐爱不够，又怎舍得伤她？二姐，你且安下心，瞧他们这场架打得多有意思。","tone":"大笑","chapter":60,"line_start":240,"line_end":242},{"speaker":"char_si_tu_xiao","speaker_name":"司徒笑","listener":null,"text":null,"tone":"狂笑","chapter":60,"line_start":258,"line_end":258},{"speaker":"char_feng_jiu_you","speaker_name":"风九幽","listener":"char_si_tu_xiao","text":"笑得好……笑得好……","tone":"怪笑","chapter":60,"line_start":260,"line_end":260},{"speaker":"char_si_tu_xiao","speaker_name":"司徒笑","listener":"char_feng_jiu_you","text":"你要我死，我也要你死……","tone":"狞笑","chapter":60,"line_start":266,"line_end":266},{"speaker":"char_zhuo_san_niang","speaker_name":"卓三娘","listener":null,"text":"老四！老四你……你……","tone":"悲伤","chapter":60,"line_start":278,"line_end":278},{"speaker":"char_yun_yi","speaker_name":"云翼","listener":"char_yun_ting_ting","text":"大旗子弟全都到这边来。","tone":"厉声","chapter":60,"line_start":284,"line_end":286},{"speaker":"char_yun_yi","speaker_name":"云翼","listener":"char_du_shen","text":"大旗门血仇已报，云某此生已无憾，再也不受被人追逐之辱……冷一枫，你来吧！","tone":"豪迈","chapter":60,"line_start":290,"line_end":292},{"speaker":"char_yun_jiu_xiao","speaker_name":"云九霄","listener":"char_yun_yi","text":"大哥！使不得。","tone":"焦急","chapter":60,"line_start":294,"line_end":294},{"speaker":"char_yun_yi","speaker_name":"云翼","listener":"char_du_shen","text":"这是大旗门最后一个仇人，我和他拼了。","tone":"狂笑","chapter":60,"line_start":298,"line_end":300},{"speaker":"char_yun_jiu_xiao","speaker_name":"云九霄","listener":"char_yun_yi","text":"大哥……大哥……","tone":"悲痛","chapter":60,"line_start":304,"line_end":304},{"speaker":null,"speaker_name":"冷青萍","listener":null,"text":"我不骗你，里面一定有人……好姐夫，你随我来吧！","tone":"柔声","chapter":60,"line_start":312,"line_end":314}],"new_entities":{"characters":[{"id":"char_hei_xing_tian","name":"黑星天","alias":[],"identity":"五福联盟中人","faction":"五福联盟","role":"villain","archetype":"warrior","rank":"炉火纯青","one_line":"五福联盟中人，与白星武生死与共，被赤足汉斩杀","personality":{"traits":["冷酷","重义气","狠毒","精明","老练"],"speech_style":"冷酷","temperament":"冷酷"},"relationships":[{"target":"char_bai_xing_wu","type":"挚友","intensity":90,"bond_level":5,"dynamic":"生死与共"},{"target":"char_yun_yi","type":"宿敌","intensity":90,"bond_level":4,"dynamic":"世代为敌"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":254,"line_end":256,"text":"黑星天虽然冷酷无情，但瞧见数十年来生死与共的弟兄尸身倒下"}]},{"id":"char_leng_qing_ping","name":"冷青萍","alias":[],"identity":"冷一枫之女","faction":null,"role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"冷一枫之女，神智不清，被亲父杀死","personality":{"traits":["天真","痴情","神智不清","悲惨","纯真"],"speech_style":"天真","temperament":"疯狂"},"relationships":[{"target":"char_du_shen","type":"亲属","intensity":100,"bond_level":5,"dynamic":"被父所杀"},{"target":"char_leng_qing_shuang","type":"亲属","intensity":80,"bond_level":4,"dynamic":"姐妹"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":316,"line_end":316,"text":"当先一人正是冷青萍"}]},{"id":"char_yun_keng","name":"云铿","alias":[],"identity":"大旗门云翼之子","faction":"大旗门","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"云翼之子，曾在再生草庐隐居，闻讯赶来","personality":{"traits":["孝顺","重情","刚烈","隐忍","悲痛"],"speech_style":"沉稳","temperament":"刚烈"},"relationships":[{"target":"char_yun_yi","type":"亲属","intensity":100,"bond_level":5,"dynamic":"父子"},{"target":"char_hai_da_shao","type":"挚友","intensity":70,"bond_level":3,"dynamic":"一见投缘"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":316,"line_end":316,"text":"赫然竟是再生草庐中的云铿"}]},{"id":"char_hai_da_shao","name":"海大少","alias":[],"identity":"江湖豪客","faction":null,"role":"npc","archetype":"warrior","rank":"出神入化","one_line":"江湖豪客，敬佩铁中棠，与云铿结伴而来","personality":{"traits":["豪迈","直爽","重义","强傲","热心"],"speech_style":"豪迈","temperament":"豪迈"},"relationships":[{"target":"char_yun_keng","type":"挚友","intensity":70,"bond_level":3,"dynamic":"一见投缘"},{"target":"char_tie_zhong_tang","type":"挚友","intensity":90,"bond_level":4,"dynamic":"敬佩"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":316,"line_end":316,"text":"久未露面的海大少"}]},{"id":"char_hua_ling_ling","name":"花灵铃","alias":["柳荷衣"],"identity":"花双霜之女","faction":null,"role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"花双霜之女，失忆后化名柳荷衣，因雷击恢复记忆","personality":{"traits":["痴情","纯真","坚贞","勇敢","多情"],"speech_style":"温柔","temperament":"温柔"},"relationships":[{"target":"char_hua_shuang_shuang","type":"亲属","intensity":100,"bond_level":5,"dynamic":"母女重逢"},{"target":"char_lei_xiao_diao","type":"恋人","intensity":90,"bond_level":4,"dynamic":"痴情等待"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":316,"line_end":316,"text":"那铁匠村中的青衣少女柳荷衣"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":331,"line_end":440,"dialogues":[{"speaker":"char_hua_ling_ling","speaker_name":"花灵铃","listener":"char_hua_shuang_shuang","text":"妈！","tone":"惊讶","chapter":60,"line_start":342,"line_end":342},{"speaker":"char_yun_keng","speaker_name":"云铿","listener":"char_yun_yi","text":"爹！","tone":"悲痛","chapter":60,"line_start":344,"line_end":344},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_du_shen","text":"爹，你在这里。","tone":"欣喜","chapter":60,"line_start":346,"line_end":346},{"speaker":"char_hua_shuang_shuang","speaker_name":"花双霜","listener":"char_hua_ling_ling","text":"呀！你才是灵铃，那个不是……那个不是……灵铃，我的好女儿，妈想死你了。","tone":"欣喜","chapter":60,"line_start":350,"line_end":354},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_du_shen","text":"呀！爹爹，你杀你女儿……你杀你亲生的女儿……好玩，真好玩。","tone":"狂笑","chapter":60,"line_start":360,"line_end":362},{"speaker":"char_xiu_du_da_shi","speaker_name":"飧毒大师","listener":"char_du_shen","text":"好，好，我要死了，本门毒神也不能留在世上，被他人所用……","tone":"大笑","chapter":60,"line_start":366,"line_end":366},{"speaker":"char_yin_da_niang","speaker_name":"阴大娘","listener":"char_zhuo_san_niang","text":"卓三娘，还不住手？","tone":"厉声","chapter":60,"line_start":384,"line_end":386},{"speaker":"char_zhuo_san_niang","speaker_name":"卓三娘","listener":"char_yin_da_niang","text":"好，好，常春岛终于来了人了……","tone":"惨笑","chapter":60,"line_start":388,"line_end":388},{"speaker":"char_yin_da_niang","speaker_name":"阴大娘","listener":"char_yun_jiu_xiao","text":"虽已来了，却已迟了……大旗门的恩怨，竟如此了结……大旗子弟听着，你们本门的恩怨纠缠，你们自己可清楚么？","tone":"悲伤","chapter":60,"line_start":390,"line_end":392},{"speaker":"char_yun_jiu_xiao","speaker_name":"云九霄","listener":"char_yin_da_niang","text":"但请赐教。","tone":"认真","chapter":60,"line_start":394,"line_end":394},{"speaker":"char_yin_da_niang","speaker_name":"阴大娘","listener":"char_yun_jiu_xiao","text":"此话须得从头说起……","tone":"认真","chapter":60,"line_start":396,"line_end":396},{"speaker":"char_yin_da_niang","speaker_name":"阴大娘","listener":"char_yun_jiu_xiao","text":"当今常春岛日后，昔日便是云翼的妻子。她自远游归来的常春圣女口中，听得此间风云际会，她老人家虽不知详情，但想来必与大旗门有关，是以，便令我前来见机化解，哪知……唉！事情的演变，竟是如此迅急激烈，我虽然抄近路由秘道赶来，还是已迟了一步。","tone":"悲伤","chapter":60,"line_start":418,"line_end":424},{"speaker":"char_yun_jiu_xiao","speaker_name":"云九霄","listener":"char_yin_da_niang","text":"常春岛既是从来不问大旗门事，此刻为何又……","tone":"激动","chapter":60,"line_start":430,"line_end":430},{"speaker":"char_yin_da_niang","speaker_name":"阴大娘","listener":"char_yun_jiu_xiao","text":"只因日后曾发下誓言，只要大旗门下，有一弟子肯为他的妻子不惜一死，她便……","tone":"认真","chapter":60,"line_start":432,"line_end":432},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":null,"tone":"悲痛","chapter":60,"line_start":432,"line_end":432},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":"char_yin_da_niang","text":"他……他……他究竟是生是死？","tone":"悲伤","chapter":60,"line_start":438,"line_end":438},{"speaker":"char_yin_da_niang","speaker_name":"阴大娘","listener":"char_wen_dai_dai","text":"是生是死，你自己去瞧瞧吧！","tone":"陈述","chapter":60,"line_start":440,"line_end":440}],"new_entities":{"characters":[{"id":"char_yin_da_niang","name":"阴大娘","alias":["摆渡老婆子"],"identity":"常春岛摆渡人","faction":"常春岛","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"常春岛摆渡人，曾与云九霄有旧情","personality":{"traits":["深沉","坚忍","重情","果断","悲伤"],"speech_style":"沉稳","temperament":"沉稳"},"relationships":[{"target":"char_yun_jiu_xiao","type":"恋人","intensity":80,"bond_level":4,"dynamic":"旧情难忘"},{"target":"char_zhuo_san_niang","type":"对手","intensity":50,"bond_level":2,"dynamic":"对峙"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":380,"line_end":380,"text":"白发鸠面，竟是常春岛上那摆渡的老婆子——阴大娘"}]},{"id":"char_leng_qing_shuang","name":"冷青霜","alias":[],"identity":"冷一枫之女","faction":null,"role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"冷一枫之女，与云铿相认","personality":{"traits":["温柔","坚强","重情","悲痛","勇敢"],"speech_style":"温柔","temperament":"温柔"},"relationships":[{"target":"char_yun_keng","type":"恋人","intensity":90,"bond_level":4,"dynamic":"重逢"},{"target":"char_du_shen","type":"亲属","intensity":80,"bond_level":4,"dynamic":"父女"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":380,"line_end":380,"text":"怀抱女儿，却是冷青霜"}]},{"id":"char_wen_dai_dai","name":"温黛黛","alias":[],"identity":"云铮之妻","faction":"大旗门","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"被司徒笑制住的大旗门人，深爱云铮","personality":{"traits":["痴情","坚贞","柔弱","勇敢","悲痛"],"speech_style":"温柔","temperament":"悲伤"},"relationships":[{"target":"char_yun_zheng","type":"恋人","intensity":100,"bond_level":5,"dynamic":"生死相许"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":432,"line_end":432,"text":"石案下已有一人放声痛哭起来，哭的人自然就是被司徒笑制住了的温黛黛"}]},{"id":"char_yun_zheng","name":"云铮","alias":[],"identity":"大旗门弟子，云翼之子","faction":"大旗门","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"云翼之子，坠崖生死未卜","personality":{"traits":["勇敢","忠义","刚毅","深情","无畏"],"speech_style":"豪迈","temperament":"刚烈"},"relationships":[{"target":"char_wen_dai_dai","type":"恋人","intensity":100,"bond_level":5,"dynamic":"生死相许"},{"target":"char_yun_yi","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父子"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":434,"line_end":434,"text":"日后既是云铮生身之母"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_chang_chun_dao","name":"常春岛","type":"武林门派","location":"海外孤岛","sub_divisions":[],"one_line":"朱夫人创立的门派，收容大旗门被遗弃的妻子","source_refs":[{"chapter":60,"line_start":402,"line_end":402,"text":"朱夫人生性较强，夫婿无情，她便远走海外，创立了常春岛"}]},{"id":"faction_feng_men","name":"风门","type":"家族","location":null,"sub_divisions":[],"one_line":"风夫人之弟创立的势力，暗中操纵五福联盟对抗大旗门","source_refs":[{"chapter":60,"line_start":406,"line_end":406,"text":"风夫人之弟见得姐姐境遇如此悲惨，一怒之下，决心报复"}]}],"locations":[{"id":"loc_chang_chun_dao","name":"常春岛","region":"海外","one_line":"朱夫人创立的海外孤岛，大旗门被遗弃妻子的归宿","source_refs":[{"chapter":60,"line_start":402,"line_end":402,"text":"她便远走海外，创立了常春岛"}]},{"id":"loc_bao_en_ci","name":"报恩祠","region":"草原","one_line":"供奉大旗门与五福联盟先人的祠堂","source_refs":[{"chapter":60,"line_start":410,"line_end":410,"text":"是以他们建造报恩祠时"}]}],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":441,"line_end":532,"dialogues":[{"speaker":"char_yun_jiu_xiao","speaker_name":"云九霄","listener":"char_yin_da_niang","text":"多……多谢夫人此行，夫人你……","tone":"悲伤","chapter":60,"line_start":446,"line_end":446},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":null,"text":"中棠……中棠……铁中棠，为何你偏偏死了？","tone":"悲痛","chapter":60,"line_start":464,"line_end":466},{"speaker":"char_lei_xiao_diao","speaker_name":"雷小雕","listener":"char_shui_ling_guang","text":"铁中棠没有死。","tone":"认真","chapter":60,"line_start":468,"line_end":468},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":"char_lei_xiao_diao","text":"你……你说什么？","tone":"惊讶","chapter":60,"line_start":470,"line_end":470},{"speaker":"char_lei_xiao_diao","speaker_name":"雷小雕","listener":"char_shui_ling_guang","text":"方才我伏身地下时，曾听得地底有人语传来，一位老人道：“铁中棠，你全是被老夫连累，你可后悔？”另一人想必就是铁中棠，他便道：“生死有命，怎可怪得你老人家？铁中棠一生无愧于天地，死又何惧？”","tone":"陈述","chapter":60,"line_start":472,"line_end":476},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":"char_lei_xiao_diao","text":"真……真的？","tone":"激动","chapter":60,"line_start":478,"line_end":478},{"speaker":"char_hai_da_shao","speaker_name":"海大少","listener":null,"text":"想必自是真的，除了铁中棠外，又有谁有如此豪迈的语气？哈哈！铁中棠呀铁中棠，俺早知你不会死的！你若死了，这还成何世界？哈哈！悲惨之事，既已都过去，世上既有如许多欢乐，他日俺必定要劝霹雳火那老儿还俗，随我闯闯江湖，总比做和尚的好。","tone":"大笑","chapter":60,"line_start":480,"line_end":486},{"speaker":"char_yi_ming","speaker_name":"易明","listener":null,"text":"我一生无憾，只恨未能见着这铁中棠一面，我实是……","tone":"悲伤","chapter":60,"line_start":510,"line_end":510},{"speaker":"char_hai_da_shao","speaker_name":"海大少","listener":"char_yi_ming","text":"莫要说了，铁中棠又未死，你还是能见他的，他……他不会死的，说不定……他此刻已远游海上，啸傲神仙。","tone":"豪迈","chapter":60,"line_start":512,"line_end":514},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":null,"text":"说不定他此刻还被困在那些山洞里，寻路不出，忍饥受饿……","tone":"悲伤","chapter":60,"line_start":516,"line_end":516},{"speaker":"char_yun_keng","speaker_name":"云铿","listener":null,"text":"你们走吧，我留在这里，我还要找。","tone":"认真","chapter":60,"line_start":518,"line_end":518},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":null,"text":"我也留在这里。","tone":"坚定","chapter":60,"line_start":520,"line_end":520},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"我也留在这里。","tone":"坚定","chapter":60,"line_start":520,"line_end":520},{"speaker":"char_yun_ting_ting","speaker_name":"云婷婷","listener":null,"text":"我也留在这里。","tone":"坚定","chapter":60,"line_start":520,"line_end":520},{"speaker":"char_tie_qing_shu","speaker_name":"铁青树","listener":null,"text":"我也留在这里。","tone":"坚定","chapter":60,"line_start":520,"line_end":520},{"speaker":"char_hai_da_shao","speaker_name":"海大少","listener":null,"text":"我也留在这里。","tone":"坚定","chapter":60,"line_start":520,"line_end":520},{"speaker":"char_leng_qing_shuang","speaker_name":"冷青霜","listener":null,"text":"我也留在这里。","tone":"坚定","chapter":60,"line_start":520,"line_end":520},{"speaker":"char_yun_jiu_xiao","speaker_name":"云九霄","listener":null,"text":"好，这也是你们的心意，只恨我……我还有事待理，不能陪同寻找。但愿你们以三个月为期，三个月后，我当重来，那时你们若……若再寻找不着，也就……也就……","tone":"悲伤","chapter":60,"line_start":524,"line_end":526}],"new_entities":{"characters":[{"id":"char_lei_xiao_diao","name":"雷小雕","alias":[],"identity":"雷鞭老人之子","faction":null,"role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"雷鞭老人之子，告知铁中棠未死的消息","personality":{"traits":["勇敢","机灵","孝顺","重情","正直"],"speech_style":"沉稳","temperament":"沉稳"},"relationships":[{"target":"char_lei_bian_lao_ren","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父子"},{"target":"char_hua_ling_ling","type":"恋人","intensity":90,"bond_level":4,"dynamic":"重逢"}],"known_skills":[],"related_skills":[],"rag_refs":[60],"source_refs":[{"chapter":60,"line_start":468,"line_end":468,"text":"雷小雕忽然道"}]},{"id":"char_lei_bian_lao_ren","name":"雷鞭老人","alias":[],"identity":"武林名宿","faction":null,"role":"npc","archetype":"warrior","rank":"登峰造极","one_line":"武林名宿，雷小雕之父","personality":{"traits":["威严","正直","豪迈","深沉","正义"],"speech_style":"威严","temperament":"沉稳"},"relationships":[{"target":"c