      "line_end": 360
    },
    {
      "speaker": "char_shen_xing_bai",
      "speaker_name": "沈杏白",
      "text": "伸手一拍沈杏白的肩头，道：",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 368,
      "line_end": 368
    },
    {
      "speaker": "char_shen_xing_bai",
      "speaker_name": "沈杏白",
      "text": "弟子虽不知道，但已有些猜着。",
      "tone": "微笑",
      "chapter": 53,
      "line_start": 372,
      "line_end": 372
    },
    {
      "speaker": "char_feng_jiu_you",
      "speaker_name": "风九幽",
      "text": "你且说来听听。",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 374,
      "line_end": 374
    },
    {
      "speaker": "char_shen_xing_bai",
      "speaker_name": "沈杏白",
      "text": "弟子怎敢说出恩师名讳。",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 376,
      "line_end": 376
    },
    {
      "speaker": "char_gong_zhuang_li_ren",
      "speaker_name": "宫装丽人",
      "text": "无妨，你说吧，我不怪你。",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 378,
      "line_end": 378
    },
    {
      "speaker": null,
      "speaker_name": null,
      "text": "不分男女，无论老少，斩尽杀绝，一个不留！",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 386,
      "line_end": 386
    },
    {
      "speaker": null,
      "speaker_name": null,
      "text": "去！",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 388,
      "line_end": 388
    },
    {
      "speaker": null,
      "speaker_name": null,
      "text": "毒神",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 388,
      "line_end": 388
    },
    {
      "speaker": null,
      "speaker_name": null,
      "text": "毒神鬼爪笔直伸出，",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 406,
      "line_end": 406
    },
    {
