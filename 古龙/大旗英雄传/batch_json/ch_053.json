      "chapter": 53,
      "line_start": 420,
      "line_end": 420
    },
    {
      "speaker": "char_lei_bian_lao_ren",
      "speaker_name": "雷鞭老人",
      "text": "的一声巨响，雷鞭老人那摄人心魂的最后一击，已着着实实击在",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 420,
      "line_end": 420
    },
    {
      "speaker": "char_lei_bian_lao_ren",
      "speaker_name": "雷鞭老人",
      "text": "毒神",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 426,
