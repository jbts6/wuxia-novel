      "chapter": 53,
      "line_start": 332,
      "line_end": 332
    },
    {
      "speaker": "char_gong_zhuang_li_ren",
      "speaker_name": "宫装丽人",
      "text": "莫非你知道他们下落？",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 334,
      "line_end": 334
    },
    {
      "speaker": "char_shen_xing_bai",
      "speaker_name": "沈杏白",
      "text": "弟子若不知道，怎敢在此胡说？",
      "tone": "陈述",
