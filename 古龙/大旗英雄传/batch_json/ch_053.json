      "speaker_name": "宫装丽人",
      "text": "谁？",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 274,
      "line_end": 274
    },
    {
      "speaker": "char_feng_jiu_you",
      "speaker_name": "风九幽",
      "text": "卓三娘，雷鞭，还有日后……",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 276,
      "line_end": 276
    },
    {
      "speaker": "char_gong_zhuang_li_ren",
      "speaker_name": "宫装丽人",
      "text": "你说什么？",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 296,
      "line_end": 296
    },
    {
      "speaker": "char_gong_zhuang_li_ren",
      "speaker_name": "宫装丽人",
      "text": "她挥了一挥手，接道：",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 304,
      "line_end": 304
    },
    {
      "speaker": "char_gong_zhuang_li_ren",
      "speaker_name": "宫装丽人",
      "text": "你们为何还不走？",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 310,
      "line_end": 310
    },
    {
      "speaker": "char_feng_jiu_you",
      "speaker_name": "风九幽",
      "text": "是小弟救了灵铃性命，二姐莫非忘了？",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 312,
      "line_end": 312
    },
    {
      "speaker": "char_feng_jiu_you",
      "speaker_name": "风九幽",
      "text": "既是如此，小弟……",
      "tone": "微笑",
