      "line_start": 336,
      "line_end": 336
    },
    {
      "speaker": "char_gong_zhuang_li_ren",
      "speaker_name": "宫装丽人",
      "text": "快些带我前去。",
      "tone": "陈述",
      "chapter": 53,
      "line_start": 338,
      "line_end": 338
    },
    {
      "speaker": "char_gong_zhuang_li_ren",
      "speaker_name": "宫装丽人",
      "text": "你敢以此相胁于我？",
      "tone": "愤怒",
      "chapter": 53,
      "line_start": 344,
      "line_end": 344
    },
    {
      "speaker": "char_shen_xing_bai",
      "speaker_name": "沈杏白",
      "text": "多谢恩师。",
