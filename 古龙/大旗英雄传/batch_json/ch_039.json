      "speaker_name": "阴素",
      "listener": "char_leng_qing_ping",
      "text": "他已不会来了。",
      "tone": "淡然",
      "chapter": 39,
      "line_start": 618,
      "line_end": 618
    },
    {
      "speaker": "char_leng_qing_ping",
      "speaker_name": "冷青萍",
      "listener": "char_yin_su",
      "text": "他为何不会来了？",
      "tone": "疑问",
      "chapter": 39,
      "line_start": 620,
      "line_end": 620
    },
    {
      "speaker": "char_yin_su",
      "speaker_name": "阴素",
      "listener": "char_leng_qing_ping",
      "text": "他已落入海中，连尸首都寻不着了。",
      "tone": "淡然",
      "chapter": 39,
      "line_start": 622,
