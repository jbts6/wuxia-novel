      "speaker": "char_yin_su",
      "speaker_name": "阴素",
      "listener": "char_leng_qing_ping",
      "text": "他可是那姓云的小子的二哥？",
      "tone": "疑问",
      "chapter": 39,
      "line_start": 614,
