      "line_start": 602,
      "line_end": 602
    },
    {
      "speaker": "char_leng_qing_ping",
      "speaker_name": "冷青萍",
      "listener": "char_yin_su",
      "text": "那边若是有个叫铁中棠的人，要到这里来，求婆婆好歹载他一程，莫要忘了。",
      "tone": "恳求",
      "chapter": 39,
      "line_start": 604,
      "line_end": 604
    },
    {
      "speaker": "char_yin_su",
      "speaker_name": "阴素",
      "listener": "char_leng_qing_ping",
      "text": "他是什么人？",
