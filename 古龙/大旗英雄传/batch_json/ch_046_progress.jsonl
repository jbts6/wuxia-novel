{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_yi_ming","speaker_name":"易明","listener":null,"text":"蛇……蛇……","tone":"恐惧","chapter":46,"line_start":12,"line_end":12},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":"char_shui_ling_guang","text":"这条小蛇你怕什么？","tone":"疑问","chapter":46,"line_start":24,"line_end":26},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":"char_wen_dai_dai","text":"这条蛇必是奇毒无比，动不得的。","tone":"认真","chapter":46,"line_start":28,"line_end":28},{"speaker":"char_yi_ming","speaker_name":"易明","listener":null,"text":"怎……怎么办呢？","tone":"恐惧","chapter":46,"line_start":34,"line_end":34},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":null,"text":"此等毒蛇，说不定已深具灵性，纵是深山大泽也不常见。","tone":"陈述","chapter":46,"line_start":36,"line_end":38},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_shui_ling_guang","text":"那它怎会跑来这里？","tone":"疑问","chapter":46,"line_start":40,"line_end":40},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":"char_yi_ming","text":"必是有人放出来的。","tone":"认真","chapter":46,"line_start":42,"line_end":42},{"speaker":"char_yi_ming","speaker_name":"易明","listener":null,"text":"人……人在那里！","tone":"恐惧","chapter":46,"line_start":44,"line_end":46},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":null,"text":"幸好那丫头还有些见识，否则你们四人此刻只怕早已都去见阎王了。","tone":"冷笑","chapter":46,"line_start":48,"line_end":50},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_leng_yi_feng","text":"我们与你无冤无仇，素不相识，你……你……你为何要放出这条毒蛇来害我们？","tone":"恐惧","chapter":46,"line_start":54,"line_end":56},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":null,"text":"不错，你们四个小丫头自谈不到与老夫有何仇恨，但你们哭的那人却是老夫的大仇人。","tone":"冷笑","chapter":46,"line_start":58,"line_end":60},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_leng_yi_feng","text":"你……你是说铁中棠？","tone":"惊讶","chapter":46,"line_start":62,"line_end":62},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":null,"text":"铁中棠呀，铁中棠！你这奸贼、恶徒，你这不是人生父母养的畜生，你……","tone":"愤怒","chapter":46,"line_start":64,"line_end":64},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_leng_yi_feng","text":"他人已死了，你还骂他？你……","tone":"愤怒","chapter":46,"line_start":66,"line_end":68},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":"char_leng_qing_ping","text":"金奴，上！","tone":"厉声","chapter":46,"line_start":70,"line_end":70},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":"char_leng_qing_ping","text":"你……你没有事么？","tone":"担心","chapter":46,"line_start":72,"line_end":73},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_leng_yi_feng","text":"你……你好……好狠。","tone":"痛苦","chapter":46,"line_start":80,"line_end":80},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":"char_leng_qing_ping","text":"这本是你白找死，须怪不得我。我家金奴既已在你腕上留痕，世上已无药可解，你只有等着见阎王了。","tone":"冷笑","chapter":46,"line_start":84,"line_end":85},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":null,"text":"不……不错，我……我立刻便将见……见着铁中棠了……你成全了我……爹爹……","tone":"悲伤","chapter":46,"line_start":88,"line_end":88},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_leng_qing_ping","text":"什么？他是你爹爹？","tone":"惊讶","chapter":46,"line_start":91,"line_end":92},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_yi_ming","text":"不错……","tone":"悲伤","chapter":46,"line_start":94,"line_end":94},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":"char_leng_qing_ping","text":"你……你是谁？","tone":"惊讶","chapter":46,"line_start":96,"line_end":96},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_leng_yi_feng","text":"女儿……青萍……","tone":"悲伤","chapter":46,"line_start":98,"line_end":98}],"new_entities":{"characters":[{"id":"char_tie_zhong_tang","name":"铁中棠","alias":[],"identity":"武林侠客","faction":"大旗门","role":"protagonist","archetype":"warrior","rank":"出神入化","one_line":"坚定温柔的武林侠客，温黛黛等人悲痛悼念的对象","personality":{"traits":["坚定","温柔","正直","深情","勇敢"],"speech_style":"沉稳","temperament":"刚毅"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":1,"line_end":10,"text":"铁中棠去了……她永远再也瞧不见那坚定而又温柔的面容"}]},{"id":"char_wen_dai_dai","name":"温黛黛","alias":[],"identity":"江湖女子","faction":null,"role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"饱经世故、聪明绝顶的江湖女子，与水灵光等人同行","personality":{"traits":["聪明","世故","果敢","深情","观察入微"],"speech_style":"沉稳","temperament":"冷静"},"relationships":[{"target":"char_tie_zhong_tang","type":"恋人","intensity":80,"bond_level":4,"dynamic":"深情悼念"}],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":20,"line_end":26,"text":"温黛黛本也吃了一惊……"}]},{"id":"char_leng_qing_ping","name":"冷青萍","alias":[],"identity":"冷一枫之女","faction":null,"role":"companion","archetype":"warrior","rank":"略有小成","one_line":"冷一枫之女，对铁中棠情深意重，身中蛇毒","personality":{"traits":["深情","刚烈","执着","勇敢","凄婉"],"speech_style":"柔弱","temperament":"悲怆"},"relationships":[{"target":"char_leng_yi_feng","type":"亲属","intensity":60,"bond_level":3,"dynamic":"父女相认"},{"target":"char_tie_zhong_tang","type":"恋人","intensity":90,"bond_level":5,"dynamic":"生死追随"}],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":66,"line_end":68,"text":"冷青萍突然飞身而起……"}]},{"id":"char_yi_ming","name":"易明","alias":[],"identity":"易挺之妹","faction":null,"role":"companion","archetype":"warrior","rank":"初窥门径","one_line":"易挺之妹，明朗爽快但胆子较小","personality":{"traits":["明朗","爽快","胆小","好奇","直率"],"speech_style":"急促","temperament":"活泼"},"relationships":[{"target":"char_yi_ting","type":"亲属","intensity":80,"bond_level":4,"dynamic":"兄妹"}],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":12,"line_end":12,"text":"易明突然发出一声惊呼……"}]},{"id":"char_shui_ling_guang","name":"水灵光","alias":[],"identity":"沼泽少女","faction":null,"role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"自幼生长在沼泽中的少女，对毒蛇颇有见识","personality":{"traits":["机敏","勇敢","善良","细心","果断"],"speech_style":"沉稳","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":22,"line_end":28,"text":"但她手掌还未伸出……"}]},{"id":"char_leng_yi_feng","name":"冷一枫","alias":[],"identity":"冷青萍之父","faction":null,"role":"villain","archetype":"assassin","rank":"出神入化","one_line":"冷青萍之父，对铁中棠怀有深仇，操纵金蛇伤人","personality":{"traits":["阴狠","偏执","残忍","疯狂","仇恨"],"speech_style":"阴沉","temperament":"暴戾"},"relationships":[{"target":"char_leng_qing_ping","type":"亲属","intensity":70,"bond_level":3,"dynamic":"误伤亲女"},{"target":"char_tie_zhong_tang","type":"宿敌","intensity":100,"bond_level":5,"dynamic":"深仇大恨"}],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":58,"line_end":64,"text":"那人狞笑道……"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_jin_she","name":"金蛇","type":"special","owner":"char_leng_yi_feng","one_line":"冷一枫以精血喂养的毒蛇，已成其元神","description":"颜色甚是怪异的小蛇，身上闪动着一层乌金色的光芒，长不及一尺，粗不及拇指，乃天下七大最毒毒蛇之一","effects":["剧毒无比","已具灵性","与主人心灵相通"],"origin":"食毒教","rarity":"稀世珍品","related_characters":["char_leng_yi_feng"],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":16,"line_end":18,"text":"只见山石上那一点香火下……"}]}]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_leng_yi_feng","text":"爹……爹你虽未认出女儿，但……但女儿却早已听出爹爹的声音。","tone":"悲伤","chapter":46,"line_start":110,"line_end":112},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":"char_leng_qing_ping","text":"你……你为何不早说？","tone":"痛苦","chapter":46,"line_start":114,"line_end":114},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_leng_yi_feng","text":"爹爹你又何尝给女儿说话的机会，一提起铁中棠，你心头便被仇恨充满，什么人的声音都听不出了。","tone":"悲伤","chapter":46,"line_start":116,"line_end":118},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":null,"text":"苍天呀苍天，我好恨……好恨。","tone":"悲痛","chapter":46,"line_start":120,"line_end":122},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":"char_leng_yi_feng","text":"他人死了，你老人家还在恨他？","tone":"无奈","chapter":46,"line_start":124,"line_end":124},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":"char_leng_qing_ping","text":"若不是他，怎会有如今这事……我若寻着他尸身，我将之碎尸万段，也难消心头之恨。","tone":"愤怒","chapter":46,"line_start":126,"line_end":128},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":null,"text":"但如今女儿却立刻便要与他相会了。","tone":"温柔","chapter":46,"line_start":130,"line_end":132},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":"char_leng_qing_ping","text":"你……你敢？","tone":"愤怒","chapter":46,"line_start":134,"line_end":134},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":null,"text":"女儿敢的……世上已再无一人能拦得住我……我的心一生中从未有过如此安适，如此自信……","tone":"温柔","chapter":46,"line_start":136,"line_end":136},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":null,"text":"看……看……他已在前面向我招手……你们瞧得见么？","tone":"温柔","chapter":46,"line_start":138,"line_end":140},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":null,"text":"唉！可惜你们瞧不见他……他笑容是多么温柔……唉！我实未想到死……竟是如此快乐的事。","tone":"温柔","chapter":46,"line_start":144,"line_end":146},{"speaker":"char_leng_qing_ping","speaker_name":"冷青萍","listener":null,"text":"莫要哭……莫要惊吵我……那甜蜜的黑暗，已渐渐近了……他的笑容，也渐渐近了。","tone":"温柔","chapter":46,"line_start":150,"line_end":152},{"speaker":"char_leng_yi_feng","speaker_name":"冷一枫","listener":"char_jin_she","text":"是你……都是你。","tone":"愤怒","chapter":46,"line_start":156,"line_end":156},{"speaker":"char_hong_yi_yi_seng","speaker_name":"红衣异僧","listener":null,"text":"毒神现体，天下无敌，食毒之门，横行天下……毒神现体，天下……","tone":"喃喃","chapter":46,"line_start":198,"line_end":198},{"speaker":"char_hong_yi_yi_seng","speaker_name":"红衣异僧","listener":"char_wen_dai_dai","text":"毒神现体，天下无敌……这话你们可懂么？","tone":"疑问","chapter":46,"line_start":202,"line_end":204},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":"char_hong_yi_yi_seng","text":"不懂。","tone":"陈述","chapter":46,"line_start":207,"line_end":207},{"speaker":"char_hong_yi_yi_seng","speaker_name":"红衣异僧","listener":null,"text":"两个小娃儿，自是不懂……其实普天之下，又有几人懂得？又有几人懂得……","tone":"大笑","chapter":46,"line_start":210,"line_end":212}],"new_entities":{"characters":[{"id":"char_hong_yi_yi_seng","name":"红衣异僧","alias":["食蛇异僧"],"identity":"食毒教主","faction":"食毒教","role":"villain","archetype":"monk","rank":"登峰造极","one_line":"身着鲜红僧袍的诡异僧人，食毒教教主飧毒大师","personality":{"traits":["诡异","神秘","阴狠","自负","深沉"],"speech_style":"阴沉","temperament":"冷酷"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":188,"line_end":198,"text":"赫然正是那食蛇异僧！……"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_shi_du_jiao","name":"食毒教","type":"武林门派","location":null,"sub_divisions":[],"one_line":"以毒功闻名的武林门派，掌握毒神现体等魔功","source_refs":[{"chapter":46,"line_start":198,"line_end":200,"text":"食毒之门，横行天下"}]}],"locations":[],"items":[]},"entity_updates":[{"id":"char_leng_yi_feng","updates":{"rank":"出神入化","source_refs":[{"chapter":46,"line_start":154,"line_end":172,"text":"冷一枫枯瘦的面容……"}]},"relationship_updates":[{"action":"add","target":"char_leng_qing_ping","type":"亲属","intensity":80,"bond_level":4,"dynamic":"误伤亲女后痛悔"},{"action":"add","target":"char_tie_zhong_tang","type":"宿敌","intensity":100,"bond_level":5,"dynamic":"深仇大恨至死不渝"}]}]}
{"segment":3,"line_start":201,"line_end":310,"dialogues":[{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_hong_yi_yi_seng","text":"毒神现体，天下无敌……这又有何难懂之处？","tone":"淡然","chapter":46,"line_start":218,"line_end":220},{"speaker":"char_hong_yi_yi_seng","speaker_name":"红衣异僧","listener":"char_yi_ting","text":"什么人？出来说话！","tone":"沉声","chapter":46,"line_start":222,"line_end":224},{"speaker":"char_hong_yi_yi_seng","speaker_name":"红衣异僧","listener":"char_yi_ting","text":"你小小年纪，懂得什么？","tone":"冷笑","chapter":46,"line_start":236,"line_end":237},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_hong_yi_yi_seng","text":"你怎知我不懂？","tone":"淡然","chapter":46,"line_start":240,"line_end":240},{"speaker":"char_hong_yi_yi_seng","speaker_name":"红衣异僧","listener":"char_yi_ting","text":"你既懂得，可知咱家是谁？","tone":"疑问","chapter":46,"line_start":248,"line_end":248},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_hong_yi_yi_seng","text":"食毒教主，飧毒大师。","tone":"陈述","chapter":46,"line_start":250,"line_end":250},{"speaker":"char_hong_yi_yi_seng","speaker_name":"飧毒大师","listener":"char_yi_ting","text":"不想你小小年纪，竟知道老僧的名字。我再问你，何谓毒神现体？","tone":"疑问","chapter":46,"line_start":260,"line_end":262},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_sun_du_da_shi","text":"毒神现体，为食毒教下两大魔功之一。","tone":"陈述","chapter":46,"line_start":264,"line_end":264},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_yi_ting","text":"不错。","tone":"陈述","chapter":46,"line_start":266,"line_end":266},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_sun_du_da_shi","text":"练成毒神之体，四体俱属极毒，纵是武功已入化境之人，一触毒神之体，也要中毒无救。","tone":"陈述","chapter":46,"line_start":268,"line_end":270},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_yi_ting","text":"不错。","tone":"陈述","chapter":46,"line_start":272,"line_end":272},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_sun_du_da_shi","text":"但要练成毒神之体，必需牺牲食毒教下，已将毒功练至五成火候以上的一个弟子性命。","tone":"陈述","chapter":46,"line_start":274,"line_end":276},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_yi_ting","text":"不错。","tone":"陈述","chapter":46,"line_start":278,"line_end":278},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_sun_du_da_shi","text":"而食毒教下弟子本极凋落，只因这毒功练到后来虽易速成，但入门这一道功夫却难如登天，食毒教主选来的弟子，十人中倒有九人在练第一道功夫时便已因毒丧身，能将毒功练至第五层火候的，实是绝无仅有，食毒教主自舍不得牺牲他的性命，来练那毒神之体。","tone":"陈述","chapter":46,"line_start":280,"line_end":282},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_yi_ting","text":"不错。","tone":"陈述","chapter":46,"line_start":284,"line_end":284},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":null,"text":"但此刻这冷一枫，却已属毒神之体了。","tone":"陈述","chapter":46,"line_start":290,"line_end":290},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":null,"text":"只因冷一枫之五毒神功，本已练至第五层火候，体中神气血液，都已含蕴剧毒，他平日便要随时吞食些奇毒之物，以毒攻毒，去克制血液中之毒性，否则便要痛苦不堪。","tone":"陈述","chapter":46,"line_start":296,"line_end":300},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":null,"text":"于是他体内之毒性，自是日渐加重，他掌力虽然越来越毒，但体内毒性发作时，自也越是猛烈。如此虽是恶性循环，但相生亦有相克，是以除非有了巨大的变故，他体内毒性，万万不致危害自身。但此刻他已遇着件巨大的变故。","tone":"陈述","chapter":46,"line_start":298,"line_end":302}],"new_entities":{"characters":[{"id":"char_yi_ting","name":"易挺","alias":[],"identity":"易明之兄","faction":null,"role":"companion","archetype":"scholar","rank":"初窥门径","one_line":"易明之兄，神情呆板似被慑去心神，却对食毒教秘密如数家珍","personality":{"traits":["聪慧","博学","冷静","深沉","神秘"],"speech_style":"平淡","temperament":"沉稳"},"relationships":[{"target":"char_yi_ming","type":"亲属","intensity":80,"bond_level":4,"dynamic":"兄妹"}],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":228,"line_end":240,"text":"只见他满身锦衣，少年英俊……"}]},{"id":"char_sun_du_da_shi","name":"飧毒大师","alias":["红衣异僧","食蛇异僧"],"identity":"食毒教主","faction":"食毒教","role":"villain","archetype":"monk","rank":"登峰造极","one_line":"食毒教教主，江湖中人人闻名丧胆的魔教第一高手","personality":{"traits":["阴狠","自负","冷酷","深沉","诡秘"],"speech_style":"阴沉","temperament":"冷酷"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":250,"line_end":262,"text":"食毒教主，飧毒大师。……"}]}],"skills":[{"id":"skill_du_shen_xian_ti","name":"毒神现体","type":"内功","faction":"食毒教","rank":"登峰造极","one_line":"食毒教两大魔功之一，炼成后全身俱毒，触之即死","techniques":[{"id":"tech_du_shen_zhi_ti","name":"毒神之体","type":"special","description":"炼成后四体俱属极毒，纵是武功已入化境之人一触即中毒无救"},{"id":"tech_wu_du_shen_gong","name":"五毒神功","type":"attack","description":"食毒教根本毒功，练至第五层火候后体中神气血液含蕴剧毒"}],"progression":"需牺牲五成火候以上弟子性命方可炼成","effects":["全身剧毒","触之即死","气力增强十倍"],"combat_style":"以毒制敌，近身接触即致命","rag_refs":[46],"source_refs":[{"chapter":46,"line_start":264,"line_end":302,"text":"毒神现体，为食毒教下两大魔功之一……"}]}],"techniques":[{"id":"tech_du_shen_zhi_ti","name":"毒神之体","type":"special","description":"炼成后四体俱属极毒，触之即死","source_skill":"skill_du_shen_xian_ti","source_refs":[{"chapter":46,"line_start":268,"line_end":270,"text":"练成毒神之体……"}]},{"id":"tech_wu_du_shen_gong","name":"五毒神功","type":"attack","description":"食毒教根本毒功，练至第五层火候后体中血液含蕴剧毒","source_skill":"skill_du_shen_xian_ti","source_refs":[{"chapter":46,"line_start":296,"line_end":300,"text":"冷一枫之五毒神功……"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":311,"line_end":420,"dialogues":[{"speaker":"char_yi_ting","speaker_name":"易挺","listener":null,"text":"方才那金蛇不但奇毒无比，而且已具灵性，乃是天下七种最毒的毒蛇之一。以食毒教练功之秘，冷一枫平日须得以自身之精血，来喂养此蛇，好教它与自身心灵相通。若以毒教魔经所载，这金蛇实已成了冷一枫的元神，这个是毒教中人故神其说，但也并非全无道理。","tone":"陈述","chapter":46,"line_start":314,"line_end":320},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":null,"text":"冷一枫方才被他自身元神咬了一口，他体内之毒，与金蛇之毒本已有了种奇异之感应，此刻两种毒性，相生相引，不但冷一枫体内之毒性已全被引发，而且更形成一种比原毒更胜十倍的毒性。是以冷一枫此刻本身之毒，也已较方才那金蛇之毒更胜十倍，他身体毛发，已无一不是奇毒无比之物。想那金蛇已是世上七大毒物之一，冷一枫此身之毒，自更非同小可。那毒蛇一滴毒液已足令人丧命，此刻冷一枫却只要手指一触，便已足可夺人魂魄。","tone":"陈述","chapter":46,"line_start":326,"line_end":333},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":null,"text":"但纵是如此，还不足以构成毒神之体。只因冷一枫此刻依然身蕴奇毒，但天下武林高手们只要不被他身子触及，还是可制服于他。","tone":"陈述","chapter":46,"line_start":338,"line_end":340},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_yi_ting","text":"要如何才能炼成毒神之体，莫非你已知道么？","tone":"沉声","chapter":46,"line_start":342,"line_end":344},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_sun_du_da_shi","text":"江湖中人人都知道，中毒之人，无论中毒深浅，只要毒性发作时，气力必定比平时强猛十倍。而冷一枫此刻所中之毒又比世上任何人重得多，他毒性发作起来，其气力如何，乃是可想而知。是以只要将他此点加以利用，以你的五毒掌力，激发他生命中最后一点潜力，使他变为一具毒尸，再以你毒教中迷神之药，令他完全变成一具傀儡，完全听命于你，那时他虽已不能思想，但气力武功，却比往昔强胜十倍，再加以那一身冠绝天下的奇毒，江湖之中还有谁能抵挡？那时你自己也可以他为工具，而横行天下了。","tone":"陈述","chapter":46,"line_start":346,"line_end":352},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_yi_ting","text":"我毒教之秘，你是如何知道的？","tone":"厉声","chapter":46,"line_start":356,"line_end":357},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_sun_du_da_shi","text":"你走过来点，我告诉你。","tone":"陈述","chapter":46,"line_start":360,"line_end":360},{"speaker":"char_yi_ting","speaker_name":"易挺","listener":"char_sun_du_da_shi","text":"再走过来些。","tone":"陈述","chapter":46,"line_start":362,"line_end":362},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_yi_ting","text":"你纵有什么阴谋诡计，难道老僧还怕了你不成？","tone":"冷笑","chapter":46,"line_start":364,"line_end":366},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"原来那少年乃是和此人一路的，他那番说话，只是要分散飧毒大师的注意，好让此人乘机将冷一枫完全毁去，永绝后患。","tone":"陈述","chapter":46,"line_start":372,"line_end":373},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_hei_yi_ren","text":"原来是你。","tone":"陈述","chapter":46,"line_start":398,"line_end":398},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":"char_sun_du_da_shi","text":"你此刻才瞧出来么？","tone":"淡然","chapter":46,"line_start":400,"line_end":400},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_hei_yi_ren","text":"我早该知道你来了的。","tone":"陈述","chapter":46,"line_start":402,"line_end":402},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":"char_sun_du_da_shi","text":"是呀，你早该知道的。","tone":"淡然","chapter":46,"line_start":404,"line_end":404},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_hei_yi_ren","text":"除了你之外，还有谁如此清楚本门秘密？那少年只不过是你的傀儡，代你说出了而已。","tone":"陈述","chapter":46,"line_start":406,"line_end":408},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":"char_sun_du_da_shi","text":"是呀，除了我之外，还有谁知道你的秘密？那少年只是无意遇着的，他姓什么我都不知道。","tone":"淡然","chapter":46,"line_start":410,"line_end":412},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_hei_yi_ren","text":"你既已来了，总是好得很。","tone":"陈述","chapter":46,"line_start":420,"line_end":420}],"new_entities":{"characters":[{"id":"char_hei_yi_ren","name":"黑衣人","alias":[],"identity":"神秘高手","faction":null,"role":"villain","archetype":"assassin","rank":"登峰造极","one_line":"黑袍蒙面的神秘高手，与飧毒大师势均力敌，操纵易挺透露食毒教秘密","personality":{"traits":["阴沉","深不可测","狠辣","从容","诡秘"],"speech_style":"平和","temperament":"冷酷"},"relationships":[{"target":"char_sun_du_da_shi","type":"宿敌","intensity":90,"bond_level":5,"dynamic":"势均力敌的死敌"}],"known_skills":[],"related_skills":[],"rag_refs":[46],"source_refs":[{"chapter":46,"line_start":392,"line_end":412,"text":"只见他一身黑袍……"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_sun_du_da_shi","updates":{"name":"飧毒大师","source_refs":[{"chapter":46,"line_start":250,"line_end":262,"text":"食毒教主，飧毒大师。"}]},"relationship_updates":[]}]}
{"segment":5,"line_start":421,"line_end":525,"dialogues":[{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":"char_sun_du_da_shi","text":"不错，好得很。","tone":"淡然","chapter":46,"line_start":422,"line_end":422},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_hei_yi_ren","text":"那你就莫要走了吧！","tone":"冷笑","chapter":46,"line_start":424,"line_end":424},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":"char_sun_du_da_shi","text":"还是你莫要走的好。","tone":"淡然","chapter":46,"line_start":426,"line_end":426},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_hei_yi_ren","text":"哪里哪里。","tone":"冷笑","chapter":46,"line_start":428,"line_end":428},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":"char_sun_du_da_shi","text":"好说好说。","tone":"淡然","chapter":46,"line_start":430,"line_end":430},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_hei_yi_ren","text":"这地方不错。","tone":"陈述","chapter":46,"line_start":438,"line_end":438},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":"char_sun_du_da_shi","text":"你留下吧！","tone":"冷酷","chapter":46,"line_start":440,"line_end":440},{"speaker":"char_sun_du_da_shi","speaker_name":"飧毒大师","listener":"char_hei_yi_ren","text":"还是你——","tone":"冷笑","chapter":46,"line_start":442,"line_end":442},{"speaker":"char_hei_yi_ren","speaker_name":"黑衣人","listener":"char_sun_du_da_shi","text":"彼此彼此。","tone":"淡然","chapter":46,"line_start":444,"line_end":444},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":"char_yi_ming","text":"你两人觉得怎样？","tone":"担心","chapter":46,"line_start":474,"line_end":476},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_wen_dai_dai","text":"怎样？","tone":"疑问","chapter":46,"line_start":478,"line_end":478},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":"char_yi_ming","text":"你两人可觉得身子有何不妥？","tone":"担心","chapter":46,"line_start":480,"line_end":480},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_wen_dai_dai","text":"没有什么呀，还……","tone":"惊讶","chapter":46,"line_start":482,"line_end":482},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":"char_yi_ming","text":"怎样？是否有些不妥？","tone":"焦急","chapter":46,"line_start":484,"line_end":484},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_wen_dai_dai","text":"我……我胸口似乎有……有些发闷……又热得难受……我手足竟……竟似也有些麻了。","tone":"恐惧","chapter":46,"line_start":486,"line_end":488},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":"char_shui_ling_guang","text":"水姑娘，你觉怎样？","tone":"担心","chapter":46,"line_start":490,"line_end":492},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":"char_wen_dai_dai","text":"和她一样……","tone":"恐惧","chapter":46,"line_start":494,"line_end":494},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_wen_dai_dai","text":"这……这究竟是怎么回事？","tone":"恐惧","chapter":46,"line_start":498,"line_end":498},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"咱……们……都已中……毒了。","tone":"恐惧","chapter":46,"line_start":500,"line_end":500},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":"char_wen_dai_dai","text":"中毒？","tone":"惊讶","chapter":46,"line_start":502,"line_end":502},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"非但已中毒了，而且中毒极深。","tone":"恐惧","chapter":46,"line_start":504,"line_end":504},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_wen_dai_dai","text":"什么毒？谁施放的毒？","tone":"焦急","chapter":46,"line_start":510,"line_end":510},{"speaker":"char_shui_ling_guang","speaker_name":"水灵光","listener":null,"text":"莫……莫非是他？","tone":"恐惧","chapter":46,"line_start":512,"line_end":514},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_shui_ling_guang","text":"是他？怎么是他？真的是他么？","tone":"惊讶","chapter":46,"line_start":516,"line_end":516},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"不错。","tone":"无奈","chapter":46,"line_start":518,"line_end":518},{"speaker":"char_yi_ming","speaker_name":"易明","listener":"char_wen_dai_dai","text":"但……但他连手指都未动过。","tone":"惊讶","chapter":46,"line_start":520,"line_end":520},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"天下人都知道飧毒大师乃是天下使毒的第一高手，而咱们却等着他出手进击，这岂非呆子。","tone":"无奈","chapter":46,"line_start":522,"line_end":523}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
