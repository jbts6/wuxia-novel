{"segment":5,"line_start":401,"line_end":530,"dialogues":[{"speaker":"char_long","speaker_name":"龙姓少年","listener":null,"text":"兄台但说无妨。","tone":"陈述","chapter":50,"line_start":404,"line_end":404},{"speaker":null,"speaker_name":null,"listener":null,"text":"彩虹七剑","tone":"陈述","chapter":50,"line_start":410,"line_end":410},{"speaker":null,"speaker_name":null,"listener":null,"text":"墨龙剑客","tone":"陈述","chapter":50,"line_start":410,"line_end":410},{"speaker":"char_long_jian_shi","speaker_name":"龙坚石","listener":null,"text":"不知兄台要打听什么人？","tone":"陈述","chapter":50,"line_start":412,"line_end":412},{"speaker":"char_long_jian_shi","speaker_name":"龙坚石奇","listener":null,"text":"她既是兄台好友，兄台怎会不知她下落？","tone":"陈述","chapter":50,"line_start":418,"line_end":418},{"speaker":"char_long_jian_shi","speaker_name":"龙坚石","listener":null,"text":"是以便将婚事拦阻，是么？","tone":"陈述","chapter":50,"line_start":424,"line_end":424},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭之子","listener":null,"text":"她便是'烟雨'花双霜之女花灵铃。","tone":"陈述","chapter":50,"line_start":442,"line_end":442},{"speaker":"char_long_jian_shi","speaker_name":"龙坚石失声","listener":null,"text":"原来竟是'烟雨'花二娘之女。","tone":"陈述","chapter":50,"line_start":444,"line_end":444},{"speaker":"char_long_jian_shi","speaker_name":"龙坚石","listener":null,"text":"未曾听过。","tone":"陈述","chapter":50,"line_start":450,"line_end":450},{"speaker":"char_long_jian_shi","speaker_name":"龙坚石","listener":null,"text":"她既是花二娘之女，又是兄台的知心人，那武功人品，自是可想而知，这样的少女若是在江湖走动，不出两个月，声名便该震动四方，但小弟既未听人说起这名字，只怕她已……","tone":"陈述","chapter":50,"line_start":450,"line_end":450},{"speaker":"char_long_jian_shi","speaker_name":"龙坚石叹","listener":null,"text":"若已改变姓名，就难找了。","tone":"无奈","chapter":50,"line_start":458,"line_end":458},{"speaker":null,"speaker_name":null,"listener":null,"text":"不曾。","tone":"陈述","chapter":50,"line_start":464,"line_end":464},{"speaker":"char_long_jian_shi","speaker_name":"龙坚石慨然","listener":null,"text":"兄台之托付，小弟必不敢忘。","tone":"陈述","chapter":50,"line_start":476,"line_end":476},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭之子","listener":null,"text":"小弟先此谢过，兄台，若是……","tone":"陈述","chapter":50,"line_start":478,"line_end":478},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭老人","listener":null,"text":"你还未说完么？","tone":"沉声","chapter":50,"line_start":480,"line_end":480},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭老人","listener":null,"text":"还问什么？还不过来！","tone":"愤怒","chapter":50,"line_start":486,"line_end":486},{"speaker":null,"speaker_name":"只是缓缓","listener":null,"text":"你还在想着她？","tone":"陈述","chapter":50,"line_start":490,"line_end":490},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭之子垂首","listener":null,"text":"爹爹明鉴。","tone":"陈述","chapter":50,"line_start":492,"line_end":492},{"speaker":null,"speaker_name":"垂首","listener":null,"text":"是。","tone":"陈述","chapter":50,"line_start":498,"line_end":498},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭老人","listener":null,"text":"还不跪下！","tone":"愤怒","chapter":50,"line_start":506,"line_end":506},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"你可瞧见了她么？","tone":"陈述","chapter":50,"line_start":510,"line_end":510},{"speaker":"char_lei_xiao_diao","speaker_name":"雷小雕","listener":null,"text":"瞧见了，孩儿正在奇怪……","tone":"陈述","chapter":50,"line_start":512,"line_end":512},{"speaker":"char_lei_xiao_diao","speaker_name":"雷小雕变色","listener":null,"text":"但她的……她的云……","tone":"陈述","chapter":50,"line_start":518,"line_end":518}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
