{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭老人捋须笑","listener":null,"text":"好！好！溜得好！","tone":"欣喜","chapter":50,"line_start":208,"line_end":208},{"speaker":null,"speaker_name":"已厉叱","listener":null,"text":"回去，回去等着。","tone":"愤怒","chapter":50,"line_start":216,"line_end":216},{"speaker":null,"speaker_name":null,"listener":null,"text":"说到这里，突然瞥见自洞中大步行出的云翼等人，面色立时改变，目光电射，厉声道：","tone":"愤怒","chapter":50,"line_start":230,"line_end":230},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛微微笑","listener":null,"text":"这些就是我的朋友。","tone":"微笑","chapter":50,"line_start":234,"line_end":234},{"speaker":null,"speaker_name":null,"listener":null,"text":"哦","tone":"陈述","chapter":50,"line_start":236,"line_end":236},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭老人","listener":null,"text":"叫你参见于我，你可听见？","tone":"愤怒","chapter":50,"line_start":248,"line_end":248},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭老人怒","listener":null,"text":"你这老儿莫非是聋子不成？","tone":"愤怒","chapter":50,"line_start":252,"line_end":252},{"speaker":null,"speaker_name":null,"listener":null,"text":"老夫为何要参见于你？","tone":"愤怒","chapter":50,"line_start":254,"line_end":254},{"speaker":null,"speaker_name":null,"listener":null,"text":"好！","tone":"愤怒","chapter":50,"line_start":264,"line_end":264},{"speaker":null,"speaker_name":null,"listener":null,"text":"好","tone":"陈述","chapter":50,"line_start":266,"line_end":266},{"speaker":"char_yun_yi","speaker_name":"云翼","listener":null,"text":"你若非雷鞭，也不配老夫出手了。","tone":"愤怒","chapter":50,"line_start":272,"line_end":272},{"speaker":null,"speaker_name":null,"listener":null,"text":"他伸手一拍云翼肩头，又道：","tone":"陈述","chapter":50,"line_start":288,"line_end":288},{"speaker":null,"speaker_name":"突然","listener":null,"text":"你老人家可是有个酒葫芦？","tone":"陈述","chapter":50,"line_start":292,"line_end":292},{"speaker":null,"speaker_name":null,"listener":null,"text":"不错。","tone":"陈述","chapter":50,"line_start":294,"line_end":294},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"那葫芦此刻是否有酒？","tone":"陈述","chapter":50,"line_start":296,"line_end":296},{"speaker":"char_lei_bian_lao_ren","speaker_name":"雷鞭","listener":null,"text":"若是无酒，老夫要个空葫芦作甚？","tone":"陈述","chapter":50,"line_start":298,"line_end":298},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"葫芦此刻在哪里？","tone":"陈述","chapter":50,"line_start":300,"line_end":300}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
