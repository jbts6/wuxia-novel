{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"他便是雷鞭老人。","tone":"陈述","chapter":50,"line_start":102,"line_end":102},{"speaker":null,"speaker_name":null,"listener":null,"text":"二……","tone":"愤怒","chapter":50,"line_start":114,"line_end":114},{"speaker":null,"speaker_name":"一字字","listener":null,"text":"冲……出……去！","tone":"陈述","chapter":50,"line_start":120,"line_end":120},{"speaker":"char_yun_yi","speaker_name":"云翼摇头笑","listener":null,"text":"好！果然不愧是我的三弟。","tone":"陈述","chapter":50,"line_start":126,"line_end":126},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛","listener":null,"text":"今日咱们也未必就定要战死。","tone":"陈述","chapter":50,"line_start":132,"line_end":132},{"speaker":"char_yun_yi","speaker_name":"云翼","listener":null,"text":"若不战死，莫非归降不成？","tone":"愤怒","chapter":50,"line_start":134,"line_end":134},{"speaker":null,"speaker_name":null,"listener":null,"text":"三……","tone":"愤怒","chapter":50,"line_start":144,"line_end":144},{"speaker":"char_yun_yi","speaker_name":"云翼惊色","listener":null,"text":"时已无多，你快说吧！","tone":"惊讶","chapter":50,"line_start":146,"line_end":146},{"speaker":"char_yun_yi","speaker_name":"云翼皱眉","listener":null,"text":"我等又该如何行事？","tone":"陈述","chapter":50,"line_start":152,"line_end":152},{"speaker":"char_wen_dai_dai","speaker_name":"温黛黛垂首","listener":null,"text":"孩儿不敢说。","tone":"陈述","chapter":50,"line_start":154,"line_end":154},{"speaker":"char_yun_yi","speaker_name":"云翼","listener":null,"text":"事已至此，你还有什么不敢说的？","tone":"愤怒","chapter":50,"line_start":156,"line_end":156},{"speaker":"char_yun_yi","speaker_name":"云翼嘶声","listener":null,"text":"但……但我大旗门怎能……","tone":"嘶声","chapter":50,"line_start":170,"line_end":170},{"speaker":null,"speaker_name":"狠然顿足","listener":null,"text":"也好。","tone":"陈述","chapter":50,"line_start":176,"line_end":176},{"speaker":null,"speaker_name":null,"listener":null,"text":"四……","tone":"愤怒","chapter":50,"line_start":178,"line_end":178},{"speaker":null,"speaker_name":null,"listener":