[
  {
    "id": "loc_zhi_bei_shan_zhuang",
    "name": "掷杯山庄",
    "region": "松江府",
    "one_line": "左轻侯的府邸，江南最美的庄园之一",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 8,
        "line_end": 22,
        "text": "掷杯山庄中有江南最美的歌妓、最醇的美酒"
      },
      {
        "chapter": 2,
        "line_start": 1,
        "line_end": 2,
        "text": "规模之雄伟，范围之辽阔，都不在掷杯山庄之下"
      }
    ]
  },
  {
