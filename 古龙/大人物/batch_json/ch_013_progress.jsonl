{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"他会不会说，我是来杀你的？","tone":"陈述","chapter":13,"line_start":120,"line_end":120},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"就算不能一把得手，至少也能抢个先机。","tone":"陈述","chapter":13,"line_start":130,"line_end":130},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"所以他现在一定在跟那老和尚鬼扯。","tone":"陈述","chapter":13,"line_start":132,"line_end":132},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"凭他那张油嘴，一定能把那老和尚骗得团团乱转。","tone":"微笑","chapter":13,"line_start":134,"line_end":134},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"你是不是也被他骗得团团乱转过？","tone":"陈述","chapter":13,"line_start":136,"line_end":136},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"你是不是又在吃醋？","tone":"陈述","chapter":13,"line_start":138,"line_end":138},{"speaker":"char_tian_xin","speaker_name":"田心","listener":null,"text":"现在就算有人要吃醋，也轮不到你了。","tone":"微笑","chapter":13,"line_start":140,"line_end":140},{"speaker":"char_tian_xin","speaker_name":"田心","listener":null,"text":"你们听，他们好像已经打起来了。","tone":"陈述","chapter":13,"line_start":150,"line_end":150},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"看来那老和尚果然是在用罗汉伏虎拳对付他。","tone":"陈述","chapter":13,"line_start":160,"line_end":160},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"所以他并没有能一击得手。","tone":"无奈","chapter":13,"line_start":162,"line_end":162},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"这一着想必是'风雷并作'。","tone":"沉声","chapter":13,"line_start":178,"line_end":178},{"speaker":null,"speaker_name":null,"listener":null,"text":"风雷并作","tone":"陈述","chapter":13,"line_start":180,"line_end":180}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"他的确避开了。","tone":"陈述","chapter":13,"line_start":202,"line_end":202},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"我真想上去看看，他在用什么功夫对付那老尚。","tone":"陈述","chapter":13,"line_start":204,"line_end":204},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"到现在为止，他还没有攻出一招。","tone":"陈述","chapter":13,"line_start":206,"line_end":206},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"难道他只挨打，不还手？","tone":"陈述","chapter":13,"line_start":208,"line_end":208},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"正是这样。","tone":"陈述","chapter":13,"line_start":210,"line_end":210},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"这又算哪门子打法？","tone":"陈述","chapter":13,"line_start":212,"line_end":212},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"你知道他用的是什么法子？","tone":"陈述","chapter":13,"line_start":218,"line_end":218},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"这人会的武功很杂……","tone":"陈述","chapter":13,"line_start":236,"line_end":236},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"这话你是说给谁听的？","tone":"微笑","chapter":13,"line_start":240,"line_end":240},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"说给我自己听的。","tone":"淡然","chapter":13,"line_start":242,"line_end":242},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我说过，我很需要他，他也很需要我。","tone":"淡然","chapter":13,"line_start":248,"line_end":248},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"他为什么需要你？","tone":"陈述","chapter":13,"line_start":250,"line_end":250},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"你调查过？","tone":"陈述","chapter":13,"line_start":256,"line_end":256},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你以为我随随便便就会相信一个人？","tone":"淡然","chapter":13,"line_start":258,"line_end":258},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"我也有件事一直都想不通。","tone":"微笑","chapter":13,"line_start":270,"line_end":270},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"哦？","tone":"陈述","chapter":13,"line_start":272,"line_end":272},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"这一着是'伏虎扬威'。","tone":"陈述","chapter":13,"line_start":280,"line_end":280},{"speaker":null,"speaker_name":null,"listener":null,"text":"伏虎扬威","tone":"陈述","chapter":13,"line_start":300,"line_end":300}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"现在他一定是神气活现，扬扬得意。","tone":"陈述","chapter":13,"line_start":334,"line_end":334},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"其实那也没什么。","tone":"淡然","chapter":13,"line_start":362,"line_end":362},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"那还不是运气，是你的战略运用成功。","tone":"陈述","chapter":13,"line_start":372,"line_end":372},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"少林的罗汉伏虎拳，经过十余代少林高僧的修正改进，到现在几乎已无懈可击，我也知道他将这趟拳一施展开来，我绝不可能有击倒他的机会，所以……","tone":"陈述","chapter":13,"line_start":378,"line_end":378},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"所以你怎么样？","tone":"陈述","chapter":13,"line_start":380,"line_end":380},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"你果然一下子就将他打倒了。","tone":"微笑","chapter":13,"line_start":386,"line_end":386},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"那两个小和尚呢？","tone":"陈述","chapter":13,"line_start":392,"line_end":392},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"那两个也不是小和尚，也是少林寺中有数的硬手。","tone":"微笑","chapter":13,"line_start":394,"line_end":394},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"你当然也把他们一起收拾了。","tone":"微笑","chapter":13,"line_start":396,"line_end":396},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"没有。","tone":"陈述","chapter":13,"line_start":398,"line_end":398},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"没有？你难道……","tone":"陈述","chapter":13,"line_start":400,"line_end":400}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"他们已去了。","tone":"陈述","chapter":13,"line_start":402,"line_end":402},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"你怎么能让他们去？","tone":"陈述","chapter":13,"line_start":404,"line_end":404},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"我故意放他们去的。","tone":"陈述","chapter":13,"line_start":406,"line_end":406},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"为什么？","tone":"陈述","chapter":13,"line_start":408,"line_end":408},{"speaker":"char_wang_da_niang","speaker_name":"王大娘","listener":null,"text":"脑袋大的人，想得果然比别人周到些。","tone":"微笑","chapter":13,"line_start":414,"line_end":414},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"那倒也并不完全是为了这原因。","tone":"陈述","chapter":13,"line_start":420,"line_end":420},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"还有什么原因？","tone":"陈述","chapter":13,"line_start":422,"line_end":422},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"多事和尚实在太多事，我久已想除掉他。","tone":"陈述","chapter":13,"line_start":424,"line_end":424},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"可是你又怕少林寺的门下来报复。","tone":"陈述","chapter":13,"line_start":426,"line_end":426},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"所以你现在就要找个替死鬼。","tone":"陈述","chapter":13,"line_start":432,"line_end":432},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"其实你早就跟我难过得很。","tone":"微笑","chapter":13,"line_start":438,"line_end":438},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"哦。","tone":"陈述","chapter":13,"line_start":440,"line_end":440},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你既然一定要这么想，我也不必否认。","tone":"淡然","chapter":13,"line_start":446,"line_end":446},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"现在我只问你，多事和尚究竟被谁杀的？","tone":"陈述","chapter":13,"line_start":448,"line_end":448},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你猜呢。","tone":"陈述","chapter":13,"line_start":450,"line_end":450},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"你！当然是你！","tone":"陈述","chapter":13,"line_start":452,"line_end":452},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你看见了？","tone":"陈述","chapter":13,"line_start":454,"line_end":454},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"然后呢？","tone":"陈述","chapter":13,"line_start":460,"line_end":460},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"然后你就将他的尸身从地道中送到后面密室里去。","tone":"陈述","chapter":13,"line_start":462,"line_end":462},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我为什么要这样做？","tone":"陈述","chapter":13,"line_start":464,"line_end":464},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"说下去。","tone":"陈述","chapter":13,"line_start":470,"line_end":470},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我怎么知道他一定会及时赶到？","tone":"陈述","chapter":13,"line_start":476,"line_end":476},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"还有呢？","tone":"陈述","chapter":13,"line_start":482,"line_end":482},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"然后呢？","tone":"陈述","chapter":13,"line_start":488,"line_end":488},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我在哪里杀他们的？","tone":"陈述","chapter":13,"line_start":494,"line_end":494},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"就在这里。","tone":"陈述","chapter":13,"line_start":496,"line_end":496},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"再说下去。","tone":"淡然","chapter":13,"line_start":500,"line_end":500}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":501,"line_end":600,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"他冷笑着，接着道：","tone":"陈述","chapter":13,"line_start":504,"line_end":504},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"还有没有？","tone":"淡然","chapter":13,"line_start":508,"line_end":508},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"多事和尚究竟是不是你杀的？","tone":"陈述","chapter":13,"line_start":518,"line_end":518},{"speaker":null,"speaker_name":null,"listener":null,"text":"他悠然接着道：","tone":"陈述","chapter":13,"line_start":522,"line_end":522},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"我呢？","tone":"陈述","chapter":13,"line_start":526,"line_end":526},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你还不配。","tone":"微笑","chapter":13,"line_start":528,"line_end":528},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"饿狗至少总比死狗好。","tone":"微笑","chapter":13,"line_start":538,"line_end":538},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"练武的人，没练过少林拳法的，只怕还不多。","tone":"微笑","chapter":13,"line_start":544,"line_end":544},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你既然练过少林拳，这件事就交给你了。","tone":"陈述","chapter":13,"line_start":548,"line_end":548},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"哪件事？","tone":"陈述","chapter":13,"line_start":550,"line_end":550},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"最后一件事。","tone":"陈述","chapter":13,"line_start":552,"line_end":552},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你们全都错了。","tone":"陈述","chapter":13,"line_start":572,"line_end":572},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"怎么错了？","tone":"陈述","chapter":13,"line_start":574,"line_end":574},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"以我看，这才是最困难的一件事。","tone":"陈述","chapter":13,"line_start":576,"line_end":576},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你若认为很容易，你为何不去杀他们？","tone":"淡然","chapter":13,"line_start":582,"line_end":582},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"你若不肯动手，我动手也没关系。","tone":"陈述","chapter":13,"line_start":584,"line_end":584},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"哦。","tone":"陈述","chapter":13,"line_start":590,"line_end":590},{"speaker":"char_zhang_hao_er","speaker_name":"张好儿","listener":null,"text":"你不信？","tone":"陈述","chapter":13,"line_start":592,"line_end":592},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"既然已经有人试，我又何必抢人家的生意。","tone":"微笑","chapter":13,"line_start":596,"line_end":596},{"speaker":null,"speaker_name":null,"listener":null,"text":"你总算不笨。","tone":"微笑","chapter":13,"line_start":598,"line_end":598},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"慢着。","tone":"陈述","chapter":13,"line_start":600,"line_end":600}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"呼","tone":"陈述","chapter":13,"line_start":606,"line_end":606},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"这就对了，你们本是好姐妹，谁也不能抛下谁走的。","tone":"微笑","chapter":13,"line_start":650,"line_end":650},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"像阁下这样的好朋友，世上只怕不多。","tone":"陈述","chapter":13,"line_start":682,"line_end":682},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"的确不多。","tone":"微笑","chapter":13,"line_start":684,"line_end":684},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"有些事其实你本来早就该想到的。","tone":"陈述","chapter":13,"line_start":690,"line_end":690},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"哦。","tone":"陈述","chapter":13,"line_start":692,"line_end":692},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你难道还不明白我的意思？","tone":"陈述","chapter":13,"line_start":694,"line_end":694},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我很想明白。","tone":"陈述","chapter":13,"line_start":696,"line_end":696}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":701,"line_end":800,"dialogues":[{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你只算错了一点，这里的暗卡一共有四十九道。","tone":"陈述","chapter":13,"line_start":702,"line_end":702},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"要找到我的确不容易。","tone":"陈述","chapter":13,"line_start":708,"line_end":708},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"所以你只有用这法子，才能将他们带到这里来。","tone":"陈述","chapter":13,"line_start":714,"line_end":714},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"所以你就连她也一起瞒住。","tone":"陈述","chapter":13,"line_start":720,"line_end":720},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"但我能懂得怎么叫一个不老实的人说实话。","tone":"陈述","chapter":13,"line_start":730,"line_end":730},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"哦。","tone":"陈述","chapter":13,"line_start":732,"line_end":732},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你做得很好，的确做得太好了。","tone":"陈述","chapter":13,"line_start":738,"line_end":738},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你是不是也很佩服我？","tone":"微笑","chapter":13,"line_start":740,"line_end":740},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我一直都很看得起你，一直都将你当我的好朋友看待，想不到你……","tone":"陈述","chapter":13,"line_start":742,"line_end":742},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你真的一直将我当朋友？","tone":"陈述","chapter":13,"line_start":744,"line_end":744},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你自己难道不明白？","tone":"陈述","chapter":13,"line_start":746,"line_end":746},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"我当然明白，而且太明白了，不明白的是你。","tone":"陈述","chapter":13,"line_start":748,"line_end":748},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"哦。","tone":"陈述","chapter":13,"line_start":750,"line_end":750},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你知不知道我为什么要去找你？","tone":"陈述","chapter":13,"line_start":752,"line_end":752},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"所以你还是不明白。","tone":"陈述","chapter":13,"line_start":758,"line_end":758},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"不明白什么？","tone":"陈述","chapter":13,"line_start":760,"line_end":760},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"是你先想要对付我，所以我才会去找你。","tone":"陈述","chapter":13,"line_start":762,"line_end":762},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我几时对付过你？","tone":"陈述","chapter":13,"line_start":764,"line_end":764},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"很久以前。","tone":"陈述","chapter":13,"line_start":766,"line_end":766},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"因为我需要钱。","tone":"陈述","chapter":13,"line_start":770,"line_end":770},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你为什么忽然急着要钱？","tone":"陈述","chapter":13,"line_start":772,"line_end":772},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"因为我要做一件大事，做大事总是需要钱的。","tone":"陈述","chapter":13,"line_start":774,"line_end":774},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"这件大事是什么事？","tone":"陈述","chapter":13,"line_start":776,"line_end":776},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"这件事难道你已经知道了？","tone":"陈述","chapter":13,"line_start":778,"line_end":778},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你还知道什么？","tone":"陈述","chapter":13,"line_start":784,"line_end":784},{"speaker":null,"speaker_name":null,"listener":null,"text":"他笑了笑，又道：","tone":"陈述","chapter":13,"line_start":788,"line_end":788},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"不但有关系，而且关系很大。","tone":"陈述","chapter":13,"line_start":796,"line_end":796},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你……你难道也是'山流'的人？","tone":"陈述","chapter":13,"line_start":798,"line_end":798},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"若没有他，又怎会有山流？","tone":"陈述","chapter":13,"line_start":800,"line_end":800}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":801,"line_end":900,"dialogues":[{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"因为……","tone":"陈述","chapter":13,"line_start":812,"line_end":812},{"speaker":null,"speaker_name":null,"listener":null,"text":"他淡淡地接下去道：","tone":"陈述","chapter":13,"line_start":816,"line_end":816},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"至少我要你做的，并不是坏事，你并没有吃亏。","tone":"陈述","chapter":13,"line_start":820,"line_end":820},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"哦。","tone":"陈述","chapter":13,"line_start":822,"line_end":822},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"但你却没有再去找别人。","tone":"陈述","chapter":13,"line_start":828,"line_end":828},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"不是这原因。","tone":"陈述","chapter":13,"line_start":834,"line_end":834},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"不是？","tone":"陈述","chapter":13,"line_start":836,"line_end":836},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"为什么？","tone":"陈述","chapter":13,"line_start":842,"line_end":842},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"因为你想要我冒充杨凡，去田家骗婚。","tone":"陈述","chapter":13,"line_start":844,"line_end":844},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我不怕被人揭穿？","tone":"陈述","chapter":13,"line_start":846,"line_end":846},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"但前几天还有人看到他。","tone":"陈述","chapter":13,"line_start":852,"line_end":852},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"那只不过是杨三爷自己用的替身。","tone":"陈述","chapter":13,"line_start":854,"line_end":854},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"替身？","tone":"陈述","chapter":13,"line_start":856,"line_end":856},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"田二爷呢？","tone":"陈述","chapter":13,"line_start":862,"line_end":862},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"田二爷近几年来，根本就没有见过杨凡。","tone":"陈述","chapter":13,"line_start":864,"line_end":864},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"真的杨凡若回来了呢？","tone":"陈述","chapter":13,"line_start":866,"line_end":866},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"他的朋友呢？","tone":"陈述","chapter":13,"line_start":872,"line_end":872},{"speaker":null,"speaker_name":null,"listener":null,"text":"他笑了笑，又道：","tone":"陈述","chapter":13,"line_start":876,"line_end":876},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"这件事本来已计划得很好，谁知事情忽又有了变化。","tone":"陈述","chapter":13,"line_start":882,"line_end":882},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"什么变化？","tone":"陈述","chapter":13,"line_start":884,"line_end":884},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"变化就发生在田二爷身上。","tone":"陈述","chapter":13,"line_start":886,"line_end":886},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你知道他已经死了。","tone":"陈述","chapter":13,"line_start":888,"line_end":888},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"我本已有些怀疑，直到今天晚上，才完全证实。","tone":"陈述","chapter":13,"line_start":890,"line_end":890},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"怎么证实的？","tone":"陈述","chapter":13,"line_start":892,"line_end":892},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"你已见过她？","tone":"陈述","chapter":13,"line_start":898,"line_end":898}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":10,"line_start":901,"line_end":1000,"dialogues":[{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"我的确知道得很清楚。","tone":"陈述","chapter":13,"line_start":908,"line_end":908},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"有些事你本来绝不该知道的。","tone":"陈述","chapter":13,"line_start":910,"line_end":910},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你想不出我怎会知道的？","tone":"陈述","chapter":13,"line_start":912,"line_end":912},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我实在想不出。","tone":"微笑","chapter":13,"line_start":914,"line_end":914},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"哪件事？","tone":"陈述","chapter":13,"line_start":920,"line_end":920},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"杨凡本来就是我，我本来就是杨凡。","tone":"淡然","chapter":13,"line_start":922,"line_end":922},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"说老实话，我直到现在还是不太明白。","tone":"微笑","chapter":13,"line_start":938,"line_end":938},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"我岂非已将每个细节都说出来了么？","tone":"陈述","chapter":13,"line_start":940,"line_end":940},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"你虽然说出来了，我却没法子记得住。","tone":"陈述","chapter":13,"line_start":944,"line_end":944},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"很合理？","tone":"陈述","chapter":13,"line_start":952,"line_end":952},{"speaker":"char_qin_ge","speaker_name":"秦歌","listener":null,"text":"早已注定要有什么样的结局？","tone":"陈述","chapter":13,"line_start":958,"line_end":958},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你并不知道无色大师和秦歌会到这里来。","tone":"陈述","chapter":13,"line_start":968,"line_end":968},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"我不知道。","tone":"陈述","chapter":13,"line_start":970,"line_end":970},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"所以这口棺材，你本来是为我准备的，是不是？","tone":"陈述","chapter":13,"line_start":972,"line_end":972},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"这口棺材并不坏。","tone":"陈述","chapter":13,"line_start":974,"line_end":974},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"所以现在我也不必再说什么……也许还有一句话。","tone":"陈述","chapter":13,"line_start":984,"line_end":984},{"speaker":"char_liu_feng_gu","speaker_name":"柳风骨","listener":null,"text":"哪句话？","tone":"陈述","chapter":13,"line_start":986,"line_end":986},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"请君入棺。","tone":"陈述","chapter":13,"line_start":988,"line_end":988},{"speaker":null,"speaker_name":null,"listener":null,"text":"柳风骨已死了多久？","tone":"陈述","chapter":13,"line_start":990,"line_end":990},{"speaker":null,"speaker_name":null,"listener":null,"text":"九个月。","tone":"陈述","chapter":13,"line_start":992,"line_end":992},{"speaker":null,"speaker_name":null,"listener":null,"text":"九个月并不长，有时好像一眨眼就过去了，但这九个月却真长。","tone":"陈述","chapter":13,"line_start":994,"line_end":994},{"speaker":null,"speaker_name":null,"listener":null,"text":"那只因你心里还是很闷。","tone":"陈述","chapter":13,"line_start":996,"line_end":996},{"speaker":null,"speaker_name":null,"listener":null,"text":"我总觉得若不是我太荒唐，爹爹就不会死得那么快的。","tone":"陈述","chapter":13,"line_start":998,"line_end":998},{"speaker":null,"speaker_name":null,"listener":null,"text":"现在你已经长大了，为什么还会有这种小孩子的想法？","tone":"陈述","chapter":13,"line_start":1000,"line_end":1000}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":11,"line_start":1001,"line_end":1090,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"你叫我怎么想。","tone":"陈述","chapter":13,"line_start":1002,"line_end":1002},{"speaker":null,"speaker_name":null,"listener":null,"text":"你并没对不起别人，也没有对不起自己，这就已够了。","tone":"陈述","chapter":13,"line_start":1004,"line_end":1004},{"speaker":null,"speaker_name":null,"listener":null,"text":"可是我……","tone":"陈述","chapter":13,"line_start":1006,"line_end":1006},{"speaker":null,"speaker_name":null,"listener":null,"text":"你要我到哪里去？","tone":"陈述","chapter":13,"line_start":1012,"line_end":1012},{"speaker":null,"speaker_name":null,"listener":null,"text":"江南——你岂非就想到江南去？","tone":"陈述","chapter":13,"line_start":1014,"line_end":1014},{"speaker":"char_tian_si_si","speaker_name":"田思思","listener":null,"text":"那次她的确连我都骗过了。","tone":"陈述","chapter":13,"line_start":1046,"line_end":1046},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"我一直觉得，我们应该想个法子谢谢她。","tone":"陈述","chapter":13,"line_start":1048,"line_end":1048},{"speaker":"char_tian_si_si","speaker_name":"田思思","listener":null,"text":"你说什么法子呢？","tone":"陈述","chapter":13,"line_start":1050,"line_end":1050},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"你是不是也想去看看？","tone":"微笑","chapter":13,"line_start":1072,"line_end":1072},{"speaker":"char_tian_si_si","speaker_name":"田思思","listener":null,"text":"看谁？","tone":"陈述","chapter":13,"line_start":1074,"line_end":1074},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"岳环山，他本来岂非也是你心目中的大人物？","tone":"陈述","chapter":13,"line_start":1076,"line_end":1076},{"speaker":"char_tian_si_si","speaker_name":"田思思","listener":null,"text":"但现在我却不想看他了！","tone":"陈述","chapter":13,"line_start":1078,"line_end":1078},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"为什么？","tone":"陈述","chapter":13,"line_start":1080,"line_end":1080},{"speaker":"char_yang_fan","speaker_name":"杨凡","listener":null,"text":"这个人是谁？","tone":"陈述","chapter":13,"line_start":1086,"line_end":1086}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
