{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"现在我还没有把握能杀你！","tone":"陈述","chapter":2,"line_start":3,"line_end":3},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"你破不了那一剑。","tone":"陈述","chapter":2,"line_start":11,"line_end":11},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"我也想不出有谁能破得了那一剑。","tone":"陈述","chapter":2,"line_start":13,"line_end":13},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"你认为那已是天下无双的剑法？","tone":"疑问","chapter":2,"line_start":15,"line_end":15},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"七大剑派，四大世家中的高手我都见过。","tone":"陈述","chapter":2,"line_start":17,"line_end":17},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"你觉得他们如何？","tone":"疑问","chapter":2,"line_start":19,"line_end":19},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"他们的剑法太保守，对自己的性命看得太重，所以他们不如你。","tone":"陈述","chapter":2,"line_start":21,"line_end":21},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"你的眼光很不错，见识却不广。","tone":"无奈","chapter":2,"line_start":23,"line_end":23},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"哦？","tone":"疑问","chapter":2,"line_start":25,"line_end":25},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"我就知道有个人，要破我那一剑，易如反掌。","tone":"陈述","chapter":2,"line_start":27,"line_end":27},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"你见过他的剑法？","tone":"惊讶","chapter":2,"line_start":29,"line_end":29},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"那才真正是天下无双的剑法。","tone":"认真","chapter":2,"line_start":33,"line_end":33},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"这个人是谁？","tone":"疑问","chapter":2,"line_start":35,"line_end":35},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"三手剑金飞？","tone":"疑问","chapter":2,"line_start":39,"line_end":39},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"真正要杀人，用不着三只手，也用不着三把剑。","tone":"陈述","chapter":2,"line_start":45,"line_end":45},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"你说的不是他？","tone":"疑问","chapter":2,"line_start":49,"line_end":49},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"不是！","tone":"陈述","chapter":2,"line_start":51,"line_end":51},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"是谁？","tone":"疑问","chapter":2,"line_start":53,"line_end":53},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"是三少爷。","tone":"陈述","chapter":2,"line_start":55,"line_end":55},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"哪一家的三少爷？","tone":"疑问","chapter":2,"line_start":57,"line_end":57},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"翠云峰下，绿水湖前。","tone":"陈述","chapter":2,"line_start":59,"line_end":59},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"他的那柄剑，也是柄天下无双的宝剑。","tone":"陈述","chapter":2,"line_start":63,"line_end":63},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"可是我劝你千万莫要去见他。","tone":"认真","chapter":2,"line_start":67,"line_end":67},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"我笑的是你。","tone":"陈述","chapter":2,"line_start":75,"line_end":75},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"哦？","tone":"疑问","chapter":2,"line_start":77,"line_end":77},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"你明知我既然已来了，就绝不会放过你。","tone":"陈述","chapter":2,"line_start":79,"line_end":79},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"我虽然没把握杀你，你也一样没把握能杀我。","tone":"陈述","chapter":2,"line_start":83,"line_end":83},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"所以你就想激我到翠云峰去，先去跟那位三少爷斗一斗。","tone":"陈述","chapter":2,"line_start":87,"line_end":87},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"这句话是笑话？","tone":"疑问","chapter":2,"line_start":91,"line_end":91},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"不是，我笑的是我自己。","tone":"苦笑","chapter":2,"line_start":93,"line_end":93},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"哦？","tone":"疑问","chapter":2,"line_start":95,"line_end":95},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"因为我的心事，被你一眼就看出来了。","tone":"苦笑","chapter":2,"line_start":97,"line_end":97}],"new_entities":{"characters":[{"id":"char_wu_ya","name":"乌鸦","alias":[],"identity":"杀手","faction":null,"role":"npc","archetype":"assassin","rank":"出神入化","one_line":"与燕十三齐名的杀手，自称乌鸦，性格冷酷直率","personality":{"traits":["冷酷","直率","精明","冷峻","务实"],"speech_style":"简洁直接","temperament":"冷漠"},"relationships":[{"target":"char_yan_shi_san","type":"对手","intensity":70,"bond_level":3,"dynamic":"亦敌亦友"}],"known_skills":[],"related_skills":[],"rag_refs":[2],"source_refs":[{"chapter":2,"line_start":3,"line_end":3,"text":"乌鸦道：\"现在我还没有把握能杀你！\""}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_cui_yun_feng","name":"翠云峰","region":"翠云峰下，绿水湖前","one_line":"三少爷所在之地，天下第一剑客的居所","source_refs":[{"chapter":2,"line_start":59,"line_end":59,"text":"翠云峰下，绿水湖前。"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"现在你不愿跟我交手？","tone":"疑问","chapter":2,"line_start":99,"line_end":99},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"很不愿意。","tone":"陈述","chapter":2,"line_start":101,"line_end":101},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"为什么？","tone":"疑问","chapter":2,"line_start":103,"line_end":103},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"因为我还有个约会。","tone":"陈述","chapter":2,"line_start":105,"line_end":105},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"什么样的约会？","tone":"疑问","chapter":2,"line_start":107,"line_end":107},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"死约会。","tone":"陈述","chapter":2,"line_start":109,"line_end":109},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"约在哪里？","tone":"疑问","chapter":2,"line_start":111,"line_end":111},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"翠云山下，绿水湖前。","tone":"陈述","chapter":2,"line_start":113,"line_end":113},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"你明知斗不过他，你还要去？","tone":"疑问","chapter":2,"line_start":115,"line_end":115},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"死约会是不见不散的。","tone":"陈述","chapter":2,"line_start":117,"line_end":117},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"难道你是故意去送死？","tone":"疑问","chapter":2,"line_start":119,"line_end":119},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"难道你觉得活着很有趣？","tone":"淡然","chapter":2,"line_start":121,"line_end":121},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"练剑的人，迟早总难免要死在别人的剑下，连逃避都无处逃避。","tone":"无奈","chapter":2,"line_start":125,"line_end":125},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"我一生杀人无算，若能死在天下第一名家的剑下，死亦无憾了。","tone":"豪迈","chapter":2,"line_start":129,"line_end":129},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"好，你去。","tone":"陈述","chapter":2,"line_start":131,"line_end":131},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"我明白你的意思。","tone":"陈述","chapter":2,"line_start":139,"line_end":139},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"哦？","tone":"疑问","chapter":2,"line_start":141,"line_end":141},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"我能去，你为什么不能去？","tone":"疑问","chapter":2,"line_start":143,"line_end":143},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"你不笨。","tone":"调侃","chapter":2,"line_start":145,"line_end":145},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"可是你并不一定要跟着我一起去。","tone":"陈述","chapter":2,"line_start":147,"line_end":147},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"一定要。","tone":"认真","chapter":2,"line_start":149,"line_end":149},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"为什么？","tone":"疑问","chapter":2,"line_start":151,"line_end":151},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"因为我不想错过你们那一战。","tone":"陈述","chapter":2,"line_start":153,"line_end":153},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"高手相争，必尽全力，我在旁边看着，一定可以看出你们剑法中的破绽来。","tone":"冷酷","chapter":2,"line_start":157,"line_end":157},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"有理。","tone":"无奈","chapter":2,"line_start":159,"line_end":159},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"这一战你们无论是谁胜谁负，最后活着的一个人必定是我。","tone":"得意","chapter":2,"line_start":161,"line_end":161},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"因为那时战胜的人必定也已将力竭，你又已看出他剑法中的破绽，若是想杀他，正是个最好的机会。","tone":"陈述","chapter":2,"line_start":163,"line_end":163},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"所以这机会我怎么能错过？","tone":"得意","chapter":2,"line_start":165,"line_end":165},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"的确不能。","tone":"无奈","chapter":2,"line_start":167,"line_end":167},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"只可惜你还是有一点错了。","tone":"陈述","chapter":2,"line_start":169,"line_end":169},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"哪一点？","tone":"疑问","chapter":2,"line_start":171,"line_end":171},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"三少爷的剑法中，根本没有破绽，完全没有！","tone":"认真","chapter":2,"line_start":173,"line_end":173},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"杀过人后，我一定要喝酒。","tone":"陈述","chapter":2,"line_start":179,"line_end":179},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"没有杀人，我也喝酒。","tone":"陈述","chapter":2,"line_start":181,"line_end":181},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"喝过酒后，我一定要去找女人。","tone":"陈述","chapter":2,"line_start":183,"line_end":183},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"没有喝酒，我也找女人。","tone":"陈述","chapter":2,"line_start":185,"line_end":185},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"想不到你竟是个酒色之徒。","tone":"大笑","chapter":2,"line_start":187,"line_end":187},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"彼此彼此。","tone":"陈述","chapter":2,"line_start":189,"line_end":189},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"你既是个酒色之徒，今天我就让你一次。","tone":"调侃","chapter":2,"line_start":193,"line_end":193},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"让什么？","tone":"疑问","chapter":2,"line_start":195,"line_end":195},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"让你付账。","tone":"调侃","chapter":2,"line_start":197,"line_end":197},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"不必让，不客气。","tone":"陈述","chapter":2,"line_start":199,"line_end":199}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":339,"dialogues":[{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"这次一定要让，一定要客气。","tone":"调侃","chapter":2,"line_start":201,"line_end":201},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"不必不必。","tone":"陈述","chapter":2,"line_start":203,"line_end":203},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"要的要的。","tone":"调侃","chapter":2,"line_start":205,"line_end":205},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"要杀人时，我身上从不带累赘的东西，免得碍手碍脚！","tone":"陈述","chapter":2,"line_start":209,"line_end":209},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"哦？","tone":"疑问","chapter":2,"line_start":211,"line_end":211},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"银子就是最累赘的东西。","tone":"陈述","chapter":2,"line_start":213,"line_end":213},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"你可以带银票。","tone":"陈述","chapter":2,"line_start":219,"line_end":219},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"我讨厌银票。","tone":"冷酷","chapter":2,"line_start":221,"line_end":221},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"为什么？","tone":"疑问","chapter":2,"line_start":223,"line_end":223},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"一张银票也不知经过多少人的手传来传去，脏得要命。","tone":"冷酷","chapter":2,"line_start":225,"line_end":225},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"你剑上的明珠可以拿去换银子。","tone":"陈述","chapter":2,"line_start":227,"line_end":227},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"这是笑话？","tone":"疑问","chapter":2,"line_start":231,"line_end":231},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"天大的笑话。","tone":"大笑","chapter":2,"line_start":233,"line_end":233},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"这些珠子都是假的，真的我早卖了。","tone":"调侃","chapter":2,"line_start":235,"line_end":235},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"所以今天我一定要客气，一定要让你。","tone":"调侃","chapter":2,"line_start":239,"line_end":239},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"我若没有跟你来呢？","tone":"疑问","chapter":2,"line_start":241,"line_end":241},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"那时我当然会有别的法子，可是现在你既然已来了，我又何必再想别的法子？","tone":"调侃","chapter":2,"line_start":243,"line_end":243},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"我笑你找错了人。","tone":"调侃","chapter":2,"line_start":249,"line_end":249},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"我也跟你一样，今天本来也是准备来杀人的。","tone":"陈述","chapter":2,"line_start":251,"line_end":251},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"你也讨厌银票？","tone":"疑问","chapter":2,"line_start":253,"line_end":253},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"讨厌得要命。","tone":"冷酷","chapter":2,"line_start":255,"line_end":255},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"所以我今天也一定要客气，一定要让你。","tone":"调侃","chapter":2,"line_start":259,"line_end":259},{"speaker":"char_zhang_gui_de","speaker_name":"掌柜的","listener":null,"text":"两位都不必客气，两位的账，楼下已经有人付了。","tone":"微笑","chapter":2,"line_start":263,"line_end":263},{"speaker":"char_xiao_hong","speaker_name":"小红","listener":null,"text":"我叫小红。","tone":"陈述","chapter":2,"line_start":281,"line_end":281},{"speaker":"char_xiao_cui","speaker_name":"小翠","listener":null,"text":"我叫小翠。","tone":"陈述","chapter":2,"line_start":283,"line_end":283},{"speaker":"char_xiao_hong","speaker_name":"小红","listener":null,"text":"我们是特地来伺候两位的。","tone":"温柔","chapter":2,"line_start":285,"line_end":285},{"speaker":"char_xiao_hong","speaker_name":"小红","listener":null,"text":"两位是想在这里喝酒，还是想到我们那里去都没有关系。","tone":"温柔","chapter":2,"line_start":293,"line_end":293},{"speaker":"char_xiao_cui","speaker_name":"小翠","listener":null,"text":"反正两边的账都有人替两位付过了。","tone":"陈述","chapter":2,"line_start":295,"line_end":295},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"这是你的运气？还是我的？","tone":"疑问","chapter":2,"line_start":299,"line_end":299},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"当然是我的。","tone":"得意","chapter":2,"line_start":301,"line_end":301},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"为什么？","tone":"疑问","chapter":2,"line_start":303,"line_end":303},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"据说一个人快要死的时候，总是会转运的。","tone":"调侃","chapter":2,"line_start":305,"line_end":305},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"翠云峰远不远？","tone":"疑问","chapter":2,"line_start":319,"line_end":319},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"不太远。","tone":"陈述","chapter":2,"line_start":321,"line_end":321},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"像这么样走，我倒希望走远一点，越远越好。","tone":"无奈","chapter":2,"line_start":323,"line_end":323},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"我们可以慢慢的走。","tone":"陈述","chapter":2,"line_start":325,"line_end":325},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"我们到树林里喝点酒好不好？","tone":"陈述","chapter":2,"line_start":329,"line_end":329},{"speaker":"char_wu_ya","speaker_name":"乌鸦","listener":"char_yan_shi_san","text":"酒呢？","tone":"疑问","chapter":2,"line_start":331,"line_end":331},{"speaker":"char_yan_shi_san","speaker_name":"燕十三","listener":"char_wu_ya","text":"你放心，只要我们想喝，自然会有人送酒来的。","tone":"得意","chapter":2,"line_start":333,"line_end":333}],"new_entities":{"characters":[{"id":"char_zhang_gui_de","name":"掌柜的","alias":[],"identity":"酒楼掌柜","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"酒楼掌柜，告知有人已替燕十三和乌鸦付账","personality":{"traits":["殷勤","和善","机灵","圆滑","世故"],"speech_style":"客气恭敬","temperament":"和蔼"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[2],"source_refs":[{"chapter":2,"line_start":261,"line_end":263,"text":"掌柜的忽然走过来，赔笑道：\"两位都不必客气，两位的账，楼下已经有人付了。\""}]},{"id":"char_xiao_hong","name":"小红","alias":[],"identity":"酒楼女子","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"与小翠一同出现的美貌女子，主动来伺候燕十三和乌鸦","personality":{"traits":["妩媚","主动","温柔","殷勤","世故"],"speech_style":"温柔甜腻","temperament":"热情"},"relationships":[{"target":"char_xiao_cui","type":"同伴","intensity":50,"bond_level":2,"dynamic":"搭档"}],"known_skills":[],"related_skills":[],"rag_refs":[2],"source_refs":[{"chapter":2,"line_start":281,"line_end":285,"text":"\"我叫小红。\"\"我叫小翠。\"两个人笑得甜又媚：\"我们是特地来伺候两位的。\""}]},{"id":"char_xiao_cui","name":"小翠","alias":[],"identity":"酒楼女子","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"与小红一同出现的美貌女子，主动来伺候燕十三和乌鸦","personality":{"traits":["妩媚","主动","温柔","殷勤","世故"],"speech_style":"温柔甜腻","temperament":"热情"},"relationships":[{"target":"char_xiao_hong","type":"同伴","intensity":50,"bond_level":2,"dynamic":"搭档"}],"known_skills":[],"related_skills":[],"rag_refs":[2],"source_refs":[{"chapter":2,"line_start":283,"line_end":295,"text":"\"我叫小翠。\"两个人笑得甜又媚：\"我们是特地来伺候两位的。\""}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
