{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":null,"text":"刀下！","tone":"厉声","chapter":24,"line_start":61,"line_end":61},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二","listener":"char_mao_da_xian_sheng","text":"你用不着顾忌我！","tone":"激动","chapter":24,"line_start":91,"line_end":91},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二","listener":"char_mao_da_xian_sheng","text":"我有把握能躲开这一刀。","tone":"陈述","chapter":24,"line_start":93,"line_end":93},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二","listener":"char_mao_da_xian_sheng","text":"就算我躲不开，你也一定要杀了他！这个人不死，就没有我们的活路，我们不能不冒险一搏。","tone":"焦急","chapter":24,"line_start":97,"line_end":97},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_mao_da_xian_sheng","text":"这绝不能算是冒险，你们的机会比他大得多。","tone":"认真","chapter":24,"line_start":99,"line_end":99}],"new_entities":{"characters":[{"id":"char_chou_er_xian_sheng","name":"仇二先生","alias":["仇二"],"identity":"剑客","faction":null,"role":"villain","archetype":"warrior","rank":null,"one_line":"与茅大先生出生入死的剑客，剑法精妙","personality":{"traits":["热血冲动","忠诚","执着","勇猛","直率"],"speech_style":"直接了当","temperament":"急躁"},"relationships":[{"target":"char_mao_da_xian_sheng","type":"挚友","intensity":90,"bond_level":5,"dynamic":"出生入死多年"}],"known_skills":[],"related_skills":[],"rag_refs":[24],"source_refs":[{"chapter":24,"line_start":21,"line_end":21,"text":"仇二先生的剑锋毒蛇般刺来"}]},{"id":"char_mao_da_xian_sheng","name":"茅大先生","alias":["茅大"],"identity":"剑客，慕容家门人","faction":null,"role":"villain","archetype":"warrior","rank":null,"one_line":"阿吉旧友，因仇恨未过门妻子被拐而极度衰老，剑法极高","personality":{"traits":["深情","痛苦","隐忍","自责","执着"],"speech_style":"嘶声呐喊般的低语","temperament":"悲愤"},"relationships":[{"target":"char_chou_er_xian_sheng","type":"挚友","intensity":90,"bond_level":5,"dynamic":"出生入死多年"},{"target":"char_a_ji","type":"宿敌","intensity":80,"bond_level":3,"dynamic":"旧友反目又和解"}],"known_skills":[],"related_skills":[],"rag_refs":[24],"source_refs":[{"chapter":24,"line_start":63,"line_end":63,"text":"茅大先生掌中的剑，已到了阿吉后颈"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_a_ji","updates":{"source_refs":[{"chapter":24,"line_start":15,"line_end":15,"text":"阿吉的手突然一抖"}]},"relationship_updates":[{"action":"add","target":"char_mao_da_xian_sheng","type":"宿敌","intensity":70,"bond_level":3,"dynamic":"旧友重逢，痛苦和解"},{"action":"add","target":"char_chou_er_xian_sheng","type":"对手","intensity":50,"bond_level":2,"dynamic":"交手"}]},{"id":"char_da_lao_ban","updates":{"source_refs":[{"chapter":24,"line_start":85,"line_end":85,"text":"仇二先生长长吐出口气，大老板也长长吐出口气"}]},"relationship_updates":[{"action":"add","target":"char_a_ji","type":"对手","intensity":40,"bond_level":2,"dynamic":"试探与被试探"}]},{"id":"char_zhu_ye_qing","updates":{"source_refs":[{"chapter":24,"line_start":289,"line_end":289,"text":"竹叶青仿佛正在微笑"}]},"relationship_updates":[]}]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"我们是不是已有五年不见了？","tone":"无奈","chapter":24,"line_start":119,"line_end":119},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"这些年来，你日子过得好不好？有没有什么病痛？","tone":"痛苦","chapter":24,"line_start":125,"line_end":125},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"我既然已认出了你，你为什么还不肯回头，让我看看你？","tone":"疑问","chapter":24,"line_start":133,"line_end":133},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_mao_da_xian_sheng","text":"你既然已认出了我，又何必再看？","tone":"无奈","chapter":24,"line_start":135,"line_end":135},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"那么你至少也该看看我已变成了什么样子。","tone":"悲伤","chapter":24,"line_start":137,"line_end":137},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"你看我是不是已变得很多？","tone":"苦笑","chapter":24,"line_start":145,"line_end":145},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"我们若是在路上偶然相逢，你只怕已不会认得出我来。","tone":"苦笑","chapter":24,"line_start":149,"line_end":149},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_da_lao_ban","text":"你是不是在奇怪，他看见我为什么会如此吃惊？","tone":"疑问","chapter":24,"line_start":151,"line_end":151},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_da_lao_ban","text":"你看他已有多大年纪？","tone":"疑问","chapter":24,"line_start":157,"line_end":157},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_mao_da_xian_sheng","text":"二十出头，不到三十。","tone":"陈述","chapter":24,"line_start":159,"line_end":159},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_da_lao_ban","text":"我呢？","tone":"疑问","chapter":24,"line_start":161,"line_end":161},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_da_lao_ban","text":"你看我是不是已有六十左右？","tone":"苦笑","chapter":24,"line_start":165,"line_end":165},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_mao_da_xian_sheng","text":"就算阁下真的已有六十岁，看起来也只有五十三四。","tone":"陈述","chapter":24,"line_start":167,"line_end":167},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"难道我全都猜错了？","tone":"惊讶","chapter":24,"line_start":173,"line_end":173},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_da_lao_ban","text":"我是属虎的，今年整整三十二。","tone":"陈述","chapter":24,"line_start":175,"line_end":175},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"他呢？","tone":"疑问","chapter":24,"line_start":177,"line_end":177},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_da_lao_ban","text":"他只比我大三岁。","tone":"陈述","chapter":24,"line_start":179,"line_end":179},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"他为什么老得如此快？","tone":"惊讶","chapter":24,"line_start":181,"line_end":181},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_da_lao_ban","text":"因为仇恨。","tone":"沉声","chapter":24,"line_start":183,"line_end":183},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"他恨的是什么？","tone":"好奇","chapter":24,"line_start":187,"line_end":187},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_da_lao_ban","text":"他恨的就是我！","tone":"痛苦","chapter":24,"line_start":189,"line_end":189},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"他为什么要恨你？","tone":"好奇","chapter":24,"line_start":191,"line_end":191},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_da_lao_ban","text":"因为我带着他未过门的妻子私奔了！","tone":"陈述","chapter":24,"line_start":193,"line_end":193},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"因为你也爱上了那个女人？","tone":"疑问","chapter":24,"line_start":199,"line_end":199}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_mao_da_xian_sheng","updates":{"age":35,"source_refs":[{"chapter":24,"line_start":179,"line_end":179,"text":"他只比我大三岁"},{"chapter":24,"line_start":181,"line_end":181,"text":"他为什么老得如此快"}]},"relationship_updates":[]}]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_a_ji","speaker_name":"阿吉","listener":null,"text":"就在我带她私奔的半个月之后，我就甩了她。","tone":"淡然","chapter":24,"line_start":201,"line_end":201},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"你为什么要做这种事？","tone":"疑问","chapter":24,"line_start":203,"line_end":203},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":null,"text":"因为我高兴！","tone":"愤怒","chapter":24,"line_start":205,"line_end":205},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"只要你高兴，不管什么事你都做得出？","tone":"疑问","chapter":24,"line_start":207,"line_end":207},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":null,"text":"是的！","tone":"陈述","chapter":24,"line_start":209,"line_end":209},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":null,"text":"现在我总算明白了。","tone":"陈述","chapter":24,"line_start":211,"line_end":211},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_da_lao_ban","text":"明白了什么事？","tone":"疑问","chapter":24,"line_start":213,"line_end":213},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_a_ji","text":"他刚才不杀你，只因为他不想让你死得太快，他要让你也像他一样，受尽折磨，再慢慢的死。","tone":"陈述","chapter":24,"line_start":215,"line_end":215},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":null,"text":"放你妈的屁！","tone":"愤怒","chapter":24,"line_start":217,"line_end":217},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"我恨的不是你，是我自己，所以我才会将自己折磨成这样子。","tone":"悲伤","chapter":24,"line_start":225,"line_end":225},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":null,"text":"我明白。","tone":"平静","chapter":24,"line_start":227,"line_end":227},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"你真的已明白？","tone":"疑问","chapter":24,"line_start":229,"line_end":229},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":null,"text":"真的！","tone":"陈述","chapter":24,"line_start":231,"line_end":231},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_a_ji","text":"你能原谅我？","tone":"恳求","chapter":24,"line_start":233,"line_end":233},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":null,"text":"我……我早已原谅你。","tone":"悲伤","chapter":24,"line_start":235,"line_end":235},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":null,"text":"谢谢你，谢谢你……","tone":"激动","chapter":24,"line_start":241,"line_end":241},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":"char_mao_da_xian_sheng","text":"他拐了你的妻子，又始乱终弃，你反而求他原谅你，反而要谢谢他，你……你……你刚才为什么不让我一剑杀了他？","tone":"愤怒","chapter":24,"line_start":243,"line_end":243},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_chou_er_xian_sheng","text":"你以为刚才真的是我救了他？","tone":"苦笑","chapter":24,"line_start":247,"line_end":247},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":"char_mao_da_xian_sheng","text":"难道不是？","tone":"愤怒","chapter":24,"line_start":249,"line_end":249},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_chou_er_xian_sheng","text":"我救的不是他，是你，刚才你那一剑出手，就死无葬身之地了。","tone":"认真","chapter":24,"line_start":251,"line_end":251},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_chou_er_xian_sheng","text":"就算我也忘恩负义，与你同时出手，也未必能伤得了他毫发。","tone":"苦笑","chapter":24,"line_start":255,"line_end":255},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":"char_mao_da_xian_sheng","text":"刚才我们双剑夹击，已成了天地交泰之势，他还有法子能破得了？","tone":"惊讶","chapter":24,"line_start":259,"line_end":259},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_chou_er_xian_sheng","text":"他有。","tone":"认真","chapter":24,"line_start":261,"line_end":261},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_chou_er_xian_sheng","text":"世上只有他一个人，只有一种法子。","tone":"认真","chapter":24,"line_start":263,"line_end":263},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":"char_mao_da_xian_sheng","text":"天地俱焚？","tone":"惊讶","chapter":24,"line_start":265,"line_end":265},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":"char_chou_er_xian_sheng","text":"不错，地破天惊，天地俱焚。","tone":"认真","chapter":24,"line_start":267,"line_end":267},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":null,"text":"难道他就是那个人？","tone":"惊讶","chapter":24,"line_start":269,"line_end":269},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":null,"text":"他就是。","tone":"陈述","chapter":24,"line_start":271,"line_end":271},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":null,"text":"我生平只做了一件罪无可赦的事，若不是一个人替我保守了秘密，我也早就已死无葬身之地了。","tone":"悲伤","chapter":24,"line_start":275,"line_end":275},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":"char_mao_da_xian_sheng","text":"他也就是这个人？","tone":"疑问","chapter":24,"line_start":277,"line_end":277},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":null,"text":"是的。","tone":"陈述","chapter":24,"line_start":279,"line_end":279},{"speaker":"char_mao_da_xian_sheng","speaker_name":"茅大先生","listener":null,"text":"已是多年前的往事了，这些年来，我也曾见过他，可是他却从未给过我说话的机会，从未听我说完过一句话，现在……","tone":"无奈","chapter":24,"line_start":283,"line_end":283},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":"char_xiao_di","text":"这个人是谁？","tone":"愤怒","chapter":24,"line_start":295,"line_end":295},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":null,"text":"我叫小弟。","tone":"陈述","chapter":24,"line_start":297,"line_end":297},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_chou_er_xian_sheng","text":"我只不过是个既没有名，也没有用的小孩子而已，像你们这样的大英雄、大剑客，当然不会杀我的。","tone":"调侃","chapter":24,"line_start":299,"line_end":299}],"new_entities":{"characters":[{"id":"char_xiao_di","name":"小弟","alias":[],"identity":"茅大先生之子，慕容秋荻所生，寄人篱下","faction":"慕容世家","role":"npc","archetype":"assassin","rank":"初窥门径","one_line":"十五岁的少年，慕容秋荻与茅大先生之子，暗中替母亲执行清理门户的任务","personality":{"traits":["冷静","机敏","隐忍","果断","早熟"],"speech_style":"冷淡从容，言语中带刺","temperament":"外表冷静内心复杂"},"relationships":[{"target":"char_a_ji","type":"宿敌","intensity":60,"bond_level":2,"dynamic":"复杂仇恨"},{"target":"char_mao_da_xian_sheng","type":"亲属","intensity":50,"bond_level":2,"dynamic":"父子关系"}],"known_skills":[],"related_skills":[],"rag_refs":[24],"source_refs":[{"chapter":24,"line_start":297,"line_end":299,"text":"这少年道：我叫小弟。我只不过是个既没有名也没有用的小孩子而已"}]}],"skills":[],"techniques":[{"id":"tech_tian_di_ju_fen","name":"天地俱焚","type":"attack","description":"地破天惊，天地俱焚。能够破解天地交泰剑阵的绝招，世上只有一种法子，威力惊人","source_skill":null,"source_refs":[{"chapter":24,"line_start":265,"line_end":267,"text":"仇二面容骤然变色道天地俱焚茅大先生道不错地破天惊天地俱焚"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_a_ji","updates":{"source_refs":[{"chapter":24,"line_start":201,"line_end":201,"text":"阿吉冷冷道就在我带她私奔的半个月之后我就甩了她"},{"chapter":24,"line_start":235,"line_end":235,"text":"阿吉道我早已原谅你"}]}},{"id":"char_mao_da_xian_sheng","updates":{"source_refs":[{"chapter":24,"line_start":217,"line_end":217,"text":"茅大先生忽然大吼放你妈的屁"},{"chapter":24,"line_start":225,"line_end":225,"text":"茅大先生道我恨的不是你是我自己"}]}}]}
{"segment":4,"line_start":301,"line_end":397,"dialogues":[{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":null,"text":"杀人者死，不管是谁杀了人都一样。","tone":"愤怒","chapter":24,"line_start":303,"line_end":303},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_chou_er_xian_sheng","text":"只有我不一样，我知道你绝不会杀我的。","tone":"调侃","chapter":24,"line_start":307,"line_end":307},{"speaker":"char_chou_er_xian_sheng","speaker_name":"仇二先生","listener":"char_xiao_di","text":"为什么？","tone":"疑问","chapter":24,"line_start":309,"line_end":309},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_chou_er_xian_sheng","text":"因为只要你一出手，就一定有人会替我杀了你！","tone":"陈述","chapter":24,"line_start":311,"line_end":311},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_xiao_di","text":"谁会替你杀他？","tone":"疑问","chapter":24,"line_start":315,"line_end":315},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_a_ji","text":"当然是你。","tone":"陈述","chapter":24,"line_start":317,"line_end":317},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_xiao_di","text":"我为什么要替你杀人？","tone":"疑问","chapter":24,"line_start":319,"line_end":319},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_a_ji","text":"因为我虽然既没有名，也没有用，却有个很好的母亲，而且跟你熟得很！","tone":"调侃","chapter":24,"line_start":321,"line_end":321},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_xiao_di","text":"难道你母亲就是……就是……","tone":"惊讶","chapter":24,"line_start":323,"line_end":323},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_a_ji","text":"家母就是江南慕容世家的大小姐，茅大先生的小师妹……","tone":"陈述","chapter":24,"line_start":329,"line_end":329},{"speaker":"char_zhu_ye_qing","speaker_name":"竹叶青","listener":null,"text":"这位大小姐的芳名，就叫做慕容秋荻。","tone":"微笑","chapter":24,"line_start":331,"line_end":331},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_a_ji","text":"家母再三嘱咐我，若有人敢在外面胡言乱语，毁坏慕容世家的名声，就算我不杀他，你也不会答应的，何况这位茅大先生本就是慕容家的门人，我这么做，只不过是替家母清理门户而已。","tone":"认真","chapter":24,"line_start":335,"line_end":335},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_xiao_di","text":"你母亲几时做了慕容家的执法掌门！","tone":"愤怒","chapter":24,"line_start":337,"line_end":337},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_a_ji","text":"还没有多久。","tone":"陈述","chapter":24,"line_start":339,"line_end":339},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_xiao_di","text":"她为什么不将你留在身旁？","tone":"疑问","chapter":24,"line_start":341,"line_end":341},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":"char_a_ji","text":"因为我是个见不得人的孩子，根本没资格进慕容家的门，只有寄人离下，做一个低三下四的。","tone":"无奈","chapter":24,"line_start":343,"line_end":343},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_xiao_di","text":"你今年已有多大年纪？","tone":"陈述","chapter":24,"line_start":345,"line_end":345},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":null,"text":"我今年才十五。","tone":"陈述","chapter":24,"line_start":347,"line_end":347},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":null,"text":"我知道别人一定看不出我今年才只有十五岁，就好像别人也看不出这位茅大先生今年才三十五一样。","tone":"苦笑","chapter":24,"line_start":351,"line_end":351},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":null,"text":"这也许只不过因为我的日子比别人家的孩子过得苦些，所以长得也就比别人快些。","tone":"悲伤","chapter":24,"line_start":353,"line_end":353},{"speaker":"char_xiao_di","speaker_name":"小弟","listener":null,"text":"明明是个聪明人，为什么偏偏要自讨无趣？","tone":"无奈","chapter":24,"line_start":375,"line_end":375},{"speaker":"char_du_bi_ren","speaker_name":"独臂人","listener":null,"text":"因为他已无路可走。","tone":"淡然","chapter":24,"line_start":377,"line_end":377},{"speaker":"char_du_bi_ren","speaker_name":"独臂人","listener":null,"text":"谁是这里的主人？","tone":"陈述","chapter":24,"line_start":391,"line_end":391},{"speaker":"char_da_lao_ban","speaker_name":"大老板","listener":"char_du_bi_ren","text":"现在好像还是我。","tone":"无奈","chapter":24,"line_start":395,"line_end":395},{"speaker":"char_du_bi_ren","speaker_name":"独臂人","listener":null,"text":"有客自远方来，连个座位都没有，岂非显得主人太无礼？","tone":"陈述","chapter":24,"line_start":397,"line_end":397}],"new_entities":{"characters":[{"id":"char_du_bi_ren","name":"独臂人","alias":["独臂单眼单足残废"],"identity":"神秘残废高手，独臂独眼独足，衣着华丽","faction":null,"role":"npc","archetype":"warrior","rank":"出神入化","one_line":"独臂独眼独足的神秘残废高手，修饰整洁衣着华丽，带着残酷的魅力登场","personality":{"traits":["傲慢","从容","神秘","威严","冷酷"],"speech_style":"语气傲慢从容","temperament":"冷峻中带残酷魅力"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[24],"source_refs":[{"chapter":24,"line_start":381,"line_end":397,"text":"门外一人冷冷道因为他已无路可走左边一只衣袖空空荡荡右腿已被齐膝砍断装着只木脚左眼上一条刀疤"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_di","updates":{"source_refs":[{"chapter":24,"line_start":329,"line_end":329,"text":"小弟道家母就是江南慕容世家的大小姐茅大先生的小师妹"},{"chapter":24,"line_start":347,"line_end":347,"text":"小弟道我今年才十五"}]}}]}
