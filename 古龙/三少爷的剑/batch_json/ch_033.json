      "speaker_name": "夏侯星",
      "listener": "char_xie_xiao_feng",
      "text": "那么你就该知道她为的是什么。",
      "tone": "冷笑",
      "chapter": 33,
      "line_start": 307,
      "line_end": 307
    },
    {
