{"segment":1,"line_start":1,"line_end":90,"dialogues":[{"speaker":"char_miao_zi","speaker_name":"苗子","listener":"char_a_ji","text":"喝！","tone":"陈述","chapter":21,"line_start":3,"line_end":3},{"speaker":"char_miao_zi","speaker_name":"苗子","listener":"char_a_ji","text":"这桌是特地为你准备的，酒也是特地为你准备的！","tone":"陈述","chapter":21,"line_start":7,"line_end":7},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_miao_zi","text":"所以我一定要喝？","tone":"疑问","chapter":21,"line_start":9,"line_end":9},{"speaker":"char_miao_zi","speaker_name":"苗子","listener":"char_a_ji","text":"一定。","tone":"陈述","chapter":21,"line_start":11,"line_end":11},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_miao_zi","text":"这是竹叶青。","tone":"陈述","chapter":21,"line_start":13,"line_end":13},{"speaker":"char_miao_zi","speaker_name":"苗子","listener":"char_a_ji","text":"竹叶青是好酒！","tone":"陈述","chapter":21,"line_start":15,"line_end":15},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_miao_zi","text":"虽然是好酒，却不是好人！","tone":"认真","chapter":21,"line_start":17,"line_end":17},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_miao_zi","text":"你已见到过竹叶青这个人？","tone":"疑问","chapter":21,"line_start":21,"line_end":21},{"speaker":"char_miao_zi","speaker_name":"苗子","listener":"char_a_ji","text":"吃。","tone":"陈述","chapter":21,"line_start":23,"line_end":23},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_miao_zi","text":"现在他的人在哪里？","tone":"疑问","chapter":21,"line_start":29,"line_end":29},{"speaker":"char_miao_zi","speaker_name":"苗子","listener":"char_a_ji","text":"谁？","tone":"疑问","chapter":21,"line_start":31,"line_end":31},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_miao_zi","text":"竹叶青！","tone":"激动","chapter":21,"line_start":33,"line_end":33},{"speaker":"char_miao_zi","speaker_name":"苗子","listener":"char_a_ji","text":"这就是竹叶青，竹叶青就在这里！","tone":"激动","chapter":21,"line_start":35,"line_end":35},{"speaker":"char_a_ji","speaker_name":"阿吉","listener":"char_miao_zi","text":"娃娃呢？","tone":"焦