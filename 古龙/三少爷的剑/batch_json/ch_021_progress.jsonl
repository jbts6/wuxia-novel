{"segment":3,"line_start":145,"line_end":300,"dialogues":[{"speaker":"char_du_fang","speaker_name":"杜方","listener":"char_chang_san","text":"这里有谁是大老板的兄弟？","tone":"陈述","chapter":21,"line_start":161,"line_end":161},{"speaker":"char_du_fang","speaker_name":"杜方","listener":"char_chang_san","text":"你们都是？","tone":"疑问","chapter":21,"line_start":167,"line_end":167},{"speaker":"char_chang_san","speaker_name":"长三","listener":"char_du_fang","text":"你找大老板干什么？","tone":"疑问","chapter":21,"line_start":170,"line_end":171},{"speaker":"char_du_fang","speaker_name":"杜方","listener":"char_chang_san","text":"我有点东西要卖给他！","tone":"陈述","chapter":21,"line_start":173,"line_end":173},{"speaker":"char_chang_san","speaker_name":"长三","listener":"char_du_fang","text":"什么东西？","tone":"疑问","chapter":21,"line_start":175,"line_end":175},{"speaker":"char_du_fang","speaker_name":"杜方","listener":"char_chang_san","text":"我们这三条命。","tone":"陈述","chapter":21,"line_start":177,"line_end":177},{"speaker":"char_chang_san","speaker_name":"长三","listener":"char_du_fang","text":"你们准备卖多少？","tone":"疑问","chapter":21,"line_start":179,"line_end":179},{"speaker":"char_du_fang","speaker_name":"杜方","listener":"char_chang_san","text":"十万两。","tone":"陈述","chapter":21,"line_start":181,"line_end":181},{"speaker":"char_chang_san","speaker_name":"长三","listener":"char_du_fang","text":"三条命十万两并不贵。","tone":"微笑","chapter":21,"line_start":183,"line_end":183},{"speaker":"char_du_fang","speaker_name":"杜方","listener":"char_chang_san","text":"本来就不贵。","tone":"陈述","chapter":21,"line_start":185,"line_end":185},{"speaker":"char_chang_san","speaker_name":"长三","listener":"char_du_fang","text":"但我却看不出你们凭什么能值十万两。","tone":"严肃","chapter":21,"line_start":187,"line_end":187},{"speaker":"char_du_fang","speaker_name":"杜方","listener":"char_chang_san","text":"就凭这柄剑！","tone":"豪迈","chapter":21,"line_start":189,"line_end":189},{"speaker":"char_du_fang","speaker_name":"杜方","listener":"char_chang_san","text":"怎么样？","tone":"疑问","chapter":21,"line_start":197,"line_end