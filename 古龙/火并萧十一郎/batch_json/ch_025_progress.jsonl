{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"站住。","tone":"沉声","chapter":25,"line_start":192,"line_end":192},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你知道这是什么地方？","tone":"疑问","chapter":25,"line_start":202,"line_end":202},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你知道我是谁？","tone":"疑问","chapter":25,"line_start":206,"line_end":206},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"那么你就不该来的。","tone":"陈述","chapter":25,"line_start":210,"line_end":210},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我已来了。","tone":"陈述","chapter":25,"line_start":212,"line_end":212},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"来干什么？","tone":"疑问","chapter":25,"line_start":214,"line_end":214},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我是个瞎子。","tone":"陈述","chapter":25,"line_start":216,"line_end":216},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"我看得出。","tone":"陈述","chapter":25,"line_start":218,"line_end":218},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"瞎子总能听见很多别人听不见的事。","tone":"陈述","chapter":25,"line_start":220,"line_end":220},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你听见了什么？","tone":"疑问","chapter":25,"line_start":222,"line_end":222},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"歌声。","tone":"陈述","chapter":25,"line_start":224,"line_end":224},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你知不知道这里是西湖？","tone":"疑问","chapter":25,"line_start":226,"line_end":226},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"这里到处都有歌声。","tone":"陈述","chapter":25,"line_start":230,"line_end":230},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"但是我刚才听见的歌声却不同。","tone":"陈述","chapter":25,"line_start":232,"line_end":232},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"不同？","tone":"疑问","chapter":25,"line_start":234,"line_end":234},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"跟别的歌声不同。","tone":"陈述","chapter":25,"line_start":236,"line_end":236},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"有什么不同？","tone":"疑问","chapter":25,"line_start":238,"line_end":238},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"有的歌声悲伤，有的歌声欢乐，有的歌声象征幸福平静，也有的歌声充满激动愤怒。","tone":"陈述","chapter":25,"line_start":240,"line_end":241},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"你若也像我一样是个瞎子，你就会从歌声中听出很多奇怪而有趣的事。","tone":"陈述","chapter":25,"line_start":242,"line_end":243}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_bai_yi_xia_zi","updates":{"source_refs":[{"chapter":25,"line_start":104,"line_end":128,"text":"他的脸也是苍白的……一双蜡黄的眼睛"}],"rag_refs":[25]},"relationship_updates":[]}]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"刚才你听出了什么？","tone":"疑问","chapter":25,"line_start":246,"line_end":246},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"灾祸。","tone":"陈述","chapter":25,"line_start":248,"line_end":248},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"暴风雨来临前的风声一定和平时的风声不同，野兽在临死前的呼叫也一定和平时两样。","tone":"陈述","chapter":25,"line_start":252,"line_end":253},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"一个人若是有灾祸要发生时，她的歌声中一定也会有种不祥的预兆，我听得出。","tone":"陈述","chapter":25,"line_start":254,"line_end":255},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你不怕被牵连？","tone":"疑问","chapter":25,"line_start":264,"line_end":264},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"现在我只不过想来看看。","tone":"陈述","chapter":25,"line_start":266,"line_end":266},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"看什么？","tone":"疑问","chapter":25,"line_start":268,"line_end":268},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"看看那位唱歌的姑娘。","tone":"陈述","chapter":25,"line_start":270,"line_end":270},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你是个瞎子？","tone":"疑问","chapter":25,"line_start":282,"line_end":282},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"瞎子看不见。","tone":"陈述","chapter":25,"line_start":288,"line_end":288},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"别人都能看见的，瞎子都看不见。","tone":"苦笑","chapter":25,"line_start":288,"line_end":289},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"可是瞎子却往往能看见一些别人看不见的事。","tone":"陈述","chapter":25,"line_start":298,"line_end":298},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"譬如说，灾祸？","tone":"疑问","chapter":25,"line_start":300,"line_end":300}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_shi_yi_lang","updates":{"source_refs":[{"chapter":25,"line_start":258,"line_end":258,"text":"萧十一郎脸色变了。"}],"rag_refs":[25]},"relationship_updates":[]},{"id":"char_bai_yi_xia_zi","updates":{"source_refs":[{"chapter":25,"line_start":288,"line_end":298,"text":"瞎子看不见……可是瞎子却往往能看见一些别人看不见的事。"}],"rag_refs":[25]},"relationship_updates":[]}]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"所以我想来看看，那究竟会是什么样的灾祸。","tone":"陈述","chapter":25,"line_start":302,"line_end":302},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"你在笑？","tone":"疑问","chapter":25,"line_start":306,"line_end":306},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"灾祸并不可笑。","tone":"陈述","chapter":25,"line_start":310,"line_end":310},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"我在笑我自己。","tone":"陈述","chapter":25,"line_start":312,"line_end":312},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"为什么？","tone":"疑问","chapter":25,"line_start":314,"line_end":314},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"因为我从来也没有听见过这么荒唐的事，但我却偏偏被你打动了。","tone":"无奈","chapter":25,"line_start":316,"line_end":317},{"speaker":"char_shen_bi_jun","speaker_name":"沈璧君","listener":"char_feng_si_niang","text":"唱歌的是冰冰？","tone":"疑问","chapter":25,"line_start":328,"line_end":328},{"speaker":"char_feng_si_niang","speaker_name":"风四娘","listener":"char_shen_bi_jun","text":"嗯。","tone":"陈述","chapter":25,"line_start":330,"line_end":330},{"speaker":"char_shen_bi_jun","speaker_name":"沈璧君","listener":"char_feng_si_niang","text":"你说冰冰病得很重，而且是种治不好的绝症？","tone":"疑问","chapter":25,"line_start":332,"line_end":332},{"speaker":"char_feng_si_niang","speaker_name":"风四娘","listener":"char_shen_bi_jun","text":"嗯。","tone":"陈述","chapter":25,"line_start":334,"line_end":334},{"speaker":"char_shen_bi_jun","speaker_name":"沈璧君","listener":"char_feng_si_niang","text":"难道这瞎子真能从她歌声中听出来？","tone":"疑问","chapter":25,"line_start":336,"line_end":336},{"speaker":"char_feng_si_niang","speaker_name":"风四娘","listener":"char_shen_bi_jun","text":"我只希望他莫要再看出别的事。","tone":"担心","chapter":25,"line_start":344,"line_end":344},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你看出了什么？","tone":"疑问","chapter":25,"line_start":400,"line_end":400}],"new_entities":{"characters":[{"id":"char_bing_bing","name":"冰冰","alias":[],"identity":"身患绝症的美丽女子","faction":null,"role":"companion","archetype":"healer","rank":"平平无奇","one_line":"美得脆弱而神秘，身患绝症却意志坚强，歌声中能听出不祥预兆。","personality":{"traits":["脆弱","坚韧","神秘","安静","忧伤"],"speech_style":"轻柔","temperament":"沉静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[25],"source_refs":[{"chapter":25,"line_start":366,"line_end":394,"text":"冰冰……她美得脆弱而神秘，美得令人心疼。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_shi_yi_lang","updates":{"source_refs":[{"chapter":25,"line_start":320,"line_end":320,"text":"萧十一郎居然也有被人打动的时候"}],"rag_refs":[25]},"relationship_updates":[]},{"id":"char_shen_bi_jun","updates":{"source_refs":[{"chapter":25,"line_start":328,"line_end":336,"text":"沈璧君又在她耳边低语"}],"rag_refs":[25]},"relationship_updates":[]},{"id":"char_feng_si_niang","updates":{"source_refs":[{"chapter":25,"line_start":350,"line_end":386,"text":"风四娘……她一直认为沈璧君是真正的美人"}],"rag_refs":[25]},"relationship_updates":[]}]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我看见了一片沼泽，绝谷下的沼泽，没有野兽，没有树木，没有生命……","tone":"梦呓般","chapter":25,"line_start":402,"line_end":403},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"可是这片沼泽里却有个人，是个女人。","tone":"陈述","chapter":25,"line_start":402,"line_end":403},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我看见这个女人正在往上爬，我看得出她有病，病得很重……","tone":"梦呓般","chapter":25,"line_start":416,"line_end":416},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"她好像已快跌下去，但却忽然有一只手伸出来，把她拉了上去。","tone":"陈述","chapter":25,"line_start":418,"line_end":418},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"那是只男人的手。","tone":"陈述","chapter":25,"line_start":420,"line_end":420},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"现在这只手上，却握着柄形状很奇特的刀，女人正在他身旁唱歌……","tone":"陈述","chapter":25,"line_start":422,"line_end":422},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"可是琴弦忽然断了，她也倒了下去。","tone":"陈述","chapter":25,"line_start":424,"line_end":424},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"唱歌的女人，就是在沼泽中的女人？","tone":"疑问","chapter":25,"line_start":426,"line_end":427},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"是的。","tone":"陈述","chapter":25,"line_start":430,"line_end":430},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你凭哪点看出来的？你能看见她的脸长得是什么样子？","tone":"疑问","chapter":25,"line_start":432,"line_end":433},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我看不见她的脸，但我却看得出她左股上有一个青色的胎记，比巴掌还大些，看来就像是一片枫叶。","tone":"陈述","chapter":25,"line_start":436,"line_end":437},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":null,"text":"我果然没有看错，我知道我绝不会看错的……","tone":"喃喃","chapter":25,"line_start":450,"line_end":450},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你杀错人了。","tone":"沉声","chapter":25,"line_start":492,"line_end":492},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"哦？","tone":"疑问","chapter":25,"line_start":494,"line_end":494},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"到这里来的人，本该杀我的。","tone":"陈述","chapter":25,"line_start":496,"line_end":496},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"你要我杀你？","tone":"疑问","chapter":25,"line_start":498,"line_end":498}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_sha_ren_ya","name":"杀人崖","region":"未知","one_line":"绝谷悬崖，下有沼泽，天公子曾将冰冰推入此谷。","source_refs":[{"chapter":25,"line_start":406,"line_end":408,"text":"杀人崖绝谷下的那片沼泽"}]}],"items":[]},"entity_updates":[{"id":"char_bai_yi_xia_zi","updates":{"source_refs":[{"chapter":25,"line_start":402,"line_end":450,"text":"瞎子说出冰冰身上的胎记"}],"rag_refs":[25]},"relationship_updates":[]},{"id":"char_bing_bing","updates":{"source_refs":[{"chapter":25,"line_start":440,"line_end":444,"text":"冰冰的脸色已变了……充满了惊讶和恐惧。"}],"rag_refs":[25]},"relationship_updates":[]}]}
{"segment":6,"line_start":501,"line_end":600,"dialogues":[{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"非杀不可。","tone":"冷酷","chapter":25,"line_start":500,"line_end":500},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"为什么？","tone":"疑问","chapter":25,"line_start":502,"line_end":502},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"因为你已在这里。","tone":"冷酷","chapter":25,"line_start":504,"line_end":504},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"也因为你想杀我？","tone":"疑问","chapter":25,"line_start":506,"line_end":506},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"其实就算要我不杀你，你还是一样可以杀我。","tone":"淡然","chapter":25,"line_start":510,"line_end":511},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我说过，我虽然是个瞎子，却能看见一些别人看不见的事。","tone":"陈述","chapter":25,"line_start":528,"line_end":529},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"现在你看见了什么？","tone":"疑问","chapter":25,"line_start":532,"line_end":532},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我又看见了那只手，手里又握住了那柄刀。","tone":"陈述","chapter":25,"line_start":534,"line_end":534},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我也看得出你一定要杀了我。","tone":"陈述","chapter":25,"line_start":540,"line_end":540},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"","tone":"冷笑","chapter":25,"line_start":542,"line_end":542},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"若是在两年前，你会让我走的，可是现在你已变了。","tone":"陈述","chapter":25,"line_start":544,"line_end":544},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"两年前你见过我？","tone":"疑问","chapter":25,"line_start":546,"line_end":546},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"不管我两年前有没有看见过你，现在我却能看得出，两年前你绝不是这么样的一个人。","tone":"淡然","chapter":25,"line_start":548,"line_end":549},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你还能看见什么？","tone":"疑问","chapter":25,"line_start":552,"line_end":552},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"我看见了一滩血，血里有一只断手，手里有一柄刀。","tone":"诡秘","chapter":25,"line_start":554,"line_end":554},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"你看得出那是谁的血？","tone":"疑问","chapter":25,"line_start":556,"line_end":556},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"是谁的？","tone":"反问","chapter":25,"line_start":558,"line_end":558},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"是你的血，你的手，你的刀。","tone":"诡秘","chapter":25,"line_start":558,"line_end":559},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"死并不可笑。","tone":"陈述","chapter":25,"line_start":564,"line_end":564},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"这次我笑的是你。","tone":"嘲讽","chapter":25,"line_start":566,"line_end":566},{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"为什么？","tone":"疑问","chapter":25,"line_start":568,"line_end":568},{"speaker":"char_xiao_shi_yi_lang","speaker_name":"萧十一郎","listener":"char_bai_yi_xia_zi","text":"因为这次你看错了。","tone":"大笑","chapter":25,"line_start":570,"line_end":570}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_ge_lu_dao","name":"割鹿刀","type":"weapon","owner":"char_xiao_shi_yi_lang","one_line":"萧十一郎的佩刀，形状奇特，杀气逼人。","description":"割鹿刀是萧十一郎的随身武器，刀未出鞘已杀气逼人。刀的形状很奇特，刀在鞘中时已令人感到无法形容的压力。","effects":[{"type":"特殊","description":"杀气可无形逼人"}],"origin":"未知","rarity":"绝世神兵","related_characters":["char_xiao_shi_yi_lang"],"related_skills":["skill_ge_lu_dao_fa"],"rag_refs":[25],"source_refs":[{"chapter":25,"line_start":480,"line_end":482,"text":"割鹿刀，犹在鞘。可是杀气却已逼人眉睫。"}]}]},"entity_updates":[{"id":"char_xiao_shi_yi_lang","updates":{"source_refs":[{"chapter":25,"line_start":514,"line_end":522,"text":"我一定见过这个人，一定见过。"},{"chapter":25,"line_start":544,"line_end":544,"text":"若是在两年前，你会让我走的，可是现在你已变了。"}],"rag_refs":[25]},"relationship_updates":[]}]}
{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":"char_bai_yi_xia_zi","speaker_name":"白衣瞎子","listener":"char_xiao_shi_yi_lang","text":"好功夫，看来你武功又比两年前精进了许多，只可惜……","tone":"大笑","chapter":25,"line_start":672,"line_end":672},{"speaker":"char_wang_meng","speaker_name":"王猛","listener":null,"text":"果然是好身手。","tone":"感叹","chapter":25,"line_start":684,"line_end":684}],"new_entities":{"characters":[{"id":"char_wang_meng","name":"王猛","alias":[],"identity":"船上的江湖豪杰","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"水月楼上的江湖人士之一，赞叹萧十一郎的好身手。","personality":{"traits":["直爽","豪迈","务实","敬佩强者","深沉"],"speech_style":"直率","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[25],"source_refs":[{"chapter":25,"line_start":684,"line_end":684,"text":"王猛忽然长长叹了口气，道：果然是好身手。"}]},{"id":"char_tian_gong_zi","name":"天公子","alias":["逍遥侯"],"identity":"神秘高手","faction":null,"role":"villain","archetype":"assassin","rank":"登峰造极","one_line":"江湖中最可怕的高手之一，曾将冰冰推入杀人崖绝谷。","personality":{"traits":["阴狠","强大","神秘","冷酷","残忍"],"speech_style":"冰冷","temperament":"冷酷"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[25],"source_refs":[{"chapter":25,"line_start":666,"line_end":668,"text":"两个人脸色全都变了，就像是忽然看见个鬼魂在他们面前凌空飞舞。"}]}],"skills":[{"id":"skill_ge_lu_dao_fa","name":"割鹿刀法","type":"刀法","faction":null,"rank":"登峰造极","one_line":"萧十一郎的绝世刀法，刀未出鞘已杀气逼人。","techniques":[{"id":"tech_ge_lu_ba_shi","name":"割鹿八式","type":"attack","description":"割鹿刀的八式变化，每一式都有致命威力。"},{"id":"tech_sha_qi_bi_ren","name":"杀气逼人","type":"special","description":"刀未出鞘，杀气已能逼人眉睫，令对手胆寒。"}],"progression":[{"level":"出神入化","chapter":25}],"effects":[{"type":"伤害","description":"割鹿刀威力极大，配合萧十一郎的武功可达一击必杀之效。"},{"type":"特殊","description":"刀未出鞘已可发出无形杀气压制对手。"}],"combat_style":"简洁有效，以静制动，后发先至。","rag_refs":[25],"source_refs":[{"chapter":25,"line_start":480,"line_end":482,"text":"割鹿刀，犹在鞘。可是杀气却已逼人眉睫。"}]}],"techniques":[{"id":"tech_zhu_zhang_dian_xue","name":"竹杖点穴","type":"attack","description":"瞎子以竹杖毒蛇般刺出，可幻化十七八道杖影，每一杖都是致命杀手。","source_skill":null,"source_refs":[{"chapter":25,"line_start":576,"line_end":620,"text":"竹杖是直的，直而硬。可是他这一招刺出，又直又硬的竹杖却像是在不停的扭曲颤动着。"}]},{"id":"tech_ling_kong_xuan_zhuan","name":"凌空旋转","type":"defense","description":"瞎子凌空翻身，衣袂猎猎飞舞，身子陀螺般在空中旋转不停，可穿窗而出。","source_skill":null,"source_refs":[{"chapter":25,"line_start":660,"line_end":670,"text":"瞎子凌空翻身，衣袂猎猎飞舞，身子陀螺般在空中旋转不停。"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_bai_yi_xia_zi","updates":{"source_refs":[{"chapter":25,"line_start":660,"line_end":676,"text":"瞎子凌空翻身……穿窗而出，飞了出去。"}],"rag_refs":[25]},"relationship_updates":[]},{"id":"char_xiao_shi_yi_lang","updates":{"source_refs":[{"chapter":25,"line_start":626,"line_end":660,"text":"萧十一郎与瞎子交手"}],"rag_refs":[25]},"relationship_updates":[]}]}
