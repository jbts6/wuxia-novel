[
  {
    "id": "loc_hua_shan",
    "name": "华山",
    "region": "五岳之一",
    "one_line": "五岳之一，山峦挺秀，风物绝胜，伊风在此偶遇凌家母女。",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 252,
        "line_end": 252,
        "text": "华山乃五岳之一，山峦挺秀，风物绝胜"
      },
      {
        "chapter": 1,
        "line_start": 258,
        "line_end": 258,
        "text": "这天华山绝顶的山阴之处"
      },
      {
        "chapter": 2,
        "line_start": 1,
        "line_end": 2,
        "text": "夺命双尸宫氏兄弟，远游华山，竟一去不返"
      }
    ]
  },
  {
    "id": "loc_zhong_nan_shan",
    "name": "终南山",
    "region": "长安之南",
    "one_line": "道教名山之一，终南派所在，上有玄妙观",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 148,
        "line_end": 150,
        "text": "终南山位于长安之南，为道教名山之一。"
      },
      {
        "chapter": 4,
        "line_start": 2,
        "line_end": 2,
        "text": "下终南山"
      },
      {
        "chapter": 7,
        "line_start": 892,
        "line_end": 893,
        "text": "终南山不知出了什么变故"
      },
      {
        "chapter": 9,
        "line_start": 84,
        "line_end": 84,
        "text": "每一处山弯的山壁下，都放有茶水架子"
      }
    ]
  },
  {
    "id": "loc_wu_liang_shan",
    "name": "无量山",
    "region": "滇边",
    "one_line": "滇边深山，独孤灵藏宝之处，内有天星秘笈、毒龙丸和蚀骨圣水解药",
    "source_refs": [
      {
        "chapter": 3,
        "line_start": 714,
        "line_end": 714,
        "text": "都埋入滇边无量山深之处"
      },
      {
        "chapter": 4,
        "line_start": 452,
        "line_end": 452,
        "text": "伊风毕竟来到了无量山，无量乃滇中名山，绵亘数百里，主峰在景东之西，山高万仞。"
      }
    ]
  },
  {
    "id": "loc_ba_zhong",
    "name": "巴中",
    "region": "四川",
    "one_line": "四川省地势较平坦之处，伊风途经之地。",
    "source_refs": [
      {
        "chapter": 4,
        "line_start": 14,
        "line_end": 14,
        "text": "到了巴中后，地势才较平坦。"
      }
    ]
  },
  {
    "id": "loc_xu_zhou",
    "name": "叙州",
    "region": "四川川滇交界",
    "one_line": "川滇交界旁的城市，伊风在此遭遇天争教和天媚教。",
    "source_refs": [
      {
        "chapter": 4,
        "line_start": 22,
        "line_end": 22,
        "text": "来到川滇交界旁的叙州。"
      }
    ]
  },
  {
    "id": "loc_jing_dong",
    "name": "景东",
    "region": "云南",
    "one_line": "云南城市，位于无量山主峰之东，伊风在此歇息一夜后上山。",
    "source_refs": [
      {
        "chapter": 4,
        "line_start": 454,
        "line_end": 454,
        "text": "伊风日落至景东"
      },
      {
        "chapter": 7,
        "line_start": 248,
        "line_end": 248,
        "text": "一到景东，他就歇下了。"
      }
    ]
  },
  {
    "id": "loc_shi_shi",
    "name": "石室",
    "region": "无量山巅",
    "one_line": "无量山巅的石屋，有窗无门，内堆山果干粮与无数珠宝，南偷北盗在此较技近十年。",
    "source_refs": [
      {
        "chapter": 5,
        "line_start": 2,
        "line_end": 4,
        "text": "石屋甚为宽大，东西两端各堆着些山薯、茯苓……南北两面却堆放着不计其数的珠宝"
      }
    ]
  },
  {
