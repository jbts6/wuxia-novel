{"segment":5,"line_start":214,"line_end":244,"dialogues":[{"speaker":"char_ling_lin","speaker_name":"凌琳","listener":"char_yi_feng","text":"伊大哥，走吧。","tone":"柔声","chapter":13,"line_start":222,"line_end":222},{"speaker":"char_yi_feng","speaker_name":"吕南人","listener":"char_ling_lin","text":"从今以后，不要叫我伊风，叫我吕南人。我要恢复吕南人三个字，报那夺妻杀友之恨。","tone":"厉声","chapter":13,"line_start":224,"line_end":226},{"speaker":"char_ling_lin","speaker_name":"凌琳","listener":"char_yi_feng","text":"伊……不，吕人哥，你……","tone":"颤声","chapter":13,"line_start":228,"line_end":228},{"speaker":"char_yi_feng","speaker_name":"吕南人","listener":"char_ling_lin","text":"对不起，吓着你了。","tone":"温柔","chapter":13,"line_start":230,"line_end":230},{"speaker":"char_ling_lin","speaker_name":"凌琳","listener":"char_yi_feng","text":"瞧你一副凶神恶煞的样子，好像要吃掉我似的。","tone":"调侃","chapter":13,"line_start":232,"line_end":232},{"speaker":"char_yi_feng","speaker_name":"吕南人","listener":"char_ling_lin","text":"我要吃的，只有一个人。","tone":"冷笑","chapter":13,"line_start":234,"line_end":234},{"speaker":"char_yi_feng","speaker_name":"吕南人","listener":"char_sun_min","text":"凌夫人目前有何打算？","tone":"疑问","chapter":13,"line_start":234,"line_end":236},{"speaker":"char_sun_min","speaker_name":"孙敏","listener":"char_yi_feng","text":"我想我们还是暂时住在这里，你呢？","tone":"疑问","chapter":13,"line_start":238,"line_end":238},{"speaker":"char_yi_feng","speaker_name":"吕南人","listener":"char_sun_min","text":"我也想再在这山洞里小住，待我练成万老前辈的'飘香剑雨'，再下山找那萧无决以死战。","tone":"豪迈","chapter":13,"line_start":240,"line_end":242}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_yi_feng","updates":{"one_line":"本名吕南人，因被萧无所害而改名伊风，万天萍托付飘香剑雨后发誓报仇","source_refs":[{"chapter":13,"line_start":224,"line_end":226,"text":"从今以后，不要叫我伊风，叫我吕南人。我要恢复吕南人三个字，报那夺妻杀友之恨。"}]},"relationship_updates":[{"action":"add","target":"char_ling_lin","type":"合作者","intensity":40,"bond_level":2,"dynamic":"同伴"},{"action":"add","target":"char_sun_min","type":"合作者","intensity":40,"bond_level":2,"dynamic":"同伴"}]},{"id":"char_ling_lin","updates":{"source_refs":[{"chapter":13,"line_start":222,"line_end":222,"text":"凌琳抹去泪痕，轻推伊风道：\"伊大哥，走吧。\""}]},"relationship_updates":[{"action":"add","target":"char_yi_feng","type":"合作者","intensity":40,"bond_level":2,"dynamic":"同伴"}]},{"id":"char_sun_min","updates":{"source_refs":[{"chapter":13,"line_start":238,"line_end":238,"text":"孙敏道：\"我想我们还是暂时住在这里，你呢？\""}]},"relationship_updates":[{"action":"add","target":"char_yi_feng","type":"合作者","intensity":40,"bond_level":2,"dynamic":"同伴"}]}]}
