{"segment":2,"line_start":53,"line_end":133,"dialogues":[{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":null,"text":"走，是为江湖除害的时候了！","tone":"豪迈","chapter":14,"line_start":66,"line_end":67},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_fei_hong_liu_jian","text":"你们就是飞虹六剑？","tone":"淡然","chapter":14,"line_start":102,"line_end":103},{"speaker":"char_fei_hong_liu_jian","speaker_name":"飞虹六剑","listener":"char_xiao_wu","text":"不，七剑。","tone":"陈述","chapter":14,"line_start":106,"line_end":106},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_fei_hong_liu_jian","text":"不，只有六剑了。因为你们的三弟已经死了。","tone":"淡然","chapter":14,"line_start":108,"line_end":108},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_fei_hong_liu_jian","text":"你们一定奇怪，我为什么会和你们的三弟相貌一样？我告诉你们吧，我脸上戴的，就是你们三弟的脸皮。","tone":"淡然","chapter":14,"line_start":114,"line_end":116}],"new_entities":{"characters":[{"id":"char_xiao_wu","name":"萧无","alias":["天争教主"],"identity":"天争教教主（实为薛若璧假扮）","faction":"faction_tian_zheng_jiao","role":"villain","archetype":"warrior","rank":"炉火纯青","one_line":"天争教主，实为薛若璧假扮，使用人皮面具和人皮手套，在西湖决斗中被吕南人识破身份后身亡","personality":{"traits":["冷酷","残忍","阴险","傲慢","心狠手辣"],"speech_style":"语声了无生气，仿佛死人说话","temperament":"冷酷无情"},"relationships":[{"target":"char_lv_nan_ren","type":"宿敌","intensity":100,"bond_level":5,"dynamic":"决斗对手"},{"target":"char_xue_ruo_bi","type":"主仆","intensity":100,"bond_level":5,"dynamic":"薛若璧假扮萧无的身份"}],"known_skills":[],"related_skills":[],"rag_refs":[14],"source_refs":[{"chapter":14,"line_start":86,"line_end":86,"text":"一个身材娇小，穿着黑衣的少年走下"}]},{"id":"char_fei_hong_liu_jian","name":"飞虹六剑","alias":["飞虹七剑"],"identity":"武林剑客团体","faction":null,"role":"npc","archetype":"warrior","rank":"略有小成","one_line":"六人剑客团体，原为七人，三弟已死且脸皮被萧无所用，在西湖挑战萧无时全部被杀","personality":{"traits":["团结","勇猛","重义气","不畏强敌","有血性"],"speech_style":"简洁直接","temperament":"刚烈"},"relationships":[{"target":"char_xiao_wu","type":"宿敌","intensity":80,"bond_level":2,"dynamic":"为三弟之死向萧无寻仇"}],"known_skills":[],"related_skills":[],"rag_refs":[14],"source_refs":[{"chapter":14,"line_start":98,"line_end":98,"text":"人群中跳出六个人，一字排在黑衣人面前"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":134,"line_end":220,"dialogues":[{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_fei_hong_liu_jian","text":"砍不到人，想砍椅子出气吗？","tone":"调侃","chapter":14,"line_start":134,"line_end":134},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":null,"text":"接着！","tone":"厉声","chapter":14,"line_start":136,"line_end":136},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_fei_hong_liu_jian","text":"长白剑阵，可惜少了一个人。","tone":"淡然","chapter":14,"line_start":148,"line_end":148},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_fei_hong_liu_jian","text":"看着，这就是你们三弟偷出来的秘笈，里面的七星锁喉爪。","tone":"淡然","chapter":14,"line_start":150,"line_end":151},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_lv_nan_ren","text":"七海渔子韦傲物是你杀的？","tone":"淡然","chapter":14,"line_start":166,"line_end":166},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_lv_nan_ren","text":"多手真人谢雨仙也是你杀的？","tone":"淡然","chapter":14,"line_start":170,"line_end":170},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_lv_nan_ren","text":"为什么？","tone":"疑问","chapter":14,"line_start":174,"line_end":174},{"speaker":"char_lv_nan_ren","speaker_name":"白衣人","listener":"char_xiao_wu","text":"为了报仇，为了替江湖除害。","tone":"淡然","chapter":14,"line_start":176,"line_end":176},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_lv_nan_ren","text":"吕南人，除掉你的面罩吧！","tone":"淡然","chapter":14,"line_start":180,"line_end":180},{"speaker":"char_lv_nan_ren","speaker_name":"白衣人","listener":"char_xiao_wu","text":"你怎么知道是我？","tone":"惊讶","chapter":14,"line_start":182,"line_end":182},{"speaker":"char_xiao_wu","speaker_name":"黑衣人","listener":"char_lv_nan_ren","text":"普天之下，有我天争教主不知道的事吗？","tone":"得意","chapter":14,"line_start":184,"line_end":184},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"你也别得意，萧无，你为什么不能脱下人皮面具？","tone":"嘲讽","chapter":14,"line_start":186,"line_end":186},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"你想要我脱下人皮面具？你有本事，你就自己来脱吧。","tone":"冷笑","chapter":14,"line_start":188,"line_end":189},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"请。","tone":"淡然","chapter":14,"line_start":192,"line_end":192},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"铁戟温侯吕南人为什么不用双戟？","tone":"疑问","chapter":14,"line_start":194,"line_end":194},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"我用剑，一样可以制得了你。","tone":"淡然","chapter":14,"line_start":196,"line_end":196},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"你果然有两下子。","tone":"陈述","chapter":14,"line_start":216,"line_end":216},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"你还有什么法宝？","tone":"淡然","chapter":14,"line_start":222,"line_end":222}],"new_entities":{"characters":[],"skills":[],"techniques":[{"id":"tech_qi_xing_suo_hou_zhua","name":"七星锁喉爪","type":"attack","description":"萧无所用的爪法绝技，身形飘动，黑色袖影穿透剑网，火速在敌人喉上一触即可致命，飞虹六剑均被此招所杀","source_skill":null,"source_refs":[{"chapter":14,"line_start":150,"line_end":156,"text":"收掌为爪，冷然道：看着，这就是你们三弟偷出来的秘笈，里面的七星锁喉爪"}]}],"factions":[],"locations":[],"items":[{"id":"item_han_jin_yu_wang","name":"寒金渔网","type":"weapon","owner":"char_wei_ao_wu","one_line":"韦傲物的兵器，被隐形杀手割成数十块碎片","description":"七海渔子韦傲物的独门兵器，以寒金打造的渔网，坚韧异常，但在洛阳城外被隐形杀手的剑法割成数十块碎片","effects":[],"origin":null,"rarity":"上乘佳品","related_characters":["char_wei_ao_wu"],"related_skills":[],"rag_refs":[14],"source_refs":[{"chapter":14,"line_start":4,"line_end":4,"text":"韦傲物的寒金渔网被割成数十块碎片"}]}]},"entity_updates":[]}
{"segment":4,"line_start":221,"line_end":318,"dialogues":[{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"有。","tone":"陈述","chapter":14,"line_start":224,"line_end":224},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"亮出来吧。","tone":"陈述","chapter":14,"line_start":226,"line_end":226},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"不能在这里亮。","tone":"陈述","chapter":14,"line_start":228,"line_end":228},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"为什么？","tone":"疑问","chapter":14,"line_start":230,"line_end":230},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"因为这里人太多了。","tone":"陈述","chapter":14,"line_start":232,"line_end":232},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"为什么人太多不能亮？","tone":"疑问","chapter":14,"line_start":234,"line_end":234},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"因为那会揭出你的疮疤。","tone":"陈述","chapter":14,"line_start":236,"line_end":236},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"我的疮疤？","tone":"疑问","chapter":14,"line_start":238,"line_end":238},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"不错。","tone":"得意","chapter":14,"line_start":240,"line_end":240},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"我没有疮疤，你亮吧。","tone":"淡然","chapter":14,"line_start":242,"line_end":242},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"好吧，我就亮给你看。","tone":"淡然","chapter":14,"line_start":244,"line_end":244},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"还是那些破铜烂铁的暗器？","tone":"嘲讽","chapter":14,"line_start":248,"line_end":248},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"你难道不想你妻子活命吗？","tone":"淡然","chapter":14,"line_start":250,"line_end":250},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"你妻子落在我手上，你还是弃剑投降吧。只要你投靠天争教，我就把妻子还给你。","tone":"狂笑","chapter":14,"line_start":254,"line_end":256},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"我妻子已死去多年，你休想拿此来威胁我。","tone":"悲痛","chapter":14,"line_start":258,"line_end":259},{"speaker":"char_xiao_wu","speaker_name":"萧兀","listener":"char_lv_nan_ren","text":"你妻子死了？","tone":"疑问","chapter":14,"line_start":262,"line_end":262},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xiao_wu","text":"不错，自从她无耻地跟了你以后，她在我心中，早已死了。","tone":"冷酷","chapter":14,"line_start":264,"line_end":265},{"speaker":"char_xiao_wu","speaker_name":"萧无","listener":"char_lv_nan_ren","text":"你……你……","tone":"愤怒","chapter":14,"line_start":268,"line_end":268},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xue_ruo_bi","text":"若璧！","tone":"惊讶","chapter":14,"line_start":286,"line_end":286},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xue_ruo_bi","text":"若璧！","tone":"悲痛","chapter":14,"line_start":294,"line_end":294},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xue_ruo_bi","text":"若璧，你是为了什么？","tone":"悲痛","chapter":14,"line_start":300,"line_end":300},{"speaker":"char_xue_ruo_bi","speaker_name":"薛若璧","listener":"char_lv_nan_ren","text":"南……哥……我错了。","tone":"痛苦","chapter":14,"line_start":302,"line_end":302},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xue_ruo_bi","text":"为什么？为什么？你是为什么？","tone":"悲痛","chapter":14,"line_start":304,"line_end":304},{"speaker":"char_xue_ruo_bi","speaker_name":"薛若璧","listener":"char_lv_nan_ren","text":"我只想称霸武林，不但做天下第一美人，还要做天下第一奇人，所以，我杀了萧无，扮成他的样子……","tone":"苦笑","chapter":14,"line_start":306,"line_end":306},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xue_ruo_bi","text":"唉！你何必呢？","tone":"无奈","chapter":14,"line_start":308,"line_end":308},{"speaker":"char_xue_ruo_bi","speaker_name":"薛若璧","listener":"char_lv_nan_ren","text":"要不是你，我就成功了，我……","tone":"苦笑","chapter":14,"line_start":310,"line_end":310},{"speaker":"char_lv_nan_ren","speaker_name":"吕南人","listener":"char_xue_ruo_bi","text":"若璧！若璧！","tone":"悲痛","chapter":14,"line_start":314,"line_end":314}],"new_entities":{"characters":[{"id":"char_xue_ruo_bi","name":"薛若璧","alias":["萧无","天争教主"],"identity":"吕南人之妻，天争教实际掌控者","faction":"faction_tian_zheng_jiao","role":"villain","archetype":"warrior","rank":"炉火纯青","one_line":"吕南人之妻，杀萧无后假扮天争教主，统一天争教、天毒教、天媚教，最终在西湖决斗中被吕南人识破后身亡","personality":{"traits":["野心勃勃","心狠手辣","工于心计","痴情","偏执"],"speech_style":"声细如丝，临死前痛苦挣扎","temperament":"阴沉偏执"},"relationships":[{"target":"char_lv_nan_ren","type":"恋人","intensity":100,"bond_level":5,"dynamic":"夫妻，深爱但走火入魔"},{"target":"char_xiao_wu","type":"主仆","intensity":100,"bond_level":5,"dynamic":"杀死真萧无后假扮其身份"}],"known_skills":[],"related_skills":[],"rag_refs":[14],"source_refs":[{"chapter":14,"line_start":292,"line_end":292,"text":"吕南人扶起气息奄奄的薛若璧，撕下她脸上的人皮面具，露出一双美艳无双的脸庞"}]}],"skills":[{"id":"skill_piao_xiang_jian_yu","name":"飘香剑雨","type":"剑法","faction":null,"rank":"炉火纯青","one_line":"吕南人的剑法绝技，漫天剑影如雨洒落，令萧无无法抵挡","techniques":[{"id":"tech_piao_xiang_man_tian","name":"漫天剑雨","type":"attack","description":"使出飘香剑雨，漫天剑影向对手袭去，剑雨密不透风"}],"progression":[],"effects":[{"type":"伤害","description":"漫天剑影密集攻击，对手无法躲避"}],"combat_style":"剑法","rag_refs":[14],"source_refs":[{"chapter":14,"line_start":272,"line_end":272,"text":"吕南人蓦然飞起，使出“飘香剑雨”，漫天剑影向萧无袭去"}]}],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_ren_pi_shou_tao","name":"人皮手套","type":"special","owner":"char_xiao_wu","one_line":"萧无所戴的人皮手套，脱下后露出薛若璧纤纤玉手，是识破其身份的关键","description":"萧无（薛若璧）手上一直戴着的人皮手套，外观与真手无异，脱下后露出涂有胭脂红指甲的纤纤玉手，以及左手中指上的红痣，是吕南人识破薛若璧身份的关键","effects":[],"origin":null,"rarity":"稀世珍品","related_characters":["char_xiao_wu","char_xue_ruo_bi"],"related_skills":[],"rag_refs":[14],"source_refs":[{"chapter":14,"line_start":270,"line_end":278,"text":"萧无双手仿佛脱了层皮似的，两只手掌向吕南人飞了过去……萧无手上一直戴着一只人皮手套