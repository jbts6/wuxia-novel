    },
    {
      "speaker": "char_jin_mei_ling",
      "speaker_name": "金梅龄",
      "listener": "char_shou_xue_lao_ren",
      "text": "我……我和你们的辛……辛老板是朋友……",
      "tone": "犹豫",
