{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"今日咱们兄弟有一点小事要相求于辛大侠——","tone":"愤怒","chapter":48,"line_start":102,"line_end":104},{"speaker":null,"speaker_name":"心中想","listener":null,"text":"这厮有什么要相求于我的？只恐有什么诡计——","tone":"陈述","chapter":48,"line_start":110,"line_end":112},{"speaker":null,"speaker_name":"口中","listener":null,"text":"什么？","tone":"陈述","chapter":48,"line_start":114,"line_end":116},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"承认什么？","tone":"陈述","chapter":48,"line_start":124,"line_end":126},{"speaker":"char_jin_lu_e","speaker_name":"金鲁厄","listener":null,"text":"只要辛大侠肯承认天竺武学在中原之上——","tone":"陈述","chapter":48,"line_start":128,"line_end":130},{"speaker":"char_jin_lu_e","speaker_name":"金鲁厄","listener":null,"text":"敝师尊们见无极岛主内疾突发才罢手而去，不料辛大侠竟不识好歹——","tone":"冷笑","chapter":48,"line_start":138,"line_end":140},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"阁下找姓辛的只为这一件事么？","tone":"愤怒","chapter":48,"line_start":142,"line_end":144},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"姓辛的回答你，叫你快滚！","tone":"大笑","chapter":48,"line_start":148,"line_end":150},{"speaker":null,"speaker_name":"径自指着为首那矮小和尚","listener":null,"text":"这位是敝门大师兄，法号密陀宝树——","tone":"轻笑","chapter":48,"line_start":160,"line_end":162},{"speaker":"char_jin_lu_e","speaker_name":"金鲁厄","listener":null,"text":"这是二师兄青尘罗汉——","tone":"陈述","chapter":48,"line_start":170,"line_end":172},{"speaker":null,"speaker_name":"接着又指着左面第二人","listener":null,"text":"三师兄加大尔——两位是见过的了。","tone":"陈述","chapter":48,"line_start":174,"line_end":176},{"speaker":null,"speaker_name":"最后指着右面的虬髯汉子","listener":null,"text":"这是四师兄温成白罗，哈哈，咱们五兄弟人称婆罗五奇——","tone":"陈述","chapter":48,"line_start":178,"line_end":180},{"speaker":null,"speaker_name":"当下冷","listener":null,"text":"嘿，怕是婆罗六奇吧！","tone":"冷酷","chapter":48,"line_start":184,"line_end":186},{"speaker":"char_jin_lu_e","speaker_name":"金鲁厄","listener":null,"text":"辛