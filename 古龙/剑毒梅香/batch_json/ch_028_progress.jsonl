{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":null,"speaker_name":"辛捷","listener":null,"text":"这样地下去除了死没有第二条路，我索性拼命干他一个算一个——","tone":"陈述","chapter":28,"line_start":38,"line_end":38},{"speaker":null,"speaker_name":"辛捷","listener":null,"text":"爸妈，佑孩儿杀仇！","tone":"陈述","chapter":28,"line_start":40,"line_end":41},{"speaker":null,"speaker_name":"辛捷","listener":null,"text":"逃！","tone":"激动","chapter":28,"line_start":50,"line_end":50},{"speaker":null,"speaker_name":"左仲望","listener":null,"text":"打！","tone":"厉声","chapter":28,"line_start":54,"line_end":54}],"new_entities":{"characters":[{"id":"char_lu_fang","name":"陆方","alias":["千手剑客"],"identity":"黄丰九豪之一","faction":"黄丰九豪","role":"villain","archetype":"warrior","rank":"炉火纯青","one_line":"黄丰九豪中的千手剑客，以剑术见长","personality":{"traits":["好斗","凶狠","狡诈","贪婪","谨慎"],"speech_style":"江湖气","temperament":"暴躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":16,"line_end":16,"text":"千手剑客陆方肩上已中了一剑"}]},{"id":"char_bai_feng","name":"白风","alias":["长天一碧"],"identity":"黄丰九豪之一","faction":"黄丰九豪","role":"villain","archetype":"warrior","rank":"炉火纯青","one_line":"黄丰九豪中的长天一碧，掌力雄厚","personality":{"traits":["凶狠","果断","老练","阴险","自信"],"speech_style":"江湖气","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":16,"line_end":16,"text":"长天一碧白风的衣袖也被三尺青锋削去尺许"}]},{"id":"char_jiao_hua","name":"焦化","alias":["海天双煞"],"identity":"黄丰九豪首领之一","faction":"黄丰九豪","role":"villain","archetype":"warrior","rank":"出神入化","one_line":"海天双煞之一，焦氏兄弟中的兄长，功力深厚","personality":{"traits":["凶残","老练","阴狠","自信","果断"],"speech_style":"江湖气","temperament":"阴沉"},"relationships":[{"target":"char_jiao_lao","type":"亲属","intensity":90,"bond_level":5,"dynamic":"兄弟同心"}],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":20,"line_end":20,"text":"呼呼两股凌厉无比的掌风袭向体后，辛捷不用看就知必是海天双煞"}]},{"id":"char_jiao_lao","n