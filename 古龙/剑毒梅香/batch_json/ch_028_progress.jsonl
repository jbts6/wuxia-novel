防"},{"id":"tech_mei_hua_san_nong","name":"梅花三弄","type":"attack","description":"连环三击的剑招"},{"id":"tech_han_mei_tu_rui","name":"寒梅吐蕊","type":"attack","description":"剑气跃然而出的凌厉剑招"}],"progression":[{"level":"出神入化","chapter":28}],"effects":["伤害"],"combat_style":"诡奇凌厉","rag_refs":[28],"source_refs":[{"chapter":28,"line_start":26,"line_end":26,"text":"虬枝剑法中的绝着冷梅拂面"}]}],"techniques":[],"factions":[{"id":"faction_huang_feng_jiu_hao","name":"黄丰九豪","type":"帮派","location":"黄丰","sub_divisions":[],"one_line":"关中地区势力强大的武林帮派，共九位高手","source_refs":[{"chapter":28,"line_start":2,"line_end":2,"text":"新关中黄丰九豪的实力比之旧九豪有过之而无不及"}]}],"locations":[{"id":"loc_guang_shan","name":"龟山","region":"关中","one_line":"辛捷曾与海天双煞交手的地方","source_refs":[{"chapter":28,"line_start":102,"line_end":102,"text":"龟山顶双战辛捷时"}]}],"items":[{"id":"item_yin_feng_shen_biao","name":"阴风神镖","type":"hidden_weapon","owner":"char_zuo_zhong_wang","one_line":"左仲望的独门暗器，无声无息","description":"一种特殊暗器，发出时不带破风之声，直到距敌三尺以内却陡然加速，敌人发觉想逃时已自不及","effects":["伤害"],"origin":"左仲望独门秘制","rarity":"上乘佳品","related_characters":["char_zuo_zhong_wang"],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":60,"line_end":60,"text":"阴风神镖左仲望的暗器功夫有一桩特别之外"}]}]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_bai_feng","speaker_name":"白风","listener":"char_jiao_lao","text":"老大，下面有人来了——啊，这家伙好俊的轻功——","tone":"惊讶","chapter":28,"line_start":144,"line_end":144},{"speaker":"char_jiao_lao","speaker_name":"焦劳","listener":null,"text":"走！","tone":"沉声","chapter":28,"line_start":152,"line_end":153},{"speaker":null,"speaker_name":"辛捷","listener":null,"text":"辛捷，你不能死，你活在世上既说不上忠，更说不上孝，这个'信'字好歹要守啊，辛捷啊，你不能死！","tone":"认真","chapter":28,"line_start":124,"line_end":125},{"speaker":null,"speaker_name":"辛捷","listener":null,"text":"吴大哥死了，如果我一死，她将等一辈子了，她一定会等一辈子的！","tone":"悲伤","chapter":28,"line_start":118,"line_end":119}],"new_entities":{"characters":[{"id":"char_wu_ling_feng","name":"吴凌风","alias":[],"identity":"辛捷的结义大哥","faction":"无","role":"companion","archetype":"warrior","rank":"炉火纯青","one_line":"辛捷的结义大哥，曾跌落泰山日观峰下，性格沉毅","personality":{"traits":["沉毅","重情","坚毅","孝顺","善良","执着"],"speech_style":"文雅","temperament":"沉稳"},"relationships":[{"target":"char_xin_jie","type":"挚友","intensity":85,"bond_level":4,"dynamic":"结义兄弟"}],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":194,"line_end":194,"text":"他，竟是跌落泰山日观峰下的吴凌风！"}]},{"id":"char_jin_yi","name":"金欹","alias":[],"identity":"吴凌风的仇人","faction":"无","role":"villain","archetype":"warrior","rank":"炉火纯青","one_line":"与吴凌风互抱滚下悬崖的丑八怪","personality":{"traits":["疯狂","凶狠","丑陋","狡诈","狠毒"],"speech_style":"粗野","temperament":"暴烈"},"relationships":[{"target":"char_wu_ling_feng","type":"宿敌","intensity":95,"bond_level":5,"dynamic":"生死仇敌"}],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":198,"line_end":198,"text":"吴凌风与金欹互抱滚下悬崖"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_tai_shan_ri_guan_feng","name":"泰山日观峰","region":"泰山","one_line":"吴凌风曾跌落的悬崖","source_refs":[{"chapter":28,"line_start":194,"line_end":194,"text":"跌落泰山日观峰下的吴凌风"}]}],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_zhu_fu_zi","speaker_name":"朱夫子","listener":"char_da_niang","text":"我瞧阿兰这孩子多半是中了金蛇毒，但是她怎么会中毒，倒是令人难解。","tone":"疑问","chapter":28,"line_start":230,"line_end":231},{"speaker":"char_da_niang","speaker_name":"大娘","listener":"char_zhu_fu_zi","text":"如果真是中了蛇毒，难道除'血果'外，别无他法医治吗？","tone":"焦急","chapter":28,"line_start":234,"line_end":235},{"speaker":"char_zhu_fu_zi","speaker_name":"朱夫子","listener":"char_da_niang","text":"这蛇原是天下三毒之一，中毒者，不出八时辰，全身时痛时痒，难过非常，任你定力多强，最后也忍耐不住，自求了结。而且最厉害的是此毒非旷世难逢的'血果'将其毒性托住，泻出体外，其他任何仙丹也难奏效。","tone":"认真","chapter":28,"line_start":238,"line_end":241},{"speaker":"char_da_niang","speaker_name":"大娘","listener":"char_zhu_fu_zi","text":"你瞧阿兰还有救吗？","tone":"担心","chapter":28,"line_start":244,"line_end":244},{"speaker":"char_zhu_fu_zi","speaker_name":"朱夫子","listener":"char_da_niang","text":"那日我那小半瓶血果汁，全给凌风服下，也是见他毒势沉重，一时心慌意乱，其实这种灵药专克天下各种蛇毒，只消数滴，便已足够，我瞧那日阿兰可能是一时情急，用口去吸凌风手指上的伤口，后来自己知道中毒，但强忍着，她怕血果汁不够，如果我们发觉她中毒，分一半给她服用，也许会耽误了凌风的病势，唉！这孩子对凌风一往情深，竟舍命救他。我现在用药将她毒势逼住，并使她昏睡，以免受各种痛苦，等明儿全身毒气都集中在一起，我再用针炙刺穴，将毒从七窍逼出，好在她中毒不太深，也许有几分希望。只是……只是一双眼睛恐怕不保了。","tone":"无奈","chapter":28,"line_start":246,"line_end":252},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"吴凌风，吴凌风，你这自私的东西，为了救自己的内伤，竟忘记了这十年来刻心铭骨的大事，你这卑鄙怕死的家伙，你这忘恩负义的混蛋！","tone":"愤怒","chapter":28,"line_start":266,"line_end":267},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"老天爷为什么那么不公平呢？我自幼父母双亡，好不容易遇上一个待我如子的大娘，可是我却累得她独生爱女双目失明，我日夜费心寻求血果，可是，却这样的被我糟塌，难道我命运是这么不祥，凡是待我好的人都要遭到灾难吗？","tone":"悲伤","chapter":28,"line_start":269,"line_end":270},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"朱夫子说我父亲一生仗义疏财，行侠除奸，可是到头来，依然不免命丧荒山，尸骨无存，这难道是所谓'天道无亲，常与善人'吗？","tone":"无奈","chapter":28,"line_start":272,"line_end":272},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"我母亲——大娘最佩服的人，是北方最有名的才女，诗、歌、赋、棋、琴、书、画、女红、烹调、无一不精，天资敏捷是盖世的天才，可是她，她在生下我后，便悄悄离开这个世界，难道世上愈有灵性的东西便愈不长久吗？","tone":"悲伤","chapter":28,"line_start":274,"line_end":274}],"new_entities":{"characters":[{"id":"char_a_lan","name":"阿兰","alias":[],"identity":"大娘的女儿","faction":"无","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"大娘的独生女，为救吴凌风而中毒失明","personality":{"traits":["善良","温柔","深情","坚强","无私"],"speech_style":"温柔","temperament":"温和"},"relationships":[{"target":"char_wu_ling_feng","type":"恋人","intensity":90,"bond_level":5,"dynamic":"一往情深"},{"target":"char_da_niang","type":"亲属","intensity":95,"bond_level":5,"dynamic":"母女"}],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":224,"line_end":224,"text":"阿兰那双大眼突然之间明亮起来"}]},{"id":"char_da_niang","name":"大娘","alias":[],"identity":"阿兰的母亲","faction":"无","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"吴凌风的养母，阿兰的母亲，温雅美丽","personality":{"traits":["慈爱","温柔","坚强","善良","忧虑"],"speech_style":"温和","temperament":"温和"},"relationships":[{"target":"char_a_lan","type":"亲属","intensity":95,"bond_level":5,"dynamic":"母女"},{"target":"char_wu_ling_feng","type":"亲属","intensity":80,"bond_level":4,"dynamic":"养育之恩"}],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":210,"line_end":210,"text":"温雅美丽的大娘"}]},{"id":"char_zhu_fu_zi","name":"朱夫子","alias":["冬烘先生"],"identity":"私塾先生","faction":"无","role":"npc","archetype":"scholar","rank":"略有小成","one_line":"私塾先生，吴凌风父亲的师兄，教吴凌风武艺","personality":{"traits":["博学","慈祥","忧心","正直","谦逊"],"speech_style":"文雅","temperament":"沉稳"},"relationships":[{"target":"char_wu_ling_feng","type":"师徒","intensity":75,"bond_level":4,"dynamic":"师徒"}],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":222,"line_end":222,"text":"还有那位朱夫子——私垫里的冬烘先生"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_xue_guo","name":"血果","type":"pill","owner":null,"one_line":"百年一结的灵药，专克天下各种蛇毒","description":"一种罕见灵药，百年才结一次果实，专克天下各种蛇毒，只消数滴便已足够，能将蛇毒托住泻出体外","effects":["增益","特殊"],"origin":"天然生长于悬崖峭壁","rarity":"稀世珍品","related_characters":["char_wu_ling_feng","char_a_lan"],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":260,"line_end":260,"text":"如今自己坐的这棵树不正就跟朱夫子所说血果树一样吗？"}]},{"id":"item_jin_she_du","name":"金蛇毒","type":"poison","owner":null,"one_line":"天下三毒之一，中毒者全身时痛时痒","description":"天下三毒之一，中毒者不出八时辰，全身时痛时痒，难过非常，任你定力多强，最后也忍耐不住，自求了结","effects":["伤害","控制"],"origin":"金色小蛇","rarity":"上乘佳品","related_characters":["char_a_lan","char_wu_ling_feng"],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":238,"line_end":238,"text":"这蛇原是天下三毒之一"}]}]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":352,"dialogues":[{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"阿兰！阿兰！我发觉了生命的价值在有些时候，那会比不上一个深情的微笑哩！","tone":"深情","chapter":28,"line_start":300,"line_end":300},{"speaker":"char_a_lan","speaker_name":"阿兰","listener":"char_wu_ling_feng","text":"大哥，你初人江湖，一切要小心，报父仇第一，血果找不到便算了。","tone":"温柔","chapter":28,"line_start":286,"line_end":287},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"你要我死，我难道偏会说不吗？","tone":"深情","chapter":28,"line_start":304,"line_end":304},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"师父交给我一枚玉瓶，他再三叮嘱，倘若找到血果，立刻放入玉瓶中，血果便会自动化为浆液。","tone":"陈述","chapter":28,"line_start":306,"line_end":307},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"我提起了勇气，怀着希望，背负着长剑及小囊，逢山过山，逢水涉水，飘泊在名山大川及诡诈千端的江湖中，血果没寻到，父仇未报得，但幸运地结识了一位肝胆照人的兄弟——辛捷。一个天真、豪放、倔强的孩子，虽然他比自己只小了半岁，可是却孩子气得很哩！","tone":"陈述","chapter":28,"line_start":310,"line_end":313},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"好不容易，在泰山大会上，看见了仇人，那名重武林的仇人，正要拼命报仇，可是，那可恨的丑八怪，那疯狂的丑八怪，不分青红皂白抱着我一起滚下悬崖。哼！这该死的东西，现在只怕已是粉身碎骨了吧！","tone":"愤怒","chapter":28,"line_start":316,"line_end":318},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"云雾虽浓，但是在太阳的光芒下总是会消散，我命途多难不也像满天乌云浓雾吗？可是我命运中的太阳是什么呢？啊，是了，那是要靠我自己奋斗，我自己努力，我自己挣扎的勇气，那就是我生命中的太阳啊！","tone":"认真","chapter":28,"line_start":322,"line_end":326},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"师父常说古来成大功立大业者，往往都是'知其不可而为之'，我受这样一点挫折，那又算得了什么呢？","tone":"豪迈","chapter":28,"line_start":328,"line_end":329},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"先仔细看看下面形势再说。","tone":"陈述","chapter":28,"line_start":336,"line_end":336},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"如果能找到五六个落脚之处，就可以安全跳下。如果只有两三可借力处，也只好冒险跃下，身体只怕会震伤哩！","tone":"陈述","chapter":28,"line_start":337,"line_end":339},{"speaker":null,"speaker_name":"吴凌风","listener":null,"text":"老天保佑那块石头不要是浮石才好。","tone":"恳求","chapter":28,"line_start":342,"line_end":343}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_jing_cong_luan_shi","name":"荆丛乱石","region":"山坡下","one_line":"辛捷滚落后经过的地方","source_refs":[{"chapter":28,"line_start":158,"line_end":158,"text":"经过一片荆丛乱石"}]},{"id":"loc_zhu_lin","name":"竹林","region":"谷底","one_line":"吴凌风脱险后发现的翠绿竹林","source_refs":[{"chapter":28,"line_start":352,"line_end":352,"text":"前面是一大片翠绿的竹林"}]}],"items":[{"id":"item_yu_ping","name":"玉瓶","type":"special","owner":"char_wu_ling_feng","one_line":"师父交给吴凌风的玉瓶，可将血果化为浆液","description":"一枚玉瓶，师父交给吴凌风，叮嘱若找到血果立刻放入，血果便会自动化为浆液保存","effects":["特殊"],"origin":"吴凌风师父所赠","rarity":"上乘佳品","related_characters":["char_wu_ling_feng"],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":306,"line_end":307,"text":"师父交给我一枚玉瓶"}]}]},"entity_updates":[]}