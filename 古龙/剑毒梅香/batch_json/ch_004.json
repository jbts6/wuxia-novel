    {
      "speaker": "char_yu_yi_fei",
      "speaker_name": "于一飞",
      "listener": "char_xin_jie",
      "text": "今天我们真是自讨没趣，唉，若不是这个主儿，也还罢了，却又偏偏是他。",
      "tone": "无奈",
      "chapter": 4,
      "line_start": 374,
      "line_end": 376
    },
    {
      "speaker": "char_xin_jie",
      "speaker_name": "辛捷",
      "listener": "char_yu_yi_fei",
