      "speaker_name": "七妙神君",
      "listener": "char_jiang_li_bai_long",
      "text": "别人交托又怎样，难道我七妙神君都不能将人带走吗？",
      "tone": "愤怒",
      "chapter": 4,
      "line_start": 486,
      "line_end": 488
    },
