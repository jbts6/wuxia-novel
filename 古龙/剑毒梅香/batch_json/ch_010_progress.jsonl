{"segment":1,"line_start":1,"line_end":483,"dialogues":[{"speaker":"char_shao_nv","speaker_name":"少女","listener":null,"text":"你们快回来呀！我已抓到一个了。\"媚目四转，远远地只看到三个人，却少了两个，奇道：","tone":"陈述","chapter":10,"line_start":16,"line_end":16},{"speaker":"char_tang_bin","speaker_name":"唐斌","listener":null,"text":"灵儿、曼儿，快追！","tone":"陈述","chapter":10,"line_start":22,"line_end":22},{"speaker":"char_zhong_nian_shu_sheng","speaker_name":"中年书生","listener":null,"text":"你这手帕哪里来的？拿来给我看看。","tone":"陈述","chapter":10,"line_start":72,"line_end":72},{"speaker":"char_zhong_nian_mei_fu","speaker_name":"中年美妇","listener":null,"text":"你发什么脾气？","tone":"陈述","chapter":10,"line_start":84,"line_end":84},{"speaker":"char_wu_hen_sheng","speaker_name":"无恨生","listener":null,"text":"这个自然。","tone":"陈述","chapter":10,"line_start":170,"line_end":170},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"我怎的？","tone":"陈述","chapter":10,"line_start":178,"line_end":178},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"我是在想一个女孩子。\"他将金梅龄的手放在嘴上亲了亲，道：","tone":"陈述","chapter":10,"line_start":184,"line_end":184},{"speaker":"char_jin_mei_ling","speaker_name":"金梅龄","listener":null,"text":"你最坏了。","tone":"陈述","chapter":10,"line_start":188,"line_end":188},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"等一会到了岸，我们去大吃一顿……","tone":"陈述","chapter":10,"line_start":244,"line_end":244},{"speaker":"char_jin_mei_ling","speaker_name":"金梅龄","listener":null,"text":"我要吃火腿鸡汤，冰糖肘子。","tone":"陈述","chapter":10,"line_start":246,"line_end":246},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"对了，冰糖肘子，还有……\"突然他念头一转，说道：\"我们先到那边的大船上看看，问他们可不可以分一点……","tone":"陈述","chapter":10,"line_start":248,"line_end":248},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"阁下为何如此相逼，我和阁下素无仇怨……","tone":"陈述","chapter":10,"line_start":326,"line_end":326},{"speaker":"char_wu_hen_sheng","speaker_name":"无恨生","listener":null,"text":"少啰嗦。","tone":"陈述","chapter":10,"line_start":328,"line_end":328},{"speaker":"char_wu_hen_sheng","speaker_name":"无恨生","listener":null,"text":"菁儿，走开。","tone":"陈述","chapter":10,"line_start":332,"line_end":332},{"speaker":"char_zhang_jing","speaker_name":"张菁","listener":null,"text":"爹爹，你老……","tone":"陈述","chapter":10,"line_start":334,"line_end":334},{"speaker":"char_wu_hen_sheng","speaker_name":"无恨生","listener":null,"text":"怎地？","tone":"陈述","chapter":10,"line_start":336,"line_end":336},{"speaker":"char_wu_hen_sheng","speaker_name":"无恨生","listener":null,"text":"你知道什么，那么我……","tone":"陈述","chapter":10,"line_start":348,"line_end":348},{"speaker":"char_xin_jie","speaker_name":"辛捷","listener":null,"text":"是我的。","tone":"陈述","chapter":10,"line_start":384,"line_end":384},{"speaker":"char_wu_hen_sheng","speaker_name":"无恨生","listener":null,"text":"是你的就好。","tone":"陈述","chapter":10,"line_start":386,"line_end":386}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
