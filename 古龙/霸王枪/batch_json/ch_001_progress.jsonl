{"segment":8,"line_start":220,"line_end":279,"dialogues":[{"speaker":"char_deng_ding_hou","speaker_name":"邓定侯","listener":null,"text":"这是什么人？什么人有这样的本事？","tone":"无奈","chapter":1,"line_start":230,"line_end":232},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"小诸葛今天竟变成小猪哥，他妈的，真是过瘾。","tone":"大笑","chapter":1,"line_start":242,"line_end":244},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"大哥，你这是干什么？","tone":"无奈","chapter":1,"line_start":252,"line_end":252},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"这只不过是给你个教训，叫你莫得意忘形。","tone":"调侃","chapter":1,"line_start":254,"line_end":254},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"你想哭？","tone":"调侃","chapter":1,"line_start":258,"line_end":258},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"想哭的人没酒喝。","tone":"调侃","chapter":1,"line_start":261,"line_end":261},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"不哭的人呢？","tone":"疑问","chapter":1,"line_start":264,"line_end":264},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"不哭的人就跟我到保定喝酒去。","tone":"微笑","chapter":1,"line_start":266,"line_end":266},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"可以喝多少？","tone":"好奇","chapter":1,"line_start":268,"line_end":268},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"今天破例，可以喝十斤。","tone":"豪迈","chapter":1,"line_start":270,"line_end":270}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
