{"segment":3,"line_start":57,"line_end":78,"dialogues":[],"new_entities":{"characters":[{"id":"char_xiao_ma","name":"马真","alias":["小马","愤怒的小马"],"identity":"丁喜的兄弟，强盗","faction":null,"role":"companion","archetype":"warrior","rank":"炉火纯青","one_line":"丁喜的兄弟，外号愤怒的小马，性如烈火的强盗","personality":{"traits":["暴躁","直率","忠义","勇猛","鲁莽","嫉恶如仇"],"speech_style":"粗犷直接，常带脏话","temperament":"暴躁"},"relationships":[{"target":"char_ding_xi","type":"挚友","intensity":90,"bond_level":5,"dynamic":"兄弟般情谊"}],"known_skills":[],"related_skills":[],"rag_refs":[1],"source_refs":[{"chapter":1,"line_start":58,"line_end":68,"text":"小马叫马真...所以有很多人叫他\"愤怒的小马\""}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":79,"line_end":119,"dialogues":[{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"但我却还是弄不懂，这些龟孙子为什么不喜欢做人，偏偏要把自己当做狗。","tone":"愤怒","chapter":1,"line_start":78,"line_end":80},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"因为狗一向是人类的朋友，会替人看门，替人带路。","tone":"陈述","chapter":1,"line_start":82,"line_end":83},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"黄狗、黑狗、花狗也是狗，他倒为什么一定要把自己比做白狗？","tone":"疑问","chapter":1,"line_start":86,"line_end":87},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"因为白的总是象征纯洁和高贵。","tone":"陈述","chapter":1,"line_start":90,"line_end":90},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"不管怎么样，狗总是狗，狗仗人势，狗眼看人低，狗改不了吃屎，白狗黑狗都一样。","tone":"愤怒","chapter":1,"line_start":92,"line_end":93},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"我虽然是个强盗，但我做的事可没有一件是见不得人的，他妈的至少不会替那些贪官污吏、恶霸奸商做看门狗。","tone":"愤怒","chapter":1,"line_start":100,"line_end":101},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"他们做的事，虽然未免太绝了，可是他们这五个人，却不能算太坏，尤其是'镇远'的邓定侯。","tone":"认真","chapter":1,"line_start":104,"line_end":105},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"这趟法好象就是他押来的。","tone":"陈述","chapter":1,"line_start":108,"line_end":108},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"应该是他。","tone":"陈述","chapter":1,"line_start":110,"line_end":110},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"听说他押的镖是从来没有出过事。","tone":"陈述","chapter":1,"line_start":112,"line_end":112},{"speaker":"char_ding_xi","speaker_name":"丁喜","listener":"char_xiao_ma","text":"神拳小诸葛并不是徒有虚名的人。","tone":"认真","chapter":1,"line_start":114,"line_end":114},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_ding_xi","text":"不管他是小诸葛也好，是大诸葛也好，这次跟斗总是要栽定了。","tone":"冷笑","chapter":1,"line_start":116,"line_end":117}],"new_entities":{"characters":[{"id":"char_deng_ding_hou","name":"邓定侯","alias":["神拳小诸葛"],"identity":"镇远镖局主人，中原四大镖局主人之一","faction":"faction_zhen_yuan_biao_ju","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"镇远镖局主人，号称神拳小诸葛，少林神拳高手，联营镖局发起人","personality":{"traits":["精明","自信","享受生活","魄力十足","开明"],"speech_style":"沉稳自信","temperament":"沉稳"},"relationships":[],"known_skills":["skill_shao_lin_shen_quan"],"related_skills":[],"rag_refs":[1],"source_refs":[{"chapter":1,"line_start":104,"line_end":114,"text":"尤其是'镇远'的邓定侯...神拳小诸葛并不是徒有虚名的人"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":120,"line_end":155,"dialogues":[],"new_entities":{"characters":[],"skills":[{"id":"skill_shao_lin_shen_quan","name":"少林神拳","type":"掌法","faction":"少林","rank":"炉火纯青","one_line":"邓定侯所习少林拳法，已达八九分火候，不在少林四大长老之下","techniques":[{"id":"tech_shao_lin_shen_quan_yi","name":"少林神拳","type":"attack","description":"少林正宗拳法，刚猛凌厉，以拳意克敌"}],"progression":[{"level":"八九分火候","chapter":1}],"effects":[{"type":"伤害","value":"高","description":"刚猛拳法，威力极强"}],"combat_style":"刚猛正面","rag_refs":[1],"source_refs":[{"chapter":1,"line_start":128,"line_end":128,"text":"他的少林神拳已经到八九分火候"}]}],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_kai_hua_wu_quan_qi","name":"开花五犬旗","type":"special","owner":"char_deng_ding_hou","one_line":"联营镖局标志旗帜，黑色旗面绣五条白犬一朵红花，旗杆藏红货","description":"黑色大旗，旗杆纯钢打造，旗面绣着五条白犬一朵红花，是联营镖局的标志，旗杆内暗藏价值百万的红货珠宝","effects":[{"type":"特殊","value":"标志","description":"联营镖局标志，见此旗即知是联营镖局的镖"}],"origin":"联营镖局","rarity":"上乘佳品","related_characters":["char_bai_li_chang_qing","char_deng_ding_hou","char_gui_dong_jing","char_jiang_xin","char_xi_men_sheng"],"related_skills":[],"rag_refs":[1],"source_refs":[{"chapter":1,"line_start":167,"line_end":168,"text":"黑缎的旗帜，旗杆是纯钢打成的，这批价值百万的红货，就藏在旗杆里"}]}]},"entity_updates":[]}
{"segment":6,"line_start":156,"line_end":188,"dialogues":[{"speaker":"char_lao_zhao","speaker_name":"老赵","listener":"char_xiao_wu","text":"就算明天一清早还得赶路回去，今天晚上我们总可以乐一乐。","tone":"欣喜","chapter":1,"line_start":180,"line_end":180}],"new_entities":{"characters":[{"id":"char_lao_zhao","name":"老赵","alias":[],"identity":"镖局镖师，护旗人员","faction":"faction_zhen_yuan_biao_ju","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"联营镖局护旗镖师，性格爱玩乐","personality":{"traits":["爱玩乐","老练","乐观","粗心","随性"],"speech_style":"粗犷随意","temperament":"随性"},"relationships":[{"target":"char_xiao_wu","type":"合作者","intensity":60,"bond_level":3,"dynamic":"老搭档"}],"known_skills":[],"related_skills":[],"rag_refs":[1],"source_refs":[{"chapter":1,"line_start":176,"line_end":182,"text":"护旗的镖局老赵...朝他的老搭档小吴打了个眼色"}]},{"id":"char_xiao_wu","name":"小吴","alias":[],"identity":"镖局镖师，老赵的搭档","faction":"faction_zhen_yuan_biao_ju","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"联营镖局镖师，老赵的老搭档","personality":{"traits":["老练","沉默","配合","务实","随性"],"speech_style":"少言","temperament":"沉稳"},"relationships":[{"target":"char_lao_zhao","type":"合作者","intensity":60,"bond_level":3,"dynamic":"老搭档"}],"known_skills":[],"related_skills":[],"rag_refs":[1],"source_refs":[{"chapter":1,"line_start":182,"line_end":182,"text":"朝他的老搭档小吴打了个眼色"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_bao_ding_fu","name":"保定府","region":"中原","one_line":"联营镖局运镖目的地，距伏击地点不远","source_refs":[{"chapter":1,"line_start":174,"line_end":174,"text":"保定府的城廓已遥遥在望"}]}],"items":[]},"entity_updates":[]}
