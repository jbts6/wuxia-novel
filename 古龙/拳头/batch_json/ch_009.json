    },
    {
      "speaker": "char_mei_tui_de_shao_nv",
      "speaker_name": "美腿的少女",
      "listener": "char_xiao_ma",
      "text": "因为我喜欢你。",
      "tone": "陈述",
      "chapter": 9,
      "line_start": 562,
