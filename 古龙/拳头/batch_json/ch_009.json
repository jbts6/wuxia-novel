    },
    {
      "speaker": "char_mei_tui_de_shao_nv",
      "speaker_name": "美腿的少女",
      "listener": "char_lan_lan",
      "text": "你们两个人可以一起跟我走。",
      "tone": "陈述",
      "chapter": 9,
      "line_start": 586,
      "line_end": 586
    },
    {
