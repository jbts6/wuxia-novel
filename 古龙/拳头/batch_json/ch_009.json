      "line_start": 602,
      "line_end": 602
    },
    {
      "speaker": "char_xiao_ma",
      "speaker_name": "小马",
      "listener": "char_chang_fa_shao_nian",
      "text": "你们朝拜的是什么？",
      "tone": "好奇",
      "chapter": 9,
      "line_start": 606,
      "line_end": 606
    },
    {
      "speaker": "char_chang_fa_shao_nian",
      "speaker_name": "长发少年",
      "listener": "char_xiao_ma",
      "text": "太阳。",
      "tone": "陈述",
      "chapter": 9,
      "line_start": 608,
      "line_end": 608
    },
    {
      "speaker": "char_xiao_ma",
      "speaker_name": "小马",
      "listener": "char_chang_fa_shao_nian",
      "text": "现在还是晚上，晚上哪里有太阳？",
