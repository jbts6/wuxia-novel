      "speaker_name": "美腿的少女",
      "listener": "char_lan_lan",
      "text": "伤心不好，我不喜欢要人伤心。",
      "tone": "温柔",
      "chapter": 9,
      "line_start": 582,
      "line_end": 582
    },
    {
      "speaker": "char_lan_lan",
      "speaker_name": "蓝兰",
      "listener": "char_mei_tui_de_shao_nv",
      "text": "那么你就该走。",
      "tone": "认真",
