      "line_start": 594,
      "line_end": 594
    },
    {
      "speaker": "char_xiao_ma",
      "speaker_name": "长发少年",
      "listener": "char_xiao_ma",
      "text": "音乐？",
      "tone": "疑问",
      "chapter": 9,
      "line_start": 596,
      "line_end": 596
    },
    {
      "speaker": "char_xiao_ma",
      "speaker_name": "小马",
      "listener": "char_chang_fa_shao_nian",
      "text": "那就是你们的音乐？",
      "tone": "疑问",
      "chapter": 9,
      "line_start": 600,
