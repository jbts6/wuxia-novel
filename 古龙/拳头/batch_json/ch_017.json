    },
    {
      "speaker": "char_zhu_wu_tai_ye",
      "speaker_name": "朱五太爷",
      "listener": "char_chang_wu_yi",
      "text": "剑在哪里？",
      "tone": "疑问",
      "chapter": 17,
      "line_start": 364,
