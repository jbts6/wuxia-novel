    },
    {
      "speaker": "char_chang_wu_yi",
      "speaker_name": "常无意",
      "listener": "char_zhu_wu_tai_ye",
      "text": "你属下也有杀人的人，有些人他们若不能杀，我就杀。",
      "tone": "淡然",
      "chapter": 17,
      "line_start": 352,
      "line_end": 354
    },
    {
      "speaker": "char_zhu_wu_tai_ye",
      "speaker_name": "朱五太爷",
      "listener": "char_chang_wu_yi",
      "text": "你说得好象很有把握。",
      "tone": "淡然",
      "chapter": 17,
      "line_start": 356,
      "line_end": 356
    },
    {
      "speaker": "char_chang_wu_yi",
      "speaker_name": "常无意",
      "listener": "char_zhu_wu_tai_ye",
      "text": "我有把握。",
      "tone": "认真",
      "chapter": 17,
      "line_start": 358,
      "line_end": 358
    },
    {
      "speaker": "char_zhu_wu_tai_ye",
      "speaker_name": "朱五太爷",
      "listener": "char_chang_wu_yi",
      "text": "只可惜再利的口舌也不能杀人。",
