      "listener": "char_xiao_ma",
      "text": "蓝兰。",
      "tone": "平静",
      "chapter": 15,
      "line_start": 14,
      "line_end": 14
    },
    {
      "speaker": "char_xiao_ma",
      "speaker_name": "小马",
      "listener": "char_shi_zhe",
      "text": "你想要她？",
      "tone": "惊讶",
      "chapter": 15,
      "line_start": 16,
      "line_end": 16
    },
    {
      "speaker": "char_shi_zhe",
      "speaker_name": "使者",
      "listener": "char_xiao_ma",
      "text": "很想。",
      "tone": "平静",
      "chapter": 15,
      "line_start": 18,
      "line_end": 18
    },
    {
      "speaker": "char_xiao_ma",
      "speaker_name": "小马",
      "listener": "char_shi_zhe",
      "text": "你不想要轿子里的那个人？",
      "tone": "疑问",
      "chapter": 15,
      "line_start": 20,
      "line_end": 20
    },
    {
      "speaker": "char_shi_zhe",
      "speaker_name": "使者",
      "listener": "char_xiao_ma",
      "text": "很想。",
      "tone": "平静",
      "chapter": 15,
      "line_start": 22,
      "line_end": 22
    },
    {
