      "chapter": 15,
      "line_start": 26,
      "line_end": 26
    },
    {
      "speaker": "char_shi_zhe",
      "speaker_name": "使者",
      "listener": "char_xiao_ma",
      "text": "只要你愿你的朋友站在我这一边，他们绝对逃不出我的掌心。",
      "tone": "平静",
      "chapter": 15,
      "line_start": 30,
      "line_end": 30
    },
    {
