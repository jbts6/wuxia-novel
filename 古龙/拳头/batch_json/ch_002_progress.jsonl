,"line_end":14,"text":"小马故意露出牙齿猛笑"}]},{"id":"tech_wu_hu_teng_shan","name":"五虎腾山","type":"defense","description":"五虎断门刀的守式，巡围身体创造防御网，可挡住多方攻击","source_skill":"skill_wu_hu_duan_men_dao","source_refs":[{"chapter":2,"line_start":258,"line_end":258,"text":"五虎断门刀"}]}],"factions":[],"locations":[{"id":"loc_lang_shan","name":"狼山","region":"江湖","one_line":"传说中群狼聚集之地，现住着比狼更可怕的狼人","source_refs":[{"chapter":2,"line_start":162,"line_end":178,"text":"据说狼山有很多狼"}]},{"id":"loc_xi_cheng","name":"西城","region":"江湖","one_line":"有能治好蓝兰弟弟怪病的名医所在之城","source_refs":[{"chapter":2,"line_start":220,"line_end":220,"text":"蓝兰道：“越过狼山到西城，至少可以少走六七天路。”"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"我并没有问你尊姓大名。","tone":"冷酷","chapter":2,"line_start":102,"line_end":102},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"可是我现在已经说了出来，你已经听见了。","tone":"陈述","chapter":2,"line_start":112,"line_end":112},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"我不是个聋子。","tone":"冷酷","chapter":2,"line_start":114,"line_end":114},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"所以现在你已知道我是什么样的人，我也知道你是什么样的人。","tone":"陈述","chapter":2,"line_start":116,"line_end":116},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"哆。","tone":"冷酷","chapter":2,"line_start":120,"line_end":120},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"所以现在你已经可以走了。","tone":"陈述","chapter":2,"line_start":122,"line_end":122},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"你就是这里的老板？","tone":"疑问","chapter":2,"line_start":128,"line_end":128},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"嗯。","tone":"陈述","chapter":2,"line_start":132,"line_end":132},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"叫人把我找到这里来的就是你？","tone":"疑问","chapter":2,"line_start":134,"line_end":134},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"嗯。","tone":"陈述","chapter":2,"line_start":136,"line_end":136},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"我揍了你们五个人，喝了你们两瓶酒，又跟你……","tone":"疑问","chapter":2,"line_start":138,"line_end":138},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你做的事我都知道，又何必再说？","tone":"淡然","chapter":2,"line_start":140,"line_end":140},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"你费了那么多功夫，神秘兮兮地把我找到这里来，为的就是要我来喝酒，揍人？","tone":"疑问","chapter":2,"line_start":142,"line_end":142},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"不是。","tone":"陈述","chapter":2,"line_start":146,"line_end":146},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"你本来想找我干什么的？","tone":"疑问","chapter":2,"line_start":148,"line_end":148},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我本来当然还有一点别的事。","tone":"陈述","chapter":2,"line_start":150,"line_end":150},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"现在呢？","tone":"疑问","chapter":2,"line_start":152,"line_end":152},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"现在我已不想找你做了。","tone":"陈述","chapter":2,"line_start":154,"line_end":154},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"为什么？","tone":"疑问","chapter":2,"line_start":156,"line_end":156},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"因为现在我已有点喜欢你，所以不忍再要你去送死。","tone":"温柔","chapter":2,"line_start":158,"line_end":158},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"送死？到哪里去送死？","tone":"惊讶","chapter":2,"line_start":160,"line_end":160},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"狼山。","tone":"陈述","chapter":2,"line_start":162,"line_end":162},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你知道狼山这地方？","tone":"疑问","chapter":2,"line_start":190,"line_end":190},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"但我却不知道我为什么要到狼山上去送死。","tone":"疑问","chapter":2,"line_start":192,"line_end":192},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"因为你要保护我们去。","tone":"陈述","chapter":2,"line_start":194,"line_end":194},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"你们？","tone":"疑问","chapter":2,"line_start":196,"line_end":196},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我们就是我跟我弟弟。","tone":"陈述","chapter":2,"line_start":198,"line_end":198},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"你们要到狼山去？","tone":"疑问","chapter":2,"line_start":200,"line_end":200}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"非去不可！","tone":"认真","chapter":2,"line_start":202,"line_end":202},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"什么时候去？","tone":"疑问","chapter":2,"line_start":204,"line_end":204},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"一早就去。","tone":"陈述","chapter":2,"line_start":206,"line_end":206},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"据说钱太多的人，都有点残病。","tone":"调侃","chapter":2,"line_start":208,"line_end":208},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我的钱不少，可是我没有残病。","tone":"认真","chapter":2,"line_start":212,"line_end":212},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"没有残病的人，为什么一定要到那鬼地方去？","tone":"疑问","chapter":2,"line_start":214,"line_end":214},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"因为那条路是近路。","tone":"陈述","chapter":2,"line_start":216,"line_end":216},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"近路？","tone":"惊讶","chapter":2,"line_start":218,"line_end":218},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"越过狼山到西城，至少可以少走六七天路。","tone":"陈述","chapter":2,"line_start":220,"line_end":220},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"你们急着要到西城？","tone":"疑问","chapter":2,"line_start":222,"line_end":222},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我弟弟有病，可能一辈子都医不好，如果不能在三天之内赶到西城，也许他就死定了。","tone":"悲伤","chapter":2,"line_start":224,"line_end":224},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"如果从狼山走，可能一辈子也到不了西城。","tone":"冷酷","chapter":2,"line_start":228,"line_end":228},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我知道。","tone":"陈述","chapter":2,"line_start":230,"line_end":230},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"可是你还要赌一赌？","tone":"疑问","chapter":2,"line_start":232,"line_end":232},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我想不出别的法子。","tone":"无奈","chapter":2,"line_start":234,"line_end":234},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"西城有人能治你弟弟的疾病？","tone":"疑问","chapter":2,"line_start":236,"line_end":236},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"只有他一个人。","tone":"陈述","chapter":2,"line_start":238,"line_end":238},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我们本来可以去请些有名的镯客，可是这件事太急，我们只请到了一个人。","tone":"陈述","chapter":2,"line_start":242,"line_end":242},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"谁？","tone":"疑问","chapter":2,"line_start":246,"line_end":246},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"只可惜那个人现在已不能算是一个完整的人了。","tone":"无奈","chapter":2,"line_start":248,"line_end":248},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"为什么？","tone":"疑问","chapter":2,"line_start":252,"line_end":252},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"因为他已被你打得七零八碎，想站起来都很难。","tone":"苦笑","chapter":2,"line_start":254,"line_end":254},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"雷老虎？","tone":"惊讶","chapter":2,"line_start":256,"line_end":256},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我们本以为他的五虎断门刀很有两下子，谁知道他一遇见你，老虎就变成了病猫。","tone":"苦笑","chapter":2,"line_start":258,"line_end":258},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"所以你就想到来找我。","tone":"陈述","chapter":2,"line_start":262,"line_end":262},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"可惜我也知道你这人是天生的牛脾气。若是好好地请你做一件事，你绝不会答应的，何况，你最近心情又不好。","tone":"无奈","chapter":2,"line_start":264,"line_end":264},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"我只希望你记住一点。","tone":"严肃","chapter":2,"line_start":268,"line_end":268},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"我心情好不好，是我的事，跟你一点关系都没有。","tone":"冷酷","chapter":2,"line_start":272,"line_end":272},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我记住了。","tone":"认真","chapter":2,"line_start":274,"line_end":274},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"很好。","tone":"陈述","chapter":2,"line_start":276,"line_end":276},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"这次你说很好是什么意思？","tone":"疑问","chapter":2,"line_start":278,"line_end":278},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"就是你现在已经找到一个保镖的意思。","tone":"陈述","chapter":2,"line_start":280,"line_end":280},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你真的肯答应？","tone":"欣喜","chapter":2,"line_start":282,"line_end":282},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"我为什么不肯答应？","tone":"疑问","chapter":2,"line_start":284,"line_end":284},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你不怕那些狼人？","tone":"疑问","chapter":2,"line_start":286,"line_end":286},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"有些怕。","tone":"陈述","chapter":2,"line_start":288,"line_end":288},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你不怕死？","tone":"疑问","chapter":2,"line_start":290,"line_end":290},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"谁不怕死？只有白痱才不怕死。","tone":"陈述","chapter":2,"line_start":292,"line_end":292},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"那你为什么还肯去？","tone":"疑问","chapter":2,"line_start":294,"line_end":294},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"因为我这个人有残病。","tone":"调侃","chapter":2,"line_start":296,"line_end":296},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我知道，你的残病有三千七百八十三点。","tone":"调侃","chapter":2,"line_start":298,"line_end":298},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"是三千七百八十四点。","tone":"调侃","chapter":2,"line_start":300,"line_end":300}],"new_entities":{"characters":[{"id":"char_lei_lao_hu","name":"雷老虎","alias":[],"identity":"镯客","faction":"无","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"被小马打败的镯客，擅长五虎断门刀","personality":{"traits":["好胜","勇猛","自信","正面交错","勇敢敢战"],"speech_style":"未知","temperament":"未知"},"relationships":[{"target":"char_xiao_ma","type":"对手","intensity":50,"bond_level":2,"dynamic":"被小马打败"}],"known_skills":["skill_wu_hu_duan_men_dao"],"related_skills":[],"rag_refs":[2],"source_refs":[{"chapter":2,"line_start":256,"line_end":258,"text":"小马道：“雷老虎？”蓝兰苦笑道：“我们本以为他的五虎断门刀很有两下子。”"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":370,"dialogues":[{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"现在又加了一点？","tone":"疑问","chapter":2,"line_start":302,"line_end":302},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"加了最要命的一点。","tone":"调侃","chapter":2,"line_start":304,"line_end":304},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"哪一点？","tone":"疑问","chapter":2,"line_start":306,"line_end":306},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"就是这一点。","tone":"调侃","chapter":2,"line_start":308,"line_end":308},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你是不是又想起了她？想起了那个被你气走了的女孩子？","tone":"温柔","chapter":2,"line_start":320,"line_end":320},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你答应这件事，是不是因为我可以让你暂时忘记她？","tone":"疑问","chapter":2,"line_start":326,"line_end":326},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我就算说错了话，你也不必这么生气的！","tone":"恐惧","chapter":2,"line_start":330,"line_end":330},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"你若说错了，我最多当你放尾，我为什么要生气？","tone":"愤怒","chapter":2,"line_start":334,"line_end":334},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"我们一早就要走。这里有二三十个家人，都练过几年功夫，你可以选几个带去。","tone":"认真","chapter":2,"line_start":354,"line_end":354},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"现在我已选中了一个。","tone":"陈述","chapter":2,"line_start":358,"line_end":358},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"谁？","tone":"疑问","chapter":2,"line_start":360,"line_end":360},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"香香。","tone":"陈述","chapter":2,"line_start":362,"line_end":362},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"为什么要带她去？","tone":"疑问","chapter":2,"line_start":364,"line_end":364},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"因为她很香，真的很香。","tone":"调侃","chapter":2,"line_start":366,"line_end":366},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"香人有什么作用？","tone":"疑问","chapter":2,"line_start":368,"line_end":368},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"香人总比臭人好。","tone":"调侃","chapter":2,"line_start":370,"line_end":370}],"new_entities":{"characters":[{"id":"char_xiang_xiang","name":"香香","alias":[],"identity":"蓝兰的家人","faction":"无","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"身上带有香气的女子，被小马选为同行护卫","personality":{"traits":["温柔","体香","守口如瓶","前的女人","听话的家人"],"speech_style":"未知","temperament":"未知"},"relationships":[{"target":"char_lan_lan","type":"主仆","intensity":40,"bond_level":2,"dynamic":"蓝兰的家人"},{"target":"char_xiao_ma","type":"合作者","intensity":30,"bond_level":2,"dynamic":"被小马选为同行"}],"known_skills":[],"related_skills":[],"rag_refs":[2],"source_refs":[{"chapter":2,"line_start":362,"line_end":366,"text":"小马道：“香香。……因为她很香，真的很香。”"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_ma","updates":{"source_refs":[{"chapter":2,"line_start":334,"line_end":334,"text":"小马睁着她，目中的痛苦之色更深，手却放松了。大声道：“你若说错了，我最多当你放尾，我为什么要生气？”"}]},"relationship_updates":[{"action":"update","target":"char_lan_lan","type":"合作者","intensity":65,"bond_level":3,"dynamic":"同意护送蓝兰姐弟穿越狼山"}]},{"id":"char_lan_lan","updates":{"source_refs":[{"chapter":2,"line_start":346,"line_end":346,"text":"她正看着他时，眼被已更柔和，充满了一种母性的怨惜和同情。"}]},"relationship_updates":[{"action":"update","target":"char_xiao_ma","type":"合作者","intensity":65,"bond_level":3,"dynamic":"小马同意护送"}]}]}
