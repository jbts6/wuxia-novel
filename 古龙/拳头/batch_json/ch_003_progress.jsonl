{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"这姐妹两人你是怎么找来的？","tone":"疑问","chapter":3,"line_start":105,"line_end":105},{"speaker":"char_lan_lan","speaker_name":"小马","listener":null,"text":"连你我都能找得来，何况她们。","tone":"微笑","chapter":3,"line_start":107,"line_end":107},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"她们是哪一派的弟子？","tone":"疑问","chapter":3,"line_start":109,"line_end":109},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"她们没有问过你是哪一派门下的弟子？","tone":"疑问","chapter":3,"line_start":111,"line_end":111},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"没有。","tone":"陈述","chapter":3,"line_start":113,"line_end":113},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"那么你又何必问她们？","tone":"陈述","chapter":3,"line_start":115,"line_end":115},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"除了她们姐妹和香香外，你还想带什么人去？","tone":"疑问","chapter":3,"line_start":119,"line_end":119},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"第一，我要找个耳朵很灵的人。","tone":"陈述","chapter":3,"line_start":121,"line_end":121},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"到哪里去找？","tone":"疑问","chapter":3,"line_start":123,"line_end":123},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"我知道城里有个人，别人就算在二三十丈外悄悄说话，他都能听见。","tone":"陈述","chapter":3,"line_start":125,"line_end":125},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"这人是谁？","tone":"疑问","chapter":3,"line_start":129,"line_end":129},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"这人叫张聋子，就是在城门口补鞋的张聋子。","tone":"陈述","chapter":3,"line_start":131,"line_end":131},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你说这人叫什么？","tone":"惊讶","chapter":3,"line_start":133,"line_end":133},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"叫张聋子。","tone":"陈述","chapter":3,"line_start":135,"line_end":135},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"他当然不是真的聋子。","tone":"疑问","chapter":3,"line_start":137,"line_end":137},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"他是的。","tone":"陈述","chapter":3,"line_start":139,"line_end":139},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你说耳朵最灵的人是个真的聋子？","tone":"惊讶","chapter":3,"line_start":141,"line_end":141},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"不错。","tone":"陈述","chapter":3,"line_start":143,"line_end":143},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"一个真的聋子，能够听见别人在二十丈外悄悄说话？","tone":"疑问","chapter":3,"line_start":145,"line_end":145},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"我保证他每字都听得见。","tone":"认真","chapter":3,"line_start":147,"line_end":147},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"看来你这人不但有毛病，而且还有点疯。","tone":"无奈","chapter":3,"line_start":149,"line_end":149},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"你若不信，为什么不找他来试试？","tone":"调侃","chapter":3,"line_start":151,"line_end":151},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_zhang_long_zi","text":"你会补鞋？","tone":"疑问","chapter":3,"line_start":177,"line_end":177},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_zhang_long_zi","text":"你姓什么？是什么地方人？家里还有些什么人？","tone":"疑问","chapter":3,"line_start":181,"line_end":181},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_lan_lan","text":"我姓张，河南人，老婆死了，女儿嫁了，现在家里只剩下我一个。","tone":"陈述","chapter":3,"line_start":183,"line_end":183},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"怎么样？","tone":"疑问","chapter":3,"line_start":193,"line_end":193},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"很好，好极了。","tone":"无奈","chapter":3,"line_start":195,"line_end":195},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"聋兄，你好。","tone":"大笑","chapter":3,"line_start":197,"line_end":197},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"我不好，很不好。","tone":"苦笑","chapter":3,"line_start":205,"line_end":205}],"new_entities":{"characters":[{"id":"char_xiang_xiang","name":"香香","alias":[],"identity":"小姑娘","faction":null,"role":"companion","archetype":"assassin","rank":null,"one_line":"美丽小姑娘，能带来消息","personality":{"traits":["美丽","活泼","消息灵通","热心","年轻"],"speech_style":"活泼","temperament":"开朗"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":325,"line_end":327,"text":"香香正穿过院子，匆匆走进来"}]},{"id":"char_zhang_long_zi","name":"张聋子","alias":["张皮匠"],"identity":"补鞋皮匠，真聋子","faction":null,"role":"companion","archetype":"warrior","rank":null,"one_line":"真聋子，耳朵却最灵，补鞋皮匠","personality":{"traits":["幽默","忠诚","胆小","重义气","聪明"],"speech_style":"直接","temperament":"谨慎"},"relationships":[{"target":"char_xiao_ma","type":"挚友","intensity":80,"bond_level":4,"dynamic":"老朋友"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":155,"line_end":155,"text":"张聋子又叫张皮匠"}]}],"skills":[],"techniques":[{"id":"tech_da_hong_quan_pu_tong_ji","name":"大洪拳普通击","type":"attack","source_skill":"skill_da_hong_quan","source_refs":[{"chapter":3,"line_start":6,"line_end":8,"text":"大洪拳"}]},{"id":"tech_fu_huo_luo_han_quan_lian_huan_ji","name":"伏虎罗汉拳连环击","type":"attack","source_skill":"skill_fu_huo_luo_han_quan","source_refs":[{"chapter":3,"line_start":20,"line_end":31,"text":"伏虎罗汉拳"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"怎么会不好？","tone":"疑问","chapter":3,"line_start":207,"line_end":207},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"遇见了你这个倒霉鬼，我怎能会好得起来？","tone":"无奈","chapter":3,"line_start":209,"line_end":209},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你为什么不问问他，肯不肯跟我们一起走？","tone":"疑问","chapter":3,"line_start":221,"line_end":221},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"他一定肯。","tone":"认真","chapter":3,"line_start":223,"line_end":223},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你怎么知道？","tone":"疑问","chapter":3,"line_start":225,"line_end":225},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"他既然已遇见了我，还有什么别的路好走？","tone":"调侃","chapter":3,"line_start":227,"line_end":227},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"你们总不会是想要我跟你们过狼山吧？","tone":"恐惧","chapter":3,"line_start":229,"line_end":229},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"不是下面还要加两个字。","tone":"调侃","chapter":3,"line_start":233,"line_end":233},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"两个什么宇？","tone":"疑问","chapter":3,"line_start":235,"line_end":235},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"不是才怪。","tone":"大笑","chapter":3,"line_start":237,"line_end":237},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"这一趟你真的非走不可？","tone":"认真","chapter":3,"line_start":247,"line_end":247},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"好，我去，可是我有个条件！","tone":"认真","chapter":3,"line_start":253,"line_end":253},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"你说。","tone":"陈述","chapter":3,"line_start":255,"line_end":255},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"你去把老皮也找来，要下水，大家一起下水。","tone":"认真","chapter":3,"line_start":257,"line_end":257},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"老皮也在城里？","tone":"欣喜","chapter":3,"line_start":259,"line_end":259},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"他刚来，正在我家厨房里喝酒。","tone":"陈述","chapter":3,"line_start":261,"line_end":261},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"老皮是什么人？","tone":"疑问","chapter":3,"line_start":265,"line_end":265},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"老皮也是个皮匠。","tone":"陈述","chapter":3,"line_start":267,"line_end":267},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"他有什么本事？","tone":"疑问","chapter":3,"line_start":269,"line_end":269},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"一点儿本事都没有。","tone":"陈述","chapter":3,"line_start":271,"line_end":271},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"有几点儿？","tone":"疑问","chapter":3,"line_start":273,"line_end":273},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"半点儿都没有。","tone":"陈述","chapter":3,"line_start":275,"line_end":275},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"他完全没有本事？","tone":"疑问","chapter":3,"line_start":277,"line_end":277},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"没有本事的人，请他来干什么？","tone":"疑问","chapter":3,"line_start":281,"line_end":281},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"真正连一点儿本事都没有的人，你见过几个？","tone":"疑问","chapter":3,"line_start":283,"line_end":283},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"好象连一个都没见过。","tone":"陈述","chapter":3,"line_start":285,"line_end":285},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"所以他这种人才真正难得。","tone":"认真","chapter":3,"line_start":287,"line_end":287},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"完全没有本事，就是他最大的本事，这种人找遍天下，也找不出几个。","tone":"认真","chapter":3,"line_start":291,"line_end":291},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"你厨房里还有多少酒？","tone":"疑问","chapter":3,"line_start":303,"line_end":303},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"三四斤。","tone":"陈述","chapter":3,"line_start":305,"line_end":305},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"那么他现在早就走了，喝了三斤酒之后，他绝不会再耽在别人的厨房里。","tone":"无奈","chapter":3,"line_start":307,"line_end":307},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"喝了三斤酒之后，他会去干什么？","tone":"疑问","chapter":3,"line_start":311,"line_end":311},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"天知道他会去千什么？喝了酒之后，他做的事只怕连神仙都猜不到。","tone":"苦笑","chapter":3,"line_start":313,"line_end":313}],"new_entities":{"characters":[],"skills":[],"techniques":[{"id":"tech_da_hong_quan_pu_tong_ji","name":"大洪拳普通击","type":"attack","source_skill":"skill_da_hong_quan","source_refs":[{"chapter":3,"line_start":6,"line_end":8,"text":"大洪拳"}]},{"id":"tech_fu_huo_luo_han_quan_lian_huan_ji","name":"伏虎罗汉拳连环击","type":"attack","source_skill":"skill_fu_huo_luo_han_quan","source_refs":[{"chapter":3,"line_start":20,"line_end":31,"text":"伏虎罗汉拳"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":423,"dialogues":[{"speaker":"char_xiang_xiang","speaker_name":"香香","listener":"char_lan_lan","text":"我刚才听见了个好消息。","tone":"激动","chapter":3,"line_start":326,"line_end":326},{"speaker":"char_xiang_xiang","speaker_name":"香香","listener":"char_lan_lan","text":"今天城里又来了一个了不起的人，我们如果能请到他，什么问题都没有了。","tone":"激动","chapter":3,"line_start":331,"line_end":331},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiang_xiang","text":"这个了不起的人是谁？","tone":"疑问","chapter":3,"line_start":335,"line_end":335},{"speaker":"char_xiang_xiang","speaker_name":"香香","listener":"char_lan_lan","text":"邓定侯。","tone":"陈述","chapter":3,"line_start":337,"line_end":337},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiang_xiang","text":"神拳小诸葛邓定侯？","tone":"惊讶","chapter":3,"line_start":339,"line_end":339},{"speaker":"char_xiang_xiang","speaker_name":"香香","listener":"char_lan_lan","text":"刚才老孙回来，说他正在天福楼喝酒，还请了好多好多人陪他一起喝。","tone":"激动","chapter":3,"line_start":341,"line_end":341},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_xiao_ma","text":"是你去还是我去？","tone":"疑问","chapter":3,"line_start":349,"line_end":349},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_zhang_long_zi","text":"我去。","tone":"陈述","chapter":3,"line_start":351,"line_end":351},{"speaker":"char_xiang_xiang","speaker_name":"香香","listener":"char_xiao_ma","text":"去找邓定侯？","tone":"疑问","chapter":3,"line_start":353,"line_end":353},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_xiang_xiang","text":"去找皮猴子，一个脸皮比一个城墙还厚的胖猴子。","tone":"调侃","chapter":3,"line_start":355,"line_end":355},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"难道这个邓定侯就是老皮冒充的？","tone":"惊讶","chapter":3,"line_start":357,"line_end":357},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"不是才怪。","tone":"大笑","chapter":3,"line_start":359,"line_end":359},{"speaker":"char_xiang_xiang","speaker_name":"香香","listener":"char_xiao_ma","text":"邓定侯是名震天下的大侠，谁敢冒充他？","tone":"惊讶","chapter":3,"line_start":361,"line_end":361},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_xiang_xiang","text":"老皮敢，喝了三斤酒之后，天下绝没有他不敢做的事。","tone":"大笑","chapter":3,"line_start":363,"line_end":363},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"可是你刚才还说他连一点本事都没有。这种事他怎做得出？","tone":"疑问","chapter":3,"line_start":365,"line_end":365},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"就因为他一点本事都没有，所以他什么事都做得出，这就是他最大的本事！","tone":"认真","chapter":3,"line_start":369,"line_end":369},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lao_pi","text":"我们上狼山去！","tone":"豪迈","chapter":3,"line_start":379,"line_end":379},{"speaker":"char_lao_pi","speaker_name":"老皮","listener":"char_xiao_ma","text":"好，我们上狼山去。","tone":"豪迈","chapter":3,"line_start":381,"line_end":381},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lao_pi","text":"你不怕？","tone":"疑问","chapter":3,"line_start":383,"line_end":383},{"speaker":"char_lao_pi","speaker_name":"老皮","listener":"char_xiao_ma","text":"为朋友两肋插刀都不怕，何况走一次狼山。","tone":"豪迈","chapter":3,"line_start":385,"line_end":385},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"现在你总算明白了吧。","tone":"微笑","chapter":3,"line_start":387,"line_end":387},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你们刚才为什么要说他是皮匠？","tone":"疑问","chapter":3,"line_start":391,"line_end":391},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_lan_lan","text":"他本来就是的！","tone":"陈述","chapter":3,"line_start":395,"line_end":395},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"可是他看来完全不象。","tone":"疑问","chapter":3,"line_start":397,"line_end":397},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_lan_lan","text":"那只因为他这个皮匠，和我这个皮匠有点不同。","tone":"陈述","chapter":3,"line_start":399,"line_end":399},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_zhang_long_zi","text":"有什么不同？","tone":"疑问","chapter":3,"line_start":401,"line_end":401},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_lan_lan","text":"我这个皮匠是补鞋的。","tone":"陈述","chapter":3,"line_start":403,"line_end":403},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_zhang_long_zi","text":"他呢？","tone":"疑问","chapter":3,"line_start":405,"line_end":405},{"speaker":"char_zhang_long_zi","speaker_name":"张聋子","listener":"char_lan_lan","text":"他是赖皮的。","tone":"调侃","chapter":3,"line_start":407,"line_end":407},{"speaker":"char_lao_pi","speaker_name":"老皮","listener":null,"text":"我们这两个臭皮匠加在一起，虽然还比不上一个诸葛亮，要比个把曹操，总是绰绰有余的了。","tone":"大笑","chapter":3,"line_start":409,"line_end":409}],"new_entities":{"characters":[{"id":"char_lao_pi","name":"老皮","alias":["皮猴子"],"identity":"皮匠，赖皮","faction":null,"role":"companion","archetype":"warrior","rank":null,"one_line":"赖皮皮匠，喝了酒什么都敢做","personality":{"traits":["幽默","勇敢","重义气","爱喝酒","大胆"],"speech_style":"豪爽","temperament":"豪放"},"relationships":[{"target":"char_xiao_ma","type":"挚友","intensity":80,"bond_level":4,"dynamic":"老朋友"},{"target":"char_zhang_long_zi","type":"挚友","intensity":80,"bond_level":4,"dynamic":"臭皮匠搭档"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":373,"line_end":375,"text":"老皮并不太胖，更不象猴子。他衣冠楚楚，一表人材"}]},{"id":"char_deng_ding_hou","name":"邓定侯","alias":["神拳小诸葛"],"identity":"名震天下的大侠","faction":null,"role":"npc","archetype":"warrior","rank":null,"one_line":"神拳小诸葛，名震天下的大侠","personality":{"traits":["正义","侠义","有名","受人尊敬","武功高强"],"speech_style":null,"temperament":null},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":337,"line_end":339,"text":"邓定侯。神拳小诸葛邓定侯？"}]},{"id":"char_lao_sun","name":"老孙","alias":[],"identity":"报信人","faction":null,"role":"npc","archetype":"npc","rank":null,"one_line":"回来报信的人","personality":{"traits":["勤快","忠诚","机灵","低调","可靠"],"speech_style":"简洁","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":341,"line_end":341,"text":"刚才老孙回来"}]}],"skills":[],"techniques":[{"id":"tech_da_hong_quan_pu_tong_ji","name":"大洪拳普通击","type":"attack","source_skill":"skill_da_hong_quan","source_refs":[{"chapter":3,"line_start":6,"line_end":8,"text":"大洪拳"}]},{"id":"tech_fu_huo_luo_han_quan_lian_huan_ji","name":"伏虎罗汉拳连环击","type":"attack","source_skill":"skill_fu_huo_luo_han_quan","source_refs":[{"chapter":3,"line_start":20,"line_end":31,"text":"伏虎罗汉拳"}]}],"factions":[],"locations":[{"id":"loc_lang_shan","name":"狼山","region":null,"one_line":"比龙潭虎穴还凶险的地方","source_refs":[{"chapter":3,"line_start":219,"line_end":219,"text":"狼山"}]},{"id":"loc_tian_fu_lou","name":"天福楼","region":null,"one_line":"城里喝酒的地方","source_refs":[{"chapter":3,"line_start":341,"line_end":341,"text":"正在天福楼喝酒"}]}],"items":[{"id":"item_tong_luo","name":"铜锣","type":"special","owner":null,"one_line":"六面大铜锣，敲响可震聋人耳","description":"六面大铜锣，每面铜锣配木棒敲击，声音巨大可震聋人耳，用于测试张聋子是否真聋。","effects":[{"type":"特殊","description":"发出巨大声响"}],"origin":"蓝兰准备","rarity":"寻常凡品","related_characters":["char_lan_lan","char_zhang_long_zi"],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":161,"line_end":163,"text":"六个人，每个人都拿着面大铜锣"}]},{"id":"item_jiao_zi","name":"轿子","type":"special","owner":null,"one_line":"密不透风的轿子，载着神秘病人","description":"密不透风的轿子，里面坐着一位奄奄一息的神秘病人，小马连这人长得是什么样子都没看见就为他去卖命。","effects":[{"type":"特殊","description":"遮蔽乘客身份"}],"origin":"蓝兰安排","rarity":"寻常凡品","related_characters":["char_xiao_ma"],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":419,"line_end":419,"text":"病人坐在轿子里，轿子密不透风"}]}]},"entity_updates":[]}
