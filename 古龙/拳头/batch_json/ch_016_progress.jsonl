{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_xiao_ma","speaker_name":"小马","listener":null,"text":"今天是十几？","tone":"疑问","chapter":16,"line_start":8,"line_end":8},{"speaker":"char_hao_sheng_yi","speaker_name":"郝生意","listener":"char_xiao_ma","text":"十四。","tone":"陈述","chapter":16,"line_start":10,"line_end":10},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_hao_sheng_yi","text":"前面是什么地方？","tone":"疑问","chapter":16,"line_start":12,"line_end":12},{"speaker":"char_hao_sheng_yi","speaker_name":"郝生意","listener":"char_xiao_ma","text":"前面就是狼山之王的皇宫。","tone":"陈述","chapter":16,"line_start":14,"line_end":14},{"speaker":"char_hao_sheng_yi","speaker_name":"郝生意","listener":"char_xiao_ma","text":"我只能送你到这里。","tone":"陈述","chapter":16,"line_start":24,"line_end":26},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_hao_sheng_yi","text":"到了这里，我就一定可以见到他？","tone":"疑问","chapter":16,"line_start":28,"line_end":28},{"speaker":"char_hao_sheng_yi","speaker_name":"郝生意","listener":"char_xiao_ma","text":"不一定。","tone":"陈述","chapter":16,"line_start":30,"line_end":30},{"speaker":"char_hao_sheng_yi","speaker_name":"郝生意","listener":"char_xiao_ma","text":"这世上本就没有绝对一定可以做得到的事，我已尽了力，你是不是可以见得到他，就全得看你自己了。","tone":"认真","chapter":16,"line_start":32,"line_end":34},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_hao_sheng_yi","text":"我明白，如果我见不到他，这里就是我的葬身之地。","tone":"无奈","chapter":16,"line_start":36,"line_end":38},{"speaker":"char_hao_sheng_yi","speaker_name":"郝生意","listener":"char_xiao_ma","text":"我还可以泄露—点秘密给你。","tone":"低语","chapter":16,"line_start":46,"line_end":48},{"speaker":"char_hao_sheng_yi","speaker_name":"郝生意","listener":"char_xiao_ma","text":"要想见朱五爷，对那扫花的老人，就得特别尊敬。","tone":"认真","chapter":16,"line_start":52,"line_end":52},{"speaker":"char_hao_sheng_yi","speaker_name":"郝生意","listener":"char_xiao_ma","text":"祝你顺利。","tone":"微笑","chapter":16,"line_start":58,"line_end":58},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_hao_sheng_yi","text":"祝你好生意。","tone":"微笑","chapter":16,"line_start":60,"line_end":60},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sao_hua_de_lao_ren","text":"我姓马，我特地来求见朱五太爷。","tone":"陈述","chapter":16,"line_start":64,"line_end":64},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sao_hua_de_lao_ren","text":"我此来并无恶意，我是来送礼的。","tone":"陈述","chapter":16,"line_start":68,"line_end":68},{"speaker":"char_sao_hua_de_lao_ren","speaker_name":"扫花的老人","listener":"char_xiao_ma","text":"跪下来说话，再爬着进","tone":"陈述","chapter":16,"line_start":70,"line_end":70},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sao_hua_de_lao_ren","text":"你叫谁跪下来？","tone":"愤怒","chapter":16,"line_start":74,"line_end":74},{"speaker":"char_sao_hua_de_lao_ren","speaker_name":"扫花的老人","listener":"char_xiao_ma","text":"叫你。","tone":"淡然","chapter":16,"line_start":76,"line_end":76},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sao_hua_de_lao_ren","text":"放你妈的屁！","tone":"愤怒","chapter":16,"line_start":78,"line_end":78},{"speaker":"char_sao_hua_de_lao_ren","speaker_name":"扫花的老人","listener":"char_xiao_ma","text":"有意思，有意思。","tone":"轻笑","chapter":16,"line_start":88,"line_end":88},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sao_hua_de_lao_ren","text":"什么事有意思？","tone":"疑问","chapter":16,"line_start":90,"line_end":90},{"speaker":"char_sao_hua_de_lao_ren","speaker_name":"扫花的老人","listener":"char_xiao_ma","text":"我已五十一年没听过'放你妈的屁'这五个字，现在忽然听见，实有很有意思。","tone":"微笑","chapter":16,"line_start":92,"line_end":94}],"new_entities":{"characters":[{"id":"char_xiao_ma","name":"小马","alias":["愤怒的小马"],"identity":"江湖人士","faction":null,"role":"protagonist","archetype":"warrior","rank":4,"one_line":"狼山上的年轻侠客，拳头极快极准","personality":{"traits":["勇猛","直率","冲动","忠诚","幽默"],"speech_style":"直接","temperament":"暴躁"},"relationships":[],"known_skills":["skill_quan_fa"],"related_skills":[],"rag_refs":[16],"source_refs":[{"chapter":16,"line_start":1,"line_end":1,"text":"第十六回　朱五太爷"}]},{"id":"cha