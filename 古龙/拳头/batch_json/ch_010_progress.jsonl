,"alias":["太平客栈老板"],"identity":"狼山生意人","faction":"无","role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"狼山唯一的生意人，经营太平客栈，精明狡猾","personality":{"traits":["精明","狡猾","圆滑","贪婪","胆大"],"speech_style":"油嘴滑舌","temperament":"圆滑世故"},"relationships":[{"target":"char_zhu_wu_tai_ye","type":"合作者","intensity":60,"bond_level":3,"dynamic":"被庇护者"},{"target":"char_xiao_ma","type":"合作者","intensity":40,"bond_level":2,"dynamic":"交易对象"}],"known_skills":[],"related_skills":[],"rag_refs":[10],"source_refs":[{"chapter":10,"line_start":50,"line_end":52,"text":"突听一个人道：各位不必再想，再想也想不出的。但是我却可以带你们去。"}]},{"id":"char_zhu_wu_tai_ye","name":"朱五太爷","alias":["朱五"],"identity":"狼山之主","faction":"无","role":"villain","archetype":"warrior","rank":"返璞归真","one_line":"狼山最有权威的人物，连生意人都受其庇护","personality":{"traits":["威严","神秘","强大","冷酷","不可违抗"],"speech_style":"无直接对话","temperament":"威严不可侵犯"},"relationships":[{"target":"char_sheng_yi_ren","type":"合作者","intensity":60,"bond_level":3,"dynamic":"庇护者"}],"known_skills":[],"related_skills":[],"rag_refs":[10],"source_refs":[{"chapter":10,"line_start":118,"line_end":118,"text":"连朱五太爷都答应了"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"太平客栈。","tone":"陈述","chapter":10,"line_start":102,"line_end":102},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"狼山也有客栈？","tone":"疑问","chapter":10,"line_start":104,"line_end":104},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"只有这一家。","tone":"陈述","chapter":10,"line_start":106,"line_end":106},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"这家客栈是谁开的？","tone":"疑问","chapter":10,"line_start":108,"line_end":108},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"我开的。","tone":"陈述","chapter":10,"line_start":110,"line_end":110},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"你那里真的很太平？","tone":"疑问","chapter":10,"line_start":112,"line_end":112},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"只要走进我那家客栈，我就负责各位太平无事。","tone":"陈述","chapter":10,"line_start":114,"line_end":114},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"你有把握？","tone":"疑问","chapter":10,"line_start":116,"line_end":116},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"这是我跟他们约好了的，连朱五太爷都答应了。","tone":"陈述","chapter":10,"line_start":118,"line_end":118},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"朱五太爷有时也会要我替他做点事，而且他老人家也知道，要闯狼山的人，一定有急事，谁也不会在我那里住一辈子。","tone":"陈述","chapter":10,"line_start":124,"line_end":125},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"所以他们要下手，机会还多得很。","tone":"陈述","chapter":10,"line_start":126,"line_end":126},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"所以他们肯让我做小生意，因为这对他们根本没妨碍。","tone":"陈述","chapter":10,"line_start":128,"line_end":130},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"好，这回生意你已做成了。","tone":"陈述","chapter":10,"line_start":132,"line_end":132},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"现在还没有。","tone":"陈述","chapter":10,"line_start":134,"line_end":134},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"还没有？","tone":"疑问","chapter":10,"line_start":136,"line_end":136},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"不瞒各位说，我那里只接待一种人，我还得看看各位是不是那种人。","tone":"微笑","chapter":10,"line_start":138,"line_end":140},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"哪种人？","tone":"疑问","chapter":10,"line_start":142,"line_end":142},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"有钱的人，很有钱的人。","tone":"陈述","chapter":10,"line_start":144,"line_end":144},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"因为我那里无论什么东西都比别的地方贵一点。","tone":"陈述","chapter":10,"line_start":146,"line_end":146},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"贵多少？","tone":"疑问","chapter":10,"line_start":148,"line_end":148},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"有些人说我那里连一杯酒都比别的地方贵三十倍，其实他们是在冤枉我。","tone":"无奈","chapter":10,"line_start":150,"line_end":152},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"贵多少？","tone":"疑问","chapter":10,"line_start":154,"line_end":154},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"只贵二十八倍。","tone":"陈述","chapter":10,"line_start":156,"line_end":156},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"却不知各位究竟是哪种人？","tone":"疑问","chapter":10,"line_start":162,"line_end":162},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_sheng_yi_ren","text":"是有钱人，很有钱的人","tone":"陈述","chapter":10,"line_start":164,"line_end":164},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"这够不够我们住半天？","tone":"疑问","chapter":10,"line_start":168,"line_end":168},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"只要各位吃得随便一点，也许勉强够了。","tone":"陈述","chapter":10,"line_start":172,"line_end":172},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"现在我才相信你真是人，不是狼。","tone":"大笑","chapter":10,"line_start":174,"line_end":174},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"为什么？","tone":"疑问","chapter":10,"line_start":176,"line_end":176},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"因为只有人才会这么样吃人。","tone":"调侃","chapter":10,"line_start":178,"line_end":178},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":null,"text":"这是我的儿子。","tone":"陈述","chapter":10,"line_start":192,"line_end":192},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":null,"text":"我老婆已经被我赶走了，我老婆不是个好东西。","tone":"陈述","chapter":10,"line_start":196,"line_end":196},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":null,"text":"我们这里有八间房子，还有个大饭厅。","tone":"陈述","chapter":10,"line_start":200,"line_end":200}],"new_entities":{"characters":[{"id":"char_sheng_yi_ren_de_er_zi","name":"生意人的儿子","alias":["癞痢头小伙子"],"identity":"客栈伙计","faction":"无","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"生意人的儿子，满头癞痢，在太平客栈帮忙","personality":{"traits":["年轻","勤快","普通","沉默","听话"],"speech_style":"无直接对话","temperament":"普通"},"relationships":[{"target":"char_sheng_yi_ren","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父子"}],"known_skills":[],"related_skills":[],"rag_refs":[10],"source_refs":[{"chapter":10,"line_start":190,"line_end":192,"text":"一个满头癞痢的小伙子。生意人道：这是我的儿子。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_tai_ping_ke_zhan","name":"太平客栈","region":"狼山","one_line":"狼山唯一的客栈，由生意人经营，价格昂贵但保证安全","source_refs":[{"chapter":10,"line_start":102,"line_end":106,"text":"太平客栈。小马道：狼山也有客栈？生意人道：只有这一家。"}]}],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":null,"text":"我们的酒菜都是第一流的，所以随便什么时候都有客人。","tone":"陈述","chapter":10,"line_start":204,"line_end":206},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":null,"text":"是谁杀了铁三角？","tone":"严肃","chapter":10,"line_start":244,"line_end":244},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_bu_zhan","text":"我！","tone":"激动","chapter":10,"line_start":246,"line_end":246},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_bu_zhan","text":"我杀的人还不止铁三角一个，你要算这账，尽管来找我。","tone":"豪迈","chapter":10,"line_start":254,"line_end":256},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_xiao_ma","text":"我听说过你。","tone":"陈述","chapter":10,"line_start":258,"line_end":258},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_bu_zhan","text":"我叫小马。","tone":"陈述","chapter":10,"line_start":260,"line_end":260},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_xiao_ma","text":"你不是马，你是头驴子。","tone":"嘲讽","chapter":10,"line_start":262,"line_end":262},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_xiao_ma","text":"只有驴子才会做这种蠢事，抢着要把别人的账算在自己身上。","tone":"嘲讽","chapter":10,"line_start":266,"line_end":268},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_xiao_ma","text":"你用的是拳头，铁三角却死在剑下。","tone":"陈述","chapter":10,"line_start":270,"line_end":270},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_bu_zhan","text":"可是我……","tone":"犹豫","chapter":10,"line_start":272,"line_end":272},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_xiao_ma","text":"他要宰你们，你们当然只有宰他，这本是天公地道的事。","tone":"陈述","chapter":10,"line_start":274,"line_end":276},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_bu_zhan","text":"想不到你这个人居然值得公道两字。","tone":"惊讶","chapter":10,"line_start":278,"line_end":278},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_xiao_ma","text":"这笔账本来并没有什么可算的，只不过……","tone":"陈述","chapter":10,"line_start":280,"line_end":280},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"只不过他实在死得太惨，我老头子实在忍不住想看看，那种阴毒狠心的剑法，是什么人使出来的！","tone":"愤怒","chapter":10,"line_start":282,"line_end":284},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"好剑！","tone":"欣喜","chapter":10,"line_start":290,"line_end":290},{"speaker":"char_chang_wu_yi","speaker_name":"常无意","listener":"char_bu_zhan","text":"是好剑！","tone":"冷酷","chapter":10,"line_start":292,"line_end":292},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"好！我等你。","tone":"陈述","chapter":10,"line_start":294,"line_end":294},{"speaker":"char_chang_wu_yi","speaker_name":"常无意","listener":"char_bu_zhan","text":"等我？","tone":"疑问","chapter":10,"line_start":296,"line_end":296},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"等你睡一觉，等你走。","tone":"陈述","chapter":10,"line_start":298,"line_end":298},{"speaker":"char_chang_wu_yi","speaker_name":"常无意","listener":"char_bu_zhan","text":"你不必等。","tone":"冷酷","chapter":10,"line_start":300,"line_end":300}],"new_entities":{"characters":[{"id":"char_bu_zhan","name":"卜战","alias":["老狼"],"identity":"狼山最老的狼","faction":"无","role":"villain","archetype":"warrior","rank":"登峰造极","one_line":"狼山上最老的一匹狼，使用旱烟袋为武器，武功高强","personality":{"traits":["老练","冷酷","威严","狠辣","高傲"],"speech_style":"冷冷道","temperament":"威严冷酷"},"relationships":[{"target":"char_chang_wu_yi","type":"对手","intensity":90,"bond_level":5,"dynamic":"生死对决"},{"target":"char_tie_san_jiao","type":"宿敌","intensity":80,"bond_level":4,"dynamic":"为铁三角报仇"}],"known_skills":["skill_bu_zhan_de_han_yan_dai"],"related_skills":[],"rag_refs":[10],"source_refs":[{"chapter":10,"line_start":238,"line_end":244,"text":"卜战！狼山上最老的一匹狼！是谁杀了铁三角？"}]},{"id":"char_tie_san_jiao","name":"铁三角","alias":[],"identity":"江湖人","faction":"无","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"已被常无意杀死的江湖人，与卜战有关系","personality":{"traits":["已故","凶狠","残忍","好斗","狂妄"],"speech_style":"无","temperament":"无"},"relationships":[{"target":"char_bu_zhan","type":"宿敌","intensity":80,"bond_level":4,"dynamic":"被杀者与复仇者"}],"known_skills":[],"related_skills":[],"rag_refs":[10],"source_refs":[{"chapter":10,"line_start":244,"line_end":244,"text":"是谁杀了铁三角？"}]}],"skills":[{"id":"skill_bu_zhan_de_han_yan_dai","name":"旱烟袋武功","type":"指法","faction":"无","rank":"登峰造极","one_line":"卜战独创的旱烟袋武功，融合多种重兵器招式","techniques":[{"id":"tech_han_yan_dai_heng_sao","name":"旱烟袋横扫","type":"attack","description":"五尺一寸长、五十一斤重的旱烟袋横扫出去，有长枪大戟的威力"},{"id":"tech_yan_si_an_qi","name":"烟丝暗器","type":"special","description":"燃烧的热烟丝作为暗器打出，比普通暗器更霸道可怕"},{"id":"tech_huo_guang_xuan_mu","name":"火光眩目","type":"debuff","description":"烟斗中闪动的火光可以眩人眼目"}],"progression":[{"level":"登峰造极","description":"已达到武学巅峰"}],"effects":[{"type":"伤害","description":"重击造成巨大伤害"}],"combat_style":"刚猛霸道，以力胜","rag_refs":[10],"source_refs":[{"chapter":10,"line_start":378,"line_end":384,"text":"五尺一寸长、五十一斤重的旱烟袋已横扫出去...那些炽热的烟丝，随时都可能打出来"}]}],"techniques":[{"id":"tech_han_yan_dai_heng_sao","name":"旱烟袋横扫","type":"attack","description":"五尺一寸长、五十一斤重的旱烟袋横扫出去，有长枪大戟的威力，其中居然还夹杂着铁拐、金铁鞭、巨石一类重兵器的招式","source_skill":"skill_bu_zhan_de_han_yan_dai","source_refs":[{"chapter":10,"line_start":378,"line_end":382,"text":"旱烟袋已横扫出去...不但有长枪大戟的威力，其中居然还夹杂着铁拐、金铁鞭、巨石一类重兵器的招式"}]},{"id":"tech_yan_si_an_qi","name":"烟丝暗器","type":"special","description":"燃烧的热烟丝作为暗器打出，比普通暗器都霸道可怕","source_skill":"skill_bu_zhan_de_han_yan_dai","source_refs":[{"chapter":10,"line_start":340,"line_end":346,"text":"我这烟斗里的烟丝，也是杀人的暗器...这种燃烧着的热烟丝，实在比什么暗器都霸道可怕"}]},{"id":"tech_huo_guang_xuan_mu","name":"火光眩目","type":"debuff","description":"烟斗中闪动的火光可以眩人眼目，干扰对手视线","source_skill":"skill_bu_zhan_de_han_yan_dai","source_refs":[{"chapter":10,"line_start":384,"line_end":384,"text":"烟斗中闪动的火光，也可以眩人眼目"}]}],"factions":[],"locations":[],"items":[{"id":"item_han_yan_dai","name":"旱烟袋","type":"weapon","owner":"char_bu_zhan","one_line":"卜战使用的纯钢旱烟袋，重五十一斤","description":"五尺一寸长、五十一斤重的纯钢旱烟袋，比小孩子的手膀子还粗，烟斗可装半斤烟丝，既是兵器也是暗器发射器","effects":["重击伤害","发射燃烧烟丝","火光眩目"],"origin":"纯钢打造","rarity":"稀世珍品","related_characters":["char_bu_zhan"],"related_skills":["skill_bu_zhan_de_han_yan_dai"],"rag_refs":[10],"source_refs":[{"chapter":10,"line_start":226,"line_end":232,"text":"一杆五尺长的旱烟袋，比小孩子的手膀子还粗，无论谁都应该看得出是纯钢打成的"}]}]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":426,"dialogues":[{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"这里不是杀人的地方。","tone":"陈述","chapter":10,"line_start":302,"line_end":302},{"speaker":"char_chang_wu_yi","speaker_name":"常无意","listener":"char_bu_zhan","text":"我现在就可以跟你出去。","tone":"冷酷","chapter":10,"line_start":304,"line_end":304},{"speaker":"char_lan_lan","speaker_name":"蓝兰","listener":"char_xiao_ma","text":"你看他有没有关系？","tone":"疑问","chapter":10,"line_start":310,"line_end":310},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"有关系，有好处。","tone":"陈述","chapter":10,"line_start":314,"line_end":314},{"speaker":"char_xiao_ma","speaker_name":"小马","listener":"char_sheng_yi_ren","text":"有什么好处？","tone":"疑问","chapter":10,"line_start":316,"line_end":316},{"speaker":"char_sheng_yi_ren","speaker_name":"生意人","listener":"char_xiao_ma","text":"他死定了，少了一个人的开销，各位至少可以多喝几杯酒。","tone":"调侃","chapter":10,"line_start":318,"line_end":320},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"我看得出你是个好手。","tone":"陈述","chapter":10,"line_start":336,"line_end":336},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"所以你也应该看得出，我这烟斗里的烟丝，也是杀人的暗器。","tone":"冷酷","chapter":10,"line_start":340,"line_end":342},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"我出手绝不会留情，你也尽管把那些阴毒的剑招使出来。","tone":"冷酷","chapter":10,"line_start":348,"line_end":350},{"speaker":"char_chang_wu_yi","speaker_name":"常无意","listener":"char_bu_zhan","text":"我会使出来的。","tone":"冷酷","chapter":10,"line_start":352,"line_end":352},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"我若也死在你剑下，我那些徒子徒孙们绝不会再来找你们的麻烦。","tone":"陈述","chapter":10,"line_start":354,"line_end":356},{"speaker":"char_chang_wu_yi","speaker_name":"常无意","listener":"char_bu_zhan","text":"很好。","tone":"冷酷","chapter":10,"line_start":358,"line_end":358},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"你就算剥了我的皮，我也绝不怨你。","tone":"冷笑","chapter":10,"line_start":360,"line_end":360},{"speaker":"char_chang_wu_yi","speaker_name":"常无意","listener":"char_bu_zhan","text":"你的皮可以留着！","tone":"嘲讽","chapter":10,"line_start":362,"line_end":362},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"哦？","tone":"疑问","chapter":10,"line_start":364,"line_end":364},{"speaker":"char_chang_wu_yi","speaker_name":"常无意","listener":"char_bu_zhan","text":"因为你的皮并不厚。","tone":"嘲讽","chapter":10,"line_start":366,"line_end":366},{"speaker":"char_bu_zhan","speaker_name":"卜战","listener":"char_chang_wu_yi","text":"很好！","tone":"陈述","chapter":10,"line_start":372,"line_end":372}],"new_entities":{"characters":[],"skills":[{"id":"skill_chang_wu_yi_de_jian_fa","name":"常无意剑法","type":"剑法","faction":"无","rank":"出神入化","one_line":"常无意独创的剑法，柔若游丝，以巧胜以智胜","techniques":[{"id":"tech_jian_guang_quan","name":"剑光圈","type":"defense","description":"笔直的剑变成无数个光圈，可消解敌方攻势"},{"id":"tech_zhi_zhi_si_di_er_hou_sheng","name":"置之死地而后生","type":"feint","description":"先将自己逼入死地再出手，以巧胜以智胜"}],"progression":[{"level":"出神入化","description":"剑法已臻化境"}],"effects":[{"type":"控制","description":"光圈消解敌方攻击"}],"combat_style":"以柔克刚，以巧胜以智胜","rag_refs":[10],"source_refs":[{"chapter":10,"line_start":404,"line_end":424,"text":"他的剑忽然又变得柔若游丝，笔直的剑竟变成了无数个光圈...这一剑并不以势胜，而以巧胜！并不以力胜，而以智胜。"}]}],"techniques":[{"id":"tech_jian_guang_quan","name":"剑光圈","type":"defense","description":"笔直的剑变成无数个光圈，闪动的光圈一圈圈绕上去，可以消解燃烧的烟丝等敌方攻势","source_skill":"skill_chang_wu_yi_de_jian_fa","source_refs":[{"chapter":10,"line_start":404,"line_end":406,"text":"他的剑忽然又变得柔若游丝，笔直的剑竟变成了无数个光圈。闪动的光圈，一圈圈绕上去，火烧的烟丝立刻消失不见。"}]},{"id":"tech_zhi_zhi_si_di_er_hou_sheng","name":"置之死地而后生","type":"feint","description":"先将自己逼入死地再出手，利用对方气势最盛时反击，以巧胜以智胜","source_skill":"skill_chang_wu_yi_de_jian_fa","source_refs":[{"chapter":10,"line_start":412,"line_end":424,"text":"他一定要卜战先将人逼入死地才出手。高手交锋，有时就正如大军对垒，要先置之死地而后生...这一剑并不以势胜，而以巧胜！并不以力胜，而以智胜。"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_chang_wu_yi","updates":{"rank":"出神入化","source_refs":[{"chapter":10,"line_start":420,"line_end":424,"text":"他忽然发现常无意这两年不但多了把好剑，剑法还精进了许多。真正高明的剑招，有时并不在剑上，而在心里。"}]},"relationship_updates":[{"action":"add","target":"char_bu_zhan","type":"对手","intensity":90,"bond_level":5,"dynamic":"生死对决"}]}]}
