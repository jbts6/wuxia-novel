{"segment":1,"line_start":1,"line_end":94,"dialogues":[{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"这……这有什么关系……","tone":"疑问","chapter":77,"line_start":2,"line_end":2},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"傻瓜，我是香神之后自然懂得各种香料，要香还不容易。","tone":"调侃","chapter":77,"line_start":4,"line_end":6},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"未搽香之前，你身上怎会臭的？","tone":"疑问","chapter":77,"line_start":8,"line_end":8},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"女人嘛，有时身上难免有种臭味。","tone":"调侃","chapter":77,"line_start":10,"line_end":10},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"咱们不说香臭的问题，快睡一夜，赶明儿大早起来练先天掌破招要紧。","tone":"陈述","chapter":77,"line_start":14,"line_end":16},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"怎么啦？我身上难道又有臭味了？","tone":"调侃","chapter":77,"line_start":33,"line_end":35},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"没……没有臭味……香……香得很……","tone":"慌张","chapter":77,"line_start":37,"line_end":37},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"香味你也怕吗？","tone":"调侃","chapter":77,"line_start":39,"line_end":39},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"不怕，不怕！","tone":"慌张","chapter":77,"line_start":41,"line_end":41},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"不怕把蒲团搬那么远作什，过来呀！","tone":"调侃","chapter":77,"line_start":43,"line_end":43},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"我……我该练先天掌破招啦……","tone":"无奈","chapter":77,"line_start":45,"line_end":45},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"好啊，这一招练成啦，换练第二招吧。","tone":"欣喜","chapter":77,"line_start":49,"line_end":49},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"真的练成了没问题吗？","tone":"欣喜","chapter":77,"line_start":50,"line_end":50},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"做老师的还骗徒弟吗？我说徒儿你先过来。","tone":"调侃","chapter":77,"line_start":52,"line_end":52},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"过去干吗？","tone":"疑问","chapter":77,"line_start":54,"line_end":54},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"老师教你练第二招啊！","tone":"轻笑","chapter":77,"line_start":56,"line_end":56},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"我自己练。","tone":"陈述","chapter":77,"line_start":58,"line_end":58},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"好，我看你怎么练。","tone":"冷笑","chapter":77,"line_start":60,"line_end":60},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"在这里，过来拿！","tone":"陈述","chapter":77,"line_start":64,"line_end":64},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"你请放在地上。","tone":"无奈","chapter":77,"line_start":66,"line_end":68},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"来拿吧！","tone":"轻笑","chapter":77,"line_start":70,"line_end":70},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"还……还……请你站过一旁……","tone":"犹豫","chapter":77,"line_start":72,"line_end":72},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"怎么，这地方我站不得？","tone":"愤怒","chapter":77,"line_start":74,"line_end":74},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"不！不是……","tone":"慌张","chapter":77,"line_start":76,"line_end":76},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"呆子，你快自己练吧，我不打扰你了。","tone":"大笑","chapter":77,"line_start":90,"line_end":90},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":null,"text":"简直活见鬼？","tone":"惊讶","chapter":77,"line_start":94,"line_end":94}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_rui_wei","updates":{"source_refs":[{"chapter":77,"line_start":2,"line_end":94,"text":"芮玮与白燕相处，学习先天掌破招"}]}},{"id":"char_bai_yan","updates":{"source_refs":[{"chapter":77,"line_start":4,"line_end":90,"text":"白燕以香料吸引芮玮，教授先天掌破招"}]}}]}
{"segment":2,"line_start":95,"line_end":130,"dialogues":[{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"今天你该一试所学了。","tone":"陈述","chapter":77,"line_start":112,"line_end":112},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"那么我去了。","tone":"欣喜","chapter":77,"line_start":114,"line_end":116},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"喂！喂！慌什么，已等了一月多，不忙在一刻呀！","tone":"焦急","chapter":77,"line_start":118,"line_end":120},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"你还有什么吩咐。","tone":"淡然","chapter":77,"line_start":122,"line_end":122},{"speaker":"char_bai_yan","speaker_name":"白燕","listener":"char_rui_wei","text":"我没有吩咐，你去吧，记得事完后……","tone":"悲伤","chapter":77,"line_start":126,"line_end":126},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_bai_yan","text":"我记得，事完我芮玮将来把命卖给你就是。","tone":"无奈","chapter":77,"line_start":128,"line_end":128}],"new_entities":{"characters":[],"skills":[{"id":"skill_xian_tian_zhang_po_zhao","name":"先天掌破招","type":"掌法","faction":"","rank":"登峰造极","one_line":"白燕以两日两夜创出的先天掌一百零八招破解之法","techniques":[{"id":"tech_xian_tian_zhang_po_zhao","name":"先天掌破招","type":"attack","description":"针对先天掌一百零八招逐一设计的破解招式，复杂玄奥处大胜先天掌本身"}],"progression":"已学全一百零八招破招","effects":["破解先天掌"],"combat_style":"以巧破力，料敌先机","rag_refs":[77],"source_refs":[{"chapter":77,"line_start":102,"line_end":108,"text":"一月过去，先天掌一百零八招破招被他学全了。破招复杂玄奥处大胜先天掌。"}]}],"techniques":[{"id":"tech_xian_tian_zhang_po_zhao","name":"先天掌破招","type":"attack","description":"白燕两日两夜创出的先天掌一百零八招破解之法，每一招针对先天掌相应招式的弱点","source_skill":"skill_xian_tian_zhang_po_zhao","source_refs":[{"chapter":77,"line_start":104,"line_end":108,"text":"破招复杂玄奥处大胜先天掌，芮玮佩服的一点，破招白燕两日两夜想成"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_rui_wei","updates":{"known_skills":["skill_xian_tian_zhang_po_zhao"],"source_refs":[{"chapter":77,"line_start":95,"line_end":130,"text":"芮玮学成先天掌破招，前往少华山闯关"}]}},{"id":"char_bai_yan","updates":{"source_refs":[{"chapter":77,"line_start":112,"line_end":130,"text":"白燕让芮玮去闯关，约定事后履行条件"}]}}]}
{"segment":3,"line_start":131,"line_end":251,"dialogues":[{"speaker":"char_lao_yu","speaker_name":"老妪","listener":"char_rui_wei","text":"谁！","tone":"惊讶","chapter":77,"line_start":138,"line_end":140},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_lao_yu","text":"老婆婆咱们又见面了。","tone":"微笑","chapter":77,"line_start":142,"line_end":142},{"speaker":"char_lao_yu","speaker_name":"老妪","listener":"char_rui_wei","text":"很好，这次见面可别麻烦老太婆。","tone":"淡然","chapter":77,"line_start":144,"line_end":144},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_lao_yu","text":"上次多谢老婆婆一臂之助。","tone":"认真","chapter":77,"line_start":146,"line_end":146},{"speaker":"char_lao_yu","speaker_name":"老妪","listener":"char_rui_wei","text":"你专程来道谢的吗？","tone":"疑问","chapter":77,"line_start":148,"line_end":148},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_lao_yu","text":"抱歉，晚辈前来闯关。","tone":"陈述","chapter":77,"line_start":150,"line_end":150},{"speaker":"char_lao_yu","speaker_name":"老妪","listener":"char_rui_wei","text":"你是不是活得不耐烦？","tone":"惊讶","chapter":77,"line_start":152,"line_end":152},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_lao_yu","text":"晚辈有备而来。","tone":"微笑","chapter":77,"line_start":154,"line_end":154},{"speaker":"char_lao_yu","speaker_name":"老妪","listener":"char_rui_wei","text":"最好能见你下山时也带这笑容，不要像上次……","tone":"冷笑","chapter":77,"line_start":156,"line_end":156},{"speaker":"char_lao_yu","speaker_name":"老妪","listener":"char_rui_wei","text":"这一关不用再试了，上吧！","tone":"无奈","chapter":77,"line_start":158,"line_end":160},{"speaker":"char_su_bai","speaker_name":"素白","listener":"char_su_xing","text":"咦，又来了？","tone":"惊讶","chapter":77,"line_start":166,"line_end":167},{"speaker":"char_su_xing","speaker_name":"素行","listener":"char_su_bai","text":"谁啊？","tone":"疑问","chapter":77,"line_start":170,"line_end":170},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_su_bai","text":"小妹妹，是我——芮玮。","tone":"轻笑","chapter":77,"line_start":172,"line_end":172},{"speaker":"char_su_bai","speaker_name":"素白","listener":"char_rui_wei","text":"打不死的施主，谁叫你又乱喊！","tone":"愤怒","chapter":77,"line_start":174,"line_end":174},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_su_bai","text":"这次你要能打死我，尽管打不要客气。","tone":"调侃","chapter":77,"line_start":178,"line_end":178},{"speaker":"char_su_bai","speaker_name":"素白","listener":"char_rui_wei","text":"好啊！","tone":"激动","chapter":77,"line_start":180,"line_end":180},{"speaker":"char_su_yan","speaker_name":"素言","listener":"char_su_bai","text":"师妹，这次让我来教训他。","tone":"冷酷","chapter":77,"line_start":182,"line_end":182},{"speaker":"char_su_xing","speaker_name":"素行","listener":"char_rui_wei","text":"施主，你已不敌，何必再来冒险。","tone":"担心","chapter":77,"line_start":190,"line_end":192},{"speaker":"char_su_bai","speaker_name":"素白","listener":"char_su_xing","text":"师姐不要管他，让他这次吃点苦头，素言师姐狠狠接他几掌，教他知道厉害。","tone":"激动","chapter":77,"line_start":194,"line_end":196},{"speaker":"char_su_bai","speaker_name":"素白","listener":"char_rui_wei","text":"喂，你打不打啊？","tone":"疑问","chapter":77,"line_start":200,"line_end":200},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_su_bai","text":"当然要打，不打你们放我过去吗？","tone":"淡然","chapter":77,"line_start":202,"line_end":202},{"speaker":"char_su_yan","speaker_name":"素言","listener":"char_rui_wei","text":"想过去？做梦！","tone":"冷酷","chapter":77,"line_start":204,"line_end":204},{"speaker":"char_su_xing","speaker_name":"素行","listener":"char_su_yan","text":"师妹打赢就行，不要当真打他。","tone":"焦急","chapter":77,"line_start":206,"line_end":206},{"speaker":"char_su_yan","speaker_name":"素言","listener":"char_su_xing","text":"师姐就关心他，哼，我才不饶他呢！","tone":"冷笑","chapter":77,"line_start":208,"line_end":208},{"speaker":"char_su_xing","speaker_name":"素行","listener":"char_su_yan","text":"你怎么啦？","tone":"焦急","chapter":77,"line_start":222,"line_end":224},{"speaker":"char_su_yan","speaker_name":"素言","listener":"char_su_xing","text":"我……我……败了……","tone":"悲伤","chapter":77,"line_start":226,"line_end":226},{"speaker":"char_su_bai","speaker_name":"素白","listener":"char_su_yan","text":"你败了？","tone":"惊讶","chapter":77,"line_start":228,"line_end":228},{"speaker":"char_su_xing","speaker_name":"素行","listener":"char_su_yan","text":"你中了他两掌？","tone":"惊讶","chapter":77,"line_start":230,"line_end":230},{"speaker":"char_su_bai","speaker_name":"素白","listener":"char_su_yan","text":"中在哪里？","tone":"惊讶","chapter":77,"line_start":234,"line_end":234},{"speaker":"char_su_xing","speaker_name":"素行","listener":"char_su_bai","text":"小师妹，你还没有看到吗？","tone":"陈述","chapter":77,"line_start":236,"line_end":236},{"speaker":"char_su_xing","speaker_name":"素行","listener":"char_rui_wei","text":"施主请过关吧。","tone":"陈述","chapter":77,"line_start":242,"line_end":242},{"speaker":"char_su_bai","speaker_name":"素白","listener":"char_su_xing","text":"师姐，咱们俩人不比就让他过关？","tone":"疑问","chapter":77,"line_start":246,"line_end":246},{"speaker":"char_su_xing","speaker_name":"素行","listener":"char_su_bai","text":"小师妹，你自忖打得过他吗？","tone":"无奈","chapter":77,"line_start":248,"line_end":248}],"new_entities":{"characters":[{"id":"char_su_xing","name":"素行","alias":["雀斑尼姑"],"identity":"慈悲庵第二关守关尼姑","faction":"faction_ci_bei_an","role":"npc","archetype":"monk","rank":"登堂入室","one_line":"慈悲庵三尼之首，雀斑尼姑，心肠最软","personality":{"traits":["善良","心软","温和","稳重","慈悲"],"speech_style":"温和有礼","temperament":"温和"},"relationships":[{"target":"char_su_yan","type":"师姐妹","intensity":70,"bond_level":4,"dynamic":"同门"},{"target":"char_su_bai","type":"师姐妹","intensity":70,"bond_level":4,"dynamic":"同门"}],"known_skills":[],"related_skills":["skill_xian_tian_zhang"],"rag_refs":[77],"source_refs":[{"chapter":77,"line_start":170,"line_end":248,"text":"雀斑尼姑最大法名素行，心肠最软"}]},{"id":"char_su_yan","name":"素言","alias":["少说话的小尼姑"],"identity":"慈悲庵第二关守关尼姑","faction":"faction_ci_bei_an","role":"npc","archetype":"monk","rank":"登堂入室","one_line":"慈悲庵三尼之二，性情古怪，身上有异味","personality":{"traits":["冷傲","好胜","古怪","冷淡","要强"],"speech_style":"冷淡简短","temperament":"冷傲"},"relationships":[{"target":"char_su_xing","type":"师姐妹","intensi