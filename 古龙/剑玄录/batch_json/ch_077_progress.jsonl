{"segment":4,"line_start":252,"line_end":352,"dialogues":[{"speaker":"char_ru_huan","speaker_name":"如幻","listener":"char_rui_wei","text":"施主好功夫，过了两关。","tone":"陈述","chapter":77,"line_start":286,"line_end":286},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_huan","text":"老法师，晚辈芮玮叩见。","tone":"认真","chapter":77,"line_start":298,"line_end":300},{"speaker":"char_ru_huan","speaker_name":"如幻","listener":"char_rui_wei","text":"施主好本领，请进。","tone":"微笑","chapter":77,"line_start":314,"line_end":316},{"speaker":"char_ru_huan","speaker_name":"如幻","listener":"char_rui_wei","text":"老身带你去见敝庵主持如梦法师。","tone":"陈述","chapter":77,"line_start":320,"line_end":322},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_huan","text":"你……你不就是主持？","tone":"惊讶","chapter":77,"line_start":324,"line_end":324},{"speaker":"char_ru_huan","speaker_name":"如幻","listener":"char_rui_wei","text":"老身怎敢以主持自居，未出家前我是如梦法师的婢女，出家后主人赐我自由身，诫名如幻。","tone":"陈述","chapter":77,"line_start":326,"line_end":328},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_huan","text":"我三关已过，可不可以不见贵主持？","tone":"疑问","chapter":77,"line_start":332,"line_end":332},{"speaker":"char_ru_huan","speaker_name":"如幻","listener":"char_rui_wei","text":"你只过了两关，怎说三关已过？","tone":"疑问","chapter":77,"line_start":334,"line_end":334},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_huan","text":"刚才庵门前相试，难道不算一关？","tone":"疑问","chapter":77,"line_start":336,"line_end":336},{"speaker":"char_ru_huan","speaker_name":"如幻","listener":"char_rui_wei","text":"不算，不算，我只不敢受你大礼，岂算一关，第三关主持如梦法师亲自相试，你要过关快见主持为是。","tone":"大笑","chapter":77,"line_start":338,"line_end":340},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_huan","text":"亲自相试？","tone":"恐惧","chapter":77,"line_start":342,"line_end":342},{"speaker":"char_ru_huan","speaker_name":"如幻","listener":"char_rui_wei","text":"本庵主持已知你来，不用再通报，请进。","tone":"陈述","chapter":77,"line_start":352,"line_end":352}],"new_entities":{"characters":[{"id":"char_ru_huan","name":"如幻","alias":["灰眉老尼"],"identity":"慈悲庵尼姑，如梦法师前婢女","faction":"faction_ci_bei_an","role":"npc","archetype":"monk","rank":"返璞归真","one_line":"慈悲庵老尼，如梦法师出家前的婢女，内功精湛","personality":{"traits":["慈祥","谦逊","温和","恭敬","稳重"],"speech_style":"谦恭有礼","temperament":"温和"},"relationships":[{"target":"char_ru_meng","type":"主仆","intensity":80,"bond_level":4,"dynamic":"旧主与前婢"}],"known_skills":[],"related_skills":["skill_xian_tian_zhang"],"rag_refs":[77],"source_refs":[{"chapter":77,"line_start":274,"line_end":352,"text":"灰眉老尼，未出家前是如梦法师的婢女，诫名如幻"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_rui_wei","updates":{"source_refs":[{"chapter":77,"line_start":252,"line_end":352,"text":"芮玮进入慈悲庵，遇如幻引路"}]}}]}
{"segment":5,"line_start":353,"line_end":446,"dialogues":[{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"起来。","tone":"冷酷","chapter":77,"line_start":360,"line_end":360},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"你要见的是何人？","tone":"陈述","chapter":77,"line_start":366,"line_end":366},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"素心。","tone":"颤声","chapter":77,"line_start":368,"line_end":368},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"我知道了，你请回吧。","tone":"淡然","chapter":77,"line_start":368,"line_end":368},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"晚辈欲要当面一见。","tone":"认真","chapter":77,"line_start":372,"line_end":372},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"你知不知道，想亲自一见定需过第三关？","tone":"冷酷","chapter":77,"line_start":374,"line_end":374},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"晚辈知道，请老法师赐教。","tone":"认真","chapter":77,"line_start":376,"line_end":376},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"这第三关从无人试过，你既敢试，定有所恃的了？","tone":"愤怒","chapter":77,"line_start":378,"line_end":380},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"晚辈斗胆，不过冀图侥幸。","tone":"恐惧","chapter":77,"line_start":382,"line_end":382},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"侥幸？天下哪有侥幸的事，你说到底要和我比什么？","tone":"冷酷","chapter":77,"line_start":384,"line_end":386},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"我想向老法师讨教掌法。","tone":"陈述","chapter":77,"line_start":388,"line_end":390},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"好，咱们以十招定输赢。","tone":"冷笑","chapter":77,"line_start":392,"line_end":392},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"风闻慈悲庵先天掌为天下掌法之最，晚辈想，要讨教就讨教这套掌法，好教晚辈一长眼界。","tone":"陈述","chapter":77,"line_start":394,"line_end":396},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"你年纪青青竟知道这套古老的掌法，也好，你要见识让你见识一番，话说明白，你既指定这套掌法，三招接不下来，什么也不用准备再问，赶快请走！","tone":"冷酷","chapter":77,"line_start":398,"line_end":400},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"倘若三招接下了呢？","tone":"严肃","chapter":77,"line_start":402,"line_end":402},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"能接三招就算你胜。","tone":"得意","chapter":77,"line_start":404,"line_end":404},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"老法师，有礼了！","tone":"认真","chapter":77,"line_start":406,"line_end":408},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"好掌法。","tone":"欣喜","chapter":77,"line_start":410,"line_end":410},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_ru_meng","text":"现在晚辈是否可以亲自见素心？","tone":"欣喜","chapter":77,"line_start":442,"line_end":442},{"speaker":"char_ru_meng","speaker_name":"如梦","listener":"char_rui_wei","text":"你既能过第三关，当然可以。","tone":"淡然","chapter":77,"line_start":444,"line_end":446}],"new_entities":{"characters":[{"id":"char_ru_meng","name":"如梦","alias":["如梦法师"],"identity":"慈悲庵主持","faction":"faction_ci_bei_an","role":"npc","archetype":"monk","rank":"返璞归真","one_line":"慈悲庵主持，内功已至无我神藏之境，先天掌造诣极高","personality":{"traits":["冷峻","威严","自负","高深莫测","严厉"],"speech_style":"冷峻威严","temperament":"冷峻"},"relationships":[{"target":"char_ru_huan","type":"主仆","intensity":70,"bond_level":3,"dynamic":"旧主"},{"target":"char_su_xin","type":"师徒","intensity":80,"bond_level":4,"dynamic":"师徒"}],"known_skills":[],"related_skills":["skill_xian_tian_zhang"],"rag_refs":[77],"source_refs":[{"chapter":77,"line_start":356,"line_end":446,"text":"慈悲庵主持如梦法师，内功真正已练至无我神藏的地步"}]},{"id":"char_su_xin","name":"素心","alias":["野儿"],"identity":"慈悲庵尼姑","faction":"faction_ci_bei_an","role":"npc","archetype":"monk","rank":"略有小成","one_line":"芮玮苦苦寻找之人，身在慈悲庵",