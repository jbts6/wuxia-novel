    {
      "speaker": "char_hui_yi_lao_zhe",
      "speaker_name": "灰衣老者",
      "listener": "char_rui_wei",
      "text": "没用！没用！你纵然内功精湛，不说话，但只要一运气，立即昏倒，你可晓得那是何等厉害的药物？",
      "tone": "得意",
      "chapter": 14,
      "line_start": 333,
      "line_end": 335
    },
    {
      "speaker": "char_gao_mo_ye",
      "speaker_name": "高莫野",
      "listener": "char_rui_wei",
      "text": "大哥，你没事吧……大哥……",
