      "chapter": 18,
      "line_start": 144,
      "line_end": 144
    },
    {
      "speaker": "char_a_luo_yi_duo",
      "speaker_name": "红袍僧人",
      "listener": "char_shi_bu_jiu",
      "text": "施主要什么就有什么。",
      "tone": "欣喜",
      "chapter": 18,
      "line_start": 146,
      "line_end": 146
    },
    {
      "speaker": "char_shi_bu_jiu",
      "speaker_name": "史不旧",
      "listener": null,
      "text": "金银财宝史某视若粪土，你们还有何物能报我？",
      "tone": "嘲讽",
