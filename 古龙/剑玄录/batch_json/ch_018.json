    },
    {
      "speaker": "char_a_luo_yi_duo",
      "speaker_name": "红袍僧人",
      "listener": "char_shi_bu_jiu",
      "text": "施主救他一次，尔后必有厚报。",
      "tone": "恳求",
      "chapter": 18,
      "line_start": 140,
      "line_end": 142
    },
    {
