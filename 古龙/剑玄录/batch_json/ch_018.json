      "line_start": 128,
      "line_end": 130
    },
    {
      "speaker": "char_a_luo_yi_duo",
      "speaker_name": "红袍僧人",
      "listener": "char_shi_bu_jiu",
      "text": "此人施主一定要救。",
      "tone": "恳求",
      "chapter": 18,
      "line_start": 134,
      "line_end": 134
    },
    {
      "speaker": "char_shi_bu_jiu",
      "speaker_name": "史不旧",
      "listener": null,
      "text": "不救就是不救，纵然他是当今圣上我也不救。",
      "tone": "冷酷",
