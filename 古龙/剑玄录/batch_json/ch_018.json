      "line_start": 148,
      "line_end": 150
    },
    {
      "speaker": "char_a_luo_yi_duo",
      "speaker_name": "红袍僧人",
      "listener": "char_shi_bu_jiu",
      "text": "闻说施主嗜武，常道能在武功上胜过你，便施救病人，老纳有本武学秘本愿赠送施主。",
      "tone": "陈述",
      "chapter": 18,
      "line_start": 152,
      "line_end": 154
    },
    {
      "speaker": "char_shi_bu_jiu",
      "speaker_name": "史不旧",
      "listener": null,
      "text": "这样说来，你自信在武功上胜我？",
      "tone": "冷笑",
