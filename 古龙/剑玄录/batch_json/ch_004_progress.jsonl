{"segment":5,"line_start":401,"line_end":497,"dialogues":[{"speaker":"char_dong_hua","speaker_name":"冬画","listener":"char_xia_shi","text":"夏姐，公子为什么要把秋姐杀死呀？","tone":"悲伤","chapter":4,"line_start":414,"line_end":415},{"speaker":"char_xia_shi","speaker_name":"夏诗","listener":"char_dong_hua","text":"别尽问，我也不知道。","tone":"无奈","chapter":4,"line_start":418,"line_end":418},{"speaker":"char_dong_hua","speaker_name":"冬画","listener":"char_xia_shi","text":"那秋姐到底是不是公子害死的。","tone":"疑问","chapter":4,"line_start":420,"line_end":420},{"speaker":"char_xia_shi","speaker_name":"夏诗","listener":"char_dong_hua","text":"我不清楚，你别瞎说小心撞祸。","tone":"担心","chapter":4,"line_start":422,"line_end":422},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":"char_rui_wei","text":"没练完，妈这几天教我和二哥二套新武功，我练得气闷不过，偷跑出来。","tone":"陈述","chapter":4,"line_start":449,"line_end":450},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_jian_huai_xuan","text":"是什么武功呀？","tone":"好奇","chapter":4,"line_start":453,"line_end":453},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":"char_rui_wei","text":"妈说大哥早就会了，叫做'天罗掌'。","tone":"陈述","chapter":4,"line_start":455,"line_end":455},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":"char_rui_wei","text":"妈说再过几天，黑堡有人来我们这里偷东西，只有这套掌法管用，大哥，这套掌法能不能打得过他们呀！","tone":"疑问","chapter":4,"line_start":459,"line_end":460},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":"char_rui_wei","text":"大哥，你怎么又瘦了！","tone":"担心","chapter":4,"line_start":465,"line_end":465},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_jian_huai_xuan","text":"哪里瘦了！","tone":"陈述","chapter":4,"line_start":467,"line_end":467},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":"char_rui_wei","text":"我刚才到大哥未婚妻那里，说你瘦了，她也不信！","tone":"陈述","chapter":4,"line_start":469,"line_end":469},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":"char_rui_wei","text":"大哥，你去看看她嘛！","tone":"恳求","chapter":4,"line_start":473,"line_end":473},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":"char_rui_wei","text":"我们一起去看她！","tone":"激动","chapter":4,"line_start":475,"line_end":476},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":null,"text":"刘姐姐！刘姐姐！","tone":"激动","chapter":4,"line_start":485,"line_end":485},{"speaker":"char_liu_yu_zhi","speaker_name":"刘育芷","listener":null,"text":"谁呀？","tone":"疑问","chapter":4,"line_start":487,"line_end":487},{"speaker":"char_jian_huai_xuan","speaker_name":"简怀萱","listener":"char_liu_yu_zhi","text":"你出来呀，有人要见你！","tone":"调侃","chapter":4,"line_start":491,"line_end":491},{"speaker":"char_rui_wei","speaker_name":"芮玮","listener":"char_xun_shi_nv","text":"驯狮女！","tone":"惊讶","chapter":4,"line_start":497,"line_end":497}],"new_entities":{"characters":[{"id":"char_liu_yu_zhi","name":"刘育芷","alias":[],"identity":"简召舞的未婚妻，即驯狮女","faction":null,"role":"companion","archetype":"warrior","rank":"出神入化","one_line":"简召舞的未婚妻，黑衣丽人，实为驯狮女","personality":{"traits":["温柔","娴静","神秘","善良","内敛"],"speech_style":"低声细语","temperament":"沉静"},"relationships":[{"target":"char_rui_wei","type":"恋人","intensity":50,"bond_level":3,"dynamic":"误认假公子为真未婚夫"}],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":495,"line_end":497,"text":"面前站着一位黑衣丽人，好熟的面孔！他不禁失声呼道：驯狮女！"}]}],"skills":[{"id":"skill_tian_luo_zhang","name":"天罗掌","type":"掌法","faction":"天池府","rank":"出神入化","one_line":"简老夫人教给简怀萱和二哥的掌法，据说能对付黑堡来犯","techniques":[{"id":"tech_tian_luo_zhang","name":"天罗掌","type":"attack","description":"天池府秘传掌法，据说能克制黑堡武学"}],"progression":"简老夫人传授","effects":["克制黑堡武学"],"combat_style":"以柔克刚","rag_refs":[4],"source_refs":[{"chapter":4,"line_start":455,"line_end":460,"text":"妈说大哥早就会了，叫做天罗掌"}]}],"techniques":[],"factions":[{"id":"faction_hei_bao","name":"黑堡","type":"帮派","location":null,"sub_divisions":[],"one_line":"武林中令人闻名丧胆的势力，计划侵犯天池府","source_refs":[{"chapter":4,"line_start":235,"line_end":239,"text":"黑堡出来的人的武艺，他是晓得的"}]}],"locations":[],"items":[]},"entity_updates":[{"id":"ch