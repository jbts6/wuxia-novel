    {
      "id": "char_hai_ling_zi",
      "updates": {
        "source_refs": [
          {
            "chapter": 4,
            "line_start": 244,
            "line_end": 244,
            "text": "好说，好说。"
          },
          {
            "chapter": 4,
            "line_start": 316,
            "line_end": 318,
            "text": "我用不着练什么鹰爪力。"
