_hui_feng_fu_liu","name":"回风拂柳","type":"attack","description":"崔仲宇第二招绝学","source_skill":"skill_shen_jian_wu_di_san_zhao","source_refs":[{"chapter":8,"line_start":122,"line_end":122,"text":"回风拂柳"}]},{"id":"tech_hua_yu_chun_feng","name":"化雨春风","type":"attack","description":"崔仲宇第三招绝学","source_skill":"skill_shen_jian_wu_di_san_zhao","source_refs":[{"chapter":8,"line_start":122,"line_end":122,"text":"化雨春风"}]}],"factions":[{"id":"faction_han_shan_si","name":"憨山寺","type":"武林门派","location":"","sub_divisions":[],"one_line":"武林中的佛门寺院，曾赠药给毒儒钱守孔导致杀孽","source_refs":[{"chapter":8,"line_start":46,"line_end":46,"text":"憨山寺"}]}],"locations":[],"items":[{"id":"item_wan_nian_xu_duan","name":"万年续断","type":"pill","owner":null,"one_line":"憨山寺秘制的救伤圣品","description":"武从中绝无仅有的救伤圣品，有化腐生肌之功，能治愈极重伤势","effects":[{"type":"增益","description":"化腐生肌，治愈重伤"}],"origin":"憨山寺秘制","rarity":"稀世珍品","related_characters":["char_du_ru_qian_shou_kong"],"related_skills":[],"rag_refs":[8],"source_refs":[{"chapter":8,"line_start":42,"line_end":42,"text":"万年续断是武从中绝无仅有的救伤圣品"}]},{"id":"item_da_tie_gui","name":"大铁龟","type":"special","owner":"char_gan_shou_lao_ren","one_line":"重逾千斤的大铁龟","description":"重逾千斤的大铁龟，龟背上插着三支宝剑，是干瘦老人的象征","effects":[],"origin":"","rarity":"上乘佳品","related_characters":["char_gan_shou_lao_ren"],"related_skills":[],"rag_refs":[8],"source_refs":[{"chapter":8,"line_start":120,"line_end":120,"text":"那只重逾千斤的大铁龟"}]},{"id":"item_jie_dao","name":"戒刀","type":"weapon","owner":null,"one_line":"僧人使用的刀具","description":"寒光闪闪的戒刀，被用于执行自断臂膀的惩罚","effects":[],"origin":"憨山寺","rarity":"寻常凡品","related_characters":["char_miao_chen","char_wu_ai_he_shang"],"related_skills":[],"rag_refs":[8],"source_refs":[{"chapter":8,"line_start":168,"line_end":168,"text":"从怀中摸出一柄寒光闪闪的戒刀"}]}]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":"沉声","listener":null,"text":"无碍和尚看出王一萍身怀武功，可是并不知道对方深浅如何。  他出手快捷，差一点的人真还不易躲过。王一萍手肘一斜，撞开无碍和尚点来的两指，闪电般点中他的软穴。  无碍和尚四肢瘫软，口不能言，眼睁睁看着王一萍微微一笑过后，翻窗而出，无法阻止，心中极为着急。  王一萍一连越过几重屋宇，来到后殿，遥遥即可看见殿中灯火通明，白天所见的干瘦老人早已盘膝坐在那张虎皮上。  在他旁边，搁着一张病榻，病榻上坐着一个满脸病容，赢弱至极的老僧。  在干瘦老人面前七尺之处，搁着那只重逾千斤的大铁龟，龟背上仍然插着三支宝剑。  这时，那塾师装扮的男子坐在一张太师椅中，闭着眼，一颗毛发蓬松的大脑袋晃个不停，突然双目一瞪，大声向站在他面前的一个老僧问道：","tone":"沉声","chapter":8,"line_start":108,"line_end":122},{"speaker":null,"speaker_name":"宽慰地","listener":null,"text":"师兄，这三招是小寒离垢老人最得意的三招绝学，自然不是轻易化解得开的。","tone":"陈述","chapter":8,"line_start":140,"line_end":142},{"speaker":null,"speaker_name":"问","listener":null,"text":"你是决意如此了！","tone":"陈述","chapter":8,"line_start":150,"line_end":150},{"speaker":null,"speaker_name":"喃喃地","listener":null,"text":"记得你昔日拒绝我时，我在绝望之余，仍然抱着万一之想地问了一句，正是你如今问我的这句话，一字不差，你总该记得你当时是怎么答复我的。","tone":"陈述","chapter":8,"line_start":152,"line_end":154},{"speaker":null,"speaker_name":"微叹","listener":null,"text":"老衲自然记得。","tone":"无奈","chapter":8,"line_start":156,"line_end":156},{"speaker":null,"speaker_name":"截然","listener":null,"text":"那么你们还挨个什么劲，老夫不为已甚，你们各人且自断一臂。","tone":"无奈","chapter":8,"line_start":158,"line_end":160},{"speaker":null,"speaker_name":"尖声嚷","listener":null,"text":"不对，不对，还短出一只！","tone":"焦急","chapter":8,"line_start":186,"line_end":188},{"speaker":null,"speaker_name":null,"listener":null,"text":"不错，我派无碍去到前面客房照顾一位施主，你尽可放心，无碍决不会吝惜他一条胳膊。  再说老衲决不容他自全躯壳，失信施主而毁去憨山寺信誉。","tone":"陈述","chapter":8,"line_start":192,"line_end":196},{"speaker":null,"speaker_name":null,"listener":null,"text":"我相信你就是。","tone":"陈述","chapter":8,"line_start":198,"line_end":198},{"speaker":"char_shu_shi_zhuang_ban_de_nan_zi","speaker_name":"塾师装扮的男子","listener":null,"text":"师父，俗语说得好，亲兄弟，明算账。  何况咱们跟这些和尚还有过一桩宿怨。咱们可不是怕他抵赖，相信他们也不敢抵赖，可是在我这本流水账上，总应该有个交代吧。  师父，您老人家说对是不对？","tone":"陈述","chapter":8,"line_start":200,"line_end":204}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_gan_shou_lao_ren","speaker_name":"干瘦老人","listener":null,"text":"该怎么样你瞧着办吧！","tone":"陈述","chapter":8,"line_start":206,"line_end":206},{"speaker":"char_gan_shou_lao_ren","speaker_name":"干瘦老人","listener":null,"text":"憨山寺共欠人臂三十六条，实收三十五，尚欠一条。","tone":"陈述","chapter":8,"line_start":208,"line_end":210},{"speaker":null,"speaker_name":null,"listener":null,"text":"咱们走！","tone":"陈述","chapter":8,"line_start":212,"line_end":214},{"speaker":"char_wang_yi_ping","speaker_name":"王一萍","listener":null,"text":"看来他跟憨山寺的事情暂时已了，我何不暗中跟去。","tone":"陈述","chapter":8,"line_start":218,"line_end":220},{"speaker":"char_shuai_bing_lao_seng","speaker_name":"衰病老僧","listener":null,"text":"你等休得无理，让位施主进来。","tone":"陈述","chapter":8,"line_start":260,"line_end":262},{"speaker":null,"speaker_name":"病僧在榻上微一欠身","listener":null,"text":"恕老衲重病在身，不便下榻相迎。  施主深夜光临，决非无因，不知可否将来意见告？","tone":"陈述","chapter":8,"line_start":270,"line_end":272},{"speaker":null,"speaker_name":"也肃容","listener":null,"text":"王一萍此来并无恶意。","tone":"陈述","chapter":8,"line_start":274,"line_end":276},{"speaker":null,"speaker_name":"不禁凄然笑","listener":null,"text":"师兄，你尽可从从容容地来拿这柄戒刀，你以为我还会阻止你么？","tone":"苦笑","chapter":8,"line_start":282,"line_end":284},{"speaker":"char_wang_yi_ping","speaker_name":"王一萍","listener":null,"text":"这位大师可否待在下将话说完之后，再决定是否自断右臂？","tone":"苦笑","chapter":8,"line_start":290,"line_end":292},{"speaker":"char_shuai_bing_lao_seng","speaker_name":"衰病老僧","listener":null,"text":"无碍暂且听这位施主说完。","tone":"陈述","chapter":8,"line_start":294,"line_end":294},{"speaker":"char_wang_yi_ping","speaker_name":"王一萍","listener":null,"text":"我已知道贵寺自愿断去右臂，一来是因昔年曾许下诺言，二来也是因为无法破解对方所说招式。","tone":"陈述","chapter":8,"line_start":296,"line_end":298},{"speaker":"char_shuai_bing_lao_seng","speaker_name":"衰病老僧","listener":null,"text":"不错！","tone":"陈述","chapter":8,"line_start":300,"line_end":300}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":"char_wang_yi_ping","speaker_name":"王一萍","listener":null,"text":"如果我有破解之策，又当如何？","tone":"陈述","chapter":8,"line_start":302,"line_end":302},{"speaker":"char_wang_yi_ping","speaker_name":"王一萍","listener":null,"text":"施主大约还不知道那名老人乃是昔年名震寰宇的神剑无敌崔仲宇，武林中公认他剑法举世无双。","tone":"陈述","chapter":8,"line_start":304,"line_end":306},{"speaker":null,"speaker_name":"说","listener":null,"text":"难道他比──","tone":"陈述","chapter":8,"line_start":308,"line_end":308},{"speaker":null,"speaker_name":"说","listener":null,"text":"他比湘江一龙又当如何","tone":"陈述","chapter":8,"line_start":310,"line_end":310},{"speaker":null,"speaker_name":"","listener":null,"text":"他比阴山四煞又当如何？","tone":"陈述","chapter":8,"line_start":318,"line_end":320},{"speaker":null,"speaker_name":"但他立即恢复平静","listener":null,"text":"不错，阴山四煞中排行单数的两位全都使剑。  不过他们专擅的是联手合斗的剑阵，若论本身的造诣，只怕仍难与神剑无敌崔仲宇相提并论。","tone":"陈述","chapter":8,"line_start":324,"line_end":328},{"speaker":"char_shuai_bing_lao_seng","speaker_name":"衰病老僧","listener":null,"text":"恕小可再斗胆借问一句，何以贵寺上下，均愿自行断去一臂，而毫无畏缩之意？","tone":"陈述","chapter":8,"line_start":338,"line_end":340},{"speaker":null,"speaker_name":"因此争","listener":null,"text":"这是敝寺私事，何劳施主过问。","tone":"陈述","chapter":8,"line_start":344,"line_end":346},{"speaker":null,"speaker_name":"缓声说","listener":null,"text":"无碍休得无礼，这位施主全是一番好意。  老衲业已看出施主年纪虽轻，但一身武学不俗。不过……不过……无碍适才说得不错，这事与施主毫无关系，何必定要趟这趟浑水？","tone":"陈述","chapter":8,"line_start":348,"line_end":352},{"speaker":null,"speaker_name":"","listener":null,"text":"老禅师请勿误会，并非王一萍定要干预旁人的私事，而是觉得干瘦老头此举实在太过。  我已知道禅师们所以甘愿忍受自断臂膀之痛，完全是因为无法破解他这自以为神妙无比的三招，同时昔年你们也曾答应过他，只要他能活着回来，决定答应他所提出的任何要求。","tone":"陈述","chapter":8,"line_start":356,"line_end":360},{"speaker":null,"speaker_name":"点点头","listener":null,"text":"不错，确有其事。  而且妙尘已实践了昔年的诺言，施主不信可以察看。","tone":"陈述","chapter":8,"line_start":362,"line_end":364},{"speaker":null,"speaker_name":"点点头","listener":null,"text":"事情发生时，我在殿外偷看。","tone":"陈述","chapter":8,"line_start":366,"line_end":368},{"speaker":null,"speaker_name":null,"listener":null,"text":"老禅师当然已知在下此行来意？","tone":"陈述","chapter":8,"line_start":374,"line_end":376},{"speaker":"char_miao_chen","speaker_name":"妙尘","listener":null,"text":"你等且先下去，自行裹治臂伤。  大师兄和无碍留下。","tone":"陈述","chapter":8,"line_start":378,"line_end":380},{"speaker":null,"speaker_name":null,"listener":null,"text":"施主自问确有把握破得了神剑无敌的三招？","tone":"陈述","chapter":8,"line_start":384,"line_end":386},{"speaker":null,"speaker_name":"立","listener":null,"text":"由云龙三现急转为龙飞九天，正好可破神剑无敌的三个招式。","tone":"陈述","chapter":8,"line_start":392,"line_end":394},{"speaker":"char_wu_ai","speaker_name":"无碍","listener":null,"text":"师父──","tone":"陈述","chapter":8,"line_start":396,"line_end":396},{"speaker":null,"speaker_name":"凝重地","listener":null,"text":"这事关系重大，老衲需慎重考虑。","tone":"陈述","chapter":8,"line_start":398,"line_end":400}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":401,"line_end":425,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"无碍，这位施主适才所说的招式你记清了没有？","tone":"陈述","chapter":8,"line_start":406,"line_end":408},{"speaker":"char_wu_ai","speaker_name":"无碍","listener":null,"text":"师父的意思是要弟子──","tone":"陈述","chapter":8,"line_start":410,"line_end":410},{"speaker":"char_miao_chen","speaker_name":"妙尘","listener":null,"text":"无碍，你要明白！老衲要你这样做，其意并非为你保存一条手臂，而是……而是……","tone":"陈述","chapter":8,"line_start":412,"line_end":412},{"speaker":null,"speaker_name":"大声","listener":null,"text":"启禀掌门，老衲觉得这事还未到公诸于世的时候，掌门但可强命无碍如何去做，而不必向他解释。","tone":"陈述","chapter":8,"line_start":414,"line_end":416},{"speaker":"char_miao_chen","speaker_name":"妙尘","listener":null,"text":"也好，其中因缘牵连极多，一时也说不明白。  无碍，你送这位施主回去。无论是神剑无敌亲自前来，或是差人前来，你就照施主适才所说的话回复便了。","tone":"陈述","chapter":8,"line_start":418,"line_end":422}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}