{"segment":1,"line_start":1,"line_end":108,"dialogues":[{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"这里冷得真邪气……","tone":"无奈","chapter":15,"line_start":10,"line_end":10},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你既不喝酒，又不站起来走动走动，就这样坐着，不怕被冷死?","tone":"陈述","chapter":15,"line_start":12,"line_end":12},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"冷不死我的。","tone":"微笑","chapter":15,"line_start":14,"line_end":14},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"普天之下，又有谁能瞧得出你也会为朋友挨饿受冻?","tone":"无奈","chapter":15,"line_start":20,"line_end":20},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"我只做我愿意做的事，别人对我是如何看法，与我又有何关系?","tone":"淡然","chapter":15,"line_start":22,"line_end":22},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"小胡呢?","tone":"陈述","chapter":15,"line_start":26,"line_end":26},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"进洞房了。","tone":"陈述","chapter":15,"line_start":28,"line_end":28},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"抬进去的?","tone":"陈述","chapter":15,"line_start":30,"line_end":30},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"活像只烤骆驼一样，只差没在肚子里塞只羊。","tone":"微笑","chapter":15,"line_start":32,"line_end":32},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"外面可有动静?","tone":"陈述","chapter":15,"line_start":38,"line_end":38},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"你什么时候也会动义气了?这倒难得。","tone":"微笑","chapter":15,"line_start":44,"line_end":44},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"你以为我是死人?","tone":"陈述","chapter":15,"line_start":46,"line_end":46},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"无论如何，这人总是我的，你们不能和他交手。","tone":"陈述","chapter":15,"line_start":48,"line_end":48},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你难道怕我被他宰了?","tone":"微笑","chapter":15,"line_start":50,"line_end":50},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"哼!","tone":"陈述","chapter":15,"line_start":56,"line_end":56},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"蛋呢?","tone":"疑问","chapter":15,"line_start":58,"line_end":58},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"骆驼肚子里是只羊，羊肚子里是只鸡，鸡肚子里才是这蛋，蛋白里才是蛋黄，他居然将毒下到蛋黄里来了，真厉害!","tone":"无奈","chapter":15,"line_start":68,"line_end":68},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"他将毒下到这种地方，都被你发觉，你岂非比他更厉害!","tone":"微笑","chapter":15,"line_start":70,"line_end":70},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"这蛋是龟兹王亲自挑起给你的，是么?","tone":"陈述","chapter":15,"line_start":72,"line_end":72},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"不错。","tone":"陈述","chapter":15,"line_start":74,"line_end":74},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"除了他自己之外，事前只怕谁也不知道他要将这蛋给什么人，下毒的……难道就是龟兹王?","tone":"陈述","chapter":15,"line_start":76,"line_end":76},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"若是龟兹王自己下的毒，他挑蛋时何必用银刀?","tone":"陈述","chapter":15,"line_start":78,"line_end":78},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"若论在蛋里下毒的机会，只有厨子比较多。","tone":"陈述","chapter":15,"line_start":80,"line_end":80},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"不是那厨子。","tone":"陈述","chapter":15,"line_start":82,"line_end":82},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你已去问过?","tone":"陈述","chapter":15,"line_start":84,"line_end":84},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"嗯!","tone":"陈述","chapter":15,"line_start":86,"line_end":86},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你怎知道他未说谎?","tone":"陈述","chapter":15,"line_start":88,"line_end":88},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"我知道。","tone":"陈述","chapter":15,"line_start":90,"line_end":90},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你想这人会是谁?","tone":"陈述","chapter":15,"line_start":100,"line_end":100},{"speaker":"char_ji_bing_yan","speaker_name":"姬冰雁","listener":null,"text":"你……","tone":"陈述","chapter":15,"line_start":106,"line_end":106},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你守过上半夜，下半夜自然要轮到我了。","tone":"陈述","chapter":15,"line_start":108,"line_end":108}],"new_entities":{"characters":[{"id":"char_chu_liu_xiang","name":"楚留香","alias":[],"identity":"盗帅","faction":"龟兹国","role":"protagonist","archetype":"assassin","rank":"登堂入室","one_line":"楚留香，盗帅","personality":{"traits":["武功高强","智勇双全","重情重义","机智过人","胆大心细"],"speech_style":"沉稳","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":10,"line_end":108,"text":"楚留香已走过来，仰视着苍穹，叹道：\"这里冷得真邪气……\""}]},{"id":"char_ji_bing_yan","name":"姬冰雁","alias":[],"identity":"富商","faction":"龟兹国","role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"姬冰雁，富商","personality":{"traits":["武功高强","智勇双全","重情重义","机智过人","胆大心细"],"speech_style":"沉稳","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":4,"line_end":106,"text":"姬冰雁身上裹着条毯子，坐在水池旁的树影下，望着满天星群渐渐繁密，又渐渐稀落。"}]},{"id":"char_gui_zi_wang","name":"龟兹王","alias":[],"identity":"龟兹国国王","faction":"龟兹国","role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"龟兹王，龟兹国国王","personality":{"traits":["武功高强","智勇双全","重情重义","机智过人","胆大心细"],"speech_style":"沉稳","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":72,"line_end":96,"text":"他脸色忽又阴沉下来，道：\"这蛋是龟兹王亲自挑起给你的，是么?\""}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_yin_dao","name":"银刀","type":"weapon","owner":null,"one_line":"银刀","description":"一把小银刀，用于检验毒物，刀尖插入蛋中会发黑显示毒性","effects":["检验毒性","御寒"],"origin":"未知","rarity":"寻常凡品","related_characters":[],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":60,"line_end":78,"text":"楚留香甩了甩袖子，蛋就到了他手心，被冷风一吹，立刻就冻得像石头似的，楚留香道：\"那银刀已插入这蛋里半"}]},{"id":"item_du_zhen","name":"毒针","type":"poison","owner":null,"one_line":"毒针","description":"一根须丝般的小针，藏在蛋黄中，含有剧毒","effects":["检验毒性","御寒"],"origin":"未知","rarity":"寻常凡品","related_characters":[],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":96,"line_end":96,"text":"过了半晌，姬冰雁又道：\"要在这蛋里下毒，也不一定厨子才有机会，任何人都可以趁人不备，将毒针射进蛋里去"}]}]},"entity_updates":[]}
{"segment":2,"line_start":109,"line_end":230,"dialogues":[{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"谁?","tone":"陈述","chapter":15,"line_start":136,"line_end":136},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"噗哧","tone":"陈述","chapter":15,"line_start":138,"line_end":138},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"新娘子","tone":"陈述","chapter":15,"line_start":140,"line_end":140},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你来这里干什么?","tone":"陈述","chapter":15,"line_start":142,"line_end":142},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你能来这里，为何我就不能来子","tone":"微笑","chapter":15,"line_start":144,"line_end":144},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"这里不是你该来的地方!","tone":"陈述","chapter":15,"line_start":146,"line_end":146},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"为什么?","tone":"陈述","chapter":15,"line_start":148,"line_end":148},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你若不立刻回到洞房去，我就……","tone":"陈述","chapter":15,"line_start":150,"line_end":150},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你……你要我到……到洞房去干什么?","tone":"微笑","chapter":15,"line_start":154,"line_end":154},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"到洞房去自然是……自然是……","tone":"陈述","chapter":15,"line_start":156,"line_end":156},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"说呀，自然是去干什么?","tone":"微笑","chapter":15,"line_start":158,"line_end":158},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"我若真的到洞房去，不被新娘子打出来才怪哩!","tone":"陈述","chapter":15,"line_start":160,"line_end":160},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"新娘子?你……难道你不是?","tone":"陈述","chapter":15,"line_start":162,"line_end":162},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"谁说我是新娘子?","tone":"微笑","chapter":15,"line_start":164,"line_end":164},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"但，但明明……","tone":"陈述","chapter":15,"line_start":166,"line_end":166},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"龟兹国的公主，又不止我一个，要嫁给胡铁花的，是我的姐姐呀!呆子……","tone":"陈述","chapter":15,"line_start":168,"line_end":168},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你姐姐……你为什么不早说子","tone":"陈述","chapter":15,"line_start":170,"line_end":170},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"我为什么要早说，我就是要你生气，要你着急……","tone":"微笑","chapter":15,"line_start":172,"line_end":172},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"叮叮当当","tone":"陈述","chapter":15,"line_start":174,"line_end":174},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你真是个又顽皮、又滑头的小坏蛋。","tone":"陈述","chapter":15,"line_start":180,"line_end":180},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你……你想怎么样?","tone":"微笑","chapter":15,"line_start":184,"line_end":184},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你猜猜看。","tone":"陈述","chapter":15,"line_start":186,"line_end":186},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"我不怕你，我不怕你，我不……","tone":"微笑","chapter":15,"line_start":188,"line_end":188},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"嘤咛","tone":"陈述","chapter":15,"line_start":190,"line_end":190},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"呆子，你想冷死我吗?","tone":"颤抖","chapter":15,"line_start":202,"line_end":202},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"我不怕你，你反而怕我么?","tone":"陈述","chapter":15,"line_start":214,"line_end":214},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你真是个小坏蛋。","tone":"无奈","chapter":15,"line_start":216,"line_end":216},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你可曾瞧见过世上有我这么美丽的小坏蛋?","tone":"陈述","chapter":15,"line_start":218,"line_end":218},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"没有。","tone":"无奈","chapter":15,"line_start":220,"line_end":220},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"我也没有瞧见过世上还有比你更可爱的呆子……呆子……呆子……","tone":"陈述","chapter":15,"line_start":222,"line_end":222}],"new_entities":{"characters":[{"id":"char_pi_pa_gong_zhu","name":"琵琶公主","alias":[],"identity":"龟兹国公主","faction":"龟兹国","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"龟兹国公主，胡铁花的新娘子的妹妹","personality":{"traits":["美丽","顽皮","大胆","热情","神秘"],"speech_style":"娇媚","temperament":"活泼"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":140,"line_end":140,"text":"这人竟是琵琶公主，\"新娘子\"竟溜出洞房来了。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_jiu_ping","name":"酒瓶","type":"special","owner":null,"one_line":"酒瓶","description":"装酒的瓶子，被用作投掷武器和饮酒工具","effects":["投掷武器","饮酒容器"],"origin":"未知","rarity":"寻常凡品","related_characters":[],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":174,"line_end":228,"text":"她银铃般娇笑着，被子也在\"叮叮当当\"的响，她从被子伸出手来，原来手里拿着两个酒瓶。"}]}]},"entity_updates":[]}
{"segment":3,"line_start":231,"line_end":327,"dialogues":[{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"天好像已亮了。","tone":"陈述","chapter":15,"line_start":240,"line_end":240},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"没有，没有……就算天亮了也没关系，这里的人昨晚一个个都喝得躺了下去，现在怎会起得来?","tone":"陈述","chapter":15,"line_start":242,"line_end":242},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"我这样对你，你可知道是为了什么?","tone":"陈述","chapter":15,"line_start":248,"line_end":248},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"我虽然不是个自我陶醉的男人，但我实在想不出一个女孩子这么做，除了喜欢那男人外，还有什么别的原因?","tone":"微笑","chapter":15,"line_start":250,"line_end":250},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你还为了什么?","tone":"陈述","chapter":15,"line_start":256,"line_end":256},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"因为我绝不能嫁给你。","tone":"陈述","chapter":15,"line_start":258,"line_end":258},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"哦!","tone":"陈述","chapter":15,"line_start":260,"line_end":260},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"哦……","tone":"陈述","chapter":15,"line_start":266,"line_end":266},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"哦，哦，哦……你难道只会说哦，你难道没有别的话说?","tone":"陈述","chapter":15,"line_start":268,"line_end":268},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"你叫我说什么?","tone":"陈述","chapter":15,"line_start":270,"line_end":270},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你……你……你至少也该问我，我为何不能嫁给你?","tone":"陈述","chapter":15,"line_start":272,"line_end":272},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"我问你，你会说么?","tone":"陈述","chapter":15,"line_start":274,"line_end":274},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"我不能说。","tone":"陈述","chapter":15,"line_start":276,"line_end":276},{"speaker":"char_chu_liu_xiang","speaker_name":"楚留香","listener":null,"text":"我就知道你不能说，所以我也不问。","tone":"陈述","chapter":15,"line_start":278,"line_end":278},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"我早就告诉过你，我不会说谎的。","tone":"陈述","chapter":15,"line_start":284,"line_end":284},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你……你这恶棍，你真的不觉难受?","tone":"陈述","chapter":15,"line_start":286,"line_end":286},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"老实说，你就算一定要嫁给我，我会不会娶你，还是个问题哩!","tone":"无奈","chapter":15,"line_start":288,"line_end":288},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"啪","tone":"陈述","chapter":15,"line_start":290,"line_end":290},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"你这混蛋，你这恶棍，你……你这老臭虫，就算天下的男人都死光了我也不会嫁给你……","tone":"陈述","chapter":15,"line_start":296,"line_end":296},{"speaker":"char_pi_pa_gong_zhu","speaker_name":"琵琶公主","listener":null,"text":"一个很正常的男人，和一个很正常的女人，在一个又冷又寂寞的晚上……你说，这又有什么不对?","tone":"微笑","chapter":15,"line_start":310,"line_end":310}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
