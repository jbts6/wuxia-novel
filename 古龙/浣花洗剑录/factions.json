    "source_refs": [
      {
        "chapter": 1,
        "line_start": 170,
        "line_end": 178,
        "text": "白三空令八弟子在外守护；其为山东省武林盟主清平剑客。"
      }
    ]
  },
  {
    "id": "faction_bai_ma_shan",
    "name": "白马山",
    "type": "帮派",
    "location": "白马山",
    "sub_divisions": [],
