[
  {"id": "evt_01_1", "name": "白衣人出海登岸", "participants": ["char_bai_yi_ren"], "location": "渤海之滨", "description": "白衣剑客在风浪中手握六尺长剑从海底一步步走上沙滩，如山之海浪竟也打不退他。上岸后倒下仍如枪般挺直。这是全书开场，展现白衣人超凡武功和钢铁意志。", "chapter": 1, "source_refs": [{"chapter": 1, "line_start": 12, "line_end": 16}]},
  {"id": "evt_01_2", "name": "白衣人挑战柳松", "participants": ["char_bai_yi_ren", "char_qing_he_liu_song"], "location": "崂山柳宅", "description": "白衣人身穿麻布白衣来到柳松宅前穿门而入，一剑杀死柳松。柳松是白衣人东来首战对手，死法为眉心一道血口直下胸膛。", "chapter": 1, "source_refs": [{"chapter": 1, "line_start": 32, "line_end": 120}]},
  {"id": "evt_01_3", "name": "白衣人斩杀飞鹤门五弟子", "participants": ["char_bai_yi_ren"], "location": "柳宅门前", "description": "五名飞鹤门弟子追出报仇，白衣人头也不回反手一剑，一剑似已化为五剑五个人竟似同时受伤。", "chapter": 1, "source_refs": [{"chapter": 1, "line_start": 128, "line_end": 148}]},
  {"id": "evt_01_4", "name": "白衣人连续击杀四大高手", "participants": ["char_bai_yi_ren"], "location": "多地", "description": "白衣人按计划连续击杀柳松、赵士鸿、李青风、金大非四人，行程表为十月初七至十月十一，四人死法完全一致。", "chapter": 1, "source_refs": [{"chapter": 1, "line_start": 152, "line_end": 173}]},
  {"id": "evt_01_5", "name": "四大门派弟子求白三空复仇", "participants": ["char_bai_san_kong"], "location": "济南白府", "description": "数十条披麻带孝大汉押着四辆灵车来到白府，求白三空为亡师复仇。白三空查看尸体后判断一招致命，内心震惊。", "chapter": 1, "source_refs": [{"chapter": 1, "line_start": 156, "line_end": 184}]},
  {"id": "evt_01_6", "name": "白衣人挑战白三空", "participants": ["char_bai_yi_ren", "char_bai_san_kong", "char_hu_bu_chou", "char_fang_bao_bao"], "location": "白府前广场", "description": "白衣人以枯枝为挑战信号，白三空观枯枝切口后深知不敌但仍出战。白三空连使两派起手式举案齐眉护住眉心，最终仍被白衣人一剑击杀。", "chapter": 1, "source_refs": [{"chapter": 1, "line_start": 186, "line_end": 327}]},
  {"id": "evt_01_7", "name": "胡不愁受命带走方宝儿", "participants": ["char_bai_san_kong", "char_hu_bu_chou", "char_fang_bao_bao"], "location": "白府后院", "description": "白三空将最重大任务交给最小弟子胡不愁，命他带走外孙方宝儿寻找五色帆船主。胡不愁带宝儿从后门离去踏上旅途。", "chapter": 1, "source_refs": [{"chapter": 1, "line_start": 266, "line_end": 402}]},
  {"id": "evt_01_8", "name": "万老夫人杀害三盗", "participants": ["char_wan_lao_fu_ren", "char_fen_biao", "char_tie_hu", "char_yi_zhen_feng"], "location": "海边篝火旁", "description": "万老夫人用言语挑拨三盗火拼，然后以紫晶珠（实为冰糖乌梅）为暗器将三人全部杀死。", "chapter": 1, "source_refs": [{"chapter": 1, "line_start": 528, "line_end": 696}]},
  {"id": "evt_02_1", "name": "胡不愁智退万老夫人", "participants": ["char_hu_bu_chou", "char_wan_lao_fu_ren", "char_fang_bao_bao"], "location": "海边", "description": "万老夫人要掳走方宝儿，胡不愁急中生智取出白衣人削下的枯枝谎称是五色帆船主所削。万老夫人见枯枝切口惊恐被吓退。", "chapter": 2, "source_refs": [{"chapter": 2, "line_start": 1, "line_end": 66}]},
  {"id": "evt_02_2", "name": "神木令聚宝", "participants": ["char_mu_lang_jun"], "location": "山坳", "description": "木郎君以神木令召集绿林高手送来珍宝，一个时辰中竟来了十七个高手。木偶端坐接受珍宝。", "chapter": 2, "source_refs": [{"chapter": 2, "line_start": 116, "line_end": 161}]},
  {"id": "evt_02_3", "name": "丐帮三弟子之死", "participants": ["char_mu_lang_jun"], "location": "山坳", "description": "三丐误闯神木令聚宝之地，瘤丐击打木偶反被枯木神功震伤致死。木郎君惩罚三丐命其自断手臂割耳。", "chapter": 2, "source_refs": [{"chapter": 2, "line_start": 166, "line_end": 346}]},
  {"id": "evt_02_4", "name": "万老夫人与木郎君交手", "participants": ["char_wan_lao_fu_ren", "char_mu_lang_jun"], "location": "山坳", "description": "万老夫人以丈三青锋杖攻击木郎君，杖头青锋化作万朵剑花。木郎君以枯木功应对。万老夫人折杖放烟逃走。", "chapter": 2, "source_refs": [{"chapter": 2, "line_start": 356, "line_end": 450}]},
  {"id": "evt_02_5", "name": "水天姬现身戏弄木郎君", "participants": ["char_shui_tian_ji", "char_mu_lang_jun"], "location": "废弃渔村", "description": "水天姬易容为珠冠人出现与木郎君对峙，揭露其真实身份，用水毒暗器逼退木郎君。", "chapter": 2, "source_refs": [{"chapter": 2, "line_start": 578, "line_end": 670}]},
  {"id": "evt_03_1", "name": "水天姬掳走方宝儿", "participants": ["char_shui_tian_ji", "char_fang_bao_bao"], "location": "渔村木屋", "description": "水天姬趁木郎君追出时潜入屋内点倒胡不愁抱走方宝儿，身法鬼魅难及。", "chapter": 3, "source_refs": [{"chapter": 3, "line_start": 10, "line_end": 40}]},
  {"id": "evt_03_2", "name": "水天姬与方宝儿海边相处", "participants": ["char_shui_tian_ji", "char_fang_bao_bao"], "location": "海边岩石", "description": "水天姬解开宝儿穴道两人互开玩笑，宝儿咬了水天姬鼻子两人笑成一团。水天姬展现了真容。", "chapter": 3, "source_refs": [{"chapter": 3, "line_start": 58, "line_end": 240}]},
  {"id": "evt_03_3", "name": "方宝儿被带至五色帆船", "participants": ["char_ling_er", "char_fang_bao_bao"], "location": "五色帆船", "description": "铃儿和白衣少女趁水天姬离开时带走沉睡的方宝儿，将其带到五色帆船作为小公主的玩伴。", "chapter": 3, "source_refs": [{"chapter": 3, "line_start": 242, "line_end": 306}]},
  {"id": "evt_03_4", "name": "方宝儿与小公主初见", "participants": ["char_fang_bao_bao", "char_xiao_gong_zhu"], "location": "五色帆船小公主房间", "description": "方宝儿见到小公主插花赞叹不已。小公主不知男女之别两人开始斗嘴。小公主因方宝儿碰到花枝大怒要方宝儿答应十件事。", "chapter": 3, "source_refs": [{"chapter": 3, "line_start": 406, "line_end": 580}]},
  {"id": "evt_04_1", "name": "紫衣侯接见各方来使", "participants": ["char_zi_yi_hou", "char_ling_er", "char_tie_jin_dao", "char_mu_lang_jun", "char_cen_zou"], "location": "五色帆船大厅", "description": "紫衣侯在屏风后接见来自大宛、安息、身毒、交趾等国的使者，各国献上珍宝求紫衣侯办事。", "chapter": 4, "source_refs": [{"chapter": 4, "line_start": 170, "line_end": 663}]},
  {"id": "evt_04_2", "name": "紫衣侯怒斥岑陬", "participants": ["char_zi_yi_hou", "char_cen_zou"], "location": "五色帆船大厅", "description": "岑陬代表大宛国请紫衣侯任国师，紫衣侯怒斥其无耻败类竟忘了自己的祖宗。", "chapter": 4, "source_refs": [{"chapter": 4, "line_start": 488, "line_end": 509}]},
  {"id": "evt_05_1", "name": "水天姬易容为居鲁大士", "participants": ["char_shui_tian_ji"], "location": "五色帆船", "description": "水天姬易容为安息使臣居鲁大士出现，解开了衣襟脱下了白袍露出绝美胴体，扯下了满头黄发露出真容。", "chapter": 5, "source_refs": [{"chapter": 5, "line_start": 70, "line_end": 84}]},
  {"id": "evt_05_2", "name": "伽星法王逼战紫衣侯", "participants": ["char_jia_xing_fa_wang", "char_zi_yi_hou"], "location": "五色帆船大厅", "description": "伽星法王以铁钉钉入自身逼紫衣侯动手，三寸多长的铁钉入肉几达两寸，但紫衣侯始终不肯出手。", "chapter": 5, "source_refs": [{"chapter": 5, "line_start": 108, "line_end": 216}]},
  {"id": "evt_05_3", "name": "胡不愁说服紫衣侯", "participants": ["char_hu_bu_chou", "char_zi_yi_hou"], "location": "五色帆船大厅", "description": "胡不愁以激将法加枯枝为战书说服紫衣侯出手对抗白衣人。紫衣侯观赏枯枝后连赞三声好高明的剑法。", "chapter": 5, "source_refs": [{"chapter": 5, "line_start": 228, "line_end": 348}]},
  {"id": "evt_05_4", "name": "方宝儿为胡不愁出头", "participants": ["char_fang_bao_bao", "char_shui_tian_ji", "char_zi_yi_hou"], "location": "五色帆船大厅", "description": "方宝儿从屏风后走出以礼教之论逼水天姬认罪，最终紫衣侯判水天姬留船读书三年。", "chapter": 5, "source_refs": [{"chapter": 5, "line_start": 472, "line_end": 584}]},
  {"id": "evt_05_5", "name": "王半侠现身", "participants": ["char_wang_ban_xia"], "location": "五色帆船", "description": "王半侠以两种声音现身，揭示白衣人已杀二十多人，白三空未死。", "chapter": 5, "source_refs": [{"chapter": 5, "line_start": 596, "line_end": 676}]},
  {"id": "evt_06_1", "name": "白衣人洛阳连战", "participants": ["char_bai_yi_ren"], "location": "洛阳连云庄", "description": "白衣人在连云庄大厅连战中州九大高手。飞天豹使流星练子锤被杀，乔飞使暗器被一剑钉死。白衣人每杀一人便道一声下一个。", "chapter": 6, "source_refs": [{"chapter": 6, "line_start": 98, "line_end": 262}]},
  {"id": "evt_06_2", "name": "紫衣侯剑刺岑陬", "participants": ["char_zi_yi_hou", "char_cen_zou"], "location": "五色帆船", "description": "紫衣侯以一剑在岑陬身上刺出七处伤口作为战书。", "chapter": 6, "source_refs": [{"chapter": 6, "line_start": 44, "line_end": 78}]},
  {"id": "evt_06_3", "name": "王半侠千里送信", "participants": ["char_wang_ban_xia"], "location": "路上", "description": "王半侠两个时辰赶两百里路赴连云庄。", "chapter": 6, "source_refs": [{"chapter": 6, "line_start": 272, "line_end": 402}]},
  {"id": "evt_06_4", "name": "木郎君劫持岑陬", "participants": ["char_mu_lang_jun", "char_cen_zou"], "location": "连云庄外", "description": "木郎君趁乱劫走岑陬以此要挟。", "chapter": 6, "source_refs": [{"chapter": 6, "line_start": 610, "line_end": 618}]},
  {"id": "evt_07_1", "name": "白衣人观战书", "participants": ["char_bai_yi_ren"], "location": "连云庄大厅", "description": "白衣人观看岑陬身上的七道剑痕，苍白的面色渐渐泛起一阵兴奋的红润，随后跪地感恩苍天赐对手。", "chapter": 7, "source_refs": [{"chapter": 7, "line_start": 36, "line_end": 58}]},
  {"id": "evt_07_2", "name": "白衣人前往东海", "participants": ["char_bai_yi_ren", "char_hu_bu_chou"], "location": "路上", "description": "白衣人与胡不愁同行前往东海，途中白衣人首次开口夸赞白三空和胡不愁，并透露身世片段唱出先父之歌。", "chapter": 7, "source_refs": [{"chapter": 7, "line_start": 78, "line_end": 182}]},
  {"id": "evt_07_3", "name": "寿天齐执行海上道义", "participants": ["char_shou_tian_qi"], "location": "东海海岸", "description": "寿天齐得知手下曾凿沉白衣人船只，逼令虬髯大汉自尽。不仁者死不义者亡海上道义坚如精钢。", "chapter": 7, "source_refs": [{"chapter": 7, "line_start": 330, "line_end": 404}]},
  {"id": "evt_07_4", "name": "紫衣侯白衣人海上决战", "participants": ["char_zi_yi_hou", "char_bai_yi_ren", "char_hu_bu_chou"], "location": "东海海面", "description": "两人各乘轻舟于海上交手，紫衣侯连换九十七种剑法最终以伏魔剑法胜半招但心脉被震断。白衣人承认败北约定七年后再战。", "chapter": 7, "source_refs": [{"chapter": 7, "line_start": 450, "line_end": 540}, {"chapter": 8, "line_start": 1, "line_end": 42}]},
  {"id": "evt_08_1", "name": "紫衣侯分财托孤", "participants": ["char_zi_yi_hou", "char_ling_er", "char_zhu_er", "char_xiao_gong_zhu"], "location": "五色帆船", "description": "紫衣侯将家财分给少女们，将小公主和帆船托付给铃儿珠儿交代后事。", "chapter": 8, "source_refs": [{"chapter": 8, "line_start": 270, "line_end": 312}]},
  {"id": "evt_08_2", "name": "紫衣侯讲述师兄故事", "participants": ["char_zi_yi_hou", "char_fang_bao_bao", "char_hu_bu_chou"], "location": "五色帆船", "description": "紫衣侯讲述师兄的故事，师兄能记住后又全都忘记剑法悟了剑意以意驭剑随心所欲。将钥匙传给胡不愁将锦囊交给方宝儿。", "chapter": 8, "source_refs": [{"chapter": 8, "line_start": 292, "line_end": 408}]},
  {"id": "evt_08_3", "name": "紫衣侯狂笑而逝", "participants": ["char_zi_yi_hou"], "location": "五色帆船密室", "description": "紫衣侯仰天狂笑人生百年终须一死能死在这样的对手中还叹的什么气。踉跄奔入密室狂笑之声渐渐低沉而终至不可再闻。", "chapter": 8, "source_refs": [{"chapter": 8, "line_start": 422, "line_end": 448}]},
  {"id": "evt_08_4", "name": "群豪悼念紫衣侯", "participants": ["char_wang_ban_xia"], "location": "东海海岸", "description": "群豪跪满沙滩王半侠高歌悲歌双剑击兮风云意龙吟绝兮巨星落。", "chapter": 8, "source_refs": [{"chapter": 8, "line_start": 464, "line_end": 490}]},
  {"id": "evt_09_1", "name": "彭清夜袭五色帆船", "participants": ["char_qing_hua_shou_peng_qing", "char_ling_er", "char_zhu_er"], "location": "五色帆船", "description": "彭清率追魂夺命二十四怪夜袭五色帆船，二十余条黑衣劲装黑巾蒙面之人影企图劫财劫色。", "chapter": 9, "source_refs": [{"chapter": 9, "line_start": 96, "line_end": 170}]},
  {"id": "evt_09_2", "name": "金河王救船", "participants": ["char_jin_he_wang"], "location": "五色帆船", "description": "金河王率黄金魔女出现以奇异武功制服黑衣人将彭清等人抛入海中。", "chapter": 9, "source_refs": [{"chapter": 9, "line_start": 286, "line_end": 460}]},
  {"id": "evt_09_3", "name": "方宝儿吞下密柬", "participants": ["char_fang_bao_bao", "char_jin_he_wang"], "location": "五色帆船", "description": "方宝儿为保护紫衣侯师兄的秘密将密柬吞入腹中，对金河王说你这金猴子你不妨杀了我吃了我但却拿不走那张纸。", "chapter": 9, "source_refs": [{"chapter": 9, "line_start": 698, "line_end": 703}]},
  {"id": "evt_10_1", "name": "水天姬智退金河王", "participants": ["char_shui_tian_ji", "char_jin_he_wang"], "location": "五色帆船", "description": "水天姬声称方宝儿是她丈夫圣水神宫小主人，又以无水黄蜂针威胁，金河王被逼退。", "chapter": 10, "source_refs": [{"chapter": 10, "line_start": 18, "line_end": 82}]},
  {"id": "evt_10_2", "name": "龙卷风袭击", "participants": ["char_shui_tian_ji", "char_hu_bu_chou", "char_jia_xing_fa_wang"], "location": "海上", "description": "龙卷风袭击五色帆船，船桅折断灯光全灭天地间一片漆黑众人被冲散。", "chapter": 10, "source_refs": [{"chapter": 10, "line_start": 268, "line_end": 320}]},
  {"id": "evt_10_3", "name": "胡不愁自锁密室", "participants": ["char_hu_bu_chou", "char_jia_xing_fa_wang"], "location": "五色帆船藏书密室", "description": "胡不愁骗伽星法王用钥匙开门趁机闪入密室将门锁上，密室四壁精钢所铸伽星法王无法破入。", "chapter": 10, "source_refs": [{"chapter": 10, "line_start": 430, "line_end": 512}]},
  {"id": "evt_11_1", "name": "牛铁娃救方宝儿", "participants": ["char_niu_tie_wa", "char_fang_bao_bao"], "location": "海滩", "description": "暴风雨后方宝儿被海浪冲上沙滩，铁娃发现后先被吓跑又回来说不对不对大海的儿子怎会被海水冲晕，将宝儿抱起使其吐出海水。", "chapter": 11, "source_refs": [{"chapter": 11, "line_start": 34, "line_end": 52}]},
  {"id": "evt_11_2", "name": "方宝儿与牛铁娃结拜", "participants": ["char_fang_bao_bao", "char_niu_tie_wa"], "location": "海滩", "description": "铁娃提议收宝儿为子宝儿反要当大哥。宝儿用湿沙抛入海中的巧技赢了铁娃的力气比试，铁娃跪地叩头认大哥。", "chapter": 11, "source_refs": [{"chapter": 11, "line_start": 94, "line_end": 174}]},
  {"id": "evt_11_3", "name": "群盗围攻牛铁娃", "participants": ["char_niu_tie_wa"], "location": "海滩", "description": "二十余条大汉手持花枪鱼叉鬼头刀等兵刃围攻铁娃。铁娃力大无穷以石头迎敌但不会武功被消耗体力左股被叉出三个血窟窿。", "chapter": 11, "source_refs": [{"chapter": 11, "line_start": 224, "line_end": 278}]},
  {"id": "evt_11_4", "name": "方宝儿智退群盗", "participants": ["char_fang_bao_bao"], "location": "海滩", "description": "宝儿以五色帆船和紫髯龙的名号震慑群盗，群盗跪满一地求饶宝儿令他们日后对铁娃恭敬。", "chapter": 11, "source_refs": [{"chapter": 11, "line_start": 340, "line_end": 420}]},
  {"id": "evt_12_1", "name": "李名生与周方互相暗算", "participants": ["char_li_ming_sheng", "char_zhou_fang"], "location": "方舟上", "description": "两人同时大笑李名生袖中飞出三点寒星打周方周方箱中银光射向李名生咽喉。两人同时扑倒躲过又互相假意道歉。", "chapter": 12, "source_refs": [{"chapter": 12, "line_start": 290, "line_end": 314}]},
  {"id": "evt_12_2", "name": "萧配秋率队攻打天风水塘", "participants": ["char_xiao_pei_qiu", "char_jiang_feng"], "location": "天风水塘", "description": "萧配秋率数十艘轻舟首尾相连如长龙以鼓声号角为号在池塘中布下蛇阵。", "chapter": 12, "source_refs": [{"chapter": 12, "line_start": 428, "line_end": 545}]},
  {"id": "evt_13_1", "name": "铁温侯vs万老夫人", "participants": ["char_tie_wen_hou", "char_wan_lao_fu_ren"], "location": "天风水塘方头船", "description": "万老夫人用梨花大枪法齐眉五行棍白蜡大竿子等招式，铁温侯以双戟化解。最终万老夫人被铁温侯逼退。", "chapter": 13, "source_refs": [{"chapter": 13, "line_start": 136, "line_end": 192}]},
  {"id": "evt_13_2", "name": "土龙子侮辱姜风", "participants": ["char_tu_long_zi", "char_jiang_feng"], "location": "天风水塘", "description": "土龙子将姜风搂入怀中又亲又嗅撕开其衣襟。姜风羞愤晕厥。", "chapter": 13, "source_refs": [{"chapter": 13, "line_start": 240, "line_end": 252}]},
  {"id": "evt_13_3", "name": "方宝儿挺身护姜风", "participants": ["char_fang_bao_bao", "char_tu_long_zi"], "location": "天风水塘", "description": "宝儿大喝你是人还是畜牲放手冲出去保护姜风。", "chapter": 13, "source_refs": [{"chapter": 13, "line_start": 256, "line_end": 260}]},
  {"id": "evt_13_4", "name": "宝儿与小公主重逢", "participants": ["char_fang_bao_bao", "char_xiao_gong_zhu"], "location": "后舱", "description": "铁温侯将宝儿推入后舱小公主等人在舱中。三人紧抱宝儿亲了又亲小公主咬了宝儿脖子和脸。", "chapter": 13, "source_refs": [{"chapter": 13, "line_start": 298, "line_end": 346}]},
  {"id": "evt_13_5", "name": "万老夫人vs木郎君vs中原四大高手混战", "participants": ["char_wan_lao_fu_ren", "char_mu_lang_jun", "char_tu_long_zi", "char_tie_wen_hou", "char_song_guang", "char_li_ying_hong", "char_zhan_chang_sheng"], "location": "天风水塘船上", "description": "混战激烈。宋光被木郎合击碎双肩；战常胜被万老夫人暗器所伤；铁温侯双臂被土龙子折断仍咬住其腿不放。", "chapter": 13, "source_refs": [{"chapter": 13, "line_start": 464, "line_end": 624}]},
  {"id": "evt_14_1", "name": "小公主自愿被掳", "participants": ["char_xiao_gong_zhu", "char_wan_lao_fu_ren", "char_mu_lang_jun"], "location": "天风水塘", "description": "小公主大喝只要咱们跟着你们走五色帆船上的珍宝就全都是你们的，以此打动万老夫人和木郎君放过宝儿。", "chapter": 14, "source_refs": [{"chapter": 14, "line_start": 31, "line_end": 42}]},
  {"id": "evt_14_2", "name": "以火制火逃生", "participants": ["char_fang_bao_bao", "char_niu_tie_lan", "char_li_ying_hong", "char_zhou_fang"], "location": "天风水塘", "description": "宝儿令将铁链连起的轻舟团团围住自己再将轻舟点着以火阻火。泥泽处不被火势波及众人伏身泥水中得以逃生。", "chapter": 14, "source_refs": [{"chapter": 14, "line_start": 256, "line_end": 300}]},
  {"id": "evt_15_1", "name": "周方教宝儿观流水悟武道", "participants": ["char_zhou_fang", "char_fang_bao_bao"], "location": "方舟上", "description": "周方让宝儿对流水静瞧三个时辰，宝儿悟出流水包涵无上武学至理生生不息。", "chapter": 15, "source_refs": [{"chapter": 15, "line_start": 130, "line_end": 241}]},
  {"id": "evt_15_2", "name": "王大娘与王半狂比武", "participants": ["char_wang_da_niang", "char_wang_ban_xia"], "location": "江岸", "description": "王大娘以双短杖为足飞旋闪动左杖轻灵右杖刚猛。王半狂点住王大娘二十余处穴道但王大娘竟能抬手拢发——原来是夫妻串通的把戏。", "chapter": 15, "source_refs": [{"chapter": 15, "line_start": 535, "line_end": 635}]},
  {"id": "evt_16_1", "name": "黄鹤楼群豪聚会", "participants": ["char_wan_zi_liang", "char_jin_zu_lin"], "location": "黄鹤楼", "description": "黄鹤楼上上下下人头蜂涌俱是武林豪强和少年英雄。群豪讨论武林大事。", "chapter": 16, "source_refs": [{"chapter": 16, "line_start": 270, "line_end": 544}]},
  {"id": "evt_17_1", "name": "方宝儿当众揭真相", "participants": ["char_fang_bao_bao", "char_wang_da_niang"], "location": "黄鹤楼", "description": "宝儿大喝谁说这两件事无法解决跃出当众指出王大娘武功破绽。", "chapter": 17, "source_refs": [{"chapter": 17, "line_start": 418, "line_end": 476}]},
  {"id": "evt_17_2", "name": "周方现身揭真相", "participants": ["char_zhou_fang", "char_wang_ban_xia", "char_wang_da_niang"], "location": "黄鹤楼", "description": "周方扯下白髯露出半边如鬼面容自认是紫衣侯师兄。王半侠面色如死灰穿窗而逃。", "chapter": 17, "source_refs": [{"chapter": 17, "line_start": 470, "line_end": 544}]},
  {"id": "evt_18_1", "name": "周方与宝儿铁娃离开黄鹤楼", "participants": ["char_zhou_fang", "char_fang_bao_bao", "char_niu_tie_wa"], "location": "黄鹤楼", "description": "周方教宝儿拉铁娃悄悄溜走三人穿入小巷消失。周方歌声余韵缭绕。", "chapter": 18, "source_refs": [{"chapter": 18, "line_start": 96, "line_end": 178}]},
  {"id": "evt_18_2", "name": "白三空隐居铜官山", "participants": ["char_bai_san_kong", "char_wan_zi_liang", "char_jin_zu_lin"], "location": "铜官山", "description": "万子良带七弟子至金祖林的铜官山林地。白三空在百丈高树上的绿色小屋中隐居已多年未下来。", "chapter": 18, "source_refs": [{"chapter": 18, "line_start": 302, "line_end": 501}]},
  {"id": "evt_19_1", "name": "方宝玉现身救人", "participants": ["char_fang_bao_bao", "char_wang_ban_xia"], "location": "铜官山", "description": "紫衣少年自百丈高处飘飘落下轻松制服跛足恶丐和枯瘦恶丐，识破王半侠蒙面身份令其逃跑时被铁娃截住。", "chapter": 19, "source_refs": [{"chapter": 19, "line_start": 102, "line_end": 195}]},
  {"id": "evt_19_2", "name": "方宝玉与七大弟子重逢", "participants": ["char_fang_bao_bao", "char_liu_da_di_zi"], "location": "铜官山", "description": "宝玉拜倒叫叔父七大弟子惊喜交集。杨不怒紧抱宝儿大哭。石不为喃喃宝儿感谢苍天。", "chapter": 19, "source_refs": [{"chapter": 19, "line_start": 308, "line_end": 344}]},
  {"id": "evt_20_1", "name": "方宝玉vs吕云（第一战）", "participants": ["char_fang_bao_bao", "char_li_yun"], "location": "洞庭湖边", "description": "吕云使八尺长枪连环四十八枪枪影笼罩一丈方圆。宝玉平剑当胸等待时机一剑削出截断吕云枪势，木剑搭住枪尖如无形枷锁吕云撒手抛枪认败。", "chapter": 20, "source_refs": [{"chapter": 20, "line_start": 26, "line_end": 120}]},
  {"id": "evt_20_2", "name": "方宝玉vs鱼传甲（第二战）", "participants": ["char_fang_bao_bao", "char_yu_chuan_jia"], "location": "嘉鱼城长江岸边", "description": "鱼传甲使短刀拐一手三绝技。宝玉闪过十余险招后一剑穿过刀光拐影点中鱼传甲右肩穴道同时接住十余枚飞鱼刺。", "chapter": 20, "source_refs": [{"chapter": 20, "line_start": 160, "line_end": 286}]},
  {"id": "evt_21_1", "name": "欧阳珠灌醉宝玉", "participants": ["char_zhu_er", "char_fang_bao_bao"], "location": "某处", "description": "欧阳珠以故人身份与宝玉痛饮谈论昔日趣事。酒后劲极大众人皆醉。", "chapter": 21, "source_refs": [{"chapter": 21, "line_start": 8, "line_end": 80}]},
  {"id": "evt_21_2", "name": "英铁翎挑战", "participants": ["char_fang_bao_bao", "char_ying_tie_ling"], "location": "金陵玄武湖", "description": "英铁翎使风雨双牌威猛霸道。宝玉心神紊乱一剑偏差木剑折断。", "chapter": 21, "source_refs": [{"chapter": 21, "line_start": 300, "line_end": 457}]},
  {"id": "evt_22_1", "name": "方宝玉反败为胜击败英铁翎", "participants": ["char_fang_bao_bao", "char_ying_tie_ling"], "location": "金陵玄武湖", "description": "宝玉心神出奇平静半截木剑轻描淡写画半圆四面铁牌被一一随手点中英铁翎足踝被扫中跌倒。", "chapter": 22, "source_refs": [{"chapter": 22, "line_start": 1, "line_end": 20}]},
  {"id": "evt_22_2", "name": "方宝玉为铁温侯疗伤", "participants": ["char_fang_bao_bao", "char_tie_wen_hou", "char_li_ying_hong"], "location": "某处", "description": "宝玉明知损耗内力会影响明日大战仍抱起铁温侯去疗伤。头也不回说若有人问起就说我已为铁大叔疗伤去了。", "chapter": 22, "source_refs": [{"chapter": 22, "line_start": 298, "line_end": 314}]},
  {"id": "evt_23_1", "name": "小公主深夜现身", "participants": ["char_xiao_gong_zhu", "char_fang_bao_bao"], "location": "某处", "description": "小公主自窗隙滑入以猜猜我是谁唤醒宝玉。两人重逢诉说别情。", "chapter": 23, "source_refs": [{"chapter": 23, "line_start": 370, "line_end": 514}]},
  {"id": "evt_24_1", "name": "五行魔宫白衣人围攻", "participants": ["char_fang_bao_bao", "char_xiao_gong_zhu"], "location": "荒林", "description": "十余条白衣人各持奇形怪异兵刃围攻。宝玉以枯枝为剑击退多人但魔火飞来小公主拉宝玉逃走。", "chapter": 24, "source_refs": [{"chapter": 24, "line_start": 210, "line_end": 324}]},
  {"id": "evt_25_1", "name": "天香茶林迷魂", "participants": ["char_fang_bao_bao", "char_xiao_gong_zhu"], "location": "天香茶林", "description": "天香茶林外观朴素但内部精舍华丽。东方玉环娇艳美妇以山歌和妙舞款待宝玉。小公主突然消失不见。", "chapter": 25, "source_refs": [{"chapter": 25, "line_start": 212, "line_end": 468}]},
  {"id": "evt_26_1", "name": "方宝玉被关入魔宫", "participants": ["char_fang_bao_bao", "char_huo_mo_shen"], "location": "魔宫", "description": "宝玉被东方玉环引入魔宫精舍，发现暗道后落入陷阱。在地下水中逃脱。", "chapter": 26, "source_refs": [{"chapter": 26, "line_start": 2, "line_end": 200}]},
  {"id": "evt_26_2", "name": "宝玉与小公主重逢", "participants": ["char_fang_bao_bao", "char_xiao_gong_zhu"], "location": "魔宫花园", "description": "宝玉从水中逃出在花园遇见小公主。两人拥抱小公主哭泣。小公主为他喝下毒茶。", "chapter": 26, "source_refs": [{"chapter": 26, "line_start": 256, "line_end": 435}]},
  {"id": "evt_27_1", "name": "火魔神vs方宝玉 verbal confrontation", "participants": ["char_huo_mo_shen", "char_fang_bao_bao"], "location": "魔宫", "description": "火魔神试图以甜言蜜语催眠宝玉，宝玉抵抗。两人展开言语对决，宝玉揭露火魔神的真实意图。", "chapter": 27, "source_refs": [{"chapter": 27, "line_start": 74, "line_end": 198}]},
  {"id": "evt_28_1", "name": "冷冰鱼vs杨不怒", "participants": ["char_leng_bing_yu", "char_yang_bu_nu"], "location": "快聚园", "description": "冷冰鱼挑战杨不怒，杨不怒借鬼头刀与冷冰鱼交手八招后被击败。", "chapter": 28, "source_refs": [{"chapter": 28, "line_start": 200, "line_end": 300}]},
  {"id": "evt_28_2", "name": "方宝玉现身救杨不怒", "participants": ["char_fang_bao_bao", "char_leng_bing_yu"], "location": "快聚园", "description": "宝玉从竹林中走出阻止冷冰鱼。两人对峙后约定泰山之会见。", "chapter": 28, "source_refs": [{"chapter": 28, "line_start": 328, "line_end": 426}]},
  {"id": "evt_29_1", "name": "万老夫人假意输给宝玉", "participants": ["char_wan_lao_fu_ren", "char_fang_bao_bao"], "location": "快聚园", "description": "万老夫人与宝玉交手但故意 miss 每一击，假装输给宝玉以保护其名声。", "chapter": 29, "source_refs": [{"chapter": 29, "line_start": 96, "line_end": 152}]},
  {"id": "evt_30_1", "name": "魏不贪杀害杨不怒", "participants": ["char_wei_bu_tan", "char_yang_bu_nu"], "location": "万竹山庄", "description": "魏不贪从背后偷袭杀害杨不怒，并伪造宝玉的名字在杨不怒的遗言中。", "chapter": 30, "source_refs": [{"chapter": 30, "line_start": 136, "line_end": 170}]},
  {"id": "evt_30_2", "name": "公孙不智揭露魏不贪", "participants": ["char_gong_sun_bu_zhi", "char_wei_bu_tan"], "location": "万竹山庄", "description": "公孙不智怀疑魏不贪是凶手，去检查时被魏不贪用毒针暗算。公孙跳窗逃脱。", "chapter": 30, "source_refs": [{"chapter": 30, "line_start": 330, "line_end": 440}]},
  {"id": "evt_31_1", "name": "方宝玉发现垂死魏不贪", "participants": ["char_fang_bao_bao", "char_wei_bu_tan"], "location": "泰山脚下", "description": "宝玉在泰山脚下发现垂死的魏不贪，魏不贪 confesses 他的罪行后身亡。", "chapter": 31, "source_refs": [{"chapter": 31, "line_start": 174, "line_end": 252}]},
  {"id": "evt_32_1", "name": "泰山英雄会开幕", "participants": ["char_ding_lao_fu_ren"], "location": "泰山", "description": "丁老夫人宣布新比赛规则，淘汰赛制。各路高手齐聚泰山。", "chapter": 32, "source_refs": [{"chapter": 32, "line_start": 2, "line_end": 93}]},
  {"id": "evt_32_2", "name": "牛铁娃击败王烈火", "participants": ["char_niu_tie_wa", "char_wang_lie_huo"], "location": "泰山", "description": "铁娃空手夺鞭击败王烈火，救下潘济城。", "chapter": 32, "source_refs": [{"chapter": 32, "line_start": 146, "line_end": 216}]},
  {"id": "evt_33_1", "name": "公孙红击败冷冰鱼", "participants": ["char_gong_sun_hong", "char_leng_bing_yu"], "location": "泰山", "description": "公孙红以天龙棍击败冷冰鱼的破云震天笔。冷冰鱼试图揭露石不为的秘密但无法开口身亡。", "chapter": 33, "source_refs": [{"chapter": 33, "line_start": 100, "line_end": 174}]},
  {"id": "evt_33_2", "name": "公孙红讲述白衣人身世", "participants": ["char_gong_sun_hong"], "location": "泰山", "description": "公孙红揭露白衣人来自东瀛，中土奇人携子赴东瀛学武，十年磨剑于棋岛。", "chapter": 33, "source_refs": [{"chapter": 33, "line_start": 182, "line_end": 332}]},
  {"id": "evt_34_1", "name": "小公主暗算欧阳天矫", "participants": ["char_xiao_gong_zhu", "char_ou_yang_tian_jiao"], "location": "泰山", "description": "小公主扮成青衣少年在泰山大会上暗算欧阳天矫致死。", "chapter": 34, "source_refs": [{"chapter": 34, "line_start": 100, "line_end": 104}]},
  {"id": "evt_34_2", "name": "方宝玉现身泰山大会", "participants": ["char_fang_bao_bao", "char_xiao_gong_zhu"], "location": "泰山", "description": "宝玉在小公主与公孙红交手时现身，抓住小公主。两人重逢。", "chapter": 34, "source_refs": [{"chapter": 34, "line_start": 300, "line_end": 346}]},
  {"id": "evt_35_1", "name": "火魔神揭示火药阴谋", "participants": ["char_huo_mo_shen"], "location": "泰山", "description": "火魔神引爆试验爆炸震慑全场，揭示火药覆盖整个泰山的阴谋。", "chapter": 35, "source_refs": [{"chapter": 35, "line_start": 2, "line_end": 78}]},
  {"id": "evt_35_2", "name": "方宝玉揭露石不为阴谋", "participants": ["char_fang_bao_bao", "char_shi_bu_wei", "char_huo_mo_shen"], "location": "泰山", "description": "宝玉在泰山大会揭露石不为才是杀害七大弟子的真凶，火魔神承认是证据。", "chapter": 35, "source_refs": [{"chapter": 35, "line_start": 274, "line_end": 358}]},
  {"id": "evt_36_1", "name": "石不为 confesses and commits suicide", "participants": ["char_shi_bu_wei", "char_gong_sun_bu_zhi", "char_tie_shen_long"], "location": "泰山", "description": "公孙不智假死揭露真相，石不为 confesses 一切后服毒自杀。铁神龙亲手诛杀叛徒。", "chapter": 36, "source_refs": [{"chapter": 36, "line_start": 155, "line_end": 340}]},
  {"id": "evt_36_2", "name": "方宝玉被尊为天下第一", "participants": ["char_fang_bao_bao", "char_wu_xiang_da_shi", "char_tie_ran_dao_zhang"], "location": "泰山", "description": "无相大师赞宝玉人中之龙，铁髯道长赞其将太阳光都用做致胜武器。", "chapter": 36, "source_refs": [{"chapter": 36, "line_start": 469, "line_end": 496}]},
  {"id": "evt_37_1", "name": "方宝玉突破六大掌门剑阵", "participants": ["char_fang_bao_bao", "char_wu_xiang_da_shi", "char_tie_ran_dao_zhang"], "location": "泰山", "description": "宝玉进入六大掌门剑阵，利用太阳光反射暂时致盲六位掌门后逃出。", "chapter": 37, "source_refs": [{"chapter": 37, "line_start": 80, "line_end": 270}]},
  {"id": "evt_37_2", "name": "紫髯龙带来白衣人信", "participants": ["char_shou_tian_qi"], "location": "泰山", "description": "紫髯龙从海上赶来带来白衣人的信：七年之约不可不赴，但愿东海之滨有人能以三尺剑赐我一败。", "chapter": 37, "source_refs": [{"chapter": 37, "line_start": 288, "line_end": 432}]},
  {"id": "evt_39_1", "name": "蒋笑民殉剑", "participants": ["char_jiang_xiao_min", "char_fang_bao_bao"], "location": "软红山庄", "description": "蒋笑民以扭转乾坤杀手剑攻击宝玉为白衣人试招后自杀殉剑。遗言：生死之搏必须公平。", "chapter": 39, "source_refs": [{"chapter": 39, "line_start": 18, "line_end": 150}]},
  {"id": "evt_41_1", "name": "铁金刀挑战宝玉", "participants": ["char_tie_jin_dao", "char_fang_bao_bao"], "location": "桑林", "description": "铁金刀持白衣人一招挑战宝玉，宝玉以飞蛾扑火之法破解。铁金刀临终透露白衣人破绽在胁下后自尽。", "chapter": 41, "source_refs": [{"chapter": 41, "line_start": 286, "line_end": 508}]},
  {"id": "evt_43_1", "name": "小公主审问李名生", "participants": ["char_xiao_gong_zhu", "char_li_ming_sheng"], "location": "桑林", "description": "小公主审问李名生逼问所见所闻。李名生透露黑衣人杀了两人夺取密柬提到大名府。", "chapter": 43, "source_refs": [{"chapter": 43, "line_start": 2, "line_end": 50}]},
  {"id": "evt_46_1", "name": "王大娘开始杀人灭口", "participants": ["char_wang_da_niang"], "location": "王大娘据点", "description": "王大娘露出真面目开始杀人灭口。单毅成被一剑刺喉身亡，孙玉龙被子母追魂脱手剑穿背钉死。", "chapter": 46, "source_refs": [{"chapter": 46, "line_start": 74, "line_end": 507}]},
  {"id": "evt_47_1", "name": "方宝玉被困火窟真情流露", "participants": ["char_fang_bao_bao", "char_xiao_gong_zhu", "char_wan_lao_fu_ren"], "location": "王大娘据点火窟", "description": "王大娘放火烧屋。宝玉与小公主隔墙相认真情流露。两人在烈火中拥抱互诉衷肠——死亡逼近时的真情告白。", "chapter": 47, "source_refs": [{"chapter": 47, "line_start": 118, "line_end": 498}]},
  {"id": "evt_48_1", "name": "白水宫位置揭晓", "participants": ["char_huo_mo_shen", "char_wan_lao_fu_ren"], "location": "太行山", "description": "火魔神出现透露铁髯等人已先到白水宫。白水宫位置在太行山中。", "chapter": 48, "source_refs": [{"chapter": 48, "line_start": 322, "line_end": 474}]},
  {"id": "evt_49_1", "name": "方宝玉闯白水宫", "participants": ["char_fang_bao_bao", "char_shui_xian_niang"], "location": "太行山白水宫", "description": "宝玉攀登迷峰天梯，两旁可见折断刀剑死人白骨。白水宫主的声音从天梯尽头传来。", "chapter": 49, "source_refs": [{"chapter": 49, "line_start": 1, "line_end": 152}]},
  {"id": "evt_50_1", "name": "公孙红被逼出海", "participants": ["char_gong_sun_hong", "char_wang_da_niang"], "location": "海上", "description": "公孙红败于王大娘手下被逼远离中土永不复返。与梅谦在船上对峙。", "chapter": 50, "source_refs": [{"chapter": 50, "line_start": 428, "line_end": 577}]},
  {"id": "evt_51_1", "name": "水天姬荒岛现身", "participants": ["char_shui_tian_ji", "char_hu_bu_chou", "char_jia_xing_fa_wang"], "location": "热带荒岛", "description": "水天姬在荒岛上与伽星大师胡不愁共处七年。胡不愁被关在铁舱中苦读紫衣侯武功秘笈。", "chapter": 51, "source_refs": [{"chapter": 51, "line_start": 334, "line_end": 418}]},
  {"id": "evt_53_1", "name": "万老夫人设计骗伽星大师", "participants": ["char_wan_lao_fu_ren", "char_jia_xing_fa_wang"], "location": "荒岛", "description": "万老夫人设计骗伽星大师拜她为干妈，以假毒梅子控制伽星大师。", "chapter": 53, "source_refs": [{"chapter": 53, "line_start": 1, "line_end": 314}]},
  {"id": "evt_54_1", "name": "胡不愁走出铁舱", "participants": ["char_hu_bu_chou", "char_shui_tian_ji"], "location": "荒岛", "description": "胡不愁走出铁舱七年暗室后的重见天日。一掌震飞伽星大师展现紫衣侯武功。", "chapter": 54, "source_refs": [{"chapter": 54, "line_start": 210, "line_end": 314}]},
  {"id": "evt_58_1", "name": "黑纱女自创绝招", "participants": ["char_fang_ling_yu", "char_fang_bao_bao"], "location": "星星小楼", "description": "黑纱女向宝玉展示自创的一招——置之死地而后生。从死角出招任何人不能抵挡。", "chapter": 58, "source_refs": [{"chapter": 58, "line_start": 462, "line_end": 490}]},
  {"id": "evt_60_1", "name": "方宝玉终极决战白衣人", "participants": ["char_fang_bao_bao", "char_bai_yi_ren"], "location": "东海海滨", "description": "宝玉与白衣人终极决战。宝玉以三招合一之法——倒地后从死角出剑。白衣人中剑倒地仰天狂笑好妙的一剑当真妙绝天下。临终之言：你永远不会知道你我这样的人活在世上是多么寂寞。", "chapter": 60, "source_refs": [{"chapter": 60, "line_start": 432, "line_end": 453}]}
]
