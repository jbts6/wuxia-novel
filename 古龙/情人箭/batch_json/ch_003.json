      "chapter": 3,
      "line_start": 98,
      "line_end": 98
    },
    {
      "speaker": "char_xiao_san_fu_ren",
      "speaker_name": "萧三夫人",
      "listener": null,
      "text": "萧三夫人",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 110,
      "line_end": 110
    },
    {
      "speaker": "char_xiao_san_fu_ren",
      "speaker_name": "萧三夫人",
      "listener": null,
      "text": "是又怎样，不是又怎样？",
      "tone": "淡然",
      "chapter": 3,
      "line_start": 118,
      "line_end": 118
    },
    {
      "speaker": "char_xiao_san_fu_ren",
      "speaker_name": "萧三夫人",
      "listener": null,
      "text": "哼",
      "tone": "陈述",
