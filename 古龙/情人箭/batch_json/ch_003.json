    },
    {
      "speaker": "char_zhan_meng_bai",
      "speaker_name": "展梦白",
      "listener": null,
      "text": "不知好歹的东西！",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 72,
      "line_end": 72
    },
    {
      "speaker": "char_fang_ju_mu",
      "speaker_name": "方巨木",
      "listener": null,
      "text": "你走回去，我便不来难为你。",
      "tone": "陈述",
