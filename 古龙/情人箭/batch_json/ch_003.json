      "line_start": 294,
      "line_end": 294
    },
    {
      "speaker": "char_fang_ju_mu",
      "speaker_name": "方巨木",
      "listener": null,
      "text": "叮，叮，叮，",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 296,
      "line_end": 296
    },
    {
