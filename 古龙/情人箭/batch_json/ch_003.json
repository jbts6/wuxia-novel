      "line_start": 302,
      "line_end": 302
    },
    {
      "speaker": "char_zhan_meng_bai",
      "speaker_name": "展梦白",
      "listener": null,
      "text": "不妨事！",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 316,
      "line_end": 316
    },
    {
      "speaker": "char_bai_yi_nv_zi",
      "speaker_name": "白衣女子",
      "listener": null,
      "text": "好强硬的男孩子！",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 318,
      "line_end": 318
    },
    {
      "speaker": "char_zhan_meng_bai",
      "speaker_name": "展梦白",
      "listener": null,
      "text": "前辈留步！",
