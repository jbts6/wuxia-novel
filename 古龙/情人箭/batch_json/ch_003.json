      "line_start": 320,
      "line_end": 320
    },
    {
      "speaker": "char_bai_yi_nv_zi",
      "speaker_name": "白衣女子",
      "listener": null,
      "text": "什么事？",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 322,
      "line_end": 322
    },
    {
      "speaker": "char_zhan_meng_bai",
      "speaker_name": "展梦白",
      "listener": null,
      "text": "救命之恩，不敢言报，只望夫人留下大名……",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 324,
      "line_end": 324
    },
    {
      "speaker": "char_bai_yi_nv_zi",
      "speaker_name": "白衣女子",
      "listener": null,
      "text": "那位萧夫人认得我的！",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 326,
      "line_end": 326
    },
    {
      "speaker": "char_zhan_meng_bai",
      "speaker_name": "展梦白",
      "listener": null,
      "text": "苏……夫人！",
      "tone": "陈述",
      "chapter": 3,
      "line_start": 330,
      "line_end": 330
    },
    {
      "speaker": "char_su_qian_xue",
      "speaker_name": "苏浅雪",
      "listener": null,
      "text": "你记得么？",
      "tone": "陈述",
