{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":null,"speaker_name":"蓝大先生","listener":null,"text":"当真是天网恢恢，疏而不漏……","tone":"喃喃","chapter":52,"line_start":4,"line_end":4},{"speaker":null,"speaker_name":"蓝大先生","listener":null,"text":"相交贵在知心，你既知我，我便不必多言，多言徒乱人意。","tone":"陈述","chapter":52,"line_start":6,"line_end":6},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"正该如此。","tone":"微笑","chapter":52,"line_start":10,"line_end":10},{"speaker":null,"speaker_name":"蓝大先生","listener":null,"text":"就此别过……","tone":"陈述","chapter":52,"line_start":12,"line_end":12},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"为何要走？","tone":"惊讶","chapter":52,"line_start":14,"line_end":14},{"speaker":null,"speaker_name":"蓝大先生","listener":null,"text":"此地我岂能再留？","tone":"黯然","chapter":52,"line_start":16,"line_end":16},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"今日一别，不知你要去何处？","tone":"无奈","chapter":52,"line_start":18,"line_end":18},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"更不知何时方能相见？","tone":"无奈","chapter":52,"line_start":20,"line_end":20},{"speaker":null,"speaker_name":"蓝大先生","listener":null,"text":"天地之广，何处不能容我，四海之大，何处不能相见……","tone":"朗声","chapter":52,"line_start":22,"line_end":22},{"speaker":null,"speaker_name":"蓝大先生","listener":null,"text":"小兄弟，今日之武林，是你的天下了……","tone":"大笑","chapter":52,"line_start":22,"line_end":22},{"speaker":null,"speaker_name":"绝红大师","listener":null,"text":"你可是要问她的下落？","tone":"微笑","chapter":52,"line_start":34,"line_end":34},{"speaker":null,"speaker_name":"绝红大师","listener":null,"text":"她就会来的。","tone":"陈述","chapter":52,"line_start":38,"line_end":38},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"她……她在……","tone":"犹豫","chapter":52,"line_start":44,"line_end":44},{"speaker":null,"speaker_name":"乐朝阳","listener":null,"text":"四山埋伏，至少有四百人。","tone":"沉声","chapter":52,"line_start":48,"line_end":48},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"四百人……","tone":"陈述","chapter":52,"line_start":52,"line_end":52},{"speaker":null,"speaker_name":"杜云天","listener":null,"text":"敌众我寡，只怕……唉，若要杀光了他们倒也容易，若要击退他们，却是难如登天。","tone":"无奈","chapter":52,"line_start":54,"line_end":54},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"不但如此，以此脚步之声听来，这四百人之中，不乏一流高手，以我数人之力，即使要想将之杀光，只怕也不容易。","tone":"叹","chapter":52,"line_start":60,"line_end":60},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"那边有人来……呀，似乎是李冠英与孟如丝两人，他们怎会在这里？","tone":"惊讶","chapter":52,"line_start":64,"line_end":64},{"speaker":null,"speaker_name":"李冠英","listener":null,"text":"展……展兄，快……快下山吧！","tone":"焦急","chapter":52,"line_start":68,"line_end":68},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"还未上山，怎能下山？","tone":"陈述","chapter":52,"line_start":72,"line_end":72},{"speaker":null,"speaker_name":"李冠英","listener":null,"text":"苏……苏夫人已在此地布下数道埋伏，第一道似有四百人之多，若要上山，只怕……","tone":"叹","chapter":52,"line_start":74,"line_end":74},{"speaker":null,"speaker_name":"孟如丝","listener":null,"text":"苏夫人在我两人无处投身之时收容了咱们，固是大恩大德，但展……展大侠你对咱们，更是义重如山，是以咱们纵然冒了性命危险，也得赶来通知展大侠一声，展大侠你即使要将她除去，也不急在今天。","tone":"焦急","chapter":52,"line_start":76,"line_end":76},{"speaker":null,"speaker_name":"李冠英","listener":null,"text":"咱们在山上这几日，已多多少少知道她一些秘密，她虽然该死，但来日方长，展兄你……","tone":"焦急","chapter":52,"line_start":80,"line_end":80},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"我等既已来到这里，已是有生无回，纵然战死，也得一战。","tone":"豪迈","chapter":52,"line_start":82,"line_end":82},{"speaker":null,"speaker_name":"杜云天","listener":null,"text":"展梦白倒不愧是帝王谷主女婿。","tone":"微笑","chapter":52,"line_start":86,"line_end":86},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"看来倒和你这有去无回的离弦箭有些相似。","tone":"微笑","chapter":52,"line_start":90,"line_end":90},{"speaker":null,"speaker_name":"乐朝阳","listener":null,"text":"这是什么人？","tone":"惊讶","chapter":52,"line_start":98,"line_end":98},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"我在这里。","tone":"陈述","chapter":52,"line_start":100,"line_end":100}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"萧老大，你……你快救他一救，此人已快死了，除你之外，无人救得了他。","tone":"焦急","chapter":52,"line_start":104,"line_end":104},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"谁受了伤？且放下他来。","tone":"陈述","chapter":52,"line_start":108,"line_end":108},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"你瞧瞧这是谁？","tone":"陈述","chapter":52,"line_start":110,"line_end":110},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"是他？是谁伤得了他？","tone":"惊讶","chapter":52,"line_start":114,"line_end":114},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"还有谁，除了那无影枪外还有谁？但无影枪也被他利刃所伤，伤的并未见得比他轻。","tone":"叹","chapter":52,"line_start":116,"line_end":116},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"杨飞在哪里？你怎会遇着他们？","tone":"疑问","chapter":52,"line_start":120,"line_end":120},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"我遇着他两人时，两人显然已拼过生死，都已重伤，只有杨飞的徒弟杨成守护在侧，杨成那时若是杀了吴七，实是易如反掌，但他却不愧是条汉子，竟不肯乘人之危，见我到了那里，便将他师傅抱走，还求我无论如何，也要将吴七救活，为教他以后亲手复仇，唉……这小子端的有种得很。","tone":"叹","chapter":52,"line_start":122,"line_end":122},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"你又怎会到了这里？","tone":"疑问","chapter":52,"line_start":126,"line_end":126},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"这却是咱们小兄弟的心上人说的。","tone":"微笑","chapter":52,"line_start":128,"line_end":128},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"前辈在哪里遇着了她？她怎的还不上山来？","tone":"焦急","chapter":52,"line_start":132,"line_end":132},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"吴七、杨飞受伤之地，便在洞庭湖边，那位萧姑娘，也在那里逛来逛去，像是在等人似的。","tone":"陈述","chapter":52,"line_start":136,"line_end":136},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"她等……","tone":"犹豫","chapter":52,"line_start":140,"line_end":140},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"小女等的是谁？","tone":"疑问","chapter":52,"line_start":142,"line_end":142},{"speaker":null,"speaker_name":"绝红大师","listener":null,"text":"少时您自知道。","tone":"微笑","chapter":52,"line_start":144,"line_end":144},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"我受人之托，忠人之事，听得萧老大在山上，便急急赶来，除了萧老大外又有谁能医得了吴七的伤势，哪知吴七这厮虽已半晕半迷，却偏偏不肯上山，嘴里只是说：求你带我去找丝丝，我死也要见丝丝最后一面。我怎知丝丝是谁，因此不管三七二十一将他带上山来。","tone":"叹","chapter":52,"line_start":146,"line_end":146},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"这伤还有救么？","tone":"疑问","chapter":52,"line_start":156,"line_end":156},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"性命虽可保全，但他那一身武功，只怕从此……唉。","tone":"叹","chapter":52,"line_start":158,"line_end":158},{"speaker":null,"speaker_name":"孟如丝","listener":null,"text":"我在这里……我在这里……","tone":"悲痛","chapter":52,"line_start":170,"line_end":170},{"speaker":null,"speaker_name":"吴七","listener":null,"text":"你……你莫要走……","tone":"温柔","chapter":52,"line_start":172,"line_end":172},{"speaker":null,"speaker_name":"孟如丝","listener":null,"text":"丝丝不走……丝丝永远陪着你……","tone":"悲痛","chapter":52,"line_start":174,"line_end":174},{"speaker":null,"speaker_name":"吴七","listener":null,"text":"好……","tone":"温柔","chapter":52,"line_start":176,"line_end":176},{"speaker":null,"speaker_name":"孟如丝","listener":null,"text":"大哥，我……我不能再跟着你了，我……你……我……","tone":"悲伤","chapter":52,"line_start":180,"line_end":180},{"speaker":null,"speaker_name":"李冠英","listener":null,"text":"我知道。","tone":"苦笑","chapter":52,"line_start":182,"line_end":182},{"speaker":null,"speaker_name":"孟如丝","listener":null,"text":"你……你知道就好……","tone":"悲伤","chapter":52,"line_start":184,"line_end":184},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"李兄，你……","tone":"无奈","chapter":52,"line_start":194,"line_end":194},{"speaker":null,"speaker_name":"李冠英","listener":null,"text":"李某此身已无牵挂，正可与恶贼决一死战。","tone":"豪迈","chapter":52,"line_start":196,"line_end":196},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"好汉子……","tone":"认真","chapter":52,"line_start":200,"line_end":200}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"伶伶……伶伶……","tone":"焦急","chapter":52,"line_start":202,"line_end":202},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"伶伶，好苦命的孩子，大叔永远不会忘记你的……","tone":"悲伤","chapter":52,"line_start":212,"line_end":212},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"与其等他们杀过来，不如咱们杀过去。","tone":"沉声","chapter":52,"line_start":222,"line_end":222},{"speaker":null,"speaker_name":"群豪","listener":null,"text":"说得好。","tone":"豪迈","chapter":52,"line_start":226,"line_end":226},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"看来也只有如此，不知三位大师……","tone":"无奈","chapter":52,"line_start":228,"line_end":228},{"speaker":null,"speaker_name":"断红大师","listener":null,"text":"咱们虽然身在方外，此事也要管的，妹子……不，师姐，你说是么？","tone":"认真","chapter":52,"line_start":230,"line_end":230},{"speaker":null,"speaker_name":"绝红大师","listener":null,"text":"佛门中人，并未忘了降魔手段。","tone":"严肃","chapter":52,"line_start":234,"line_end":234},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"好！杜兄与我带着梦白前冲，三位大师断后，乐大侠率领群豪居中，首尾切莫失了连络。","tone":"认真","chapter":52,"line_start":236,"line_end":236},{"speaker":null,"speaker_name":"乐朝阳","listener":null,"text":"全凭前辈做主。","tone":"认真","chapter":52,"line_start":240,"line_end":240},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"冲！","tone":"厉声","chapter":52,"line_start":242,"line_end":242},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"咱们若再冲不上去，只怕苏浅雪便要逃了。","tone":"焦急","chapter":52,"line_start":270,"line_end":270},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"她有心在此山中将已知情人箭秘密之人一举而灭，此刻万万不会逃走的，怕只怕……","tone":"沉声","chapter":52,"line_start":274,"line_end":274},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"我等此番血战之后，纵能冲出，已是精力交疲，哪里还能冲过后面几道埋伏？","tone":"叹","chapter":52,"line_start":276,"line_end":276},{"speaker":null,"speaker_name":"杜云天","listener":null,"text":"纵然有人能够冲过，但见到苏浅雪时，只怕连刀都举不起来，哪里还能厮杀？","tone":"黯然","chapter":52,"line_start":280,"line_end":280},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"纵然如此，咱们也只有冲得一步是一步了。","tone":"豪迈","chapter":52,"line_start":284,"line_end":284},{"speaker":null,"speaker_name":"玉空子","listener":null,"text":"你不妨事么？","tone":"担心","chapter":52,"line_start":298,"line_end":298},{"speaker":null,"speaker_name":"乐朝阳","listener":null,"text":"区区一条伤口，算得了什么？","tone":"豪迈","chapter":52,"line_start":300,"line_end":300}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":null,"speaker_name":"乐朝阳","listener":null,"text":"……兄……弟，你莫管我，快……快去干吧。","tone":"痛苦","chapter":52,"line_start":306,"line_end":306},{"speaker":null,"speaker_name":"乐朝阳","listener":null,"text":"兄……弟，我……我还能厮杀，快放开手。","tone":"焦急","chapter":52,"line_start":312,"line_end":312},{"speaker":null,"speaker_name":"玉空子","listener":null,"text":"今日我虽已抱定决心，战死为止，但却不能让大哥你死在我之前……","tone":"认真","chapter":52,"line_start":316,"line_end":316},{"speaker":null,"speaker_name":"莫忘我","listener":null,"text":"萧老大，展梦白。我老头子与天马大和尚来了。","tone":"大声","chapter":52,"line_start":320,"line_end":320},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"来得好……来得好！","tone":"大笑","chapter":52,"line_start":324,"line_end":324},{"speaker":null,"speaker_name":"大鲨鱼","listener":null,"text":"展梦白，展兄弟，大鲨鱼率领太湖众家兄弟，为你助拳来了。","tone":"大声","chapter":52,"line_start":326,"line_end":326},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"来得好……来得好！","tone":"大笑","chapter":52,"line_start":330,"line_end":330},{"speaker":null,"speaker_name":"乐朝阳","listener":null,"text":"兄弟，这一下咱们都不必死了。","tone":"欣慰","chapter":52,"line_start":332,"line_end":332},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"大鲨鱼，你好么？","tone":"大笑","chapter":52,"line_start":340,"line_end":340},{"speaker":null,"speaker_name":"大鲨鱼","listener":null,"text":"好，好，待杀完这些畜生，再和你痛饮三百杯。","tone":"大笑","chapter":52,"line_start":342,"line_end":342},{"speaker":null,"speaker_name":"大鲨鱼","listener":null,"text":"白布旗一般奴才，又戴着白帽子在山下出现了，俺若非急着上来，少不得先和他们打一架。","tone":"陈述","chapter":52,"line_start":346,"line_end":346},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"幸好你未曾与他们厮打，否则便变成大水淹倒龙王庙，自家人打自家人了。","tone":"微笑","chapter":52,"line_start":350,"line_end":350},{"speaker":null,"speaker_name":"大鲨鱼","listener":null,"text":"莫非那些奴才也……","tone":"惊讶","chapter":52,"line_start":354,"line_end":354},{"speaker":null,"speaker_name":"熊正雄","listener":null,"text":"萧老前辈、展大侠，熊正雄与布旗门兄弟为两位效力来了。","tone":"大声","chapter":52,"line_start":356,"line_end":356},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"有劳三位大师在此压住脚阵，莫老人与马大师、杜兄、铁老弟，与梦白且随我先上山去。","tone":"认真","chapter":52,"line_start":366,"line_end":366},{"speaker":null,"speaker_name":"大鲨鱼","listener":null,"text":"前辈放心，将这些畜生都交给大鲨鱼就是。","tone":"豪迈","chapter":52,"line_start":370,"line_end":370},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"走！","tone":"厉声","chapter":52,"line_start":374,"line_end":374},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"驼子我来开路。","tone":"豪迈","chapter":52,"line_start":376,"line_end":376},{"speaker":null,"speaker_name":"萧飞雨","listener":null,"text":"还有我呢？","tone":"娇笑","chapter":52,"line_start":378,"line_end":378},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"飞……雨，你……你何时来的？","tone":"激动","chapter":52,"line_start":382,"line_end":382},{"speaker":null,"speaker_name":"萧飞雨","listener":null,"text":"分别之后，我伤势立刻好了，才知道师父早已令人快马传柬江湖，我到了这里，便在山下等候莫大伯和大鲨鱼他们，好带他们上山，只是你……你呀，我到了你身旁你都不知道。","tone":"娇嗔","chapter":52,"line_start":386,"line_end":386},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"我……我……","tone":"激动","chapter":52,"line_start":390,"line_end":390},{"speaker":null,"speaker_name":"天马和尚","listener":null,"text":"小伙子，走吧，要聊等到明天也不迟，何况明天之后还不知有多少个明天在等着你们哩！","tone":"大笑","chapter":52,"line_start":392,"line_end":392},{"speaker":null,"speaker_name":"铁驼","listener":null,"text":"苏浅雪若是在这里弄成滚木擂石，咱们可惨了，幸好没有。","tone":"陈述","chapter":52,"line_start":398,"line_end":398}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":null,"speaker_name":"柳轻絮","listener":null,"text":"展梦白，滚木要来了，你等死吧！","tone":"大声","chapter":52,"line_start":402,"line_end":402},{"speaker":null,"speaker_name":"林软红","listener":null,"text":"秦琪死了……秦琪死了……你们走吧……你们走吧……","tone":"喃喃","chapter":52,"line_start":420,"line_end":420},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"贵宾远来，怎的不通知贱妾一声，好教贱妾恭迎大驾。","tone":"微笑","chapter":52,"line_start":428,"line_end":428},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"真人面前不说假话，各位既然来到这里，贱妾若再隐隐藏藏，推推托托，自己先觉不好意思，各位有什么话只管问吧，贱妾只要知道，必定从实说出，各位俱是前辈英雄，萧老前辈更是侠中清流，想必也不会对妇道人家太过无礼。","tone":"微笑","chapter":52,"line_start":436,"line_end":436},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"夫人既是人中之杰，在下等自也不愿以俗人相待夫人，只是有些话在下等虽已知道，却仍不得不再问一声。","tone":"认真","chapter":52,"line_start":442,"line_end":442},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"请问。","tone":"微笑","chapter":52,"line_start":446,"line_end":446},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"不知夫人可是那情人箭之主？","tone":"严肃","chapter":52,"line_start":448,"line_end":448},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"正是。","tone":"含笑","chapter":52,"line_start":450,"line_end":450},{"speaker":null,"speaker_name":"萧飞雨","listener":null,"text":"问完再动手也不迟。","tone":"低语","chapter":52,"line_start":454,"line_end":454},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"夫人确是快人，但在下还有件不情之请，要想请教夫人，那情人箭究竟有何秘密魔力？竟能令天下为之震动？","tone":"严肃","chapter":52,"line_start":458,"line_end":458},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"此事说来，倒也有趣得很，我得分几条来说，才能说得清楚。","tone":"微笑","chapter":52,"line_start":462,"line_end":462},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"我小时便常听人说起一些昔日武林雄主的故事，却从未听过有个女的，于是我便想做第一个武林女王，直到我长大后，与唐迪一见钟情，才开始将这想法淡忘。","tone":"陈述","chapter":52,"line_start":468,"line_end":468},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"我与唐迪婚事若是能成，此事也就罢了，哪知我与唐迪相恋时，唐无影竟已为唐迪订下了婚事，唐迪自不敢反抗那专横的老人，我一怒之下，便决心要将那幼时的想法实现，便用尽各种手段，令一些武林中一流高手不得不拜倒在我裙下，好教他们日后不敢与我作对，而我与每一人分手时，都与他们约定一个暗记以为标志，日后他们只要瞧着这暗记，就如同瞧见我一样。","tone":"陈述","chapter":52,"line_start":470,"line_end":470},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"经过十数年的时间，江湖中与我有交情的武林高手已不少了，我又求得一种最毒的毒药秘方，于是我便开始炼制情人箭，这情人箭除了奇毒无比外，本无什么秘方，于是我便想尽办法，增加它的神秘之感，故意将它染成红、黑两色，故意只在月圆时才令它出现，至于发射情人箭的机簧弩筒，却是唐迪监工所制的，唐门暗器世家，他监制的弩筒劲力自比别人强些。","tone":"陈述","chapter":52,"line_start":472,"line_end":472},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"更厉害的是，那弩筒机簧乃是以烂铁柔钢所制，是以发射时绝无声息。","tone":"陈述","chapter":52,"line_start":474,"line_end":474},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"所有的玄妙之处，都在那死神帖上，那死神帖每张看来，虽都一样，其实眼睛里却有些不同，只因我将昔日与那些武林高手约定的暗记，以碧磷画在那骷髅双目之中，情人箭制成，我便拿那些与我有交情的武林高手开刀，他们一接到那奇异死神帖，已是一怔，再瞧那骷髅双目中的暗记，又是一怔，我便乘他们这怔神之际，将暗器无声无息地发射而出，竟然全都成功，只因他们都认为昔日与我交往，乃是件亏心事，是以一见那暗记，便已失常。","tone":"陈述","chapter":52,"line_start":476,"line_end":476},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"如此经过数月之久，武林中便已有数十高手伤在那情人箭下，情人箭神奇的声名，立刻四面八方地传送了出去，再加上我那些故意的做作，使它更平添许多神奇的魔力，这时我便令秦瘦翁在暗中将情人箭发售，一些想秘密寻仇的人，都是我的主顾。","tone":"陈述","chapter":52,"line_start":478,"line_end":478},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"他们所用的死神帖，自然已无暗记，但这时武林中人都已认为情人箭与死神帖必定有种神秘的魔力，是以一接死神帖，心已慌了，心神一慌，自然容易被暗器射中，这期间当然也有些未能成功的例子，但人们总是有种劣根性，惟恐天下不乱，一传十，十传百，将情人箭越说越是神奇，千方百计要来购买情人箭之人，也越来越多！","tone":"陈述","chapter":52,"line_start":480,"line_end":480},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"买箭的人越多，死在情人箭下的人自也越多，如此因果循环，终于使得江湖中人谈箭色变，而买了我情人箭的人，少不得要为我吹嘘，为我效力，这就是情人箭那神秘魔力的由来……唉，有些事说穿了虽然不值一文，但这谜底若不揭开，谁也不能完全确定自己能猜中它的秘密！","tone":"陈述","chapter":52,"line_start":482,"line_end":482},{"speaker":null,"speaker_name":"萧飞雨","listener":null,"text":"唐凤唐姑娘在哪里？","tone":"疑问","chapter":52,"line_start":488,"line_end":488},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"死了，被唐迪杀了，他不但杀了自己的女儿，也杀了他爹爹，这一切都是为了我。","tone":"陈述","chapter":52,"line_start":490,"line_end":490},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"先父……","tone":"愤怒","chapter":52,"line_start":496,"line_end":496},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"展化雨也是我杀死的。","tone":"淡然","chapter":52,"line_start":498,"line_end":498}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":501,"line_end":569,"dialogues":[{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"少年人，你且坐下来，我既然挡不住你们，早已没有心活了，也不必你费力动手。","tone":"淡然","chapter":52,"line_start":502,"line_end":502},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"我与唐迪，俱是罪大恶极，本就该死，死时能有各位如此显赫的人物殉葬，更是荣幸之至。","tone":"冷笑","chapter":52,"line_start":506,"line_end":506},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"你说什么？","tone":"惊讶","chapter":52,"line_start":510,"line_end":510},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"这庄院一里方圆之内，都埋有极厉害的炸药，引线布在厅外，都有专人看守，只要我一声令下，咱们这些人便都要被炸成粉末。","tone":"狞笑","chapter":52,"line_start":512,"line_end":512},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"这便是我三十年布置之最后一着，本来是不想用的，但事已至此，却不得不用了。哈哈，各位来到这里，插翅也难飞出去了。","tone":"狞笑","chapter":52,"line_start":514,"line_end":514},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"那点燃引线之人，难道也不想活了么？","tone":"疑问","chapter":52,"line_start":522,"line_end":522},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"那四人俱是自告奋勇，要接这差事的，只因你们若是不死，他四人终必要死在你们的手下，倒不如与你们同时而死，以方辛、方逸、柳淡烟、孙玉佛四条命，来换萧王孙、杜云天、铁驼、莫忘我四条，总是划算的，我与唐迪一生什么福都享过，展梦白与萧飞雨却正是如日方中，以我两人换他两人，也已够本，何况还要加上个大名鼎鼎的天马和尚。","tone":"狞笑","chapter":52,"line_start":524,"line_end":524},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"情人箭光了，咱们也完了，放吧……放吧……放吧……","tone":"狂笑","chapter":52,"line_start":530,"line_end":530},{"speaker":null,"speaker_name":"萧王孙","listener":null,"text":"莫让她点引线。","tone":"厉声","chapter":52,"line_start":536,"line_end":536},{"speaker":null,"speaker_name":"孙玉佛等","listener":null,"text":"苏夫人，抱歉得很，咱们还不想死，此后必定妥妥当当藏起来，待机而动，药引也是咱们弄湿的，只因咱们生怕还未出炸药范围，引线便被夫人点燃。展梦白、萧王孙，咱们今日救了你一命，你可千万莫要忘记。苏夫人、唐迪，后会有期，再见吧！","tone":"陈述","chapter":52,"line_start":542,"line_end":542},{"speaker":null,"speaker_name":"展梦白","listener":null,"text":"苏浅雪，你……","tone":"愤怒","chapter":52,"line_start":552,"line_end":552},{"speaker":null,"speaker_name":"苏浅雪","listener":null,"text":"谁也杀不了我……","tone":"狂笑","chapter":52,"line_start":554,"line_end":554}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
