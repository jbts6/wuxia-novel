{"segment":10,"line_start":901,"line_end":1000,"dialogues":[{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"那株忘忧草呢？","tone":"陈述","chapter":3,"line_start":904,"line_end":904},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"那就是忘忧草？","tone":"陈述","chapter":3,"line_start":914,"line_end":914},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"是的。","tone":"陈述","chapter":3,"line_start":916,"line_end":916},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"这只不过是棵毒草而已，想不到也如此珍贵。","tone":"陈述","chapter":3,"line_start":922,"line_end":922},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"你说是不是？","tone":"陈述","chapter":3,"line_start":928,"line_end":928},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"是的。","tone":"陈述","chapter":3,"line_start":930,"line_end":930},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"难道那是神？","tone":"陈述","chapter":3,"line_start":942,"line_end":942},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"那只不过是一只鹰！","tone":"陈述","chapter":3,"line_start":944,"line_end":944},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"鹰为什么要来找忘忧草？难道鹰也有忧愁烦恼？","tone":"陈述","chapter":3,"line_start":946,"line_end":946}],"new_entities":{"characters":[{"id":"char_qing_qing","name":"青青","alias":[],"identity":"江湖人士","faction":"未知","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"青青是本章出现的角色","personality":{"traits":["神秘","强大","冷酷","机智","果断"],"speech_style":"正式","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":901,"line_end":1000,"text":"第3章中出现"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_wang_you_cao","name":"忘忧草","type":"special","owner":null,"one_line":"能让人忘记所有忧愁烦恼的神奇植物","description":"每年只长一次，每次只有三片叶子，碧绿比翡翠还绿，比花更美","effects":["忘记忧愁"],"origin":"忧愁谷","rarity"