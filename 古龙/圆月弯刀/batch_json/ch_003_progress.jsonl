{"segment":11,"line_start":1001,"line_end":1100,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"刚才惊走我儿子的人就是你？","tone":"陈述","chapter":3,"line_start":1026,"line_end":1026},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"那不是鸟，是鹰，是神鹰，是鹰中的神。","tone":"陈述","chapter":3,"line_start":1032,"line_end":1032},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"鹰也是鸟，你的儿子是鸟，难道你也是只鸟？","tone":"陈述","chapter":3,"line_start":1036,"line_end":1036},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"哦！","tone":"陈述","chapter":3,"line_start":1054,"line_end":1054},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"可是我不杀你！","tone":"陈述","chapter":3,"line_start":1056,"line_end":1056},{"speaker":null,"speaker_name":null,"listener":null,"text":"因为这世上够资格让我杀的，已经只剩下两个人。","tone":"陈述","chapter":3,"line_start":1058,"line_end":1058},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"哎呀！","tone":"陈述","chapter":3,"line_start":1060,"line_end":1060},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"哎呀是什么意思？","tone":"陈述","chapter":3,"line_start":1062,"line_end":1062},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"哎呀的意思，就是你如果真要杀我，还是可以杀我！","tone":"陈述","chapter":3,"line_start":1064,"line_end":1064},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"为什么？","tone":"陈述","chapter":3,"line_start":1066,"line_end":1066},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"因为我根本不是人。","tone":"陈述","chapter":3,"line_start":1068,"line_end":1068},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"你是什么东西？","tone":"陈述","chapter":3,"line_start":1070,"line_end":1070},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"我也不是东西，我是狐。","tone":"陈述","chapter":3,"line_start":1072,"line_end":1072},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"狐鬼异类，更不配让我老人家拔剑！","tone":"陈述","chapter":3,"line_start":1074,"line_end":1074},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"为什么。","tone":"陈述","chapter":3,"line_start":1086,"line_end":1086},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"拿来！","tone":"陈述","chapter":3,"line_start":1096,"line_end":1096},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"拿什么？","tone":"陈述","chapter":3,"line_start":1098,"line_end":1098},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"你的刀。","tone":"陈述","chapter":3,"line_start":1100,"line_end":1100}],"new_entities":{"characters":[{"id":"char_qing_qing","name":"青青","alias":[],"identity":"江湖人士","faction":"未知","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"青青是本章出现的角色","personality":{"traits":["神秘","强大","冷酷","机智","果断"],"speech_style":"正式","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":1001,"line_end":1100,"text":"第3章中出现"}]},{"id":"char_jin_pao_lao_ren","name":"金袍老人","alias":[],"identity":"江湖人士","faction":"未知","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"金袍老人是本章出现的角色","personality":{"traits":["神秘","强大","冷酷","机智","果断"],"speech_style":"正式","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":1001,"line_end":1100,"text":"第3章中出现"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_wang_you_cao","name":"忘忧草","type":"special","owner":null,"one_line":"能让人忘记所有忧愁烦恼的神奇植物","description":"每年只长一次，每次只有三片叶子，碧绿比翡翠还绿，比花更美","effects":["忘记忧愁"],"origin":"忧愁谷","rarity":"稀世珍品","related_characters":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":1001,"line_end":1100,"text":"忘忧草的描述"}]}]},"entity_updates":[]}
{"segment":12,"line_start":1101,"line_end":1157,"dialogues":[{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"我为什么要把我的刀拿给你？","tone":"陈述","chapter":3,"line_start":1102,"line_end":1102},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"因为我要看看。","tone":"陈述","chapter":3,"line_start":1104,"line_end":1104},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"现在你已经看见了。","tone":"陈述","chapter":3,"line_start":1106,"line_end":1106},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"我想看的是刀，不是刀鞘。","tone":"陈述","chapter":3,"line_start":1108,"line_end":1108},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"我劝你，只看看刀鞘就很不错了，绝不要看这把刀。","tone":"陈述","chapter":3,"line_start":1110,"line_end":1110},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"为什么？","tone":"陈述","chapter":3,"line_start":1112,"line_end":1112},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"因为这把刀是绝对看不得的。","tone":"陈述","chapter":3,"line_start":1114,"line_end":1114},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"不是，绝不是，你还年轻，你太年轻。","tone":"陈述","chapter":3,"line_start":1130,"line_end":1130},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"你是不是认得一个很像我的人？","tone":"陈述","chapter":3,"line_start":1132,"line_end":1132},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"我不认得你，我只认得这把刀，我绝不会认错的，绝不会……","tone":"陈述","chapter":3,"line_start":1134,"line_end":1134},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"这把刀上是不是刻着七个字？","tone":"陈述","chapter":3,"line_start":1136,"line_end":1136},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"哪七个字？","tone":"疑问","chapter":3,"line_start":1138,"line_end":1138},{"speaker":"char_jin_pao_lao_ren","speaker_name":"金袍老人","listener":null,"text":"小楼一夜听春雨。","tone":"陈述","chapter":3,"line_start":1140,"line_end":1140},{"speaker":null,"speaker_name":null,"listener":null,"text":"欲说还休","tone":"陈述","chapter":3,"line_start":1148,"line_end":1148}],"new_entities":{"characters":[{"id":"char_qing_qing","name":"青青","alias":[],"identity":"江湖人士","faction":"未知","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"青青是本章出现的角色","personality":{"traits":["神秘","强大","冷酷","机智","果断"],"speech_style":"正式","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":1101,"line_end":1157,"text":"第3章中出现"}]},{"id":"char_jin_pao_lao_ren","name":"金袍老人","alias":[],"identity":"江湖人士","faction":"未知","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"金袍老人是本章出现的角色","personality":{"traits":["神秘","强大","冷酷","机智","果断"],"speech_style":"正式","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":1101,"line_end":1157,"text":"第3章中出现"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
