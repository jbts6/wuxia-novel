{"segment":6,"line_start":501,"line_end":600,"dialogues":[{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"是七月，七月十五日。","tone":"陈述","chapter":3,"line_start":574,"line_end":574},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"你是鬼？","tone":"陈述","chapter":3,"line_start":586,"line_end":586},{"speaker":null,"speaker_name":null,"listener":null,"text":"你看我像不像是个鬼？","tone":"陈述","chapter":3,"line_start":588,"line_end":588},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"你是天上的仙子？","tone":"陈述","chapter":3,"line_start":592,"line_end":592},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"不管怎么样，你绝不会是人。","tone":"陈述","chapter":3,"line_start":598,"line_end":598},{"speaker":null,"speaker_name":null,"listener":null,"text":"我当然不是人。","tone":"陈述","chapter":3,"line_start":600,"line_end":600}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":601,"line_end":700,"dialogues":[{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"你……你是什么？","tone":"陈述","chapter":3,"line_start":602,"line_end":602},{"speaker":null,"speaker_name":null,"listener":null,"text":"我是狐。","tone":"陈述","chapter":3,"line_start":604,"line_end":604},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"狐？","tone":"陈述","chapter":3,"line_start":606,"line_end":606},{"speaker":null,"speaker_name":null,"listener":null,"text":"难道你从来没有听见过这世上有'狐'？","tone":"陈述","chapter":3,"line_start":608,"line_end":608},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"狐","tone":"陈述","chapter":3,"line_start":610,"line_end":610},{"speaker":null,"speaker_name":null,"listener":null,"text":"狐","tone":"陈述","chapter":3,"line_start":620,"line_end":620},{"speaker":null,"speaker_name":null,"listener":null,"text":"你觉得这种事很好笑？","tone":"疑问","chapter":3,"line_start":636,"line_end":636},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"这种事并不好笑，可是你也吓不倒我的。","tone":"陈述","chapter":3,"line_start":638,"line_end":638},{"speaker":null,"speaker_name":null,"listener":null,"text":"哦？","tone":"陈述","chapter":3,"line_start":640,"line_end":640},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"因为我根本不怕你，不管你是鬼是狐，我都不怕你。","tone":"陈述","chapter":3,"line_start":642,"line_end":642},{"speaker":null,"speaker_name":null,"listener":null,"text":"人人都怕鬼狐，为什么你偏偏不怕？","tone":"陈述","chapter":3,"line_start":644,"line_end":644},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"因为我反正也要死了。","tone":"陈述","chapter":3,"line_start":646,"line_end":646},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"一点都不错！","tone":"陈述","chapter":3,"line_start":656,"line_end":656},{"speaker":null,"speaker_name":null,"listener":null,"text":"可是一个人年纪轻轻，为什么要死呢？","tone":"陈述","chapter":3,"line_start":658,"line_end":658},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"年纪轻轻的人，有时也会想死的。","tone":"陈述","chapter":3,"line_start":660,"line_end":660},{"speaker":null,"speaker_name":null,"listener":null,"text":"你真的想死？","tone":"陈述","chapter":3,"line_start":662,"line_end":662},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"真的！","tone":"陈述","chapter":3,"line_start":664,"line_end":664},{"speaker":null,"speaker_name":null,"listener":null,"text":"你非死不可？","tone":"陈述","chapter":3,"line_start":666,"line_end":666},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"非死不可！","tone":"陈述","chapter":3,"line_start":668,"line_end":668},{"speaker":null,"speaker_name":null,"listener":null,"text":"可惜，你忘了一件事！","tone":"陈述","chapter":3,"line_start":670,"line_end":670},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"什么事？","tone":"陈述","chapter":3,"line_start":672,"line_end":672},{"speaker":null,"speaker_name":null,"listener":null,"text":"现在你还没有死，还是个人。","tone":"陈述","chapter":3,"line_start":674,"line_end":674},{"speaker":null,"speaker_name":null,"listener":null,"text":"我却是狐，是个狐仙，我有法力，你没有，所以，我若不要你死，你就绝对死不了，除非……","tone":"陈述","chapter":3,"line_start":678,"line_end":678},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"除非怎么样？","tone":"陈述","chapter":3,"line_start":680,"line_end":680},{"speaker":null,"speaker_name":null,"listener":null,"text":"除非你先告诉我，是什么事让你非死不可。","tone":"陈述","chapter":3,"line_start":682,"line_end":682},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"我本来就是。","tone":"陈述","chapter":3,"line_start":700,"line_end":700}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":701,"line_end":800,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"你叫什么名字？","tone":"疑问","chapter":3,"line_start":702,"line_end":702},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"你为什么要问我的名字？","tone":"疑问","chapter":3,"line_start":704,"line_end":704},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"你为什么不先把你的名字告诉我，狐也应该有名字的。","tone":"陈述","chapter":3,"line_start":710,"line_end":710},{"speaker":null,"speaker_name":null,"listener":null,"text":"我有名字，我告诉你。","tone":"陈述","chapter":3,"line_start":712,"line_end":712},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"我叫青青。","tone":"陈述","chapter":3,"line_start":714,"line_end":714},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"你也用刀？","tone":"疑问","chapter":3,"line_start":736,"line_end":736},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"我为什么不能用刀？","tone":"陈述","chapter":3,"line_start":738,"line_end":738},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"你杀过人？","tone":"陈述","chapter":3,"line_start":740,"line_end":740},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"会用刀的人，并不一定都要杀人的。","tone":"陈述","chapter":3,"line_start":742,"line_end":742},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"杀人的人，也并不一定都要用刀。","tone":"陈述","chapter":3,"line_start":744,"line_end":744},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"你遇到过这种人？","tone":"陈述","chapter":3,"line_start":748,"line_end":748},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"嗯！","tone":"陈述","chapter":3,"line_start":750,"line_end":750},{"speaker":"char_qing_qing","speaker_name":"青青","listener":null,"text":"所以他虽然没有用刀杀你，你还是非死不可。","tone":"陈述","chapter":3,"line_start":752,"line_end":752},{"speaker":"char_ding_peng","speaker_name":"丁鹏","listener":null,"text":"我倒宁愿他用刀杀了我。","tone":"陈述","chapter":3,"line_start":754,