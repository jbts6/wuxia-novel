  {
    "id": "faction_lian_yun_shi_si_sha",
    "name": "连云十四煞",
    "type": "帮派",
    "location": "江湖各地",
    "sub_divisions": [],
    "one_line": "黑道中被称为煞星的杀手组织，江湖口碑却誉为盗中君子",
