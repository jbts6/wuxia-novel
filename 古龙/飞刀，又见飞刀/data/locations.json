    ],
    "source_refs": [
      {
        "chapter": 9,
        "anchor": "高地帐篷公孙夜宴",
        "event_type": "first_mention",
        "line_start": 247,
        "line_end": 251,
        "text": "　　铁银衣还没有开口，李坏已经闪电般出手，从那个织锦缎的盒子里，把那个致命的豆子抢了过来。豆子从他掌心里面一下子弹起，弹入他的嘴，一下子就被他吞进了肚子。就好像一个半醉的酒鬼在吃花生米一样。然后又笑嘻嘻地问铁银衣。\n\n　　“现在是我抢不走你的豆子，还是你抢不走我的豆子？”\n\n　　铁银衣变色。",
        "anchors_hit": [
          "公孙"
        ],
        "anchors_total": 2,
        "locate_status": "located_chapter_level",
        "locate_score": 74,
        "locate_method": "chapter_score",
        "hint_chapter": 9,
        "alternatives": [
          {
            "chapter": 10,
            "line_start": 236,
            "line_end": 240,
            "text": "\n　　铁银衣闭着嘴，等着她说下去。\n\n　　又过了很久，公孙太夫人才一个字一个字地说：“他的名字叫无胜。”\n",
            "score": 71,
            "anchors_hit": [
              "公孙"
            ],
            "method": "chapter_score"
          }
        ]
      }
    ]
