  {
    "id": "loc_zhen_hai_lou",
    "name": "镇海楼",
    "type": "建筑",
    "region": "淮阳一带",
    "one_line": "段八方调停后走出处",
    "description": "段八方调停纷争、饮酒后呼拥走出的楼阁，随后收到画刀信。",
    "related_characters": [
      "char_duan_ba_fang",
      "char_tu_er_ye"
    ],
    "rag_refs": [
      1
    ],
    "source_refs": [
      {
        "chapter": 1,
        "anchor": "段八方走出镇海楼",
        "event_type": "first_mention",
        "line_start": 18,
        "line_end": 22,
        "text": "\n　　段八方也一样。这一天他刚调停了近十年来江湖中最大的一次纷争，接受了淮阳十三大门派的衷心感激和赞扬，喝了他们特地为他准备的真正泸州大曲，足足喝了有六斤。\n\n　　他在他的好友和扈从呼拥之下走出镇海楼的时候，全身都散发着热意，对他来说，生命就好像一杯干不尽的醇酒，正在等着他慢慢享受。\n",
        "anchors_hit": [
          "段八方",
          "镇海楼"
        ],
        "anchors_total": 2,
        "locate_status": "located",
        "locate_score": 248,
        "locate_method": "window",
        "hint_chapter": 1,
        "alternatives": []
      }
    ]
  },
