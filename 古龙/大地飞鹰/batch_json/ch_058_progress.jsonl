":"item_fu_tou","name":"斧头","type":"weapon","owner":"char_lao_er","one_line":"老二的飞斧，一把大四把小，可脱手掷出","description":"老二使用的兵器，一把大四把小共五把斧头，斜插在腰间皮带上。可脱手飞掷，速度力量远超暗器，但被神秘力量打歪折断。","effects":[],"origin":"不明","rarity":"上乘佳品","related_characters":["char_lao_er"],"related_skills":["skill_fei_fu"],"rag_refs":[58],"source_refs":[{"chapter":58,"line_start":87,"line_end":87,"text":"腰上一条比巴掌还宽的皮带上斜插着五把斧头"}]},{"id":"item_tie_ji","name":"铁戟","type":"weapon","owner":"char_lao_san","one_line":"老三肩上挑着的比人还长的铁戟","description":"老三使用的重型长兵器，比人还长的铁戟，需要极大的力量才能挥舞。","effects":[],"origin":"不明","rarity":"上乘佳品","related_characters":["char_lao_san"],"related_skills":[],"rag_refs":[58],"source_refs":[{"chapter":58,"line_start":88,"line_end":88,"text":"肩上挑着根比人还长的铁戟"}]},{"id":"item_jin_gang_mo_chu","name":"金钢魔杵","type":"weapon","owner":"char_lao_san","one_line":"老三手中倒提的金钢魔杵","description":"老三使用的另一件重型兵器，金钢魔杵，倒提在手中，与铁戟、鬼头刀同为老三的兵器。","effects":[],"origin":"不明","rarity":"上乘佳品","related_characters":["char_lao_san"],"related_skills":[],"rag_refs":[58],"source_refs":[{"chapter":58,"line_start":88,"line_end":88,"text":"手里倒提着根金钢魔杵"}]},{"id":"item_gui_tou_dao","name":"鬼头刀","type":"weapon","owner":"char_lao_san","one_line":"老三板腰带上插着的厚背薄刃鬼头刀","description":"老三的第三件兵器，厚背薄刃的鬼头刀，插在板腰带上，造型凶悍。","effects":[],"origin":"不明","rarity":"上乘佳品","related_characters":["char_lao_san"],"related_skills":[],"rag_refs":[58],"source_refs":[{"chapter":58,"line_start":88,"line_end":88,"text":"板腰带上还插着把厚背薄刃鬼头刀"}]},{"id":"item_qing_gang_jian","name":"青钢剑","type":"weapon","owner":"char_lao_si","one_line":"老四使用的普通青钢剑","description":"老四使用的兵器，一柄很普通的青钢剑，但他出剑极快，能攻出连环八剑。","effects":[],"origin":"不明","rarity":"寻常凡品","related_characters":["char_lao_si"],"related_skills":[],"rag_refs":[58],"source_refs":[{"chapter":58,"line_start":89,"line_end":89,"text":"用的居然只不过是柄很普通的青钢剑"}]}]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_lao_san","speaker_name":"老三","listener":"char_lao_da","text":"老大，就是这几个蜡人在捣鬼，青貂岭的兄弟就是死在他们手上的。","tone":"陈述","chapter":58,"line_start":101,"line_end":103},{"speaker":"char_lao_da","speaker_name":"老大","listener":null,"text":"蜡人也会杀人？这倒真他妈的活见鬼。","tone":"冷笑","chapter":58,"line_start":105,"line_end":105},{"speaker":null,"speaker_name":null,"listener":null,"text":"不管他们是什么变的，咱们不如先把他们毁了再说。","tone":"陈述","chapter":58,"line_start":107,"line_end":107},{"speaker":"char_lao_da","speaker_name":"老大","listener":null,"text":"好主意。","tone":"陈述","chapter":58,"line_start":109,"line_end":109},{"speaker":"char_lao_er","speaker_name":"老二","listener":"char_lao_si","text":"等一等。","tone":"陈述","chapter":58,"line_start":115,"line_end":115},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_lao_er","text":"既然已经来了，还等什么？","tone":"疑问","chapter":58,"line_start":117,"line_end":117},{"speaker":"char_lao_er","speaker_name":"老二","listener":"char_lao_si","text":"等着看我的！","tone":"得意","chapter":58,"line_start":119,"line_end":119},{"speaker":"char_lao_da","speaker_name":"老大","listener":"char_lao_er","text":"好，咱们就先看老二的！","tone":"陈述","chapter":58,"line_start":121,"line_end":123},{"speaker":"char_lao_da","speaker_name":"老大","listener":"char_lao_er","text":"直娘贼，叫你多吃两斤肉，手上才有力气，你他妈的偏要去玩姑娘。玩得手发软，真他妈的丢人现眼。","tone":"愤怒","chapter":58,"line_start":159,"line_end":161}],"new_entities":{"characters":[],"skills":[{"id":"skill_fei_fu_shu","name":"飞斧术","type":"暗器","faction":null,"rank":"炉火纯青","one_line":"将斧头脱手飞掷的江湖罕见功夫，力量远超暗器","techniques":[{"id":"tech_fei_fu_zhi_ji","name":"飞斧掷击","type":"attack","description":"将斧头脱手飞出，力量大速度快，三十步外可劈开核桃，但难在准头"},{"id":"tech_fei_fu_lian_huan","name":"连环飞斧","type":"attack","description":"连续掷出飞斧，第二斧更快更准力量更大"}],"progression":"炉火纯青","effects":["远程杀伤","力量极大"],"combat_style":"远程投掷","rag_refs":[58],"source_refs":[{"chapter":58,"line_start":127,"line_end":133,"text":"一斧头的力量远比任何一种暗器都大得多"}]}],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"你好。我好像见过你。","tone":"微笑","chapter":58,"line_start":202,"line_end":202},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"哦？","tone":"疑问","chapter":58,"line_start":204,"line_end":204},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"我好像刚才遇见你，在另外一个地方见过你。","tone":"陈述","chapter":58,"line_start":206,"line_end":206},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"哦。在哪里见过我？","tone":"疑问","chapter":58,"line_start":208,"line_end":208},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"就在那家商号里。你好像跟那个蜡像长得完全一样。","tone":"陈述","chapter":58,"line_start":210,"line_end":211},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"我自己也觉得有点像。你贵姓？","tone":"轻笑","chapter":58,"line_start":216,"line_end":216},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"我叫老四。","tone":"陈述","chapter":58,"line_start":218,"line_end":218},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"老四？谁的老四？","tone":"疑问","chapter":58,"line_start":220,"line_end":220},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"是我们老大的老四。","tone":"陈述","chapter":58,"line_start":222,"line_end":222},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"你们的老大是谁？","tone":"疑问","chapter":58,"line_start":224,"line_end":224},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"是个从来都不会杀人的人。他只会打人，常常一下子就把别人打成肉泥。","tone":"陈述","chapter":58,"line_start":226,"line_end":228},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"那么他一定很累。","tone":"调侃","chapter":58,"line_start":230,"line_end":231},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"很累？","tone":"疑问","chapter":58,"line_start":233,"line_end":233},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"无论谁要把别人打成肉泥，都是件很费力气的事。他怎么会不累？","tone":"调侃","chapter":58,"line_start":235,"line_end":237},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"你的暗器呢？","tone":"疑问","chapter":58,"line_start":240,"line_end":240},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"什么暗器？","tone":"疑问","chapter":58,"line_start":242,"line_end":242},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"打斧头的暗器。","tone":"陈述","chapter":58,"line_start":244,"line_end":244},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"我没有这种暗器。如果我有暗器，也不打斧头。","tone":"微笑","chapter":58,"line_start":246,"line_end":246},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"不打斧头打什么？","tone":"疑问","chapter":58,"line_start":248,"line_end":248},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"打人。打人绝对比打斧头好玩得多。","tone":"轻笑","chapter":58,"line_start":250,"line_end":250},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"你也会使剑？","tone":"疑问","chapter":58,"line_start":260,"line_end":260},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_lao_si","text":"会一点。一点点。","tone":"陈述","chapter":58,"line_start":262,"line_end":262},{"speaker":"char_lao_si","speaker_name":"老四","listener":"char_xiao_fang","text":"那好极了。碰巧我也会使剑，也只会一点点。","tone":"陈述","chapter":58,"line_start":264,"line_end":264}],"new_entities":{"characters":[{"id":"char_lao_si","name":"老四","alias":[],"identity":"五兄弟之四，身材最高大最秀气，擅使连环八剑","faction":null,"role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"五兄弟中的老四，身高八尺一寸最秀气，擅使连环八剑却一招不敌小方","personality":{"traits":["秀气","自信","好胜","勇猛","果断"],"speech_style":"从容不迫","temperament":"刚烈"},"relationships":[{"target":"char_lao_da","type":"挚友","intensity":80,"bond_level":4,"dynamic":"兄弟"},{"target":"c