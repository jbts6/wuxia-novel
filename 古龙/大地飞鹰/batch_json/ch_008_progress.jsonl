{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"line_start":10,"line_end":10,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"你真的不怕死？","tone":"疑问","chapter":8},{"line_start":40,"line_end":40,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"这是你的剑？","tone":"疑问","chapter":8},{"line_start":44,"line_end":44,"speaker":"char_xiao_fang","speakerName":"小方","text":"是，是我的剑。","tone":"陈述","chapter":8},{"line_start":46,"line_end":46,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"你使剑？","tone":"疑问","chapter":8},{"line_start":48,"line_end":48,"speaker":"char_xiao_fang","speakerName":"小方","text":"是。","tone":"陈述","chapter":8},{"line_start":62,"line_end":66,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"世人铸剑千万，能称为利器却只不过其中二三而已。宝剑名驹，本来就可遇而不可求，万中能得其一，已经不能算少了。","tone":"陈述","chapter":8},{"line_start":68,"line_end":68,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"你的剑是利器。","tone":"陈述","chapter":8},{"line_start":70,"line_end":70,"speaker":"char_xiao_fang","speakerName":"小方","text":"你的眼也很利。","tone":"微笑","chapter":8},{"line_start":72,"line_end":72,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"你用它杀过人？","tone":"疑问","chapter":8},{"line_start":74,"line_end":74,"speaker":"char_xiao_fang","speakerName":"小方","text":"偶一为之，只杀该杀的。","tone":"陈述","chapter":8},{"line_start":76,"line_end":76,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"善用利器者，才能杀人而未被杀，你的剑法想必不差。","tone":"陈述","chapter":8},{"line_start":78,"line_end":78,"speaker":"char_xiao_fang","speakerName":"小方","text":"还算过得去。","tone":"陈述","chapter":8},{"line_start":80,"line_end":80,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"那么你另外还有条路可走。","tone":"陈述","chapter":8},{"line_start":82,"line_end":82,"speaker":"char_xiao_fang","speakerName":"小方","text":"哪条路？怎么走？","tone":"疑问","chapter":8},{"line_start":84,"line_end":86,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"用你的剑杀了我！你能杀我，你就可以不死。","tone":"冷酷","chapter":8},{"line_start":88,"line_end":88,"speaker":"char_xiao_fang","speakerName":"小方","text":"否则我是不是就要死在你的剑下？","tone":"疑问","chapter":8},{"line_start":90,"line_end":90,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"是的！","tone":"冷酷","chapter":8},{"line_start":92,"line_end":94,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"有资格死在我剑下的人并不多，你能死在我剑下，已可算死而无憾。","tone":"冷酷","chapter":8}],"new_entities":{"characters":[{"id":"char_shen_mi_jian_ke","name":"神秘剑客","alias":["神秘人"],"identity":"神秘的无名剑客，剑法高深莫测","faction":"无","role":"villain","archetype":"warrior","rank":"出神入化","one_line":"在大漠中出现的神秘剑客，以剑试人，追求剑道极致","personality":{"traits":["冷酷","孤傲","执着","淡漠","强大","神秘"],"speech_style":"声音奇特而生冷，说话简洁","temperament":"绝对冷静，对生死淡漠"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[8],"source_refs":[{"chapter":8,"line_start":8,"line_end":14,"text":"就在他刚想闭上眼睛时，忽然听见一个人用奇特而生冷的声音问他"}]},{"id":"char_wei_tian_peng","name":"卫天鹏","alias":[],"identity":"神秘势力的人物","faction":"未知","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"在大漠中活动的神秘人物，与水银有关联","personality":{"traits":["沉默","深沉","强大","神秘","冷酷"],"speech_style":"沉默寡言","temperament":"深不可测"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[8],"source_refs":[{"chapter":8,"line_start":138,"line_end":138,"text":"卫天鹏没有反应，就好像根本没有听见这句话。"}]},{"id":"char_shui_yin","name":"水银","alias":[],"identity":"神秘势力的人物","faction":"未知","role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"神秘势力的女子，对神秘剑客的决定有异议","personality":{"traits":["冲动","服从","畏惧","年轻","直接"],"speech_style":"直接，带有情绪","temperament":"冲动但服从权威"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[8],"source_refs":[{"chapter":8,"line_start":140,"line_end":148,"text":"水银好像要跳了起来：'你说什么？'"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"line_start":110,"line_end":110,"speaker":"char_xiao_fang","speakerName":"小方","text":"什么时候？什么地方？","tone":"疑问","chapter":8},{"line_start":112,"line_end":112,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"你说。","tone":"陈述","chapter":8},{"line_start":114,"line_end":114,"speaker":"char_xiao_fang","speakerName":"小方","text":"就在此地，就是此刻。","tone":"认真","chapter":8},{"line_start":116,"line_end":116,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"不行。","tone":"冷酷","chapter":8},{"line_start":118,"line_end":118,"speaker":"char_xiao_fang","speakerName":"小方","text":"我的人在此，剑也在此，为什么不行？","tone":"疑问","chapter":8},{"line_start":120,"line_end":122,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"因为你的人剑虽在，精气却已不在。我若在此时此地杀了你，我就对不起我的剑。","tone":"冷酷","chapter":8},{"line_start":124,"line_end":124,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"现在你根本不配让我出手！","tone":"冷酷","chapter":8},{"line_start":132,"line_end":134,"speaker":"char_xiao_fang","speakerName":"小方","text":"你给我一袋水、一袋酒、一袋肉！一袋饼、一套布衣、一张毛毡，三天后我再来。","tone":"认真","chapter":8},{"line_start":136,"line_end":136,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"可以。","tone":"陈述","chapter":8},{"line_start":140,"line_end":140,"speaker":"char_shui_yin","speakerName":"水银","text":"你说什么？","tone":"惊讶","chapter":8},{"line_start":142,"line_end":144,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"我说的话你没有听清楚？","tone":"冷酷","chapter":8},{"line_start":146,"line_end":148,"speaker":"char_shui_yin","speakerName":"水银","text":"我听清楚了。我听得很清楚。","tone":"服从","chapter":8},{"line_start":150,"line_end":150,"speaker":"char_shen_mi_jian_ke","speakerName":"神秘人","text":"你有意见？","tone":"冷酷","chapter":8},{"line_start":152,"line_end":152,"speaker":"char_shui_yin","speakerName":"水银","text":"我没有。","tone":"服从","chapter":8},{"line_start":182,"line_end":182,"speaker":"char_xiao_fang","speakerName":"小方","text":"想不到你又来了。","tone":"微笑","chapter":8},{"line_start":186,"line_end":188,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"我看起来跟你第一次看见我时有什么不同？","tone":"疑问","chapter":8},{"line_start":190,"line_end":190,"speaker":"char_xiao_fang","speakerName":"小方","text":"没有。","tone":"陈述","chapter":8},{"line_start":192,"line_end":192,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"可是你却变得不同了。","tone":"陈述","chapter":8},{"line_start":194,"line_end":194,"speaker":"char_xiao_fang","speakerName":"小方","text":"有什么不同？","tone":"疑问","chapter":8},{"line_start":196,"line_end":196,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"你看起来就像是个暴发户。","tone":"嘲讽","chapter":8}],"new_entities":{"characters":[{"id":"char_bu_ying","name":"卜鹰","alias":[],"identity":"神秘的高人，对剑道有深刻理解","faction":"无","role":"npc","archetype":"scholar","rank":"登峰造极","one_line":"神秘高人，衣着永远雪白，对剑道有禅意般的理解","personality":{"traits":["深邃","冷峻","智慧","神秘","洞察力强"],"speech_style":"声音冷如刀削，说话简洁有力","temperament":"外表冷漠，内心洞察"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[8],"source_refs":[{"chapter":8,"line_start":178,"line_end":180,"text":"等他醒来时，第一眼看见的就是卜鹰。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_yang_pi_jiu_dai","name":"羊皮酒袋","type":"special","owner":"char_xiao_fang","one_line":"装有酒的羊皮袋，是大漠中补充体力的重要物品","description":"用羊皮制成的酒袋，里面装着酒，在酷热的大漠中，酒可以帮助恢复精神和体力。","effects":["恢复精神","补充体力"],"origin":"大漠","rarity":"寻常凡品","related_characters":["char_xiao_fang","char_bu_ying"],"related_skills":[],"rag_refs":[8],"source_refs":[{"chapter":8,"line_start":198,"line_end":198,"text":"他身旁的羊皮袋，卜鹰的锐眼当然不会错过。"}]}]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"line_start":208,"line_end":210,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"可是你这个暴发户好像并没有做什么见不得人的事。","tone":"微笑","chapter":8},{"line_start":214,"line_end":216,"speaker":"char_xiao_fang","speakerName":"小方","text":"我只不过遇见了一个人而已。他暂时还不想让我被渴死。","tone":"陈述","chapter":8},{"line_start":218,"line_end":218,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"这个人是谁？","tone":"疑问","chapter":8},{"line_start":220,"line_end":220,"speaker":"char_xiao_fang","speakerName":"小方","text":"是个准备在三天后再亲手杀我的人。","tone":"陈述","chapter":8},{"line_start":222,"line_end":222,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"他准备用什么杀你？","tone":"疑问","chapter":8},{"line_start":224,"line_end":224,"speaker":"char_xiao_fang","speakerName":"小方","text":"用他的剑！","tone":"陈述","chapter":8},{"line_start":226,"line_end":228,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"你也有剑，被杀的很可能不是你，是他。","tone":"陈述","chapter":8},{"line_start":230,"line_end":230,"speaker":"char_xiao_fang","speakerName":"小方","text":"有可能，却不太可能。","tone":"无奈","chapter":8},{"line_start":232,"line_end":234,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"你有把好剑，你的剑法不很差，出手也不慢，能胜过你的人并不多。","tone":"陈述","chapter":8},{"line_start":236,"line_end":236,"speaker":"char_xiao_fang","speakerName":"小方","text":"你怎么知道我剑法如何？你几时见过我出手？","tone":"疑问","chapter":8},{"line_start":238,"line_end":238,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"我没有见过，我听过。","tone":"陈述","chapter":8},{"line_start":240,"line_end":240,"speaker":"char_xiao_fang","speakerName":"小方","text":"你听过？","tone":"惊讶","chapter":8},{"line_start":244,"line_end":246,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"昨天晚上，我听见你那一剑出手的风声，就知道来刺杀你的那个人必将伤在你的剑下。能避开你那一剑的人也不多。","tone":"淡然","chapter":8},{"line_start":248,"line_end":248,"speaker":"char_xiao_fang","speakerName":"小方","text":"所以你就走了。","tone":"陈述","chapter":8},{"line_start":250,"line_end":252,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"你既然暂时还不会死，我只有走。自己等死和等别人死都同样不是令人愉快的事。","tone":"冷酷","chapter":8},{"line_start":266,"line_end":266,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"你没有见过那个人？","tone":"疑问","chapter":8},{"line_start":270,"line_end":272,"speaker":"char_xiao_fang","speakerName":"小方","text":"没有。当今天下的剑法名家，我差不多全都知道，却始终想不出有他这么一个人。","tone":"沉思","chapter":8},{"line_start":274,"line_end":276,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"你当然想不出。因为真正的剑客，都是无名的。","tone":"深思","chapter":8},{"line_start":280,"line_end":280,"speaker":"char_xiao_fang","speakerName":"小方","text":"为什么？","tone":"疑问","chapter":8},{"line_start":282,"line_end":288,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"因为真正的剑客，所求的只是剑法中的精义，所想达到的只是剑境中至高至深，从来没有人能到达的境界，他的心已痴于剑，他的人已与他的剑联为一体，他所找的对手，一定是能帮助他到达这种境界的人。这种人既不会到江湖中去求名，甚至会将自己的名字都浑然忘记。","tone":"深思","chapter":8},{"line_start":290,"line_end":292,"speaker":"char_xiao_fang","speakerName":"小方","text":"最主要的是，他们根本不希望别人知道他们的名字，因为一个人如果太有名，就不能专心做他自己喜欢做的事了。","tone":"认真","chapter":8},{"line_start":294,"line_end":294,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"你实在是个聪明人，绝顶聪明，只可惜……","tone":"叹息","chapter":8},{"line_start":296,"line_end":296,"speaker":"char_xiao_fang","speakerName":"小方","text":"只可惜聪明人通常都很短命。","tone":"苦笑","chapter":8},{"line_start":298,"line_end":298,"speaker":"char_bu_ying","speakerName":"卜鹰","text":"所以三天后我一定会去替你收尸。","tone":"冷酷","chapter":8}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_fang","updates":{"source_refs":[{"chapter":8,"line_start":1,"line_end":10,"text":"小方又躺了下去，好像已经准备让他们送回风砂中去等死。"}]},"relationship_updates":[{"action":"add","target":"char_shen_mi_jian_ke","type":"对手","intensity":80,"bond_level":4,"dynamic":"生死对决的约定"},{"action":"add","target":"char_bu_ying","type":"合作者","intensity":50,"bond_level":3,"dynamic":"亦敌亦友的默契"}]}]}
