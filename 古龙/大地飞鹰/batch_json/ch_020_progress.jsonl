{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_wei_tian_peng","speaker_name":"卫天鹏","listener":"char_bu_ying","text":"你不后悔？","tone":"疑问","chapter":20,"line_start":4,"line_end":4},{"speaker":"char_wei_tian_peng","speaker_name":"卫天鹏","listener":"char_bu_ying","text":"好。你既然不怕流血，我们为什么要怕？","tone":"愤怒","chapter":20,"line_start":10,"line_end":10},{"speaker":"char_song_lao_fu_zi","speaker_name":"宋老夫子","listener":"char_wei_tian_peng","text":"说不定你这次带来的人耳朵都不太好，都没有听见你在叫他们。","tone":"调侃","chapter":20,"line_start":38,"line_end":40},{"speaker":"char_song_lao_fu_zi","speaker_name":"宋老夫子","listener":"char_wei_tian_peng","text":"这一次连聋子都应该听见了。","tone":"调侃","chapter":20,"line_start":44,"line_end":44},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":null,"text":"他们不是聋子。","tone":"淡然","chapter":20,"line_start":50,"line_end":50},{"speaker":"char_song_lao_fu_zi","speaker_name":"宋老夫子","listener":"char_bu_ying","text":"不是聋子为什么听不见？","tone":"疑问","chapter":20,"line_start":52,"line_end":52},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":null,"text":"他们听得见。","tone":"淡然","chapter":20,"line_start":54,"line_end":54},{"speaker":"char_song_lao_fu_zi","speaker_name":"宋老夫子","listener":"char_bu_ying","text":"听得见为什么还不冲过来？刀枪剑戟齐下，把我们一个个剁成肉泥？","tone":"疑问","chapter":20,"line_start":56,"line_end":58},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":null,"text":"因为我还没有要他们过来。","tone":"冷酷","chapter":20,"line_start":60,"line_end":60},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":null,"text":"你马上就会相信的。","tone":"冷酷","chapter":20,"line_start":62,"line_end":62},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":null,"text":"过来！","tone":"严肃","chapter":20,"line_start":64,"line_end":64},{"speaker":null,"speaker_name":"身后的人","listener":null,"text":"不许动，一动就死！","tone":"冷酷","chapter":20,"line_start":92,"line_end":94}],"new_entities":{"characters":[{"id":"char_bu_ying","name":"卜鹰","alias":[],"identity":"领袖","faction":null,"role":"protagonist","archetype":"warrior","rank":"出神入化","one_line":"运筹帷幄的鹰族领袖，以智谋和实力碾压对手","personality":{"traits":["冷静","深谋远虑","威严","果断","冷酷"],"speech_style":"简洁有力，一语中的","temperament":"沉稳如山"},"relationships":[{"target":"char_ban_cha_ba_na","type":"挚友","intensity":90,"bond_level":5,"dynamic":"深厚信任"},{"target":"char_wei_tian_peng","type":"宿敌","intensity":80,"bond_level":4,"dynamic":"完胜对手"},{"target":"char_liu_fen_fen","type":"对手","intensity":60,"bond_level":3,"dynamic":"利用与被利用"},{"target":"char_xiao_fang","type":"合作者","intensity":50,"bond_level":3,"dynamic":"同阵营"}],"known_skills":[],"related_skills":[],"rag_refs":[20],"source_refs":[{"chapter":20,"line_start":6,"line_end":6,"text":"卜鹰拒绝回答。"}]},{"id":"char_wei_tian_peng","name":"卫天鹏","alias":[],"identity":"敌方首领","faction":null,"role":"villain","archetype":"warrior","rank":"登峰造极","one_line":"曾被形容为静如山岳稳如磐石的敌方首领，遭惨败后彻底崩溃","personality":{"traits":["刚硬","自负","好胜","怕死","崩溃"],"speech_style":"强硬但底气不足","temperament":"外刚内脆"},"relationships":[{"target":"char_bu_ying","type":"宿敌","intensity":80,"bond_level":4,"dynamic":"惨败"},{"target":"char_liu_fen_fen","type":"合作者","intensity":60,"bond_level":3,"dynamic":"被出卖"},{"target":"char_sou_hun_shou","type":"主仆","intensity":70,"bond_level":4,"dynamic":"下属"}],"known_skills":[],"related_skills":[],"rag_refs":[20],"source_refs":[{"chapter":20,"line_start":2,"line_end":2,"text":"卫天鹏的脸色发青，掌心冒汗。"}]},{"id":"char_song_lao_fu_zi","name":"宋老夫子","alias":[],"identity":"卜鹰阵营","faction":null,"role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"卜鹰阵营中的谋士，言语诙谐，善于嘲讽对手","personality":{"traits":["诙谐","机智","从容","嘲讽","冷静"],"speech_style":"含蓄幽默，暗藏锋芒","temperament":"从容不迫"},"relationships":[{"target":"char_bu_ying","type":"合作者","intensity":70,"bond_level":4,"dynamic":"同阵营"},{"target":"char_wei_tian_peng","type":"对手","intensity":60,"bond_level":3,"dynamic":"嘲讽"}],"known_skills":[],"related_skills":[],"rag_refs":[20],"source_refs":[{"chapter":20,"line_start":38,"line_end":40,"text":"宋老夫子忽然笑了笑：说不定你这次带来的人耳朵都不太好"}]},{"id":"char_sou_hun_shou","name":"搜魂手","alias":["毒手搜魂"],"identity":"卫天鹏属下","faction":null,"role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"名满江湖的搜魂手，杀人无数却最怕死，被班察巴那一拳击倒","personality":{"traits":["怕死","狠辣","软弱","务实","服从"],"speech_style":"简短直接","temperament":"外强中干"},"relationships":[{"target":"char_wei_tian_peng","type":"主仆","intensity":70,"bond_level":4,"dynamic":"下属"},{"target":"char_ban_cha_ba_na","type":"宿敌","intensity":80,"bond_level":4,"dynamic":"被打"}],"known_skills":[],"related_skills":[],"rag_refs":[20],"source_refs":[{"chapter":20,"line_start":120,"line_end":122,"text":"从来不开口的搜魂手却回答了：我们不想死。"}]},{"id":"char_liu_fen_fen","name":"柳分分","alias":[],"identity":"卫天鹏阵营","faction":null,"role":"npc","archetype":"assassin","rank":"炉火纯青","one_line":"拥有一半人一半魔双重人格的女子，在惨败后魔性被消灭，出卖同伴以自保","personality":{"traits":["狡黠","自私","善变","狠毒","务实"],"speech_style":"狡猾而直接","temperament":"多变"},"relationships":[{"target":"char_wei_tian_peng","type":"合作者","intensity":50,"bond_level":3,"dynamic":"出卖"},{"target":"char_bu_ying","type":"对手","intensity":60,"bond_level":3,"dynamic":"互相利用"},{"target":"char_xiao_fang","type":"对手","intensity":50,"bond_level":2,"dynamic":"敌对"}],"known_skills":[],"related_skills":[],"rag_refs":[20],"source_refs":[{"chapter":20,"line_start":106,"line_end":108,"text":"柳分分少女般的红颜笑靥，现在也已变得如新丧的寡妇般衰老苍白憔悴。"}]},{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"卜鹰阵营","faction":null,"role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"卜鹰阵营的年轻武者，在旁观战局中逐渐理解卜鹰的谋略","personality":{"traits":["好奇","机敏","忠诚","观察力强","谨慎"],"speech_style":"简洁","temperament":"沉稳"},"relationships":[{"target":"char_bu_ying","type":"合作者","intensity":70,"bond_level":4,"dynamic":"同阵营"},{"target":"char_liu_fen_fen","type":"对手","intensity":50,"bond_level":2,"dynamic":"敌对"}],"known_skills":[],"related_skills":[],"rag_refs":[20],"source_refs":[{"chapter":20,"line_start":82,"line_end":82,"text":"小方忽然发现刚才还在营火旁高歌欢唱痛饮的那些浪子行商旅客"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_wei_tian_peng","text":"你们虽然败了，却还没有死，你们外面那七十位久经训练，百战不死的战士也还没有死。","tone":"冷酷","chapter":20,"line_start":112,"line_end":114},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_wei_tian_peng","text":"你们想不想死？想不想要那七十位战士陪你们一起死？","tone":"冷酷","chapter":20,"line_start":116,"line_end":118},{"speaker":"char_sou_hun_shou","speaker_name":"搜魂手","listener":"char_bu_ying","text":"我们不想死。","tone":"恐惧","chapter":20,"line_start":122,"line_end":122},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_sou_hun_shou","text":"现在是不是已经到了最后关头？","tone":"冷酷","chapter":20,"line_start":130,"line_end":130},{"speaker":"char_sou_hun_shou","speaker_name":"搜魂手","listener":"char_bu_ying","text":"是。","tone":"恐惧","chapter":20,"line_start":132,"line_end":132},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_sou_hun_shou","text":"现在你们还有一顶轿子，轿子里可能有位绝顶高手，也可能有足够把我们全都炸成飞灰的火药。你们是不是还想赌一赌？","tone":"冷酷","chapter":20,"line_start":134,"line_end":138},{"speaker":"char_sou_hun_shou","speaker_name":"搜魂手","listener":"char_bu_ying","text":"我们不想。轿子里没有高手，也没有火药，只有……","tone":"恐惧","chapter":20,"line_start":140,"line_end":141},{"speaker":"char_ban_cha_ba_na","speaker_name":"班察巴那","listener":null,"text":"我不是名家弟子，也没有学过你们那些高妙的武功，我只不过是个粗鲁野蛮无知的藏人，在你们眼中，很可能跟野兽差不多。","tone":"沉声","chapter":20,"line_start":160,"line_end":160},{"speaker":"char_ban_cha_ba_na","speaker_name":"班察巴那","listener":null,"text":"可是我说出来的话一向算数。","tone":"严肃","chapter":20,"line_start":162,"line_end":162},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":null,"text":"他要说的，就是我要说的。他说的话跟我同样有效。","tone":"认真","chapter":20,"line_start":168,"line_end":170},{"speaker":"char_ban_cha_ba_na","speaker_name":"班察巴那","listener":null,"text":"我们不想知道那顶轿子里有什么，不想听，也不想看！","tone":"愤怒","chapter":20,"line_start":176,"line_end":177},{"speaker":"char_ban_cha_ba_na","speaker_name":"班察巴那","listener":null,"text":"如果有人说出了那顶轿子里是什么？如果有人让我看见了那顶轿子里是什么？不管他是谁，我都会杀了他！","tone":"冷酷","chapter":20,"line_start":178,"line_end":182},{"speaker":"char_ban_cha_ba_na","speaker_name":"班察巴那","listener":"char_wei_tian_peng","text":"现在我们之间的战争已结束，你们已惨败，我们的条件，你都得接受。","tone":"严肃","chapter":20,"line_start":188,"line_end":190},{"speaker":"char_wei_tian_peng","speaker_name":"卫天鹏","listener":"char_ban_cha_ba_na","text":"你们有什么条件？","tone":"颤声","chapter":20,"line_start":196,"line_end":196}],"new_entities":{"characters":[{"id":"char_ban_cha_ba_na","name":"班察巴那","alias":[],"identity":"卜鹰挚友","faction":null,"role":"companion","archetype":"warrior","rank":"出神入化","one_line":"藏族勇士，卜鹰最信任的伙伴，以惊人速度和绝对忠诚著称","personality":{"traits":["忠诚","勇猛","果断","冷酷","守信"],"speech_style":"直接有力，言出必行","temperament":"刚猛"},"relationships":[{"target":"char_bu_ying","type":"挚友","intensity":95,"bond_level":5,"dynamic":"深厚信任"},{"target":"char_sou_hun_shou","type":"宿敌","intensity":80,"bond_level":4,"dynamic":"一拳击倒"},{"target":"char_wei_tian_peng","type":"宿敌","intensity":80,"bond_level":4,"dynamic":"对峙"}],"known_skills":[],"related_skills":[],"rag_refs":[20],"source_refs":[{"chapter":20,"line_start":144,"line_end":146,"text":"班察巴那忽然挥拳，痛击在他脸上，封住了他的嘴。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":266,"dialogues":[{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_wei_tian_peng","text":"你们可以把那顶轿子带走，但是你们不能这样走。","tone":"严肃","chapter":20,"line_start":210,"line_end":210},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_wei_tian_peng","text":"你们每个人都得留下点东西来才能走。","tone":"冷酷","chapter":20,"line_start":212,"line_end":212},{"speaker":"char_wei_tian_peng","speaker_name":"卫天鹏","listener":"char_bu_ying","text":"你要我们留下什么？","tone":"痛苦","chapter":20,"line_start":214,"line_end":214},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_liu_fen_fen","text":"留下一样能让你们永远记住这次教训的东西。你说你们应该留下什么？","tone":"冷酷","chapter":20,"line_start":216,"line_end":217},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_liu_fen_fen","text":"只要你说出来，我就答应。","tone":"淡然","chapter":20,"line_start":234,"line_end":234},{"speaker":"char_liu_fen_fen","speaker_name":"柳分分","listener":"char_bu_ying","text":"我们是一起来的，我留下了什么，他们也该留下什么。","tone":"嘲讽","chapter":20,"line_start":240,"line_end":240},{"speaker":"char_liu_fen_fen","speaker_name":"柳分分","listener":"char_bu_ying","text":"我已经留下了一只手。","tone":"冷酷","chapter":20,"line_start":242,"line_end":242},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_liu_fen_fen","text":"这是你说的。你是不是认为这样做很公平？","tone":"冷酷","chapter":20,"line_start":252,"line_end":252},{"speaker":"char_liu_fen_fen","speaker_name":"柳分分","listener":"char_bu_ying","text":"是。绝对公平。","tone":"认真","chapter":20,"line_start":254,"line_end":254}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
