{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"什么事？","tone":"陈述","chapter":29,"line_start":102,"line_end":102},{"speaker":"char_bo_wa","speaker_name":"波娃","listener":null,"text":"你不杀我，有人就要杀你！","tone":"陈述","chapter":29,"line_start":104,"line_end":104},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我知道。","tone":"陈述","chapter":29,"line_start":108,"line_end":108},{"speaker":null,"speaker_name":null,"listener":null,"text":"这柄剑本来就不是我的，是你的。","tone":"陈述","chapter":29,"line_start":134,"line_end":134},{"speaker":null,"speaker_name":null,"listener":null,"text":"不是你的，你应该还给我。","tone":"陈述","chapter":29,"line_start":136,"line_end":136},{"speaker":null,"speaker_name":null,"listener":null,"text":"现在你还有什么话可说？","tone":"陈述","chapter":29,"line_start":152,"line_end":152},{"speaker":null,"speaker_name":null,"listener":null,"text":"有，我还有话说，还有事要问你。","tone":"陈述","chapter":29,"line_start":154,"line_end":154},{"speaker":"char_ga_lun_la_ma","speaker_name":"噶伦喇嘛","listener":null,"text":"什么事？","tone":"陈述","chapter":29,"line_start":156,"line_end":156},{"speaker":null,"speaker_name":null,"listener":null,"text":"你是不是要我去杀了她？","tone":"陈述","chapter":29,"line_start":180,"line_end":180},{"speaker":null,"speaker_name":null,"listener":null,"text":"是。","tone":"陈述","chapter":29,"line_start":184,"line_end":184},{"speaker":null,"speaker_name":null,"listener":null,"text":"是","tone":"陈述","chapter":29,"line_start":192,"line_end":192},{"speaker":null,"speaker_name":null,"listener":null,"text":"你想干什么？","tone":"陈述","chapter":29,"line_start":200,"line_end":200}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
