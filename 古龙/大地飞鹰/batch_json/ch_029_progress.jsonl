{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_bo_wa","speaker_name":"波娃","listener":null,"text":"我知道普松一定不会让你来见我，一定会杀你。","tone":"陈述","chapter":29,"line_start":42,"line_end":42},{"speaker":"char_bo_wa","speaker_name":"波娃","listener":null,"text":"波娃说：","tone":"陈述","chapter":29,"line_start":56,"line_end":56},{"speaker":null,"speaker_name":null,"listener":null,"text":"你为什么要告诉我这些事？","tone":"陈述","chapter":29,"line_start":64,"line_end":64},{"speaker":"char_bo_wa","speaker_name":"波娃","listener":null,"text":"因为我不想再骗你。","tone":"陈述","chapter":29,"line_start":66,"line_end":66},{"speaker":null,"speaker_name":null,"listener":null,"text":"所以你随时都可以杀了我，我绝不怪你。","tone":"陈述","chapter":29,"line_start":78,"line_end":78},{"speaker":"char_bo_wa","speaker_name":"波娃","listener":null,"text":"你杀我也好，不杀我也好，我都不勉强你。","tone":"陈述","chapter":29,"line_start":98,"line_end":98}],"new_entities":{"characters":[{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"剑客","faction":null,"role":"protagonist","archetype":"warrior","rank":"登堂入室","one_line":"年轻的剑客，面对爱恨情仇的抉择","personality":{"traits":["正义","犹豫","深情","勇敢","矛盾"],"speech_style":"直接","temperament":"热血"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[29],"source_refs":[{"chapter":29,"line_start":2,"line_end":2,"text":"小方是真的已下了决心要来杀波娃。"}]},{"id":"char_bo_wa","name":"波娃","alias":[],"identity":"神秘女子","faction":null,"role":"npc","archetype":"assassin","rank":"炉火纯青","one_line":"神秘的女子，与多位男性有情感纠葛","personality":{"traits":["聪明","冷酷","神秘","残忍","美丽"],"speech_style":"温柔","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[29],"source_refs":[{"chapter":29,"line_start":2,"line_end":2,"text":"小方是真的已下了决心要来杀波娃。"}]},{"id":"char_ga_lun_la_ma","name":"噶伦喇嘛","alias":["噶伦"],"identity":"高僧","faction":null,"role":"npc","archetype":"monk","rank":"出神入化","one_line":"精明厉害的高僧，隐藏着秘密","personality":{"traits":["精明","厉害","隐忍","慈祥","痛苦"],"speech_style":"沉稳","temperament":"冷静"},"relationships":[],"kn