{"segment":2,"line_start":100,"line_end":199,"dialogues":[{"speaker":"char_yang_guang","speaker_name":"\"阳光\"","listener":"char_xiao_fang","text":"\"卜鹰在哪里？\"","tone":"疑问","chapter":31,"line_start":120,"line_end":121},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_yang_guang","text":"\"我要去见他！现在就要去见他！\"","tone":"焦急","chapter":31,"line_start":122,"line_end":122},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你是不是已决定要走？\"","tone":"疑问","chapter":31,"line_start":128,"line_end":130},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"是！\"","tone":"陈述","chapter":31,"line_start":132,"line_end":132},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"我很了解你，你已经决定了的事，就绝对不会更改的。\"","tone":"陈述","chapter":31,"line_start":144,"line_end":146},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"我已经决定了。\"","tone":"平静","chapter":31,"line_start":148,"line_end":148},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"我非走不可。\"","tone":"平静","chapter":31,"line_start":148,"line_end":148},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你还记不记得班察巴那说过的那句话？\"","tone":"疑问","chapter":31,"line_start":150,"line_end":152},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"我记得。\"","tone":"陈述","chapter":31,"line_start":154,"line_end":154},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"他说，从来都没有人能泄漏你们的秘密。\"","tone":"陈述","chapter":31,"line_start":154,"line_end":154},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"我相信你绝不会泄漏别人的秘密，但是他不同，他从不相信任何人。\"","tone":"陈述","chapter":31,"line_start":156,"line_end":158},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"他总认为只有死人才能保守秘密。\"","tone":"陈述","chapter":31,"line_start":156,"line_end":158},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"你呢？\"","tone":"疑问","chapter":31,"line_start":160,"line_end":160},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"有些事，我也不能做主的。\"","tone":"无奈","chapter":31,"line_start":162,"line_end":166},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"譬如说，你要走，我也没法子留住你。\"","tone":"无奈","chapter":31,"line_start":162,"line_end":166},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"我早就知道你要走的。\"","tone":"陈述","chapter":31,"line_start":182,"line_end":184},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你回到拉萨，没有再去看波娃，我就已知道你决心要离开我们，因为你自己知道你永远都无法了解我们，也无法了解我们所做的事。\"","tone":"陈述","chapter":31,"line_start":182,"line_end":184},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你在想什么？\"","tone":"疑问","chapter":31,"line_start":186,"line_end":186},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"江南。\"","tone":"陈述","chapter":31,"line_start":188,"line_end":188},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"我在想江南。\"","tone":"陈述","chapter":31,"line_start":188,"line_end":188},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你在想江南？此时此刻，你居然在想江南？\"","tone":"惊讶","chapter":31,"line_start":190,"line_end":190},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你根本不是我们这一类的，你是个诗人，不是战士，也不是剑客，所以你才要走，因为现在你居然还在想江南。\"","tone":"无奈","chapter":31,"line_start":192,"line_end":194},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"现在，我应该怎么想？应该想什么？\"","tone":"疑问","chapter":31,"line_start":198,"line_end":198}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":200,"line_end":243,"dialogues":[{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你应该想想严正刚，想想宋老夫子，想想朱云，想想他们是些什么样的人。\"","tone":"严肃","chapter":31,"line_start":200,"line_end":202},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"我为什么要想他们？\"","tone":"疑问","chapter":31,"line_start":204,"line_end":204},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"因为他们绝不会让你走的。\"","tone":"严肃","chapter":31,"line_start":206,"line_end":208},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"如果世上只有一个法子能留住你，他们一定就会用那个法子对付你，如果他们认为一定要割断你的咽喉才能留下你，他们的刀就绝不会落在别的地方。\"","tone":"严肃","chapter":31,"line_start":206,"line_end":208},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"他们都是这种人？\"","tone":"疑问","chapter":31,"line_start":210,"line_end":210},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"他们都是的。\"","tone":"冷酷","chapter":31,"line_start":212,"line_end":214},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"他们不但能把人的咽喉像割草般割断，也能把刀锋上的人血当作水一样擦干。\"","tone":"冷酷","chapter":31,"line_start":212,"line_end":214},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"你应该知道有时候我也会这样做的。\"","tone":"认真","chapter":31,"line_start":216,"line_end":218},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你看那是什么？\"","tone":"疑问","chapter":31,"line_start":222,"line_end":222},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_bu_ying","text":"\"那是一盏灯。\"","tone":"陈述","chapter":31,"line_start":226,"line_end":226},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你知道那是什么意思？\"","tone":"疑问","chapter":31,"line_start":228,"line_end":228},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"那意思就是说，他们也知道你要走了，已准备为你饯行。\"","tone":"陈述","chapter":31,"line_start":234,"line_end":234},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"所以现在你已经可以走了。\"","tone":"无奈","chapter":31,"line_start":240,"line_end":241},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_xiao_fang","text":"\"你走吧！\"","tone":"无奈","chapter":31,"line_start":240,"line_end":241}],"new_entities":{"characters":[{"id":"char_yan_zheng_gang","name":"严正刚","alias":[],"identity":"江湖人物","faction":"未知","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"卜鹰提到的严正刚","personality":{"traits":["严厉","正直","刚强","无情","果断"],"speech_style":"未知","temperament":"严厉"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[31],"source_refs":[{"chapter":31,"line_start":200,"line_end":202,"text":"你应该想想严正刚，想想宋老夫子，想想朱云，想想他们是些什么样的人。"}]},{"id":"char_song_lao_fu_zi","name":"宋老夫子","alias":[],"identity":"江湖人物","faction":"未知","role":"npc","archetype":"scholar","rank":"炉火纯青","one_line":"卜鹰提到的宋老夫子","personality":{"traits":["老练","智慧","严厉","无情","果断"],"speech_style":"未知","temperament":"严厉"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[31],"source_refs":[{"chapter":31,"line_start":200,"line_end":202,"text":"你应该想想严正刚，想想宋老夫子，想想朱云，想想他们是些什么样的人。"}]},{"id":"char_zhu_yun","name":"朱云","alias":[],"identity":"江湖人物","faction":"未知","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"卜鹰提到的朱云","personality":{"traits":["果断","无情","强大","冷酷","残忍"],"speech_style":"未知","temperament":"冷酷"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[31],"source_refs":[{"chapter":31,"line_start":200,"line_end":202,"text":"你应该想想严正刚，想想宋老夫子，想想朱云，想想他们是些什么样的人。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
