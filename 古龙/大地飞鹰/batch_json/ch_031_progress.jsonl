{"segment":1,"line_start":1,"line_end":99,"dialogues":[{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_yang_guang","text":"\"他要到哪里去，你就带他到哪里去！\"","tone":"严肃","chapter":31,"line_start":6,"line_end":6},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":"char_yang_guang","text":"\"他要什么，你就给他什么！\"","tone":"严肃","chapter":31,"line_start":6,"line_end":8},{"speaker":"char_yang_guang","speaker_name":"\"阳光\"","listener":"char_xiao_fang","text":"\"你想要什么？想要我陪你到哪里去？\"","tone":"疑问","chapter":31,"line_start":18,"line_end":18},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_yang_guang","text":"\"我要一万两银子。\"","tone":"陈述","chapter":31,"line_start":22,"line_end":22},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_yang_guang","text":"\"我要到一个你绝不能陪我去的地方去。\"","tone":"陈述","chapter":31,"line_start":24,"line_end":24},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":"char_yang_guang","text":"\"你绝不能问我要到哪里去，更不能在暗中跟踪我，否则我说不定会杀了你！\"","tone":"冷酷","chapter":31,"line_start":46,"line_end":48},{"speaker":"char_yang_guang","speaker_name":"\"阳光\"","listener":"char_xiao_fang","text":"\"你去，我等你。\"","tone":"陈述","chapter":31,"line_start":54,"line_end":54},{"speaker":"char_na_hai_zi","speaker_name":"那孩子","listener":"char_xiao_fang","text":"\"……如果你违背了誓言，终生都要像这个人一样，受尽罗刹鬼女恶毒的折磨。\"","tone":"冷酷","chapter":31,"line_start":90,"line_end":92}],"new_entities":{"characters":[{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"江湖游侠","faction":"未知","role":"protagonist","archetype":"warrior","rank":"炉火纯青","one_line":"江湖游侠，卜鹰的伙伴","personality":{"traits":["勇敢","正直","执着","善良","重情义"],"speech_style":"简洁直接","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[31],"source_refs":[{"chapter":31,"line_start":4,"line_end":4,"text":"卜鹰又将小方交给了她。"}]},{"id":"char_bu_ying","name":"卜鹰","alias":[],"identity":"神秘人物","faction":"未知","role":"npc","archetype":"scholar","rank":"出神入化","one_line":"神秘的卜鹰","personality":{"traits":["神秘","冷静","智慧","果