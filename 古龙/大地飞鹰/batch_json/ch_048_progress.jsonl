{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我也跟别人一样，我也有父母。\n\n","tone":"陈述","chapter":48,"line_start":214,"line_end":214},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我的父亲是个镖师，十五年前在江南也有点名望。","tone":"陈述","chapter":48,"line_start":218,"line_end":218},{"speaker":null,"speaker_name":null,"listener":null,"text":"我的母亲温柔贤慧，胆子又小。\n\n每次我父亲出去走镖的时候，她没有一天晚上能睡得着觉。\n\n","tone":"温柔","chapter":48,"line_start":220,"line_end":220},{"speaker":null,"speaker_name":null,"listener":null,"text":"阳光","tone":"陈述","chapter":48,"line_start":226,"line_end":226},{"speaker":"char_zhao_qun","speaker_name":"赵群","listener":null,"text":"金手","tone":"陈述","chapter":48,"line_start":226,"line_end":226},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"在我五岁的那一年，我母亲担心的事终于还是发生了。\n\n","tone":"陈述","chapter":48,"line_start":230,"line_end":230},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"那一年的三月，我父亲护镖到中原，镖车在中条山遇盗被劫，我父亲再也没有回来。\n\n","tone":"陈述","chapter":48,"line_start":234,"line_end":234},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"镖师的收入并不多。我父亲的出手一向很大方，我们家里日子虽然还过得去，但是连一点积蓄都没有。\n\n他遇难之后，我们母子就连日子都过不下去了。","tone":"陈述","chapter":48,"line_start":238,"line_end":238},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"那家镖局呢？","tone":"疑问","chapter":48,"line_start":242,"line_end":242},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你父亲为他们拼命殉职，他们难道不照顾你们母子的生活？\n\n","tone":"疑问","chapter":48,"line_start":244,"line_end":244},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"为了赔那趟镖，那家镖局也垮了，镖局的主人也上了吊。","tone":"陈述","chapter":48,"line_start":248,"line_end":248},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"但是你们还得活下去。","tone":"陈述","chapter":48,"line_start":256,"line_end":256},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你们是怎么活下去的？","tone":"疑问","chapter":48,"line_start":258,"line_end":258},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我们是怎么活下去的？是怎么活下去的？……","tone":"疑问","chapter":48,"line_start":260,"line_end":260},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"一个无亲无故，无依无靠的女人，带着一个五岁大的孩子，要怎么样才能活得下去？\n\n","tone":"疑问","chapter":48,"line_start":264,"line_end":264},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"但是我的父亲并没有死。","tone":"陈述","chapter":48,"line_start":282,"line_end":282},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"三年之后他又回来了。","tone":"陈述","chapter":48,"line_start":284,"line_end":284},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"你父亲又回去了？","tone":"疑问","chapter":48,"line_start":288,"line_end":288},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"他知不知道你母亲在干什么？","tone":"疑问","chapter":48,"line_start":290,"line_end":290},{"speaker":null,"speaker_name":null,"listener":null,"text":"他知道。","tone":"陈述","chapter":48,"line_start":292,"line_end":292},{"speaker":null,"speaker_name":null,"listener":null,"text":"他……他……","tone":"陈述","chapter":48,"line_start":294,"line_end":294},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"他怎么样对你的母亲？","tone":"疑问","chapter":48,"line_start":296,"line_end":296},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"如果我是他，定会对你母亲更尊敬更感激。\n\n","tone":"陈述","chapter":48,"line_start":298,"line_end":298}],"new_entities":{"characters":[{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":201,"line_end":300,"text":"提及小方"}]},{"id":"char_su_su","name":"苏苏","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":201,"line_end":300,"text":"提及苏苏"}]},{"id":"char_zhao_qun","name":"赵群","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":201,"line_end":300,"text":"提及赵群"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":400,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"你不是他。","tone":"陈述","chapter":48,"line_start":302,"line_end":302},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你不是男人。","tone":"陈述","chapter":48,"line_start":304,"line_end":304},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"难道……难道他不要你母亲了？","tone":"疑问","chapter":48,"line_start":306,"line_end":306},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我告诉你这件事，只因为我要你知道，我有个这么样的母亲。","tone":"陈述","chapter":48,"line_start":318,"line_end":318},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"她在哪里？","tone":"疑问","chapter":48,"line_start":320,"line_end":320},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"她是不是还活着？","tone":"疑问","chapter":48,"line_start":322,"line_end":322},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"她还活着。","tone":"陈述","chapter":48,"line_start":324,"line_end":324},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"那时我还小，她不能死。","tone":"陈述","chapter":48,"line_start":326,"line_end":326},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"那时我虽然还小，可是已经知道她为我牺牲了什么。\n\n所以我告诉她，如果她死，我也死。","tone":"陈述","chapter":48,"line_start":328,"line_end":328},{"speaker":null,"speaker_name":null,"listener":null,"text":"现在你已经长大了。","tone":"陈述","chapter":48,"line_start":332,"line_end":332},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"现在她在哪里？","tone":"疑问","chapter":48,"line_start":334,"line_end":334},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"在一个没有人认得她，也没有人知道她往事的地方。\n\n在一栋小小的木屋里。","tone":"陈述","chapter":48,"line_start":336,"line_end":336},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"她不让我常去见她，甚至不要别人知道她是我的母亲。","tone":"陈述","chapter":48,"line_start":340,"line_end":340},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"她那木屋里只有一张床，一张桌子，几张椅子，一个衣柜，一盏油灯。\n\n","tone":"陈述","chapter":48,"line_start":344,"line_end":344},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"她虽然不让我常去，我还是常常去。她那里的每样东西我都很熟悉。\n\n","tone":"陈述","chapter":48,"line_start":348,"line_end":348},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"这屋子里的这些东西，就是从她那里搬来的。\n\n","tone":"陈述","chapter":48,"line_start":352,"line_end":352},{"speaker":"char_lv_san","speaker_name":"吕三","listener":null,"text":"阳光","tone":"陈述","chapter":48,"line_start":364,"line_end":364},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我带你去。","tone":"陈述","chapter":48,"line_start":368,"line_end":368},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"我带你去找吕三。","tone":"陈述","chapter":48,"line_start":370,"line_end":370},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你不必。","tone":"陈述","chapter":48,"line_start":376,"line_end":376},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"不必？","tone":"疑问","chapter":48,"line_start":378,"line_end":378},{"speaker":null,"speaker_name":null,"listener":null,"text":"你不必带我去，不必陪我送死。","tone":"陈述","chapter":48,"line_start":380,"line_end":380},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"可是你不妨告诉我他的人在哪里。","tone":"陈述","chapter":48,"line_start":382,"line_end":382},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"我不能。","tone":"陈述","chapter":48,"line_start":384,"line_end":384},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"我可不能告诉你。","tone":"陈述","chapter":48,"line_start":386,"line_end":386},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"为什么？","tone":"疑问","chapter":48,"line_start":388,"line_end":388},{"speaker":null,"speaker_name":null,"listener":null,"text":"因为我也不知道他在哪里。","tone":"陈述","chapter":48,"line_start":390,"line_end":390},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"我只能带你去。","tone":"陈述","chapter":48,"line_start":392,"line_end":392},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"他是个谜一样的人，每个市镇乡村都有他的落脚处，却从来没有人知道他落脚在哪里。\n\n","tone":"陈述","chapter":48,"line_start":394,"line_end":394},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我也不知道，可是我能找得到。","tone":"陈述","chapter":48,"line_start":398,"line_end":398},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"那么我们就去找。","tone":"陈述","chapter":48,"line_start":400,"line_end":400}],"new_entities":{"characters":[{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":301,"line_end":400,"text":"提及小方"}]},{"id":"char_su_su","name":"苏苏","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":301,"line_end":400,"text":"提及苏苏"}]},{"id":"char_lv_san","name":"吕三","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":301,"line_end":400,"text":"提及吕三"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"也许我们要找很久，他的落脚处实在太多了。","tone":"陈述","chapter":48,"line_start":402,"line_end":402},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"只要能找得到，不管要找多久都没有关系。","tone":"陈述","chapter":48,"line_start":404,"line_end":404},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"阳光","tone":"陈述","chapter":48,"line_start":408,"line_end":408},{"speaker":null,"speaker_name":null,"listener":null,"text":"吉祥如意，恭喜发财","tone":"欣喜","chapter":48,"line_start":440,"line_end":440},{"speaker":null,"speaker_name":null,"listener":null,"text":"过年","tone":"陈述","chapter":48,"line_start":444,"line_end":444},{"speaker":null,"speaker_name":null,"listener":null,"text":"过年","tone":"陈述","chapter":48,"line_start":444,"line_end":444},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我为她做了些什么？\n\n","tone":"疑问","chapter":48,"line_start":452,"line_end":452},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你是不是病了？","tone":"疑问","chapter":48,"line_start":462,"line_end":462},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你是不是有点不舒服？\n\n什么地方不舒服呢？","tone":"疑问","chapter":48,"line_start":464,"line_end":464},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"我好像已经有了孕。\n\n","tone":"陈述","chapter":48,"line_start":468,"line_end":468},{"speaker":null,"speaker_name":null,"listener":null,"text":"你是不是想问我，我肚里的孩子是你的？还是赵群的？","tone":"疑问","chapter":48,"line_start":480,"line_end":480},{"speaker":"char_zhao_qun","speaker_name":"赵群","listener":null,"text":"我可以告诉你，孩子是你的，因为赵群不会有孩子。\n\n","tone":"陈述","chapter":48,"line_start":482,"line_end":482},{"speaker":"char_zhao_qun","speaker_name":"赵群","listener":null,"text":"在花不拉的商队里，我们住在你们隔壁的时候，我们每天晚上都发出那些声音来，并不是因为我们喜欢做那件事。\n\n","tone":"欣喜","chapter":48,"line_start":486,"line_end":486},{"speaker":null,"speaker_name":null,"listener":null,"text":"你们是为了什么？","tone":"疑问","chapter":48,"line_start":490,"line_end":490},{"speaker":null,"speaker_name":null,"listener":null,"text":"我们是故意的。","tone":"陈述","chapter":48,"line_start":492,"line_end":492},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"我们故意那么做，别人才不会怀疑我们就是吕三要追捕的人，所以别人才会怀疑你。\n\n","tone":"陈述","chapter":48,"line_start":494,"line_end":494},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"为什么？","tone":"疑问","chapter":48,"line_start":498,"line_end":498}],"new_entities":{"characters":[{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":401,"line_end":500,"text":"提及小方"}]},{"id":"char_su_su","name":"苏苏","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":401,"line_end":500,"text":"提及苏苏"}]},{"id":"char_zhao_qun","name":"赵群","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":401,"line_end":500,"text":"提及赵群"}]},{"id":"char_lv_san","name":"吕三","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":401,"line_end":500,"text":"提及吕三"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":501,"line_end":549,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"\n\n苏苏的声音更痛苦：","tone":"陈述","chapter":48,"line_start":502,"line_end":502},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"\n\n小方又怔住，完全怔住。\n\n","tone":"陈述","chapter":48,"line_start":504,"line_end":504},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"\n\n苏苏眼中已有泪光：","tone":"陈述","chapter":48,"line_start":508,"line_end":508},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"\n\n她接着道：","tone":"陈述","chapter":48,"line_start":512,"line_end":512},{"speaker":null,"speaker_name":null,"listener":null,"text":"\n\n——女人的感情，女人的心事，有谁能完全了解？\n\n小方也不能。\n\n苏苏直视着她：","tone":"疑问","chapter":48,"line_start":516,"line_end":516},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"\n\n小方开始喝酒，低着头喝酒，因为他已不敢去看她。\n\n他知道她的说是真话。他不能不承认孩子是他的，也不会不承认。\n\n他绝不是那种不负责任的男人。\n\n只不过对他这么样一个没有根的浪子来说，这件事来得实在太突然，突然得令他完全无法适应。\n\n——他居然有了孩子，跟一个本来属于别人的女人有了孩子。\n\n有谁能想得到这种事。\n\n","tone":"陈述","chapter":48,"line_start":524,"line_end":524},{"speaker":null,"speaker_name":null,"listener":null,"text":"\n\n苏苏擦干眼泪，举起酒杯，","tone":"陈述","chapter":48,"line_start":538,"line_end":538}],"new_entities":{"characters":[{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":501,"line_end":549,"text":"提及小方"}]},{"id":"char_su_su","name":"苏苏","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":501,"line_end":549,"text":"提及苏苏"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}