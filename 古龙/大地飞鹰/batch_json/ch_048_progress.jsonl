{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"我没有看见，什么都没有看见。","tone":"陈述","chapter":48,"line_start":102,"line_end":102},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"所以我要出去看看。","tone":"陈述","chapter":48,"line_start":106,"line_end":106},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":null,"text":"五个人","tone":"陈述","chapter":48,"line_start":110,"line_end":110},{"speaker":"char_bu_ying","speaker_name":"卜鹰","listener":null,"text":"阳光","tone":"陈述","chapter":48,"line_start":110,"line_end":110},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"以前你有没有到这一家来过？","tone":"疑问","chapter":48,"line_start":130,"line_end":130},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"没有。","tone":"陈述","chapter":48,"line_start":132,"line_end":132},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"可是我知道这一家住的是什么人。","tone":"陈述","chapter":48,"line_start":134,"line_end":134},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"是什么人？","tone":"疑问","chapter":48,"line_start":136,"line_end":136},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"这一家住的就是那樵夫的表哥。","tone":"陈述","chapter":48,"line_start":138,"line_end":138},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"我们到这樵夫家里去的时候，他们一家大小就全都住到他表哥家里来了。\n\n","tone":"陈述","chapter":48,"line_start":140,"line_end":140},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你看见了什么？","tone":"疑问","chapter":48,"line_start":172,"line_end":172}],"new_entities":{"characters":[{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":101,"line_end":200,"text":"提及小方"}]},{"id":"char_su_su","name":"苏苏","