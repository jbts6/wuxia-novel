{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我们再等一天。","tone":"陈述","chapter":48,"line_start":10,"line_end":10},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"不管我们要怎么做，都要再等一天。","tone":"陈述","chapter":48,"line_start":12,"line_end":12},{"speaker":null,"speaker_name":null,"listener":null,"text":"等什么？","tone":"疑问","chapter":48,"line_start":14,"line_end":14},{"speaker":null,"speaker_name":null,"listener":null,"text":"等赵群。","tone":"陈述","chapter":48,"line_start":16,"line_end":16},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我一定要让他知道。虽然我也没有脸见他，却还是要等他回来。\n\n","tone":"陈述","chapter":48,"line_start":18,"line_end":18},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"如果他没有回来呢？","tone":"疑问","chapter":48,"line_start":24,"line_end":24},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"如果他不回来，我就走。","tone":"陈述","chapter":48,"line_start":26,"line_end":26},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"你打算要到哪里去？","tone":"疑问","chapter":48,"line_start":28,"line_end":28},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"去找吕三，去死！","tone":"激动","chapter":48,"line_start":30,"line_end":30},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"到那时不管你要怎么样，我都只有这一条路可走了。\n\n","tone":"陈述","chapter":48,"line_start":30,"line_end":30},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你不能陪我到别的地方去？","tone":"疑问","chapter":48,"line_start":34,"line_end":34},{"speaker":null,"speaker_name":null,"listener":null,"text":"我不能。","tone":"陈述","chapter":48,"line_start":36,"line_end":36},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"为什么？","tone":"疑问","chapter":48,"line_start":38,"line_end":38},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"因为我忘不了这些人，这些事。","tone":"陈述","chapter":48,"line_start":40,"line_end":40},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"不管我们躲到哪里去，就算能躲开别人，却还是有一个人是我永远躲不了的。\n\n","tone":"陈述","chapter":48,"line_start":42,"line_end":42},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"谁？","tone":"疑问","chapter":48,"line_start":46,"line_end":46},{"speaker":null,"speaker_name":null,"listener":null,"text":"我自己。","tone":"陈述","chapter":48,"line_start":48,"line_end":48},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你以前到这里来过没有？","tone":"疑问","chapter":48,"line_start":88,"line_end":88},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"我来过。","tone":"陈述","chapter":48,"line_start":90,"line_end":90},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你知不知道这里的人平常都吃些什么？","tone":"疑问","chapter":48,"line_start":92,"line_end":92},{"speaker":null,"speaker_name":null,"listener":null,"text":"吃鱼，吃肉，吃米，吃面，吃蔬菜水果。","tone":"陈述","chapter":48,"line_start":94,"line_end":94},{"speaker":"char_su_su","speaker_name":"苏苏","listener":null,"text":"别人吃什么，这里的人也吃什么。","tone":"陈述","chapter":48,"line_start":96,"line_end":96},{"speaker":"char_xiao_fang","speaker_name":"小方","listener":null,"text":"你是不是看见了什么奇怪的事？\n\n","tone":"疑问","chapter":48,"line_start":98,"line_end":98}],"new_entities":{"characters":[{"id":"char_xiao_fang","name":"小方","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":1,"line_end":100,"text":"提及小方"}]},{"id":"char_su_su","name":"苏苏","alias":[],"identity":"","faction":"","role":"","archetype":"","rank":"","one_line":"","personality":{"traits":[],"speech_style":"","temperament":""},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":48,"line_start":1,"line_end":100,"text":"提及苏苏"}]},{"id":"char_zhao_qun","name":"赵群","alias":[],"ident