[
  {
    "id": "loc_tian_xiang_lou",
    "name": "天香楼",
    "region": "杭州",
    "one_line": "杭州酒楼，杜七等待各方来客之地，后为龙五设宴之所",
    "source_refs": [
      {
        "chapter": 1,
        "line_start": 10,
        "line_end": 10,
        "text": "这里是酒楼，天香楼。"
      },
      {
        "chapter": 1,
        "line_start": 688,
        "line_end": 692,
        "text": "杭州天香楼还是和平常一样，还不到吃晚饭的时候，就已座无虚席。"
      },
      {
        "chapter": 8,
        "line_start": 242,
        "line_end": 242,
        "text": "我常常都在天香楼喝酒。"
      }
    ],
    "relationships": []
  },
  {
