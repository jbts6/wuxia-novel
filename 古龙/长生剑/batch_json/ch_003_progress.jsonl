{"segment":4,"line_start":300,"line_end":399,"dialogues":[{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"这人岂非已经被仇家逼到东瀛扶桑去了？","tone":"陈述","chapter":3,"line_start":300,"line_end":300},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"扶桑不是地狱，去了还可以再回来的。","tone":"陈述","chapter":3,"line_start":302,"line_end":302},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"想必是的。","tone":"淡然","chapter":3,"line_start":310,"line_end":310},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"什么叫忍术？","tone":"陈述","chapter":3,"line_start":312,"line_end":312},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"可是我想听。","tone":"陈述","chapter":3,"line_start":318,"line_end":318},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"想听我也不能说。","tone":"陈述","chapter":3,"line_start":320,"line_end":320},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"为什么？","tone":"陈述","chapter":3,"line_start":322,"line_end":322},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"因为我也不懂。","tone":"陈述","chapter":3,"line_start":324,"line_end":324},{"speaker":null,"speaker_name":null,"listener":null,"text":"猿飞佐助","tone":"陈述","chapter":3,"line_start":328,"line_end":328},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"你怎么知道他们等的是卫天鹰？","tone":"陈述","chapter":3,"line_start":342,"line_end":342},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"刚才他们自己说的。","tone":"陈述","chapter":3,"line_start":344,"line_end":344},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"他们说的话你能听见？","tone":"陈述","chapter":3,"line_start":346,"line_end":346},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"听不见，却看得见。","tone":"陈述","chapter":3,"line_start":348,"line_end":348},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"说话也能看见？怎么看？