{"segment":3,"line_start":200,"line_end":299,"dialogues":[{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"还有个戴毡帽的呢？","tone":"淡然","chapter":3,"line_start":200,"line_end":200},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"我敬你一杯。","tone":"陈述","chapter":3,"line_start":218,"line_end":218},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"为什么忽然敬我？","tone":"陈述","chapter":3,"line_start":220,"line_end":220},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"我只怕再不敬你以后就没机会了。","tone":"无奈","chapter":3,"line_start":222,"line_end":222},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"你不妨先看看来的是谁，再敬我也不迟。","tone":"陈述","chapter":3,"line_start":224,"line_end":224},{"speaker":null,"speaker_name":null,"listener":null,"text":"为什么……","tone":"陈述","chapter":3,"line_start":236,"line_end":236},{"speaker":null,"speaker_name":null,"listener":null,"text":"贫僧的账，请记在郭老太太账上。","tone":"陈述","chapter":3,"line_start":250,"line_end":250},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"考什么？","tone":"陈述","chapter":3,"line_start":260,"line_end":260},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"两件事。","tone":"陈述","chapter":3,"line_start":262,"line_end":262},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"考吧。","tone":"无奈","chapter":3,"line_start":264,"line_end":264},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"你看刚才那两个和尚，身上少了样什么？","tone":"陈述","chapter":3,"line_start":266,"line_end":266},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"戒疤。","tone":"陈述","chapter":3,"line_start":270,"line_end":270},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"连一个都没有。","tone":"陈述","chapter":3,"line_start":276,"line_end":276},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"他们……他们难道不是真的和尚？","to