{"segment":6,"line_start":499,"line_end":598,"dialogues":[{"speaker":"char_miao_shao_tian","speaker_name":"苗烧天","listener":null,"text":"方老板果然好眼力。","tone":"陈述","chapter":3,"line_start":499,"line_end":499},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"刚才……","tone":"陈述","chapter":3,"line_start":501,"line_end":501},{"speaker":"char_miao_shao_tian","speaker_name":"苗烧天","listener":null,"text":"刚才我在吃饭。我吃饭的时候从不杀人的。","tone":"陈述","chapter":3,"line_start":503,"line_end":503},{"speaker":"char_miao_shao_tian","speaker_name":"苗烧天","listener":null,"text":"砰","tone":"陈述","chapter":3,"line_start":521,"line_end":521},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"是谁杀了他？为什么要杀他？","tone":"陈述","chapter":3,"line_start":529,"line_end":529},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"因为他是个假和尚。","tone":"陈述","chapter":3,"line_start":531,"line_end":531},{"speaker":"char_fang_long_xiang","speaker_name":"方龙香","listener":null,"text":"假和尚？……为什么有人要杀假和尚？","tone":"陈述","chapter":3,"line_start":533,"line_end":533},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"死的假和尚。","tone":"陈述","chapter":3,"line_start":541,"line_end":541},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"你冷？","tone":"陈述","chapter":3,"line_start":547,"line_end":547},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"也许他们都是为了你而来的。","tone":"陈述","chapter":3,"line_start":553,"line_end":553},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"为了我？","tone":"陈述","chapter":3,"line_start":555,"line_end":555},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"越可怕的人，越喜欢好看的女人。","tone":"陈述","chapter":3,"line_start":557,"line_end":557},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"你呢？你岂非也是个很可怕的人？","tone":"陈述","chapter":3,"line_start":559,"line_end":559},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"我……","tone":"陈述","chapter":3,"line_start":561,"line_end":561},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"有……有贼。","tone":"陈述","chapter":3,"line_start":569,"line_end":569},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"有没有什么东西不见？","tone":"陈述","chapter":3,"line_start":575,"line_end":575},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"我……我根本就没什么东西好让贼偷的。","tone":"陈述","chapter":3,"line_start":577,"line_end":577},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"来的也许不是贼。","tone":"微笑","chapter":3,"line_start":579,"line_end":579},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"不是贼为什么要闯进别人屋里来乱翻东西？","tone":"陈述","chapter":3,"line_start":581,"line_end":581},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"看来他们果然是来找我的。","tone":"陈述","chapter":3,"line_start":583,"line_end":583},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"找你？谁？为什么要找你？","tone":"陈述","chapter":3,"line_start":585,"line_end":585},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"我出去看看。","tone":"陈述","chapter":3,"line_start":593,"line_end":593}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":599,"line_end":698,"dialogues":[{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"可是我……","tone":"无奈","chapter":3,"line_start":599,"line_end":599},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"求求你，求求你，现在我真的怕得要命。","tone":"陈述","chapter":3,"line_start":601,"line_end":601},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"现在你真的怕得要命？","tone":"陈述","chapter":3,"line_start":605,"line_end":605},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"嗯。","tone":"陈述","chapter":3,"line_start":607,"line_end":607},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"刚才呢？","tone":"陈述","chapter":3,"line_start":609,"line_end":609},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"刚才……刚才我还有点假装的。","tone":"陈述","chapter":3,"line_start":611,"line_end":611},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"为什么要假装？","tone":"陈述","chapter":3,"line_start":613,"line_end":613},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"因为我……","tone":"陈述","chapter":3,"line_start":615,"line_end":615},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"我既然不是好人，你还敢让我留在屋子里？","tone":"陈述","chapter":3,"line_start":621,"line_end":621},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"我怎么忍心让你睡在地上？","tone":"陈述","chapter":3,"line_start":627,"line_end":627},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"还是你睡床。","tone":"陈述","chapter":3,"line_start":633,"line_end":633},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"不……","tone":"陈述","chapter":3,"line_start":635,"line_end":635},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"我也没有想到。","tone":"陈述","chapter":3,"line_start":649,"line_end":649},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"你……是不是怕有人闯进来？","tone":"陈述","chapter":3,"line_start":651,"line_end":651},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"不完全是。","tone":"陈述","chapter":3,"line_start":653,"line_end":653},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"不完全是？","tone":"陈述","chapter":3,"line_start":655,"line_end":655},{"speaker":null,"speaker_name":null,"listener":null,"text":"他伸出手，轻抚着她的手，柔声道：","tone":"柔声","chapter":3,"line_start":659,"line_end":659},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"你难道故意叫那些人来吓我？","tone":"陈述","chapter":3,"line_start":663,"line_end":663},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"那倒不是，但他们却的确是来找我的。","tone":"微笑","chapter":3,"line_start":665,"line_end":665},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"为什么来找你？","tone":"陈述","chapter":3,"line_start":667,"line_end":667},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"因为我身上有样东西，是他们很想要的东西。","tone":"陈述","chapter":3,"line_start":669,"line_end":669},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"我从来没有这么想过。","tone":"陈述","chapter":3,"line_start":675,"line_end":675},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"假如我也是呢？","tone":"陈述","chapter":3,"line_start":677,"line_end":677},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"那么我就给你。","tone":"陈述","chapter":3,"line_start":679,"line_end":679},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"把那样东西给我？","tone":"陈述","chapter":3,"line_start":681,"line_end":681},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"嗯。","tone":"陈述","chapter":3,"line_start":683,"line_end":683},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"无论什么东西，只要你开口，我立刻就给你。","tone":"陈述","chapter":3,"line_start":689,"line_end":689},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"真的？","tone":"陈述","chapter":3,"line_start":691,"line_end":691},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"我现在就给你。","tone":"陈述","chapter":3,"line_start":693,"line_end":693}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":699,"line_end":790,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"我什么都不要，我只要你陪着我……","tone":"柔声","chapter":3,"line_start":699,"line_end":699},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"你在哭？","tone":"陈述","chapter":3,"line_start":703,"line_end":703},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"因为我太高兴了。","tone":"陈述","chapter":3,"line_start":705,"line_end":705},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"你说，我听。","tone":"陈述","chapter":3,"line_start":711,"line_end":711},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"可是现在不同了。","tone":"陈述","chapter":3,"line_start":743,"line_end":743},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"有什么不同？","tone":"陈述","chapter":3,"line_start":745,"line_end":745},{"speaker":null,"speaker_name":null,"listener":null,"text":"只要你肯要我，我什么都给你，一辈子不离开你……","tone":"陈述","chapter":3,"line_start":755,"line_end":755},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"你肯带我走？","tone":"陈述","chapter":3,"line_start":761,"line_end":761},{"speaker":"char_bai_yu_jing","speaker_name":"白玉京","listener":null,"text":"从今后，无论我到哪里，都一定带你去。","tone":"陈述","chapter":3,"line_start":763,"line_end":763},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"真的？","tone":"陈述","chapter":3,"line_start":765,"line_end":765},{"speaker":"char_yuan_zi_xia","speaker_name":"袁紫霞","listener":null,"text":"我们现在就走？","tone":"陈述","chapter":3,"line_start":777,"line_end":777}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
