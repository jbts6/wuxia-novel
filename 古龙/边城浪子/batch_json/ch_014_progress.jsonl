{"segment":4,"line_start":701,"line_end":914,"dialogues":[{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":null,"text":"这个人是我的兄弟，只有他是我的兄弟。","tone":"悲伤","chapter":14,"line_start":792,"line_end":792},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":null,"text":"若没有他的话，我也绝不能活到现在。","tone":"悲伤","chapter":14,"line_start":796,"line_end":796},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"我们都知道他是个好人。","tone":"悲伤","chapter":14,"line_start":798,"line_end":798},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":null,"text":"他的确是个好人，没有人比他更忠实，没有人比他更勇敢，可是他自己这一生中，却从未有过一天好日子。","tone":"悲伤","chapter":14,"line_start":802,"line_end":802},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":null,"text":"他本不该死的，但现在却已死了。","tone":"悲伤","chapter":14,"line_start":808,"line_end":808},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"一定是傅红雪杀了他。","tone":"愤怒","chapter":14,"line_start":810,"line_end":810},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":null,"text":"我对不起他，我本该听他的话，先将那些人杀了的。","tone":"悲痛","chapter":14,"line_start":812,"line_end":812},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"现在……","tone":"陈述","chapter":14,"line_start":816,"line_end":816},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":null,"text":"现在已太迟了，太迟了……","tone":"悲痛","chapter":14,"line_start":818,"line_end":818},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"但我们却更不能放过傅红雪，我们一定要为他复仇。","tone":"愤怒","chapter":14,"line_start":820,"line_end":820},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"当然要复仇，只不过……","tone":"陈述","chapter":14,"line_start":822,"line_end":822},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"只不过，复仇之前，我还有件事要做。","tone":"厉声","chapter":14,"line_start":824,"line_end":824},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"什么事？","tone":"疑问","chapter":14,"line_start":826,"line_end":826},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"你过来，我跟你说。","tone":"陈述","chapter":14,"line_start":828,"line_end":828},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"我要你替我做件事。","tone":"陈述","chapter":14,"line_start":832,"line_end":832},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"堂主就吩咐。","tone":"陈述","chapter":14,"line_start":834,"line_end":834},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"我要你死！","tone":"冷酷","chapter":14,"line_start":836,"line_end":836},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"我不懂，我……我真的实在不懂。","tone":"颤声","chapter":14,"line_start":868,"line_end":868},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"你应该懂的。","tone":"冷酷","chapter":14,"line_start":870,"line_end":870},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"这地方本来是我的，无论谁想从我手上夺走，他都得死！","tone":"冷酷","chapter":14,"line_start":872,"line_end":872},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"原来你已全都知道。","tone":"无奈","chapter":14,"line_start":876,"line_end":876},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"我早已知道。","tone":"陈述","chapter":14,"line_start":878,"line_end":878},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"我低估了你。","tone":"苦笑","chapter":14,"line_start":880,"line_end":880},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"我早就说过，世上有很多事都和灰尘一样，虽然早已在你身旁，你却一直看不见它——我也一直没有看清你。","tone":"陈述","chapter":14,"line_start":882,"line_end":882},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"可是阳光迟早总会照进来的。","tone":"冷笑","chapter":14,"line_start":886,"line_end":886},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"现在你已懂了么？","tone":"疑问","chapter":14,"line_start":892,"line_end":892},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"我懂了。","tone":"陈述","chapter":14,"line_start":894,"line_end":894},{"speaker":"char_ma_kong_qun","speaker_name":"马空群","listener":"char_yun_zai_tian","text":"你本不该出卖我的，你本该很了解我这个人。","tone":"无奈","chapter":14,"line_start":896,"line_end":896},{"speaker":"char_yun_zai_tian","speaker_name":"云在天","listener":"char_ma_kong_qun","text":"我虽然出卖了你，可是……","tone":"陈述","chapter":14,"line_start":900,"line_end":900}],"new_entities":{"characters":[],"skills":[{"id":"skill_tui_chuang_wang_yue_fei_yun_shi","name":"推窗望月飞云式","type":"轻功","faction":"","rank":"炉火纯青","one_line":"云在天遇袭时凌空翻出的飞云身法。","techniques":[{"id":"tech_ling_kong_fan_chu","name":"凌空翻出","type":"defense","description":"遇刀光突袭时身子凌空翻出，用翻掠卸开正面杀势。"},{"id":"tech_fei_yun_bi_dao","name":"飞云避刀","type":"defense","description":"借飞云式身法避过致命刀锋，即使受创也能保住性命。"}],"progression":[{"level":"炉火纯青","description":"云在天在马空群近身突袭下预先提防，仍能以此式翻出刀光。"}],"effects":[{"type":"控制","description":"以腾掠翻身脱离敌人刀势中心。"}],"combat_style":"突遭近身袭击时以凌空翻掠闪避，重在身法速度与预判。","rag_refs":[14],"source_refs":[{"chapter":14,"line_start":844,"line_end":846,"text":"刀光挥出，云在天的人也已掠起，一个推窗望月飞云式，身子凌空翻出。"}]}],"techniques":[{"id":"tech_ling_kong_fan_chu","name":"凌空翻出","type":"defense","description":"云在天以推窗望月飞云式凌空翻出，从马空群刀光中脱身。","source_skill":"skill_tui_chuang_wang_yue_fei_yun_shi","source_refs":[{"chapter":14,"line_start":844,"line_end":846,"text":"云在天施展推窗望月飞云式，身子凌空翻出，鲜血随之飞出。"}]},{"id":"tech_fei_yun_bi_dao","name":"飞云避刀","type":"defense","description":"以飞云般翻掠避开近身刀锋，虽被刀光伤及仍避开立毙结局。","source_skill":"skill_tui_chuang_wang_yue_fei_yun_shi","source_refs":[{"chapter":14,"line_start":844,"line_end":846,"text":"云在天以飞云式避开马空群突然削来的弯刀。"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_gong_sun_duan","updates":{"source_refs":[{"chapter":14,"line_start":712,"line_end":792,"text":"公孙断倒下后，马空群称他是自己唯一的兄弟，并追忆其忠实勇敢。"}]},"relationship_updates":[{"action":"update","target":"char_ma_kong_qun","type":"挚友","intensity":88,"bond_level":5,"dynamic":"死后被马空群称作唯一兄弟，忠实勇敢却一生没有好日子"}]},{"id":"char_ma_kong_qun","updates":{"one_line":"马空群借公孙断之死引出复仇话题，随后突然以弯刀袭杀已暴露背叛的云在天。","source_refs":[{"chapter":14,"line_start":792,"line_end":900,"text":"马空群哀悼公孙断后，突然命云在天去死，揭穿他背叛并重申谁想夺走万马堂都得死。"}]},"relationship_updates":[{"action":"update","target":"char_gong_sun_duan","type":"挚友","intensity":88,"bond_level":5,"dynamic":"认定公孙断是唯一兄弟，并为其死哽咽悲痛"},{"action":"update","target":"char_yun_zai_tian","type":"宿敌","intensity":95,"bond_level":5,"dynamic":"揭穿云在天出卖自己后亲手以弯刀突袭，要他去死"}]},{"id":"char_yun_zai_tian","updates":{"known_skills":["skill_tui_chuang_wang_yue_fei_yun_shi"],"rank":"炉火纯青","source_refs":[{"chapter":14,"line_start":820,"line_end":900,"text":"云在天先附和复仇，后被马空群突然袭杀，承认自己低估了堂主。"}]},"relationship_updates":[{"action":"update","target":"char_ma_kong_qun","type":"宿敌","intensity":95,"bond_level":5,"dynamic":"背叛之事被马空群看破，受袭后承认低估了他"}]}]}
