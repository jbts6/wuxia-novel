{"segment":2,"line_start":56,"line_end":100,"dialogues":[{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"老太太，你怎么突然变得年轻起来了？\"","tone":"调侃","chapter":17,"line_start":60,"line_end":60},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"不是年轻，是骨头轻，我看见你这样的小白脸，骨头就会变得奇轻。\"","tone":"调侃","chapter":17,"line_start":62,"line_end":64},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"听说老人家若是喝了人血，年纪也会变轻的。\"","tone":"淡然","chapter":17,"line_start":66,"line_end":66},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"你要我喝你的血？\"","tone":"疑问","chapter":17,"line_start":68,"line_end":68},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"你刚才岂非也喝过乐乐山的血？\"","tone":"疑问","chapter":17,"line_start":70,"line_end":70},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"那糟老头子血里的酒太多，还是喝你的血好。\"","tone":"冷酷","chapter":17,"line_start":72,"line_end":72},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"你还有什么宝贝，为什么不一起使出来，也好让我见识见识。\"","tone":"调侃","chapter":17,"line_start":86,"line_end":88},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"你……你究竟是什么人？\"","tone":"恐惧","chapter":17,"line_start":90,"line_end":90},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"我姓叶，叫叶开，树叶子的叶，开心的开。\"","tone":"陈述","chapter":17,"line_start":92,"line_end":92},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"只可惜我开心的时候，你就不会开心了。\"","tone":"调侃","chapter":17,"line_start":94,"line_end":94},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"好，好轻功。\"","tone":"欣慰","chapter":17,"line_start":100,"line_end":100}],"new_entities":{"characters":[{"id":"char_ye_kai","name":"叶开","alias":[],"identity":"轻功敏捷、识见机敏的江湖人物","faction":"","role":"companion","archetype":"warr