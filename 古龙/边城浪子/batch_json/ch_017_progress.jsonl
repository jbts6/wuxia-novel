{"segment":3,"line_start":102,"line_end":156,"dialogues":[{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"倒也不是轻功好，只不过是骨头轻罢了。\"","tone":"调侃","chapter":17,"line_start":102,"line_end":102},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"看来你骨头比我还轻。\"","tone":"苦笑","chapter":17,"line_start":104,"line_end":104},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"我不认得你，你为什么要跟我作对？\"","tone":"疑问","chapter":17,"line_start":124,"line_end":124},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"谁说我要跟你作对？\"","tone":"疑问","chapter":17,"line_start":126,"line_end":126},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"那么你想怎么样？\"","tone":"疑问","chapter":17,"line_start":128,"line_end":128},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"只不过想请你喝杯酒而已。\"","tone":"陈述","chapter":17,"line_start":130,"line_end":130},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"请我喝酒？\"","tone":"惊讶","chapter":17,"line_start":132,"line_end":132},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"我一向难得请人喝酒的，这机会错过可惜。\"","tone":"调侃","chapter":17,"line_start":134,"line_end":134},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"到哪里去喝？\"","tone":"疑问","chapter":17,"line_start":136,"line_end":136},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"当然是萧别离的店里，那地方可以挂账。\"","tone":"调侃","chapter":17,"line_start":138,"line_end":138},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_xi_men_chun","text":"\"等一等。\"","tone":"冷酷","chapter":17,"line_start":150,"line_end":150},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_xi_men_chun","text":"\"我已杀过人。\"","tone":"冷酷","chapter":17,"line_start":154,"line_end":154},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_xi_men_chun","text":"\"我并不在乎多杀一个。\"","tone":"冷酷","chapter":17,"line_start":156,"line_end":156}],"new_entities":{"characters":[],"skills":[],"techniques":[{"id":"tech_ye_kai_qie_mai_zhi_shou","name":"切脉制手","type":"attack","description":"叶开在对方出手时轻划脉门，使其双手不能再抬。","source_skill":"skill_ye_kai_kuai_shou","source_refs":[{"chapter":17,"line_start":112,"line_end":112,"text":"他的出手既不奇怪，也不诡异。只不过很快，快得令人不可思议。"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":158,"line_end":208,"dialogues":[{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"杀人就像喝酒一样，只有第一杯最难入口，你若能喝下第一杯，再多喝几杯当然就不在乎了。\"","tone":"认真","chapter":17,"line_start":158,"line_end":158},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"只不过怎么样？\"","tone":"疑问","chapter":17,"line_start":160,"line_end":160},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"杀人也像喝酒一样，喝多了慢慢就会上瘾的。\"","tone":"认真","chapter":17,"line_start":162,"line_end":162},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"这件事还是莫要上瘾的好。\"","tone":"认真","chapter":17,"line_start":164,"line_end":164},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"我并不想杀你。\"","tone":"冷酷","chapter":17,"line_start":166,"line_end":166},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"你想杀她？\"","tone":"疑问","chapter":17,"line_start":168,"line_end":168},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"我本来只杀两种人，现在却又多了一种。\"","tone":"冷酷","chapter":17,"line_start":170,"line_end":170},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"哪一种？\"","tone":"疑问","chapter":17,"line_start":172,"line_end":172},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"想杀我的人。\"","tone":"冷酷","chapter":17,"line_start":174,"line_end":174},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"她刚才想杀你，你现在想杀她，这倒也很公平。\"","tone":"认真","chapter":17,"line_start":176,"line_end":178},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"你闪开。\"","tone":"冷酷","chapter":17,"line_start":180,"line_end":180},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"我可以闪开，但你却不能真的杀了她。知道吗？\"","tone":"认真","chapter":17,"line_start":182,"line_end":182},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"为什么？\"","tone":"疑问","chapter":17,"line_start":184,"line_end":184},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"因为她也没有真的杀了你。\"","tone":"陈述","chapter":17,"line_start":186,"line_end":186},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"你究竟是个什么人？嗯？\"","tone":"疑问","chapter":17,"line_start":190,"line_end":190},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"你们明明全知道我是什么人，为什么还要问我这句话？\"","tone":"调侃","chapter":17,"line_start":192,"line_end":194},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"我要问清楚些，只因为我欠你一样东西。\"","tone":"认真","chapter":17,"line_start":196,"line_end":196},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_fu_hong_xue","text":"\"欠我什么？\"","tone":"疑问","chapter":17,"line_start":198,"line_end":198},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"欠你一条命。\"","tone":"认真","chapter":17,"line_start":200,"line_end":200},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ye_kai","text":"\"这笔账我迟早总会还你的，你也可以随时问我来要。\"","tone":"认真","chapter":17,"line_start":202,"line_end":204}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":210,"line_end":276,"dialogues":[{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"这地方如何？\"","tone":"轻笑","chapter":17,"line_start":216,"line_end":218},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"不错。\"","tone":"陈述","chapter":17,"line_start":220,"line_end":220},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"酒呢？\"","tone":"疑问","chapter":17,"line_start":222,"line_end":222},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"也不错。\"","tone":"陈述","chapter":17,"line_start":224,"line_end":224},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"那么你就该感激我。若不是我，你怎么能到这里来喝酒？\"","tone":"调侃","chapter":17,"line_start":226,"line_end":228},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"为什么不能？\"","tone":"疑问","chapter":17,"line_start":230,"line_end":230},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"这里是男人的天下，'断肠针'杜婆婆虽然是名闻天下的武林高手，但却是个女人。\"","tone":"陈述","chapter":17,"line_start":232,"line_end":234},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"我是杜婆婆？\"","tone":"疑问","chapter":17,"line_start":236,"line_end":236},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"我看到乐乐山中的断肠针，就已想到是你。\"","tone":"陈述","chapter":17,"line_start":238,"line_end":238},{"speaker":"char_xi_men_chun","speaker_name":"老太婆","listener":"char_ye_kai","text":"\"好眼力。\"","tone":"欣慰","chapter":17,"line_start":240,"line_end":240},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"可是我并没有替他报仇的意思。\"","tone":"陈述","chapter":17,"line_start":242,"line_end":242},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_xi_men_chun","text":"\"我只想问问你，你为什么要替万马堂杀人？\"","tone":"疑问","chapter":17,"line_start":246,"line_end":246},{"speaker":"char_xi_men_chu