{"segment":8,"line_start":384,"line_end":438,"dialogues":[{"speaker":"char_li_ma_hu","speaker_name":"李马虎","listener":"char_fu_hong_xue","text":"\"你的包袱……哦，不错，这里是有个包袱。\"","tone":"慌张","chapter":17,"line_start":384,"line_end":384},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_li_ma_hu","text":"\"蛋怎么卖？\"","tone":"疑问","chapter":17,"line_start":396,"line_end":396},{"speaker":"char_li_ma_hu","speaker_name":"李马虎","listener":"char_fu_hong_xue","text":"\"想买？\"","tone":"疑问","chapter":17,"line_start":398,"line_end":398},{"speaker":"char_li_ma_hu","speaker_name":"李马虎","listener":"char_fu_hong_xue","text":"\"不，这蛋不能卖给你。\"","tone":"陈述","chapter":17,"line_start":404,"line_end":404},{"speaker":"char_li_ma_hu","speaker_name":"李马虎","listener":"char_fu_hong_xue","text":"\"这蛋不能卖给你，因为蛋是生的，你总不能吃生蛋。\"","tone":"陈述","chapter":17,"line_start":416,"line_end":418},{"speaker":"char_li_ma_hu","speaker_name":"李马虎","listener":"char_fu_hong_xue","text":"\"后面有炉子，炉子里有火，不但可以炒蛋，还可以热酒。\"","tone":"陈述","chapter":17,"line_start":422,"line_end":424},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_li_ma_hu","text":"\"你要多少？\"","tone":"疑问","chapter":17,"line_start":426,"line_end":426},{"speaker":"char_li_ma_hu","speaker_name":"李马虎","listener":"char_fu_hong_xue","text":"\"公子你既然是个明白人，就马马虎虎算十二两吧。\"","tone":"调侃","chapter":17,"line_start":428,"line_end":430}],"new_entities":{"characters":[{"id":"char_gong_sun_duan","name":"公孙断","alias":[],"identity":"已被傅红雪杀死的万马堂人物","faction":"","role":"villain","archetype":"warrior","rank":"炉火纯青","one_line":"其死让傅红雪的黑刀仍带血，强化复仇压力。","personality":{"traits":["强悍","已死","敌对","江湖地位高","牵动仇杀"],"speech_style":"本章无直接发言","temperament":"死亡阴影"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[17],"source_refs":[{"chapter":17,"line_start":392,"line_end":392,"text":"这也许连他自己都不知道。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_fu_hong_xue_de_hei_dao","name":"傅红雪的黑刀","type":"weapon","owner":"char_fu_hong_xu