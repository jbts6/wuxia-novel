{"segment":16,"line_start":692,"line_end":726,"dialogues":[{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"就是马空群的女儿，听说叫做马芳铃。","tone":"陈述","chapter":28,"line_start":692,"line_end":692},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"所以马空群今天想必也会到白云庄去。","tone":"恐惧","chapter":28,"line_start":696,"line_end":696},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"果然是好身手！","tone":"无奈","chapter":28,"line_start":702,"line_end":704},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"你放心，我不会让他甩下你的。","tone":"微笑","chapter":28,"line_start":712,"line_end":712},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"请上车。","tone":"微笑","chapter":28,"line_start":718,"line_end":718},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"那女人不该抛下你跟路小佳走的，你是个君子。","tone":"陈述","chapter":28,"line_start":720,"line_end":722},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"只可惜这年头君子在女人面前已不吃香了。","tone":"苦笑","chapter":28,"line_start":724,"line_end":726}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ma_fang_ling","updates":{"source_refs":[{"chapter":28,"line_start":692,"line_end":692,"text":"薛大汉说白云庄少庄主的新娘是马空群的女儿马芳铃。"}]},"relationship_updates":[]},{"id":"char_ma_kong_qun","updates":{"source_refs":[{"chapter":28,"line_start":692,"line_end":696,"text":"薛大汉推测马空群因女儿马芳铃婚事今天也会到白云庄。"}]},"relationship_updates":[]},{"id":"char_xue_da_han","updates":{"source_refs":[{"chapter":28,"line_start":702,"line_end":724,"text":"薛大汉看出傅红雪好身手，又主动照顾翠浓上车，被翠浓称为君子。"}]},"relationship_updates":[]},{"id":"char_cui_nong","updates":{"source_refs":[{"chapter":28,"line_start":720,"line_end":722,"text":"翠浓称薛大汉不该被女人抛弃，是个君子。"}]},"relationship_updates":[]}]}
