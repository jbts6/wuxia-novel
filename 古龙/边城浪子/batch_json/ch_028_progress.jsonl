{"segment":1,"line_start":1,"line_end":40,"dialogues":[{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"你还在想那个人？","tone":"疑问","chapter":28,"line_start":22,"line_end":22},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"就因为他喜欢吃花生，所以你不吃？","tone":"疑问","chapter":28,"line_start":26,"line_end":26},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"我知道……","tone":"无奈","chapter":28,"line_start":30,"line_end":30},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"你知道什么？","tone":"疑问","chapter":28,"line_start":32,"line_end":32},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"你的病发作时，不愿被人看见，但他却偏偏看见了，所以你恨他。","tone":"陈述","chapter":28,"line_start":34,"line_end":36}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_fu_hong_xue","updates":{"source_refs":[{"chapter":28,"line_start":16,"line_end":38,"text":"傅红雪看人剥花生出神，因病发时被路小佳看见而沉默握刀。"}]},"relationship_updates":[]},{"id":"char_cui_nong","updates":{"source_refs":[{"chapter":28,"line_start":22,"line_end":34,"text":"翠浓悄声追问傅红雪心事，猜到他恨路小佳的原因。"}]},"relationship_updates":[]}]}
{"segment":2,"line_start":42,"line_end":78,"dialogues":[{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"九月十五，白云庄，他为什么要在九月十五这天到白云庄去呢？  我真不明白……","tone":"无奈","chapter":28,"line_start":42,"line_end":44},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"你不明白的事很多。","tone":"冷酷","chapter":28,"line_start":46,"line_end":46},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"但是我却不能不想。","tone":"陈述","chapter":28,"line_start":48,"line_end":48},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"想什么？","tone":"疑问","chapter":28,"line_start":50,"line_end":50},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"他要我们去，一定没甚好意，所以我更不懂你为什么一定偏偏要去。","tone":"疑问","chapter":28,"line_start":52,"line_end":54},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"没有人要你去。","tone":"陈述","chapter":28,"line_start":56,"line_end":56},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"王聋子，给我打五斤酒，切十个卤蛋，今天我要请客。","tone":"微笑","chapter":28,"line_start":64,"line_end":66},{"speaker":"char_wang_long_zi","speaker_name":"王聋子","listener":"char_gan_che_xiao_huo_zi","text":"你小子疯了？","tone":"冷酷","chapter":28,"line_start":70,"line_end":70},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"小伙子","listener":null,"text":"谁说我疯了？","tone":"疑问","chapter":28,"line_start":72,"line_end":72},{"speaker":"char_wang_long_zi","speaker_name":"王聋子","listener":"char_gan_che_xiao_huo_zi","text":"没有疯好好的请什么客？","tone":"疑问","chapter":28,"line_start":74,"line_end":74},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"小伙子","listener":null,"text":"今天我发了点小财，遇见了个大方客人。","tone":"陈述","chapter":28,"line_start":76,"line_end":76},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"赶车小伙子","listener":null,"text":"提起这个人来，倒真是大大地有名。","tone":"微笑","chapter":28,"line_start":78,"line_end":80}],"new_entities":{"characters":[{"id":"char_gan_che_xiao_huo_zi","name":"赶车小伙子","alias":["小伙子"],"identity":"清河镇至白云庄路上的赶车人","faction":"无","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"收了路小佳二十两车资后请客吹嘘，后来又被薛大汉雇去白云庄。","personality":{"traits":["健壮","爱炫耀","胆小","市井","见钱眼开"],"speech_style":"口气轻浮，常赔笑或卖关子","temperament":"外强中干，遇强即怯"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":64,"line_end":76,"text":"黝黑健壮的小伙子进茶亭请王聋子打酒切卤蛋，称遇见大方客人。"}]},{"id":"char_wang_long_zi","name":"王聋子","alias":["茶亭老板"],"identity":"茶亭老板，欠账时装聋","faction":"无","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"经营茶亭酒食，对请客和欠账格外敏感。","personality":{"traits":["精明","吝惜","市侩","怕事","嘴硬"],"speech_style":"冷冷质问，语气现实","temperament":"精明怕惹事"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":68,"line_end":74,"text":"王聋子其实并不聋，只不过有人要欠账时，他就聋了。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":80,"line_end":126,"dialogues":[{"speaker":null,"speaker_name":"茶客","listener":null,"text":"这人是谁？","tone":"疑问","chapter":28,"line_start":82,"line_end":82},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"小伙子","listener":null,"text":"我说出来，你们也未必听说过。","tone":"微笑","chapter":28,"line_start":84,"line_end":84},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"这是什么话？","tone":"疑问","chapter":28,"line_start":86,"line_end":86},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"既然大大地有名，我们为什么没听说过？","tone":"疑问","chapter":28,"line_start":88,"line_end":88},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"因为你们还不配。","tone":"陈述","chapter":28,"line_start":90,"line_end":90},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"我们不配，你配？","tone":"疑问","chapter":28,"line_start":92,"line_end":92},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"我若不是有个堂兄在镖局里做事，我也不会听说的。","tone":"陈述","chapter":28,"line_start":94,"line_end":94},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"你少卖关子好不好，那人倒底是姓什么？叫什么？","tone":"疑问","chapter":28,"line_start":96,"line_end":96},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"小伙子","listener":null,"text":"他姓路，叫做路小佳。","tone":"陈述","chapter":28,"line_start":98,"line_end":98},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"这路小佳是干什么的？","tone":"疑问","chapter":28,"line_start":102,"line_end":102},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"是个刺客。","tone":"陈述","chapter":28,"line_start":104,"line_end":104},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"刺客？","tone":"疑问","chapter":28,"line_start":108,"line_end":108},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"刺客的意思就是说，你只要给他银子，他就替你杀人，据说他杀一个人至少也要上万两的银子。","tone":"陈述","chapter":28,"line_start":110,"line_end":112},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"我堂兄那家镖局的总镖头，就是被他杀了的。","tone":"陈述","chapter":28,"line_start":116,"line_end":116},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"你说的是上半年刚做过丧事的那位邓大爷？","tone":"疑问","chapter":28,"line_start":118,"line_end":118},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"不错，他出丧的那天，你们都去了，每个人都得了五两银子，是不是？","tone":"疑问","chapter":28,"line_start":120,"line_end":122},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"嗯，那天的气派真不小。","tone":"陈述","chapter":28,"line_start":124,"line_end":124},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"所以你们总该看得出，他活着时当然也是个很了不起的人，可是他遇见这位路大爷，连刀都没拔出来，就被人家一剑刺穿了喉咙。","tone":"陈述","chapter":28,"line_start":126,"line_end":128}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_lu_xiao_jia","updates":{"source_refs":[{"chapter":28,"line_start":98,"line_end":126,"text":"赶车小伙子称路小佳是刺客，杀一人至少上万两，曾一剑刺穿邓大爷喉咙。"}]},"relationship_updates":[]}]}
{"segment":4,"line_start":128,"line_end":168,"dialogues":[{"speaker":null,"speaker_name":"茶客","listener":null,"text":"你怎么知道的？","tone":"疑问","chapter":28,"line_start":130,"line_end":130},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"我堂兄在旁边亲眼看见的，就因为他一回去就把这位路大爷的样子告诉了我，所以今天我才认出了他——倒也不是认出了他的人，是认出了他的剑。","tone":"陈述","chapter":28,"line_start":132,"line_end":134},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"他的剑有什么特别？","tone":"疑问","chapter":28,"line_start":136,"line_end":136},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"他的剑没有鞘，看来就像是把破铜烂铁，但我堂兄却告诉我，他这一辈子从来也没有看见过这么可怕的剑了。","tone":"恐惧","chapter":28,"line_start":138,"line_end":140},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"人家杀个人就能赚上万两的银子，怎么会坐上你的破车？","tone":"疑问","chapter":28,"line_start":144,"line_end":144},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"他的马蹄铁磨穿了，我刚巧路过，从前面的清河镇到白云庄这么点路，他就给了我二十两。","tone":"恐惧","chapter":28,"line_start":146,"line_end":148},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"看来你这小子的造化真不错。","tone":"陈述","chapter":28,"line_start":150,"line_end":150},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"不吃白不吃，今天我们若不吃他个三五两银子，这小子回去怎么睡得着？","tone":"无奈","chapter":28,"line_start":152,"line_end":154},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"要请客也得请我。","tone":"陈述","chapter":28,"line_start":156,"line_end":156},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"请你，凭什么请你？","tone":"疑问","chapter":28,"line_start":162,"line_end":162},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"赶车小伙子","listener":null,"text":"四海之内皆兄弟，就请请你也没什么，朋友你既然要喝酒，就请起来吧。","tone":"疑问","chapter":28,"line_start":164,"line_end":166},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"我虽然喝你的酒，却不是你的朋友，你最好记着。","tone":"冷酷","chapter":28,"line_start":168,"line_end":168}],"new_entities":{"characters":[{"id":"char_xue_da_han","name":"薛大汉","alias":["薛果","大汉"],"identity":"自称杀人无数、仇家遍天下的江湖豪客","faction":"无","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"身高八尺、力大豪饮，因路小佳卷走家当和女人而赶赴白云庄寻仇。","personality":{"traits":["豪放","凶悍","重诺","多疑","自嘲"],"speech_style":"大声直白，常冷笑、叹息或豪饮后发话","temperament":"粗豪凶猛而有君子气"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":170,"line_end":178,"text":"他推开帽子露出彪形大汉身形，随后把酒食揽为己有。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"item_lu_xiao_jia_jian","updates":{"source_refs":[{"chapter":28,"line_start":132,"line_end":140,"text":"赶车小伙子称路小佳的剑没有鞘，像破铜烂铁，却极可怕。"}]},"relationship_updates":[]}]}
{"segment":5,"line_start":170,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":"茶客","listener":null,"text":"这一份归我。","tone":"陈述","chapter":28,"line_start":178,"line_end":180},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"照这样再来一份。","tone":"陈述","chapter":28,"line_start":188,"line_end":190},{"speaker":"char_wang_long_zi","speaker_name":"王聋子","listener":"char_gan_che_xiao_huo_zi","text":"再来一份？","tone":"惊讶","chapter":28,"line_start":192,"line_end":192},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"我说的话你听不见？","tone":"厉声","chapter":28,"line_start":194,"line_end":194},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"你怕什么？  怕请客？","tone":"疑问","chapter":28,"line_start":200,"line_end":202}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xue_da_han","updates":{"source_refs":[{"chapter":28,"line_start":170,"line_end":200,"text":"薛大汉身高八尺、肩宽手大，连吞五斤酒十个卤蛋后再要一份。"}]},"relationship_updates":[]}]}
{"segment":6,"line_start":202,"line_end":240,"dialogues":[{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"小伙子","listener":null,"text":"我……我……","tone":"恐惧","chapter":28,"line_start":206,"line_end":206},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"你不请，我请。","tone":"陈述","chapter":28,"line_start":208,"line_end":208},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"这锭银子全是你的了，但明天一早，你就得在这里等着，载我去白云庄，你若敢误了我的事，你的脑袋就会变得像这锭银子一样。","tone":"恐惧","chapter":28,"line_start":214,"line_end":216},{"speaker":null,"speaker_name":"歌声","listener":null,"text":"九月十五月当头，  月当头兮血可流，  流不尽的英雄泪，  杀不尽仇人头……","tone":"陈述","chapter":28,"line_start":224,"line_end":230},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"好一个杀不尽的仇人头！","tone":"无奈","chapter":28,"line_start":234,"line_end":236}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_xue_da_han_yin_ding","name":"薛大汉银锭","type":"special","owner":"char_gan_che_xiao_huo_zi","one_line":"薛大汉掷给赶车小伙子的车资和威胁凭证。","description":"一锭被薛大汉捏变形的银子，用来买下次日去白云庄的大车，也显示他惊人的手力。","effects":[{"type":"特殊","description":"以重金雇车并震慑赶车小伙子"}],"origin":"薛大汉随身银钱","rarity":"寻常凡品","related_characters":["char_xue_da_han","char_gan_che_xiao_huo_zi"],"related_skills":[],"rag_refs":[28],"source_refs":[{"chapter":28,"line_start":214,"line_end":220,"text":"薛大汉把银子给小伙子，并威胁误事就把脑袋捏成银子模样。"}]}]},"entity_updates":[]}
{"segment":7,"line_start":242,"line_end":286,"dialogues":[{"speaker":null,"speaker_name":"茶客","listener":null,"text":"你累了。","tone":"无奈","chapter":28,"line_start":260,"line_end":262},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"累的应该是你，你本该多睡一会儿的。","tone":"柔声","chapter":28,"line_start":264,"line_end":264},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我睡不着，可是你……","tone":"陈述","chapter":28,"line_start":266,"line_end":266},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"你睡不着，我怎么能睡得着？","tone":"疑问","chapter":28,"line_start":268,"line_end":268},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"还没有找到马空群之前，我绝不能回去，也没有脸回去。","tone":"陈述","chapter":28,"line_start":274,"line_end":276},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"我知道。","tone":"陈述","chapter":28,"line_start":278,"line_end":278},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"所以我只有要你陪着我吃苦。","tone":"陈述","chapter":28,"line_start":280,"line_end":280},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"你应该知道我不怕吃苦，什么苦我都吃过。","tone":"柔声","chapter":28,"line_start":282,"line_end":284},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"只要你能对我好一点，不要看不起我，就算叫我死，我也愿意。","tone":"陈述","chapter":28,"line_start":286,"line_end":288}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_fu_hong_xue","updates":{"source_refs":[{"chapter":28,"line_start":274,"line_end":280,"text":"傅红雪说未找到马空群前不能回去，只能让翠浓陪他吃苦。"}]},"relationship_updates":[]},{"id":"char_cui_nong","updates":{"source_refs":[{"chapter":28,"line_start":282,"line_end":288,"text":"翠浓表示不怕吃苦，只盼傅红雪对她好一点。"}]},"relationship_updates":[{"action":"update","target":"char_fu_hong_xue","type":"恋人","intensity":78,"bond_level":4,"dynamic":"愿陪傅红雪吃苦赴险，情意更明"}]}]}
{"segment":8,"line_start":288,"line_end":334,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我实在对你不好，我自己也知道，所以那天你就算真的走了，我也不会怪你的。","tone":"无奈","chapter":28,"line_start":290,"line_end":292},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"可是我怎么会走？就算你用鞭子来赶我，我也不会走的。","tone":"疑问","chapter":28,"line_start":294,"line_end":296},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"你知道我最喜欢的是什么？","tone":"无奈","chapter":28,"line_start":302,"line_end":304},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"我最喜欢看到你的笑，但你却偏偏总是不肯笑。","tone":"微笑","chapter":28,"line_start":308,"line_end":308},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我会常常笑给你看的，只不过，现在……","tone":"柔声","chapter":28,"line_start":310,"line_end":310},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"现在还不到笑的时候？","tone":"疑问","chapter":28,"line_start":312,"line_end":312},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"那个人为什么还不来？","tone":"疑问","chapter":28,"line_start":314,"line_end":316},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"你放心，我想他绝不会不来的。","tone":"无奈","chapter":28,"line_start":320,"line_end":322},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"你看他是个怎么样的人？","tone":"疑问","chapter":28,"line_start":324,"line_end":324},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"我看他一定是路小佳的仇人，既然已知道路小佳在白云庄，他怎么会不去？","tone":"疑问","chapter":28,"line_start":326,"line_end":328},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"今天已经是九月十五了，今天究竟会发生些什么事？  ……","tone":"喃喃","chapter":28,"line_start":330,"line_end":332}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":336,"line_end":386,"dialogues":[{"speaker":null,"speaker_name":"歌声","listener":null,"text":"流不尽的英雄血，  杀不尽的仇人头，  头可断，血可流，  仇恨难罢休……","tone":"陈述","chapter":28,"line_start":336,"line_end":342},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"果然来了。","tone":"惊讶","chapter":28,"line_start":346,"line_end":346},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"嗯。","tone":"陈述","chapter":28,"line_start":348,"line_end":348},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"我们要不要先躲一躲？","tone":"疑问","chapter":28,"line_start":350,"line_end":350},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我从来不逃，也从来不躲。","tone":"冷酷","chapter":28,"line_start":352,"line_end":352},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"好一个从来不逃，从来不躲，这才是真正的男子汉。","tone":"大笑","chapter":28,"line_start":354,"line_end":356},{"speaker":"char_cui_nong","speaker_name":"翠浓","listener":"char_fu_hong_xue","text":"这人的耳朵好尖。","tone":"苦笑","chapter":28,"line_start":358,"line_end":358},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"果然是你，我就知道你一定也会在这里等的。","tone":"大笑","chapter":28,"line_start":360,"line_end":362},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"你知道？","tone":"疑问","chapter":28,"line_start":364,"line_end":364},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"我不知道谁知道？","tone":"疑问","chapter":28,"line_start":366,"line_end":366},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"傅红雪怔了怔，道：\"我为什么要动手？","tone":"疑问","chapter":28,"line_start":370,"line_end":372},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"来取我项上的人头。","tone":"陈述","chapter":28,"line_start":374,"line_end":374},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我为什么要取你项上的人头？","tone":"疑问","chapter":28,"line_start":376,"line_end":376},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"薛果纵横天下，杀人无数，有谁不想要我这颗大好头颅？","tone":"大笑","chapter":28,"line_start":378,"line_end":380},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我不想。","tone":"陈述","chapter":28,"line_start":382,"line_end":382},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我根本不认得你。","tone":"陈述","chapter":28,"line_start":386,"line_end":386}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xue_da_han","updates":{"source_refs":[{"chapter":28,"line_start":354,"line_end":380,"text":"薛大汉循歌而来，自称薛果纵横天下、杀人无数，等傅红雪取他人头。"}]},"relationship_updates":[]}]}
{"segment":10,"line_start":388,"line_end":442,"dialogues":[{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"薛果仇家虽遍布天下，认得我的却早已被我杀光了，还能活着来杀我的，本就已只剩下些不认得的。","tone":"冷笑","chapter":28,"line_start":388,"line_end":390},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"你常常等着别人来杀你？","tone":"疑问","chapter":28,"line_start":392,"line_end":392},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"不错。","tone":"陈述","chapter":28,"line_start":394,"line_end":394},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"只可惜这次你却要失望了。","tone":"陈述","chapter":28,"line_start":396,"line_end":396},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"你不是在这里等着杀我的？","tone":"疑问","chapter":28,"line_start":398,"line_end":398},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我已立誓杀人绝不再等。","tone":"陈述","chapter":28,"line_start":400,"line_end":400},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"你说得不错，杀人的机会本就是稍纵即逝，错过了实在可惜，实在是等不得的！","tone":"陈述","chapter":28,"line_start":402,"line_end":404},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"所以你若是我的仇人，我昨夜就已杀了你！","tone":"冷酷","chapter":28,"line_start":406,"line_end":406},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"所以我并不是你的仇人？","tone":"疑问","chapter":28,"line_start":408,"line_end":408},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"不是。","tone":"陈述","chapter":28,"line_start":410,"line_end":410},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"看来我运气还不错，看来做你的仇人并不是件愉快的事。","tone":"大笑","chapter":28,"line_start":414,"line_end":416},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"绝不是。","tone":"陈述","chapter":28,"line_start":418,"line_end":418},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"做你的朋友呢？","tone":"疑问","chapter":28,"line_start":420,"line_end":420},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我没有朋友。","tone":"陈述","chapter":28,"line_start":422,"line_end":422},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"连薛大汉也做不了你的朋友？","tone":"疑问","chapter":28,"line_start":424,"line_end":424},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"薛大汉？","tone":"疑问","chapter":28,"line_start":426,"line_end":426},{"speaker":"char_xue_da_han","speaker_name":"大汉","listener":"char_fu_hong_xue","text":"我就是薛大汉。","tone":"微笑","chapter":28,"line_start":428,"line_end":428},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我还是不认得你。","tone":"陈述","chapter":28,"line_start":430,"line_end":430},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"你也不想认得我？","tone":"疑问","chapter":28,"line_start":432,"line_end":432},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"不想。","tone":"陈述","chapter":28,"line_start":434,"line_end":434},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"既不想要我人头，也不想做我朋友，这种人倒少见得很。","tone":"喃喃","chapter":28,"line_start":436,"line_end":438},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"本来就少见得很。","tone":"陈述","chapter":28,"line_start":440,"line_end":440},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"你想要什么？","tone":"疑问","chapter":28,"line_start":442,"line_end":442}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xue_da_han","updates":{"source_refs":[{"chapter":28,"line_start":388,"line_end":428,"text":"薛大汉承认自己仇家遍天下，并向傅红雪报出名号。"}]},"relationship_updates":[{"action":"add","target":"char_fu_hong_xue","type":"合作者","intensity":35,"bond_level":2,"dynamic":"试探后发现傅红雪不是仇人，愿意同行"}]},{"id":"char_fu_hong_xue","updates":{"source_refs":[{"chapter":28,"line_start":396,"line_end":422,"text":"傅红雪称已立誓杀人绝不再等，并否认有朋友。"}]},"relationship_updates":[]}]}
{"segment":11,"line_start":444,"line_end":490,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"只想跟着你的大车，到白云庄去。","tone":"恐惧","chapter":28,"line_start":444,"line_end":444},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"就这样？","tone":"疑问","chapter":28,"line_start":446,"line_end":446},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"就这样。","tone":"陈述","chapter":28,"line_start":448,"line_end":448},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"好，上车吧。","tone":"陈述","chapter":28,"line_start":450,"line_end":450},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"我不上车。","tone":"陈述","chapter":28,"line_start":452,"line_end":452},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"为什么又不上车了？","tone":"惊讶","chapter":28,"line_start":454,"line_end":454},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"因为我没有五十两银子付车钱。","tone":"陈述","chapter":28,"line_start":456,"line_end":456},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"你难道要跟在车子后面走？","tone":"疑问","chapter":28,"line_start":458,"line_end":458},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"你坐你的车，我走我的路，我们本就没有关系。","tone":"陈述","chapter":28,"line_start":460,"line_end":460},{"speaker":null,"speaker_name":"茶客","listener":null,"text":"你真是个怪人，简直比我还怪！","tone":"无奈","chapter":28,"line_start":462,"line_end":464},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"快起来，赶车到白云庄去。","tone":"恐惧","chapter":28,"line_start":474,"line_end":476},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"小伙子","listener":null,"text":"大爷就请上车。","tone":"微笑","chapter":28,"line_start":478,"line_end":478},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"大爷不上车。","tone":"陈述","chapter":28,"line_start":480,"line_end":480},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"小伙子","listener":null,"text":"为什么不上车？","tone":"惊讶","chapter":28,"line_start":482,"line_end":482},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"因为大爷高兴。","tone":"陈述","chapter":28,"line_start":484,"line_end":484}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":12,"line_start":492,"line_end":538,"dialogues":[{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"我们又不是赶去奔丧，你慢点行不行？","tone":"疑问","chapter":28,"line_start":504,"line_end":506},{"speaker":"char_gan_che_xiao_huo_zi","speaker_name":"小伙子","listener":null,"text":"行，当然行。","tone":"微笑","chapter":28,"line_start":508,"line_end":508},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"白云庄又不远，反正今天一定可以赶到。","tone":"恐惧","chapter":28,"line_start":512,"line_end":514},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"却不知你到白云庄去干什么？","tone":"疑问","chapter":28,"line_start":518,"line_end":518},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"你认得袁秋云？","tone":"疑问","chapter":28,"line_start":522,"line_end":522},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"袁秋云是谁？","tone":"疑问","chapter":28,"line_start":524,"line_end":524},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"就是白云庄的庄主。","tone":"恐惧","chapter":28,"line_start":526,"line_end":526},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"不认得。","tone":"陈述","chapter":28,"line_start":528,"line_end":528},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"你连薛大汉都不认得，当然是不会认得袁秋云的了。","tone":"微笑","chapter":28,"line_start":530,"line_end":532},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"你认得他？","tone":"疑问","chapter":28,"line_start":534,"line_end":534},{"speaker":"char_xue_da_han","speaker_name":"薛大汉","listener":"char_fu_hong_xue","text":"我怎么会认得那种老古董。","tone":"疑问","chapter":28,"line_start":536,"line_end":536},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_cui_nong","text":"你只认得路小佳？","tone":"疑问","chapter":28,"line_start":538,"line_end":538}],"new_entities":{"characters":[{"id":"char_yuan_qi