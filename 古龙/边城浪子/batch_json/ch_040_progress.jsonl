{"segment":33,"line_start":1256,"line_end":1292,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你说过他迟早一定会来找你的。\"","tone":"冷酷","chapter":40,"line_start":1258,"line_end":1258},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"他当然会来找我，他绝不是个无情的人。\"","tone":"陈述","chapter":40,"line_start":1260,"line_end":1262},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"这地方很安静，他若能安安静静地死在这里，上天对他已算不薄。\"","tone":"陈述","chapter":40,"line_start":1264,"line_end":1266},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你在等他来？\"","tone":"疑问","chapter":40,"line_start":1268,"line_end":1268},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"但是他并不知道我在这里。\"","tone":"陈述","chapter":40,"line_start":1274,"line_end":1274},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"他会知道的。\"","tone":"陈述","chapter":40,"line_start":1276,"line_end":1276},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"为什么？\"","tone":"疑问","chapter":40,"line_start":1278,"line_end":1278},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"因为有很多人都看见我挟着你往这里走。\"","tone":"陈述","chapter":40,"line_start":1280,"line_end":1280},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"就算他来了又怎么样？你难道真的要杀他？\"","tone":"疑问","chapter":40,"line_start":1282,"line_end":1282},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你真的能下得了毒手？难道你已忘了他以前为你做的那些事？若不是他，你怎么能活到现在？\"","tone":"疑问","chapter":40,"line_start":1288,"line_end":1290},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"他让我活着，也许就是为了要我忍受痛苦。\"","tone":"痛苦","chapter":40,"line_start":1292,"line_end":1294}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":34,"line_start":1294,"line_end":1332,"dialogues":[{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"他常常对我说，你做的事虽可怕，但你的心却本是善良的，你……你几时变得如此狠毒？\"","tone":"疑问","chapter":40,"line_start":1298,"line_end":1300},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"也许他不会来了。\"","tone":"陈述","chapter":40,"line_start":1316,"line_end":1316},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"就算他要来，也没有人知道他什么时候才来。\"","tone":"陈述","chapter":40,"line_start":1320,"line_end":1320},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"他若三天后才来，你难道就这样在这里等三天？\"","tone":"疑问","chapter":40,"line_start":1324,"line_end":1324},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"他三年后才来，我就等三年。\"","tone":"冷酷","chapter":40,"line_start":1326,"line_end":1326},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你……你难道要我陪着你在这里等三年？\"","tone":"疑问","chapter":40,"line_start":1328,"line_end":1330},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"我能等，你为什么不能？\"","tone":"疑问","chapter":40,"line_start":1332,"line_end":1332}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":35,"line_start":1334,"line_end":1372,"dialogues":[{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"因为我是个人。\"","tone":"陈述","chapter":40,"line_start":1334,"line_end":1334},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"哦？\"","tone":"疑问","chapter":40,"line_start":1336,"line_end":1336},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"只要是个人，就没法子在这里等三年，也许连三天都不能等。\"","tone":"陈述","chapter":40,"line_start":1338,"line_end":1340},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"哦？\"","tone":"疑问","chapter":40,"line_start":1342,"line_end":1342},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你若真的要我坐在这里等下去，我就算不冷死，也要被活活饿死。\"","tone":"陈述","chapter":40,"line_start":1344,"line_end":1346},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"其实你很本不必在这里等他，你可以下山去找他，那总比在这里等的好。\"","tone":"陈述","chapter":40,"line_start":1350,"line_end":1352},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你为什么不说话？难道……\"","tone":"疑问","chapter":40,"line_start":1356,"line_end":1356},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"傅红雪，你到哪里去了？你回来了！\"","tone":"大笑","chapter":40,"line_start":1364,"line_end":1364}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
