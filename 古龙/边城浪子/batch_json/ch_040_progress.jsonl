{"segment":23,"line_start":880,"line_end":910,"dialogues":[{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_ding_ling_lin","text":"\"你……你说这种话是什么意思？\"","tone":"疑问","chapter":40,"line_start":882,"line_end":882},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"我的意思你应该明白，我二哥就算真的死了，你也绝不会为他掉一滴眼泪的，他的死活你根本就没有放在心上。\"","tone":"冷酷","chapter":40,"line_start":884,"line_end":886},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"你要我去杀了这个人报仇，只不过因为你恨他，就好像你恨叶开一样。\"","tone":"陈述","chapter":40,"line_start":890,"line_end":892},{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_ding_ling_lin","text":"\"我知道你恨我，因为我要你二哥带你回去，你却宁可跟着叶开像野狗一样在外面流浪。\"","tone":"陈述","chapter":40,"line_start":898,"line_end":900},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"不错，我宁可跟着他流浪，因为我爱他。\"","tone":"陈述","chapter":40,"line_start":902,"line_end":902},{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_ding_ling_lin","text":"\"你当然也知道我爱他，所以你才嫉妒，才要我哥逼着我离开他，因为你也爱他，爱得要命。\"","tone":"冷酷","chapter":40,"line_start":904,"line_end":906},{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_ding_ling_lin","text":"\"我爱他？……我只盼望他快点死。\"","tone":"大笑","chapter":40,"line_start":908,"line_end":908},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"现在你恨他，只因你知道他绝不会爱你。\"","tone":"陈述","chapter":40,"line_start":910,"line_end":910}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ding_ling_lin","updates":{"rag_refs":[40],"status":"当面揭穿马芳铃对傅红雪的嫉妒与爱恨","source_refs":[{"chapter":40,"line_start":860,"line_end":930,"text":"一个人动也不动地坐在车箱里，苍白而美丽的脸上，带着种空虚麻木的表情。一个人只有在忽然失去自己最珍贵的东西时，才会有这种表情。傅红雪也看见了这个人，他认得这个人。丁灵琳她怎么会在这里？她失去的是什么？叶开呢？马芳铃霍然回身，指着傅红雪，大声道"}]},"relationship_updates":[{"action":"update","target":"char_ma_fang_ling","type":"情敌冲突","intensity":80,"bond_level":4,"dynamic":"直指马芳铃爱傅红雪而嫉妒翠浓与自己。"}]}]}
{"segment":24,"line_start":912,"line_end":946,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你既然要杀我，为什么还不过来动手？\"","tone":"疑问","chapter":40,"line_start":918,"line_end":920},{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_ding_ling_lin","text":"\"你若不杀我，就带我走，无论到什么地方，我都跟你去，无论要我干什么，我都依你。\"","tone":"陈述","chapter":40,"line_start":924,"line_end":926},{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_fu_hong_xue","text":"\"只要你肯带我走，我……我甚至可以带你去找我父亲。\"","tone":"陈述","chapter":40,"line_start":930,"line_end":932},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ma_fang_ling","text":"\"滚！\"","tone":"冷酷","chapter":40,"line_start":938,"line_end":938},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"好；我滚，你既然不要我，我只有滚，可是你难道已忘了那天野狗般在我身上爬的样子？难道你只有在没人看见的时候才敢强占我？\"","tone":"疑问","chapter":40,"line_start":946,"line_end":948}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":25,"line_start":948,"line_end":986,"dialogues":[{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"你现在是不是在后悔，那天没有答应他？\"","tone":"疑问","chapter":40,"line_start":952,"line_end":952},{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_ding_ling_lin","text":"\"你也用不着得意！你以为叶开真的喜欢你，他若真的喜欢你，为什么让我们将你带走？\"","tone":"冷笑","chapter":40,"line_start":954,"line_end":958},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"她本来的确是个很可怜的女人，只可惜她每件事都做错了，最错的是，她总是找错了男人。\"","tone":"陈述","chapter":40,"line_start":964,"line_end":966},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你呢？\"","tone":"疑问","chapter":40,"line_start":968,"line_end":968},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"我没有错。\"","tone":"陈述","chapter":40,"line_start":970,"line_end":970},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"叶开……\"","tone":"陈述","chapter":40,"line_start":972,"line_end":972},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"我早就知道小叶是个什么样的人，就算他不喜欢我，也没关系，因为我真的喜欢他，这就已够了！\"","tone":"激动","chapter":40,"line_start":974,"line_end":976},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"但你却离开了他。\"","tone":"痛苦","chapter":40,"line_start":978,"line_end":980},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"那只因我没法子。\"","tone":"陈述","chapter":40,"line_start":982,"line_end":982},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"为什么？\"","tone":"疑问","chapter":40,"line_start":984,"line_end":984},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"因为丁老二乘我不注意的时候，点了我腿上的穴道。\"","tone":"愤怒","chapter":40,"line_start":986,"line_end":988}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":26,"line_start":988,"line_end":1022,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"叶开就这样看着他们把你带走？\"","tone":"疑问","chapter":40,"line_start":990,"line_end":990},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"他也没法子，丁老二是我的亲哥哥，他能对他怎么样？\"","tone":"疑问","chapter":40,"line_start":992,"line_end":994},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"现在你是不是想去找他？\"","tone":"疑问","chapter":40,"line_start":1000,"line_end":1000},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"这世上有种人是你永远找不到的，你只有等着他来找你，小叶就是这种人。\"","tone":"轻笑","chapter":40,"line_start":1002,"line_end":1004},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"你虽然伤了我二哥，可是我并不怪你。\"","tone":"陈述","chapter":40,"line_start":1008,"line_end":1008},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"哦？\"","tone":"疑问","chapter":40,"line_start":1010,"line_end":1010},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"那倒并不是因为他逼着我走，所以我恨他。\"","tone":"陈述","chapter":40,"line_start":1012,"line_end":1012},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"哦。\"","tone":"陈述","chapter":40,"line_start":1014,"line_end":1014},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"那只因你虽然砍断了他的一条手，却让他明白了马芳铃是个什么样的女人，若不是你这一刀，他以后说不定要被她害一辈子。\"","tone":"陈述","chapter":40,"line_start":1016,"line_end":1018},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_ma_fang_ling","text":"\"你现在已可以走了，我也不愿他醒来时再看见你。\"","tone":"陈述","chapter":40,"line_start":1022,"line_end":1022}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ding_ling_lin","updates":{"rag_refs":[40],"status":"解释自己离开和怨恨的原因，仍关心傅红雪","source_refs":[{"chapter":40,"line_start":980,"line_end":1030,"text":"\"丁灵琳道：\"那只因我没法子。\"傅红雪道：\"为什么？\"丁灵琳恨恨道：\"因为丁老二乘我不注意的时候，点了我腿上的穴道。\"傅红雪道：\"叶开就这样看着他们把你带走？\"丁灵琳黯然道：\"他也没法子，丁老二是我的亲哥哥，他能对他怎么样？\"她眨了眨眼，眼"}]},"relationship_updates":[{"action":"update","target":"char_fu_hong_xue","type":"深情守候","intensity":88,"bond_level":5,"dynamic":"虽因误会与痛苦离开，仍追随并担忧傅红雪。"}]}]}
{"segment":27,"line_start":1024,"line_end":1062,"dialogues":[{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你为什么还不走？\"","tone":"疑问","chapter":40,"line_start":1026,"line_end":1026},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"因为我正在考虑一件事。\"","tone":"陈述","chapter":40,"line_start":1028,"line_end":1028},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"什么事？\"","tone":"疑问","chapter":40,"line_start":1030,"line_end":1030},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"我不知道是应该解开你的穴道，让你跟我走，还是应该抱着你走。\"","tone":"陈述","chapter":40,"line_start":1032,"line_end":1034},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你这是什么意思？\"","tone":"疑问","chapter":40,"line_start":1036,"line_end":1036},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"我的意思就是要把你带走。\"","tone":"陈述","chapter":40,"line_start":1038,"line_end":1038},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你……你疯了！\"","tone":"激动","chapter":40,"line_start":1040,"line_end":1040},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"我没有疯，我也知道你绝不会跟我走的。\"","tone":"冷酷","chapter":40,"line_start":1042,"line_end":1042},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你这不要脸的跛子，快放开我。\"","tone":"陈述","chapter":40,"line_start":1058,"line_end":1058}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":28,"line_start":1064,"line_end":1104,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你怕？\"","tone":"冷酷","chapter":40,"line_start":1088,"line_end":1088},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"我怕什么？我为什么要怕？\"","tone":"轻笑","chapter":40,"line_start":1090,"line_end":1090},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"他的仇人呢？\"","tone":"疑问","chapter":40,"line_start":1098,"line_end":1098},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"他好像并没有什么仇人。\"","tone":"陈述","chapter":40,"line_start":1100,"line_end":1100},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"他若有仇人，当然也就是你的仇人。\"","tone":"冷酷","chapter":40,"line_start":1102,"line_end":1102},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"也可以这么说，因为……\"","tone":"陈述","chapter":40,"line_start":1104,"line_end":1104}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":29,"line_start":1106,"line_end":1142,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"因为你觉得在这世上最亲近的人就是他。\"","tone":"陈述","chapter":40,"line_start":1106,"line_end":1106},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你若知道有人杀了他，你会对那个人怎么样？\"","tone":"疑问","chapter":40,"line_start":1110,"line_end":1110},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"没有人会杀他的，也没有人能杀得了他。\"","tone":"陈述","chapter":40,"line_start":1112,"line_end":1112},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"假如有呢？\"","tone":"疑问","chapter":40,"line_start":1114,"line_end":1114},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"那么我就绝不会放过那个人，甚至会不择一切手段来对付他。\"","tone":"陈述","chapter":40,"line_start":1116,"line_end":1118},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"不择一切手段？\"","tone":"疑问","chapter":40,"line_start":1120,"line_end":1120},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"当然不择一切手段。\"","tone":"陈述","chapter":40,"line_start":1122,"line_end":1122},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"这堆土是什么？\"","tone":"疑问","chapter":40,"line_start":1136,"line_end":1136},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"是个坟墓？\"","tone":"疑问","chapter":40,"line_start":1138,"line_end":1138},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"坟墓？你怎么知道是个坟墓？\"","tone":"疑问","chapter":40,"line_start":1140,"line_end":1140},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"因为这是我亲手堆成的。\"","tone":"陈述","chapter":40,"line_start":1142,"line_end":1142}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":30,"line_start":1144,"line_end":1180,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"是我最亲近的人。\"","tone":"陈述","chapter":40,"line_start":1148,"line_end":1148},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你……你很喜欢她？\"","tone":"疑问","chapter":40,"line_start":1150,"line_end":1150},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"我对她的情感。比你对叶开的情感更深！\"","tone":"激动","chapter":40,"line_start":1152,"line_end":1152},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"我只希望她不是被别人杀了的，否则那个人身上的肉，岂非也要被你一口口咬下来？\"","tone":"轻笑","chapter":40,"line_start":1154,"line_end":1156},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"她是被人杀死的！\"","tone":"激动","chapter":40,"line_start":1158,"line_end":1158},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"这里的风好冷。\"","tone":"喃喃","chapter":40,"line_start":1160,"line_end":1160},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你用不着为她担心，她现在已不怕冷了。\"","tone":"陈述","chapter":40,"line_start":1162,"line_end":1162},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"可是我怕。\"","tone":"陈述","chapter":40,"line_start":1164,"line_end":1164},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"怕我？\"","tone":"疑问","chapter":40,"line_start":1166,"line_end":1166},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"不是怕你，是怕冷。\"","tone":"陈述","chapter":40,"line_start":1168,"line_end":1168},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"我会将你也埋起来，你就再也不会怕冷了。\"","tone":"冷酷","chapter":40,"line_start":1170,"line_end":1170},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"那倒不必麻烦你，我还没有死。\"","tone":"轻笑","chapter":40,"line_start":1172,"line_end":1172},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"可是她已经死了……你却没有死，她为什么要死？为什么要死？……\"","tone":"疑问","chapter":40,"line_start":1174,"line_end":1176},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"每个人都会死的，只不过有人死得早些，有人死得迟些，所以你也不必伤心。\"","tone":"陈述","chapter":40,"line_start":1180,"line_end":1182}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":31,"line_start":1182,"line_end":1220,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"叶开若死了，你也不伤心？\"","tone":"疑问","chapter":40,"line_start":1184,"line_end":1184},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"我……我……\"","tone":"陈述","chapter":40,"line_start":1186,"line_end":1186},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你不伤心，只因为叶开还没有死，叶开不伤心，只因为你还没有死，可是……可是她却已死了……\"","tone":"陈述","chapter":40,"line_start":1188,"line_end":1188},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"你为什么不问我，谁杀了她？\"","tone":"厉声","chapter":40,"line_start":1190,"line_end":1192},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你不问我，是不是因为你已知道是谁杀了她的？\"","tone":"疑问","chapter":40,"line_start":1196,"line_end":1196},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"我不知道……我怎么会知道？\"","tone":"疑问","chapter":40,"line_start":1198,"line_end":1198},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你应该知道的。\"","tone":"陈述","chapter":40,"line_start":1200,"line_end":1200},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"为什么？\"","tone":"疑问","chapter":40,"line_start":1202,"line_end":1202},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"因为杀她的人就是叶开。\"","tone":"陈述","chapter":40,"line_start":1204,"line_end":1204},{"speaker":"char_ding_ling_lin","speaker_name":"丁灵琳","listener":"char_fu_hong_xue","text":"\"不可能，绝不可能，我一直跟小叶在一起的，我可以保证他没有杀过人。\"","tone":"陈述","chapter":40,"line_start":1206,"line_end":1208},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"昨天晚上你也跟他在一起？\"","tone":"疑问","chapter":40,"line_start":1210,"line_end":1210},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ding_ling_lin","text":"\"你知道他昨天晚上在哪里？做些什么事？\"","tone":"疑问","chapter":40,"line_start":1214,"line_end":1216}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
