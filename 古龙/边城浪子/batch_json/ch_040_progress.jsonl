{"segment":18,"line_start":694,"line_end":728,"dialogues":[{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_fu_hong_xue","text":"\"你这么样痛苦，为的若是那位翠浓姑娘，就未免太不值得了，她一直是我爹爹的女人，你难道一点都不知道？\"","tone":"冷笑","chapter":40,"line_start":714,"line_end":716}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ma_fang_ling","updates":{"rag_refs":[40],"status":"在傅红雪与丁灵琳面前扭曲诋毁翠浓并挑动仇恨","source_refs":[{"chapter":40,"line_start":650,"line_end":760,"text":"这也许只因在他的心底深处，一直是将叶开当做朋友的。你若爱过一个人，恨他时才会恨得更深。这种仇恨远比他对马空群的仇恨更新鲜，更强烈。远比人类所有的情感都强烈！现在他是一无所有，若不是还有这种仇恨，只怕已活不下去。他发誓要活下去。他发誓要报复—"}]},"relationship_updates":[{"action":"update","target":"char_fu_hong_xue","type":"怨毒纠缠","intensity":85,"bond_level":4,"dynamic":"以翠浓旧事刺激傅红雪，迫使他面对马空群与公孙断。"}]}]}
{"segment":19,"line_start":730,"line_end":760,"dialogues":[{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_fu_hong_xue","text":"\"其实我早就知道她迟早都会甩下你跟别人走的，就像她甩下叶开跟你走一样，除了我爹爹外，别的男人她根本就没有看在眼里。\"","tone":"冷笑","chapter":40,"line_start":732,"line_end":734},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ma_fang_ling","text":"\"你已说够了。\"","tone":"陈述","chapter":40,"line_start":736,"line_end":736},{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_fu_hong_xue","text":"\"我说的话你不喜欢听？\"","tone":"疑问","chapter":40,"line_start":738,"line_end":738},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ma_fang_ling","text":"\"只要你再说一个字，我就杀了你！\"","tone":"激动","chapter":40,"line_start":740,"line_end":742},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_ma_fang_ling","text":"\"你刚才说什么？\"","tone":"冷酷","chapter":40,"line_start":756,"line_end":758}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ma_kong_qun","updates":{"rag_refs":[40],"status":"被马芳铃指为翠浓旧日依附之人，成为傅红雪复仇目标之一","source_refs":[{"chapter":40,"line_start":714,"line_end":744,"text":"马芳铃却又在冷笑着，道：\"你这么样痛苦，为的若是那位翠浓姑娘，就未免太不值得了，她一直是我爹爹的女人，你难道一点都不知道？\"她说的话就像是一根针，一条鞭子。傅红雪突然跳起来，用一双满布红丝的眼睛，狠狠地瞪着她。他的样子看来既可怜，又可怕。若"}]},"relationship_updates":[{"action":"update","target":"char_fu_hong_xue","type":"宿敌","intensity":95,"bond_level":5,"dynamic":"翠浓之死与旧怨交织，使傅红雪杀意更深。"}]},{"id":"char_gong_sun_duan","updates":{"rag_refs":[40],"status":"被马芳铃指出曾强占翠浓并伤害傅红雪所爱之人","source_refs":[{"chapter":40,"line_start":734,"line_end":760,"text":"\"傅红雪苍白的脸突然发红，呼吸突然急促，道：\"你已说够了。\"马芳铃道：\"我说的话你不喜欢听？\"傅红雪握刀的手已凸出青筋，缓缓道：\"只要你再说一个字，我就杀了你！\"马芳铃却笑了。她开始笑的时候，已有一个人忽然出现在她身旁。一个很高大，很神气的"}]},"relationship_updates":[{"action":"update","target":"char_fu_hong_xue","type":"仇敌","intensity":90,"bond_level":5,"dynamic":"成为傅红雪追索翠浓旧恨时必须面对的人。"}]}]}
{"segment":20,"line_start":762,"line_end":808,"dialogues":[{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":null,"text":"\"那么她若再说一个字，你就得另外去找个活女人做老婆了。\"","tone":"冷笑","chapter":40,"line_start":772,"line_end":774},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":null,"text":"\"哦。\"","tone":"陈述","chapter":40,"line_start":782,"line_end":782},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":null,"text":"\"哦。\"","tone":"陈述","chapter":40,"line_start":786,"line_end":786},{"speaker":"char_ding_ling_jia","speaker_name":"丁灵甲","listener":null,"text":"\"你虽然无礼，但我却可以原谅你，因为你现在看来并不像还能杀人的样子。\"","tone":"陈述","chapter":40,"line_start":788,"line_end":790},{"speaker":"char_ma_fang_ling","speaker_name":"马芳铃","listener":"char_fu_hong_xue","text":"\"我无论想说什么都没有关系？\"","tone":"疑问","chapter":40,"line_start":806,"line_end":806},{"speaker":"char_ding_ling_jia","speaker_name":"丁灵甲","listener":null,"text":"\"只要有我在你身旁，你无论想说什么都没关系。\"","tone":"轻笑","chapter":40,"line_start":808,"line_end":808}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
