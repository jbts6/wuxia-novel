{"segment":11,"line_start":412,"line_end":454,"dialogues":[{"speaker":"char_wang_da_hong","speaker_name":"王大洪","listener":"char_fu_hong_xue","text":"\"我能不能相信你呢？你真的肯放我走？\"","tone":"疑问","chapter":40,"line_start":412,"line_end":412},{"speaker":"char_fu_hong_xue","speaker_name":"傅红雪","listener":"char_wang_da_hong","text":"\"我已说过一次。\"","tone":"陈述","chapter":40,"line_start":414,"line_end":414},{"speaker":"char_wang_da_hong","speaker_name":"王大洪","listener":"char_fu_hong_xue","text":"\"那个人本是你的朋友，你的行踪，没有人比他知道得更清楚。\"","tone":"陈述","chapter":40,"line_start":418,"line_end":420},{"speaker":"char_wang_da_hong","speaker_name":"王大洪","listener":"char_fu_hong_xue","text":"\"他姓……\"","tone":"陈述","chapter":40,"line_start":432,"line_end":432}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ye_kai","updates":{"rag_refs":[40],"status":"被王大洪临死前嫁祸为幕后主使","source_refs":[{"chapter":40,"line_start":438,"line_end":490,"text":"\"他姓……\"王大洪永远也不能说出这个人姓什么了，他也已用不着再说。这柄短刀已说明了一切。——刀光一闪，一柄短刀插上了李马虎的手腕。——刀光一闪，一柄短刀杀了那无辜的孩子。现在刀光又一闪，封住了王大洪的口。三柄同样的刀，同样的速度同样可怕。三"}]},"relationship_updates":[{"action":"update","target":"char_fu_hong_xue","type":"被疑忌的朋友","intensity":80,"bond_level":4,"dynamic":"王大洪说幕后主使是傅红雪的朋友，使傅红雪疑心叶开。"}]}]}
