{"segment":1,"line_start":1,"line_end":437,"dialogues":[{"speaker":"char_wang_feng","speakerName":"王风","listener":null,"listenerName":null,"text":"我居然追来这里。","tone":"陈述","chapter":14,"line_start":34,"line_end":34},{"speaker":null,"speakerName":null,"listener":null,"listenerName":null,"text":"鹦鹉楼那边，不知弄成什么样子了？","tone":"疑问","chapter":14,"line_start":40,"line_end":40},{"speaker":null,"speakerName":"铜钟声杀手","listener":null,"listenerName":null,"text":"三爷还未到。","tone":"陈述","chapter":14,"line_start":60,"line_end":60},{"speaker":null,"speakerName":"阴森声杀手","listener":null,"listenerName":null,"text":"应该是时候了。","tone":"陈述","chapter":14,"line_start":62,"line_end":62},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"好！你们都来了。","tone":"激动","chapter":14,"line_start":90,"line_end":90},{"speaker":"char_wang_feng","speakerName":"王风","listener":null,"listenerName":null,"text":"你们是名满大河南北的七杀手？","tone":"疑问","chapter":14,"line_start":126,"line_end":126},{"speaker":null,"speakerName":null,"listener":null,"listenerName":null,"text":"好说。","tone":"陈述","chapter":14,"line_start":128,"line_end":128},{"speaker":null,"speakerName":null,"listener":null,"listenerName":null,"text":"据知只要出得起重价，不单止杀人，什么事你们都肯去做？","tone":"疑问","chapter":14,"line_start":130,"line_end":130},{"speaker":null,"speakerName":null,"listener":null,"listenerName":null,"text":"这是事实。","tone":"陈述","chapter":14,"line_start":132,"line_end":132},{"speaker":null,"speakerName":null,"listener":null,"listenerName":null,"text":"今夜我请你们到来就是有件事要请你们替我去解决。","tone":"陈述","chapter":14,"line_start":134,"line_end":134},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"三爷你这是说笑？","tone":"疑问","chapter":14,"line_start":138,"line_end":138},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"你们看我武镇山可是一个喜欢说笑的人？","tone":"疑问","chapter":14,"line_start":140,"line_end":140},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"我只是还不想与那个人正面冲突。","tone":"陈述","chapter":14,"line_start":152,"line_end":152},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"所以三爷才找我们对付那个人。","tone":"陈述","chapter":14,"line_start":154,"line_end":154},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"那个人到底是谁？","tone":"疑问","chapter":14,"line_start":160,"line_end":160},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"李大娘！","tone":"激动","chapter":14,"line_start":162,"line_end":162},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"这最好。","tone":"陈述","chapter":14,"line_start":168,"line_end":168},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"三爷到底要我们怎样做？","tone":"疑问","chapter":14,"line_start":170,"line_end":170},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"我要你们替我将她的女儿抓起来。","tone":"陈述","chapter":14,"line_start":172,"line_end":172},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"血奴？","tone":"疑问","chapter":14,"line_start":174,"line_end":174},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"就是血奴，你们认识她？","tone":"疑问","chapter":14,"line_start":176,"line_end":176},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"是否还记得她的样子？","tone":"疑问","chapter":14,"line_start":182,"line_end":182},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"像她那么漂亮的女孩子，就瞧一眼，已叫人毕生难忘。","tone":"陈述","chapter":14,"line_start":184,"line_end":184},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"好，很好。","tone":"陈述","chapter":14,"line_start":186,"line_end":186},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"现在是你的机会了。","tone":"陈述","chapter":14,"line_start":192,"line_end":192},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"你为什么要将她抓起来？用来要挟李大娘？","tone":"疑问","chapter":14,"line_start":194,"line_end":194},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"只要有钱就可以。","tone":"陈述","chapter":14,"line_start":206,"line_end":206},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"我一百两黄金买你一个人，给你们七百两黄金。","tone":"陈述","chapter":14,"line_start":208,"line_end":208},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"什么时候你才给我们通知？","tone":"疑问","chapter":14,"line_start":218,"line_end":218},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"就是一两天，那三百黄金也是归我们所有？","tone":"疑问","chapter":14,"line_start":224,"line_end":224},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"是！","tone":"激动","chapter":14,"line_start":226,"line_end":226},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"我们明白。","tone":"陈述","chapter":14,"line_start":246,"line_end":246},{"speaker":"char_wang_feng","speakerName":"王风","listener":null,"listenerName":null,"text":"他笑笑又道：","tone":"陈述","chapter":14,"line_start":258,"line_end":258},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"现在。","tone":"陈述","chapter":14,"line_start":260,"line_end":260},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"现在？","tone":"疑问","chapter":14,"line_start":262,"line_end":262},{"speaker":"char_wang_feng","speakerName":"王风","listener":null,"listenerName":null,"text":"他随即从怀中取出了白巾，道：","tone":"陈述","chapter":14,"line_start":266,"line_end":266},{"speaker":"char_wang_feng","speakerName":"王风","listener":null,"listenerName":null,"text":"他的语声更轻快．又道：","tone":"陈述","chapter":14,"line_start":274,"line_end":274},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"好，我们兄弟就现在动手。","tone":"大笑","chapter":14,"line_start":278,"line_end":278},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"我们也不想。","tone":"陈述","chapter":14,"line_start":284,"line_end":284},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"否则，我又怎会将这件事交给你们？","tone":"疑问","chapter":14,"line_start":294,"line_end":294},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"总之一句话，尽管放心。","tone":"陈述","chapter":14,"line_start":296,"line_end":296},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"鹦鹉楼莫非也是个卧虎藏龙的地方？","tone":"疑问","chapter":14,"line_start":302,"line_end":302},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"龙没有，只有条母老虎。","tone":"陈述","chapter":14,"line_start":304,"line_end":304},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"血奴那个奶妈宋妈妈？","tone":"疑问","chapter":14,"line_start":306,"line_end":306},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"那只是老巫婆。","tone":"陈述","chapter":14,"line_start":308,"line_end":308},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"那是谁？","tone":"疑问","chapter":14,"line_start":310,"line_end":310},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"你到过鹦鹉楼，可记得那个应门的红衣小姑娘？","tone":"疑问","chapter":14,"line_start":312,"line_end":312},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"她只是个十四五岁小姑娘。","tone":"陈述","chapter":14,"line_start":314,"line_end":314},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"好像是的。","tone":"陈述","chapter":14,"line_start":316,"line_end":316},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"你可知鬼童子第一次杀人的时候年纪有多大？","tone":"疑问","chapter":14,"line_start":328,"line_end":328},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"据讲就只有五岁。","tone":"陈述","chapter":14,"line_start":330,"line_end":330},{"speaker":"char_wang_feng","speakerName":"王风","listener":null,"listenerName":null,"text":"他杀的第一个人你可知是什么人？","tone":"疑问","chapter":14,"line_start":332,"line_end":332},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"言家门的高手活僵尸。","tone":"陈述","chapter":14,"line_start":334,"line_end":334},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"活僵尸的武功似乎并不在你们兄弟之下？","tone":"疑问","chapter":14,"line_start":336,"line_end":336},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"五岁的小孩子已懂得这样杀人，已有这种本领。","tone":"陈述","chapter":14,"line_start":342,"line_end":342},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"鬼童子是个男孩子。","tone":"陈述","chapter":14,"line_start":348,"line_end":348},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"她到底是什么人？","tone":"疑问","chapter":14,"line_start":350,"line_end":350},{"speaker":"char_wu_san_ye","speakerName":"武三爷","listener":null,"listenerName":null,"text":"我也不清楚。","tone":"陈述","chapter":14,"line_start":352,"line_end":352},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"你却知道她是一条母老虎？","tone":"疑问","chapter":14,"line_start":354,"line_end":354},{"speaker":"char_qi_sha_shou_lao_da","speakerName":"老大","listener":null,"listenerName":null,"text":"除了这一个，是否还有人需要避忌？","tone":"疑问","chapter":14,"line_start":366,"line_end":366},{"speaker":"char_wang_feng","speakerName":"王风","listener":nul