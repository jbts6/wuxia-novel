{"segment":1,"line_start":1,"line_end":87,"dialogues":[{"speaker":null,"speaker_name":"小姑娘","listener":"char_wang_feng","text":"你是不是敲错了门？","tone":"疑问","chapter":4,"line_start":14,"line_end":14},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"没有。","tone":"陈述","chapter":4,"line_start":16,"line_end":16},{"speaker":null,"speaker_name":"小姑娘","listener":"char_wang_feng","text":"你知道这里是什么地方？","tone":"疑问","chapter":4,"line_start":18,"line_end":18},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"是鹦鹉楼。","tone":"陈述","chapter":4,"line_start":20,"line_end":20},{"speaker":null,"speaker_name":"小姑娘","listener":"char_wang_feng","text":"你找谁。","tone":"疑问","chapter":4,"line_start":22,"line_end":22},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"血奴。","tone":"陈述","chapter":4,"line_start":24,"line_end":24},{"speaker":null,"speaker_name":"小姑娘","listener":"char_wang_feng","text":"你认得她？","tone":"疑问","chapter":4,"line_start":26,"line_end":26},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"不认得。","tone":"陈述","chapter":4,"line_start":28,"line_end":28},{"speaker":null,"speaker_name":"小姑娘","listener":"char_wang_feng","text":"不认得的客人，她从来不见。","tone":"严肃","chapter":4,"line_start":30,"line_end":30},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"你只要告诉她我是谁，她一定会见。","tone":"认真","chapter":4,"line_start":32,"line_end":32},{"speaker":null,"speaker_name":"小姑娘","listener":"char_wang_feng","text":"你是谁？","tone":"疑问","chapter":4,"line_start":34,"line_end":34},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"我也是只鹦鹉，血鹦鹉。","tone":"陈述","chapter":4,"line_start":36,"line_end":36},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_lao_tai_po","text":"现在我是不是可以进去？","tone":"疑问","chapter":4,"line_start":52,"line_end":52},{"speaker":null,"speaker_name":"老太婆","listener":"char_wang_feng","text":"这里是妓院，只要是活人，都可以进来。","tone":"冷笑","chapter":4,"line_start":54,"line_end":54},{"speaker":null,"speaker_name":"老太婆","listener":"char_wang_feng","text":"可是死人我们就恕不招待。","tone":"冷酷","chapter":4,"line_start":56,"line_end":56},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_lao_tai_po","text":"你知道我找的是谁？","tone":"疑问","chapter":4,"line_start":74,"line_end":74},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_lao_tai_po","text":"好，你带路。","tone":"陈述","chapter":4,"line_start":78,"line_end":78}],"new_entities":{"characters":[{"id":"char_wang_feng","name":"王风","alias":[],"identity":"带着棺材闯荡江湖的年轻人","faction":null,"role":"protagonist","archetype":"warrior","rank":"登堂入室","one_line":"带着棺材去妓院的神秘年轻人，自称血鹦鹉","personality":{"traits":["沉着冷静","胆大妄为","重情重义","幽默风趣","果敢决断"],"speech_style":"直率简洁，时而调侃","temperament":"外冷内热"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":2,"line_end":12,"text":"王风的装束，显然与经常到她们这里来的那些人不大相同。王风还带着口棺材。"}]},{"id":"char_xiao_gu_niang","name":"小姑娘","alias":[],"identity":"鹦鹉楼的应门侍女","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"鹦鹉楼穿红衣裳的应门小姑娘，眸子黑如点漆","personality":{"traits":["机警伶俐","直言不讳","守规矩","有些势利","好奇心强"],"speech_style":"直接干脆","temperament":"活泼"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":4,"line_end":6,"text":"应门的是个小姑娘，穿着套红衣裳的小姑娘，一双眸子却黑如点漆。"}]},{"id":"char_lao_tai_po","name":"老太婆","alias":[],"identity":"鹦鹉楼的老鸨或管事","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"鹦鹉楼穿红衣裳的老太婆，在妓院混了四十年","personality":{"traits":["精明世故","察言观色","皮笑肉不笑","识相知趣","见多识广"],"speech_style":"阴阳怪气","temperament":"圆滑"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":46,"line_end":48,"text":"老太婆也穿着一身红衣裳，也正上上下下打量着他。"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_ying_wu_lou","name":"鹦鹉楼","type":"帮派","location":"loc_ying_wu_lou","sub_divisions":[],"one_line":"一座神秘的妓院，门户比衙门还紧，与血鹦鹉传说有关","source_refs":[{"chapter":4,"line_start":40,"line_end":40,"text":"这里是个妓院，门户却比衙门还紧。"}]}],"locations":[{"id":"loc_ying_wu_lou","name":"鹦鹉楼","region":null,"one_line":"一座神秘的妓院，楼帘下挂着十七八个空鸟笼","source_refs":[{"chapter":4,"line_start":96,"line_end":98,"text":"穿过回廊，走过花径，来到一座小楼，楼帘下挂着十七八个鸟笼。只有鸟笼，没有鸟。"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":88,"line_end":173,"dialogues":[{"speaker":null,"speaker_name":"老太婆","listener":"char_wang_feng","text":"姑娘叫你上去。","tone":"陈述","chapter":4,"line_start":108,"line_end":108},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_lao_tai_po","text":"是叫我上去还是请我上去？","tone":"疑问","chapter":4,"line_start":110,"line_end":110},{"speaker":null,"speaker_name":"老太婆","listener":"char_wang_feng","text":"请！","tone":"陈述","chapter":4,"line_start":112,"line_end":112}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":174,"line_end":259,"dialogues":[{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你喜欢这幅画？","tone":"微笑","chapter":4,"line_start":174,"line_end":174},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"血奴。你一定就是血奴。","tone":"陈述","chapter":4,"line_start":200,"line_end":200},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你不是鹦鹉，更不是血鹦鹉。你是个人。","tone":"微笑","chapter":4,"line_start":208,"line_end":208},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你看错了。","tone":"陈述","chapter":4,"line_start":210,"line_end":210},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你不是人？","tone":"疑问","chapter":4,"line_start":212,"line_end":212},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"如果你是血奴，我为什么不能是血鹦鹉？","tone":"调侃","chapter":4,"line_start":214,"line_end":214},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你一定不是。","tone":"陈述","chapter":4,"line_start":216,"line_end":216},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"为什么？","tone":"疑问","chapter":4,"line_start":218,"line_end":218},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"因为我认得血鹦鹉。","tone":"陈述","chapter":4,"line_start":220,"line_end":220},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你见过它？","tone":"好奇","chapter":4,"line_start":222,"line_end":222},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"当然见过。","tone":"得意","chapter":4,"line_start":224,"line_end":224},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"它也给了你三个愿望？","tone":"疑问","chapter":4,"line_start":226,"line_end":226},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"它没有。","tone":"陈述","chapter":4,"line_start":228,"line_end":228},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"为什么？","tone":"疑问","chapter":4,"line_start":230,"line_end":230},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"因为我是血奴。","tone":"陈述","chapter":4,"line_start":232,"line_end":232},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你看中了我？","tone":"调侃","chapter":4,"line_start":238,"line_end":238},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你既然知道我是什么人，就应该知道我很贵。","tone":"得意","chapter":4,"line_start":246,"line_end":246},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我看得出。","tone":"陈述","chapter":4,"line_start":248,"line_end":248},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你带来什么？","tone":"疑问","chapter":4,"line_start":250,"line_end":250},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你也应该看得出。","tone":"陈述","chapter":4,"line_start":252,"line_end":252}],"new_entities":{"characters":[{"id":"char_xue_nu","name":"血奴","alias":[],"identity":"鹦鹉楼的神秘女子，自称为血鹦鹉的奴才","faction":"faction_ying_wu_lou","role":"companion","archetype":"assassin","rank":"出神入化","one_line":"鹦鹉楼的绝色女子，半边裸半边穿衣，性格怪异而妖异","personality":{"traits":["妖异魅惑","反复无常","心地善良","沉迷传说","大胆放纵"],"speech_style":"娇美妩媚，时而疯狂","temperament":"神秘多变"},"relationships":[{"target":"char_wang_feng","type":"合作者","intensity":50,"bond_level":3,"dynamic":"初识"}],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":176,"line_end":192,"text":"她并不是赤裸着的。她还穿着一半衣裳——既不是上面一半，也不是下面一半。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_xue_ying_wu_bi_hua","name":"血鹦鹉壁画","type":"special","owner":"char_xue_nu","one_line":"小楼墙壁上的巨大壁画，画满妖魔和血鹦鹉","description":"五丈宽的墙壁上画满了各式各样的妖魔，有的半人半兽，有的非人非兽。妖魔们手里都有柄弯刀，刀锋上都在滴着血，滴成了一只血鹦鹉。血鹦鹉旁有十三只美丽的怪鸟围绕飞翔。画的是奇浓嘉嘉普诸魔世界，魔王十万岁寿诞的景象。","effects":["激发观者对血鹦鹉传说的敬畏与迷惑"],"origin":"姓郭的古怪老头子所画","rarity":"稀世珍品","related_characters":["char_xue_nu","char_guo_lao_tou"],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":126,"line_end":153,"text":"五丈宽的墙壁上，画满了妖魔。各式各样的妖魔，有的半人半兽，有的非人非兽。"}]}]},"entity_updates":[]}
{"segment":4,"line_start":260,"line_end":398,"dialogues":[{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"来找我的人，好像是没有用棺材装银子的，你倒是第一个。","tone":"调侃","chapter":4,"line_start":256,"line_end":257},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我也不是。","tone":"陈述","chapter":4,"line_start":260,"line_end":260},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"不是？","tone":"疑问","chapter":4,"line_start":262,"line_end":262},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"这口棺材里，连一分银子都没有。","tone":"陈述","chapter":4,"line_start":264,"line_end":264},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"棺材里有什么？","tone":"疑问","chapter":4,"line_start":266,"line_end":266},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"有个人。","tone":"陈述","chapter":4,"line_start":268,"line_end":268},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"死人？","tone":"疑问","chapter":4,"line_start":270,"line_end":270},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"不知道。","tone":"陈述","chapter":4,"line_start":272,"line_end":272},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你自己也不知道，他是死是活？","tone":"惊讶","chapter":4,"line_start":274,"line_end":274},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我只知道他是我的朋友，是死是活都不重要，所以我就忘了。","tone":"认真","chapter":4,"line_start":276,"line_end":277},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你至少还应该知道一件事。","tone":"微笑","chapter":4,"line_start":280,"line_end":280},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"什么事？","tone":"疑问","chapter":4,"line_start":282,"line_end":282},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"今天晚上，是你留下？还是他？","tone":"调侃","chapter":4,"line_start":284,"line_end":284},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"这有分别？","tone":"疑问","chapter":4,"line_start":286,"line_end":286},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"有一点。只要是活人，就得付钱，死人我免费。","tone":"微笑","chapter":4,"line_start":288,"line_end":289},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"如是个已经快死的人呢？","tone":"调侃","chapter":4,"line_start":292,"line_end":292},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"如果你已经快死了，我可以考虑半价。","tone":"微笑","chapter":4,"line_start":294,"line_end":294},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"不能免费？","tone":"无奈","chapter":4,"line_start":296,"line_end":296},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"不能。","tone":"陈述","chapter":4,"line_start":298,"line_end":298},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"这么样看来，好像只有他留下，我出去。","tone":"无奈","chapter":4,"line_start":300,"line_end":300},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你想到哪里去？","tone":"疑问","chapter":4,"line_start":304,"line_end":304},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"在外面等。","tone":"陈述","chapter":4,"line_start":306,"line_end":306},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"现在还没有到晚上，你又何必急着出去？","tone":"柔声","chapter":4,"line_start":308,"line_end":308},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"因为我若不出去，我身上就有样东西出去了。","tone":"调侃","chapter":4,"line_start":310,"line_end":311},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"什么东西？","tone":"好奇","chapter":4,"line_start":314,"line_end":314},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"也不是什么太好的东西，只不过是颗宝珠而已。","tone":"轻笑","chapter":4,"line_start":316,"line_end":316},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"我看不出，真的看不出。","tone":"无奈","chapter":4,"line_start":338,"line_end":339},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你看不出这颗珠子的来历？","tone":"疑问","chapter":4,"line_start":342,"line_end":342},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"看不出你这样的人，身上居然有这样的宝珠。","tone":"惊讶","chapter":4,"line_start":344,"line_end":344},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我本来就没有，这是偷来的。","tone":"轻笑","chapter":4,"line_start":346,"line_end":346},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"偷来的更好，我最喜欢偷来的东西。","tone":"欣喜","chapter":4,"line_start":348,"line_end":348},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"为什么？","tone":"疑问","chapter":4,"line_start":350,"line_end":350},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"因为偷来的东西，通常都是好东西。","tone":"陈述","chapter":4,"line_start":352,"line_end":352},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"现在你已经可以留下来了。","tone":"柔声","chapter":4,"line_start":358,"line_end":359},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我的朋友呢？","tone":"认真","chapter":4,"line_start":362,"line_end":362},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"如果你想要他留下来，我也不在乎。","tone":"柔声","chapter":4,"line_start":364,"line_end":364},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"屋子里摆着口棺材，你在不在乎？","tone":"调侃","chapter":4,"line_start":366,"line_end":366},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"只要有人肯送我这样的珠子，不管他是死是活，我都让他觉得满意。","tone":"得意","chapter":4,"line_start":368,"line_end":369},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"这是用来踩人的。","tone":"陈述","chapter":4,"line_start":382,"line_end":382},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"这是用来抽人的。","tone":"陈述","chapter":4,"line_start":386,"line_end":386},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"有很多男人都喜欢脱光躺在地上，让我用皮靴踢他们，踩他们，用鞭子抽他们。你呢？","tone":"娇声","chapter":4,"line_start":390,"line_end":392},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我只喜欢踢人。","tone":"轻笑","chapter":4,"line_start":394,"line_end":394},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"只要你真的喜欢，我也可以让你踢，让你踩，让你用鞭子抽我。","tone":"娇声","chapter":4,"line_start":396,"line_end":397}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_ming_zhu","name":"明珠","type":"special","owner":"char_wang_feng","one_line":"王风随身携带的晶莹圆润的宝珠","description":"晶莹圆润的明珠，美丽非凡，血奴用两根纤纤玉指拈起时眼中发光。后被血奴吞噬引发魔化，最终明珠神秘失踪，魔石取而代之回到王风怀中。","effects":["引发血奴魔化反应","被吞后变为魔石"],"origin":"王风偷来","rarity":"稀世珍品","related_characters":["char_wang_feng","char_xue_nu"],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":324,"line_end":332,"text":"晶莹圆润的明珠，世上有没有女孩子不喜欢的？没有。血奴用两根春葱般的纤纤玉指，拈起了明珠，眼睛里就发出了光。"}]},{"id":"item_ying_di_pi_xue","name":"硬底皮靴","type":"weapon","owner":"char_xue_nu","one_line":"血奴用来踩人的硬底皮靴，摆在精致雕花木架上","description":"硬底的皮靴，摆在一个精致的雕花的木架上，是血奴用来踩踏男人的工具。","effects":["踩踏攻击"],"origin":null,"rarity":"寻常凡品","related_characters":["char_xue_nu"],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":378,"line_end":382,"text":"硬底的皮靴，摆在一个精致的，雕花的木架上。这是干什么的？这是用来踩人的。"}]},{"id":"item_dai_ci_pi_bian","name":"带刺皮鞭","type":"weapon","owner":"char_xue_nu","one_line":"血奴用来抽人的带刺皮鞭","description":"带刺的皮鞭，挂在皮靴旁，是血奴用来抽打男人的工具。","effects":["抽打攻击"],"origin":null,"rarity":"寻常凡品","related_characters":["char_xue_nu"],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":384,"line_end":386,"text":"带刺的皮鞭，挂在皮靴旁。这是用来抽人的。"}]},{"id":"item_yin_gou","name":"银钩","type":"weapon","owner":"char_xue_nu","one_line":"床顶上挂着的发亮银钩","description":"床顶上挂着的发亮的银钩，用途不明，王风不敢问其用途。","effects":[],"origin":null,"rarity":"寻常凡品","related_characters":["char_xue_nu"],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":388,"line_end":388,"text":"床顶上挂着发亮的银钩，王风却不敢问这是干什么的了。"}]}]},"entity_updates":[]}
{"segment":5,"line_start":399,"line_end":495,"dialogues":[{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你为什么要在墙上画这些可怕的图画？","tone":"疑问","chapter":4,"line_start":404,"line_end":404},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"因为我喜欢要人害怕。害怕也是种刺激，常常会刺激得男人们发狂。","tone":"微笑","chapter":4,"line_start":406,"line_end":407},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"这些妖魔在干什么？","tone":"疑问","chapter":4,"line_start":410,"line_end":410},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"在庆贺魔王的寿诞。这个人，就是魔王。","tone":"陈述","chapter":4,"line_start":412,"line_end":413},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"魔王为什么这么好看？","tone":"好奇","chapter":4,"line_start":416,"line_end":416},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"对女人们来说，本来就只有最好看的男人才配做魔王。","tone":"娇声","chapter":4,"line_start":418,"line_end":418},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"今天晚上，你就是我的魔王。","tone":"娇声","chapter":4,"line_start":420,"line_end":421},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"这只鹦鹉怎么会是红的？","tone":"疑问","chapter":4,"line_start":424,"line_end":424},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"因为它本就是用魔血滴成的，围绕在它旁边的十三只怪鸟，就是它的奴才，叫做血奴。","tone":"陈述","chapter":4,"line_start":426,"line_end":427},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你为什么也叫血奴？","tone":"疑问","chapter":4,"line_start":430,"line_end":430},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"因为，我一直都很想做它的奴隶，可是今天晚上……今天晚上，我只想做你的奴隶。","tone":"激动","chapter":4,"line_start":432,"line_end":433},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"十万神魔，十万滴魔血，滴成这只血鹦鹉，却只用了九万八千六百八十七滴，剩下的一千三百滴，就化成了这十三只血奴。","tone":"陈述","chapter":4,"line_start":440,"line_end":441},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"还有十三滴呢？","tone":"疑问","chapter":4,"line_start":444,"line_end":444},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"最后剩下的十三滴，都结成了石头。","tone":"陈述","chapter":4,"line_start":446,"line_end":446},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"石头？什么样的石头？","tone":"惊讶","chapter":4,"line_start":448,"line_end":448},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"血红的石头，在一瞬间就可以夺走人的魂魄。我真希望我就是血奴，甚至让我变成块石头，我都心甘情愿。","tone":"激动","chapter":4,"line_start":450,"line_end":452},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"为什么？","tone":"疑问","chapter":4,"line_start":456,"line_end":456},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"因为那样，我就可以接近魔王了，就可以使他踢我，踩我，用鞭子抽我。","tone":"激动","chapter":4,"line_start":458,"line_end":459},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"现在你就是我的魔王，随便你用什么法子糟踢我折磨我，我都愿意。","tone":"激动","chapter":4,"line_start":464,"line_end":465},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我还想让你看样东西。","tone":"认真","chapter":4,"line_start":468,"line_end":468},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"看什么？","tone":"疑问","chapter":4,"line_start":470,"line_end":470},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你说的石头是不是这一种？","tone":"认真","chapter":4,"line_start":472,"line_end":472},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"这不是石头，这就是魔血……","tone":"激动","chapter":4,"line_start":480,"line_end":480},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"这是魔血，喝过魔血的人，就可以看见魔王了……","tone":"激动","chapter":4,"line_start":482,"line_end":482}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_hong_shi","name":"魔石","type":"special","owner":"char_wang_feng","one_line":"血红的魔石，由血鹦鹉的魔血凝结而成","description":"血红的石头，由血鹦鹉最后剩下的十三滴魔血结成，在一瞬间就可以夺走人的魂魄。血奴吞下后引发魔化，随后魔石又回到王风怀中。","effects":["引发魔化反应","夺走魂魄","使人看见魔王"],"origin":"血鹦鹉魔血凝结","rarity":"绝世神兵","related_characters":["char_wang_feng","char_xue_nu"],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":446,"line_end":450,"text":"最后剩下的十三滴，都结成了石头。血红的石头，在一瞬间就可以夺走人的魂魄。"}]}]},"entity_updates":[]}
{"segment":6,"line_start":496,"line_end":595,"dialogues":[{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"不要，我痛……","tone":"痛苦","chapter":4,"line_start":498,"line_end":498},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你是什么人？","tone":"厉声","chapter":4,"line_start":514,"line_end":514},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我叫王风。","tone":"认真","chapter":4,"line_start":516,"line_end":516},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你骗我，你想骗我。你叫王重生，你是个不要命的小杂种。","tone":"狂笑","chapter":4,"line_start":518,"line_end":519},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"应该滚的是你，你才是个不要脸的老杂种。","tone":"愤怒","chapter":4,"line_start":528,"line_end":529},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"现在我已知道你是谁了，你是血奴。","tone":"厉声","chapter":4,"line_start":546,"line_end":546},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我见过你的主人，我还有它的两个愿望，我可以要你死，要你化作飞灰，万劫不复。","tone":"冷酷","chapter":4,"line_start":550,"line_end":551},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"所以我劝你还是最好快滚，滚回奇浓嘉嘉普去。","tone":"冷酷","chapter":4,"line_start":556,"line_end":556},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你这小杂种，你要强抢我的女人还要管我们的闲事，就算我饶了你，魔王也不会饶你的。","tone":"厉声","chapter":4,"line_start":558,"line_end":559}],"new_entities":{"characters":[{"id":"char_wang_zhong_sheng","name":"王重生","alias":["王风"],"identity":"王风的真名或另一身份","faction":null,"role":"protagonist","archetype":"warrior","rank":"登堂入室","one_line":"血奴口中王风的另一个名字，被血奴称为不要命的小杂种","personality":{"traits":["沉着冷静","胆大妄为","重情重义","幽默风趣","果敢决断"],"speech_style":"直率简洁，时而调侃","temperament":"外冷内热"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":518,"line_end":519,"text":"你叫王重生，你是个不要命的小杂种。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_qi_nong_jia_jia_pu","name":"奇浓嘉嘉普","region":null,"one_line":"诸魔的世界，血鹦鹉和魔王的所在地","source_refs":[{"chapter":4,"line_start":556,"line_end":556,"text":"滚回奇浓嘉嘉普去。"}]}],"items":[]},"entity_updates":[]}
{"segment":7,"line_start":596,"line_end":714,"dialogues":[{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你真是个可怕的人。","tone":"认真","chapter":4,"line_start":604,"line_end":605},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"哦。","tone":"陈述","chapter":4,"line_start":608,"line_end":608},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"因为你会变，刚才就好像忽然变了，变成个妖魔。刚才你就好像把我活生生的撕开来，血淋淋的吞下去。","tone":"柔声","chapter":4,"line_start":610,"line_end":612},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你送我的那颗珠子呢？","tone":"疑问","chapter":4,"line_start":626,"line_end":626},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"没关系，就算你又拿回去了，也没有关系。像你这样的男人，本就用不着花钱找女人。","tone":"柔声","chapter":4,"line_start":634,"line_end":637},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"现在我才知道你给我的那块石头是什么了。","tone":"认真","chapter":4,"line_start":646,"line_end":646},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"那是什么？","tone":"疑问","chapter":4,"line_start":648,"line_end":648},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"是春药，一定是春药。","tone":"娇声","chapter":4,"line_start":650,"line_end":650},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"可是你刚才却说那是魔血滴成的魔石。","tone":"认真","chapter":4,"line_start":656,"line_end":656},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"刚才我的确那么想，因为魔王和血鹦鹉的故事，实在把我迷住了。","tone":"认真","chapter":4,"line_start":658,"line_end":659},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"这故事是谁告诉你的？","tone":"疑问","chapter":4,"line_start":662,"line_end":662},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"就是在墙上画这幅画的人。","tone":"陈述","chapter":4,"line_start":664,"line_end":664},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"这个人是谁？","tone":"疑问","chapter":4,"line_start":666,"line_end":666},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"他姓郭，是个古里古怪的老头子。","tone":"陈述","chapter":4,"line_start":668,"line_end":668},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"他叫郭繁！","tone":"激动","chapter":4,"line_start":670,"line_end":670},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"可是我听说他有位兄弟叫郭繁，曾经真的见过血鹦鹉。听说血鹦鹉每隔七年出现一次，现在又到了它出现的时候。","tone":"激动","chapter":4,"line_start":672,"line_end":674},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"所以你就叫自己做血奴，在这里等它出现。","tone":"陈述","chapter":4,"line_start":678,"line_end":678},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"我说过，这故事真的叫人着迷。","tone":"认真","chapter":4,"line_start":680,"line_end":680},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你真的相信？","tone":"疑问","chapter":4,"line_start":682,"line_end":682},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你呢？","tone":"疑问","chapter":4,"line_start":684,"line_end":684},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我……我不知道。","tone":"犹豫","chapter":4,"line_start":686,"line_end":686},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"那里面养的本来全都是鹦鹉，因为血鹦鹉也是鹦鹉，我总认为它一定会在那鹦鹉最多的地方出现。","tone":"陈述","chapter":4,"line_start":696,"line_end":697},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"只可惜它们全都死了。","tone":"无奈","chapter":4,"line_start":700,"line_end":700},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"死得很可怜。","tone":"悲伤","chapter":4,"line_start":702,"line_end":702},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"是不是在七月初一那天晚上死的。","tone":"疑问","chapter":4,"line_start":704,"line_end":704},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你怎么知道？","tone":"惊讶","chapter":4,"line_start":706,"line_end":706},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我知道很多事，尤其是些不该知道的事。","tone":"苦笑","chapter":4,"line_start":708,"line_end":708},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你是不是也知道血鹦鹉会在这里出现，所以才到这里来？","tone":"疑问","chapter":4,"line_start":710,"line_end":711},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"不是。","tone":"陈述","chapter":4,"line_start":714,"line_end":714}],"new_entities":{"characters":[{"id":"char_guo_lao_tou","name":"郭老头","alias":["姓郭的古怪老头子"],"identity":"画血鹦鹉壁画的人","faction":null,"role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"姓郭的古怪老头子，在血奴墙上画了血鹦鹉壁画","personality":{"traits":["古怪","神秘","画技高超","痴迷传说","行踪隐秘"],"speech_style":null,"temperament":"神秘"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":668,"line_end":668,"text":"他姓郭，是个古里古怪的老头子。"}]},{"id":"char_guo_fan","name":"郭繁","alias":[],"identity":"郭老头的兄弟，曾见过血鹦鹉","faction":null,"role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"郭老头的兄弟，曾经真的见过血鹦鹉","personality":{"traits":["神秘","有奇遇","见多识广","胆识过人","执着探索"],"speech_style":null,"temperament":"神秘"},"relationships":[{"target":"char_guo_lao_tou","type":"亲属","intensity":80,"bond_level":4,"dynamic":"兄弟"}],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":672,"line_end":672,"text":"可是我听说他有位兄弟叫郭繁，曾经真的见过血鹦鹉。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":715,"line_end":814,"dialogues":[{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"为了我这朋友。他也死得很惨，他这一生中，只希望死后能葬在故乡。","tone":"悲伤","chapter":4,"line_start":718,"line_end":719},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"所以你就护送他的尸身回去安葬？","tone":"疑问","chapter":4,"line_start":722,"line_end":722},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"他的朋友不多，我正好没有别的事做。","tone":"陈述","chapter":4,"line_start":724,"line_end":724},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"能交到你这么样的朋友，实在是他的运气。","tone":"欣慰","chapter":4,"line_start":726,"line_end":727},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你能不能为我做件事？","tone":"认真","chapter":4,"line_start":736,"line_end":736},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你说。","tone":"陈述","chapter":4,"line_start":738,"line_end":738},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"把墙壁上这幅画毁掉，就算一时毁不掉，先刷层白粉上去也行。","tone":"认真","chapter":4,"line_start":740,"line_end":741},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"为什么？","tone":"疑问","chapter":4,"line_start":744,"line_end":744},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"因为……因为我不喜欢。","tone":"犹豫","chapter":4,"line_start":746,"line_end":746},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"我若听你的话，你是不是就肯留在这里？","tone":"恳求","chapter":4,"line_start":748,"line_end":748},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"我……我至少可以多陪你一段日子。","tone":"温柔","chapter":4,"line_start":750,"line_end":750},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"我们现在就去街上买白粉。","tone":"欣喜","chapter":4,"line_start":752,"line_end":752},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"你躺着，我去。你可以安心睡觉，有我的朋友在这里陪你，就算魔鬼都绝不敢来惊扰你的。","tone":"温柔","chapter":4,"line_start":754,"line_end":755},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"你为什么要这么说？","tone":"疑问","chapter":4,"line_start":758,"line_end":758},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"因为我这朋友活着时是强人，死了也一定是个厉鬼。","tone":"轻笑","chapter":4,"line_start":760,"line_end":760},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"他会不会来找我？","tone":"恐惧","chapter":4,"line_start":764,"line_end":764},{"speaker":"char_wang_feng","speaker_name":"王风","listener":"char_xue_nu","text":"绝不会。因为他是我的朋友，你也是。","tone":"温柔","chapter":4,"line_start":766,"line_end":766},{"speaker":"char_xue_nu","speaker_name":"血奴","listener":"char_wang_feng","text":"那么就算他忽然从棺材里跳出来，我也不怕了。","tone":"柔声","chapter":4,"line_start":768,"line_end":768},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"你陪我去。","tone":"厉声","chapter":4,"line_start":788,"line_end":788},{"speaker":null,"speaker_name":"生意人","listener":"char_wang_feng","text":"去干什么？","tone":"慌张","chapter":4,"line_start":790,"line_end":791},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"去买白粉。","tone":"陈述","chapter":4,"line_start":794,"line_end":794},{"speaker":null,"speaker_name":"生意人","listener":"char_wang_feng","text":"白粉？","tone":"疑问","chapter":4,"line_start":796,"line_end":796},{"speaker":"char_wang_feng","speaker_name":"王风","listener":null,"text":"就是刷墙用的那种白粉。","tone":"陈述","chapter":4,"line_start":798,"line_end":798},{"speaker":null,"speaker_name":"两鬓斑白的人","listener":"char_wang_feng","text":"白粉很容易买，你快回来，我们等你。","tone":"淡然","chapter":4,"line_start":813,"line_end":813}],"new_entities":{"characters":[{"id":"char_sheng_yi_ren","name":"生意人","alias":[],"identity":"六角亭中衣着光鲜的生意人","faction":null,"role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"六角亭中衣着光鲜的生意人，被王风强行拉去买白粉","personality":{"traits":["胆小怕事","贪图享乐","无可奈何","察言观色","随遇而安"],"speech_style":"慌张结巴","temperament":"怯懦"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":790,"line_end":791,"text":"这人衣着光鲜，看来好像是个很成功的生意人，吃吃道：去干什么？"}]},{"id":"char_liang_bin_ban_bai_de_ren","name":"两鬓斑白的人","alias":[],"identity":"六角亭中两鬓斑白的冷淡男子","faction":null,"role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"六角亭中两鬓斑白的男子，对一切漠不关心","personality":{"traits":["冷漠","淡然","事不关己","沉稳","观察力强"],"speech_style":"淡然简洁","temperament":"冷漠"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[4],"source_refs":[{"chapter":4,"line_start":806,"line_end":812,"text":"另外一个两鬓斑白，虽然在狂欢痛饮的时候，他的眼睛里并没有愉快的表情。"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
