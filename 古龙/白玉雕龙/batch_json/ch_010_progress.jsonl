{"segment":4,"line_start":82,"line_end":115,"dialogues":[],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_feng_bao","name":"风堡","region":"大风堂领地","one_line":"大风堂据点风堡，同样被唐家堡攻陷","source_refs":[{"chapter":10,"line_start":88,"line_end":89,"text":"第二天中午，他满脸风尘的抵达\"风堡\"了。感伤的事又一次发生。"}]},{"id":"loc_shang_guan_bao","name":"上官堡","region":"原大风堂领地","one_line":"上官刃原来的城堡，大风堂三个据点之一，也被唐家堡攻陷","source_refs":[{"chapter":10,"line_start":107,"line_end":108,"text":"那是上官堡，上官刃的城堡。"}]}],"items":[]},"entity_updates":[]}
