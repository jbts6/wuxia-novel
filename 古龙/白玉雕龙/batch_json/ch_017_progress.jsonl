{"segment":6,"line_start":320,"line_end":399,"dialogues":[{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"喂！","tone":"焦急","chapter":17,"line_start":323,"line_end":323},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"怎么啦？","tone":"淡然","chapter":17,"line_start":325,"line_end":325},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"我不想等了。","tone":"焦急","chapter":17,"line_start":327,"line_end":327},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"不等？不等的话你要怎样？","tone":"疑问","chapter":17,"line_start":329,"line_end":329},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"我要走。","tone":"陈述","chapter":17,"line_start":331,"line_end":331},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"走？走哪一条路？","tone":"疑问","chapter":17,"line_start":333,"line_end":333},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"你希望我走哪一条？","tone":"疑问","chapter":17,"line_start":335,"line_end":335},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我？","tone":"犹豫","chapter":17,"line_start":337,"line_end":337},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我希望你走左边的那一条。","tone":"陈述","chapter":17,"line_start":337,"line_end":339},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"为什么？","tone":"疑问","chapter":17,"line_start":341,"line_end":341},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"为什么？","tone":"疑问","chapter":17,"line_start":343,"line_end":343},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"不为什么，我只是说出我的希望而已。","tone":"无奈","chapter":17,"line_start":343,"line_end":345},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"好吧！就照你的希望走好了。","tone":"陈述","chapter":17,"line_start":347,"line_end":347},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"怎么？你不想走？","tone":"疑问","chapter":17,"line_start":359,"line_end":359},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"走，走，当然走，怎么不走？","tone":"无奈","chapter":17,"line_start":361,"line_end":361},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"怎么啦？为什么这么慢？","tone":"疑问","chapter":17,"line_start":365,"line_end":365},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"路黑漆漆的，危险呀，姑娘。","tone":"陈述","chapter":17,"line_start":367,"line_end":367},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"危险？我看你是故意慢慢走，在拖延吧？","tone":"嘲讽","chapter":17,"line_start":369,"line_end":369},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我为什么要拖延？","tone":"疑问","chapter":17,"line_start":369,"line_end":369},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"因为这条路就是通往上官堡的路。","tone":"陈述","chapter":17,"line_start":371,"line_end":371},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"对不对？","tone":"疑问","chapter":17,"line_start":375,"line_end":375},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"你说对就对吧，我可是真的是为了安全呀！","tone":"无奈","chapter":17,"line_start":377,"line_end":377},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"哼！鬼才相信你呢！","tone":"嘲讽","chapter":17,"line_start":379,"line_end":379},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"你很高兴？","tone":"疑问","chapter":17,"line_start":383,"line_end":383},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"当然了，我猜中你的心事，这还不值得高兴吗？","tone":"得意","chapter":17,"line_start":385,"line_end":385},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"值得。","tone":"无奈","chapter":17,"line_start":387,"line_end":387},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我看你还是进去睡一下吧，明天早上你就知道怎么回事了。","tone":"陈述","chapter":17,"line_start":387,"line_end":389},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"哼！睡就睡，你可别故意往回开啊！","tone":"嘲讽","chapter":17,"line_start":391,"line_end":391},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我是这种小人吗？","tone":"无奈","chapter":17,"line_start":393,"line_end":393},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"最好你不是。","tone":"淡然","chapter":17,"line_start":395,"line_end":395}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":17,"line_start":320,"line_end":399,"text":"卫凤娘与唐花在夜间路上进行心理博弈，选择走左边道路"}]},"relationship_updates":[{"action":"add","target":"char_tang_hua","type":"合作者","intensity":20,"bond_level":1,"dynamic":"被迫同行"}]},{"id":"char_tang_hua","updates":{"source_refs":[{"chapter":17,"line_start":325,"line_end":395,"text":"唐花与卫凤娘对话，以心理战术应对她的追问"}]},"relationship_updates":[{"action":"add","target":"char_wei_feng_niang","type":"合作者","intensity":15,"bond_level":1,"dynamic":"奉命护送"}]}]}
{"segment":7,"line_start":400,"line_end":503,"dialogues":[{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"你回头看看。","tone":"陈述","chapter":17,"line_start":405,"line_end":405},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"怎么回事？","tone":"惊讶","chapter":17,"line_start":411,"line_end":411},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我们刚才从这条路过来。","tone":"陈述","chapter":17,"line_start":413,"line_end":413},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"另外两条，就是你猜疑不决的路。","tone":"陈述","chapter":17,"line_start":413,"line_end":415},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"你是说，昨天我们面对的三条路，每一条都通到这里？","tone":"惊讶","chapter":17,"line_start":417,"line_end":417},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"一点也不错。","tone":"陈述","chapter":17,"line_start":419,"line_end":419},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"你这个人怎么这样？你知道你耽误了我多少时间吗？","tone":"愤怒","chapter":17,"line_start":421,"line_end":421},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我当然知道，因为那是我的目的。","tone":"陈述","chapter":17,"line_start":423,"line_end":423},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"这两条路呢？哪一条才是正确的？","tone":"疑问","chapter":17,"line_start":427,"line_end":427},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"左边那条。","tone":"陈述","chapter":17,"line_start":429,"line_end":429},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"你没骗我吧？","tone":"疑问","chapter":17,"line_start":431,"line_end":431},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我不会骗你的。","tone":"认真","chapter":17,"line_start":433,"line_end":433},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"为什么？","tone":"疑问","chapter":17,"line_start":435,"line_end":435},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"因为从这里到上官堡，马不停蹄的赶路，也要到今天夜里，才能抵达。","tone":"陈述","chapter":17,"line_start":437,"line_end":438},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"真的吗？","tone":"疑问","chapter":17,"line_start":439,"line_end":439},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我可以发誓。","tone":"认真","chapter":17,"line_start":441,"line_end":441},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"那我们就走在左边的路吧！","tone":"陈述","chapter":17,"line_start":443,"line_end":443},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"我建议我们先吃早点。","tone":"陈述","chapter":17,"line_start":445,"line_end":445},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"不，我心急得很，恨不得早点赶去。","tone":"焦急","chapter":17,"line_start":447,"line_end":447},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"据我的估计，赶到了，也只不过是替其中一人收尸而已，又何必急呢？","tone":"淡然","chapter":17,"line_start":449,"line_end":451},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"好吧，我们先用早点吧！","tone":"无奈","chapter":17,"line_start":465,"line_end":465},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"你想通了？","tone":"疑问","chapter":17,"line_start":467,"line_end":467},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"其实，你根本就不应该赶去上官堡。","tone":"陈述","chapter":17,"line_start":471,"line_end":471},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"为什么？","tone":"疑问","chapter":17,"line_start":473,"line_end":473},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"因为你这样赶去，遇到了赵无忌，他一定会追问你为何这么急切的找他。","tone":"陈述","chapter":17,"line_start":475,"line_end":477},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"那又怎样？","tone":"疑问","chapter":17,"line_start":479,"line_end":479},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"那表示，他知道你一定有重要的话急着告诉他。","tone":"陈述","chapter":17,"line_start":481,"line_end":481},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"你能编个谎言骗他吗？","tone":"疑问","chapter":17,"line_start":481,"line_end":483},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"骗不了他。","tone":"陈述","chapter":17,"line_start":485,"line_end":485},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"你就得实告诉他，但是，他已经把上官刃杀了，你告诉他真相，岂不让他一辈子痛苦？","tone":"陈述","chapter":17,"line_start":485,"line_end":487},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"你怕死的是无忌？","tone":"疑问","chapter":17,"line_start":493,"line_end":493},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"那你倒是要去替他收尸的。","tone":"陈述","chapter":17,"line_start":497,"line_end":497},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_hua","text":"不！无忌不会死的！","tone":"激动","chapter":17,"line_start":499,"line_end":499},{"speaker":"char_tang_hua","speaker_name":"唐花","listener":"char_wei_feng_niang","text":"假如你有信心，你就应该回去等他。","tone":"认真","chapter":17,"line_start":501,"line_end":501}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_shang_guan_bao","name":"上官堡","region":"川蜀","one_line":"上官刃的据地，唐家堡势力范围内的堡寨","source_refs":[{"chapter":17,"line_start":427,"line_end":437,"text":"唐花指向上官堡方向，说起马不停蹄也要到夜里才能抵达"}]}],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":17,"line_start":400,"line_end":503,"text":"卫凤娘在五路岔口与唐花对峙，最终决定先吃早点，面临是否赶往上官堡的抉择"}]},"relationship_updates":[]},{"id":"char_tang_hua","updates":{"source_refs":[{"chapter":17,"line_start":405,"line_end":501,"text":"唐花带卫凤娘绕路至五路岔口，劝她不必赶去上官堡"}]},"relationship_updates":[]}]}
