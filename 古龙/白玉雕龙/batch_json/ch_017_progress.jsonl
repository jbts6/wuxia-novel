{"segment":3,"line_start":99,"line_end":173,"dialogues":[{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_zhuang_jia","text":"我下注了。","tone":"陈述","chapter":17,"line_start":102,"line_end":103},{"speaker":"char_zhuang_jia","speaker_name":"庄家","listener":"char_zhao_wu_ji","text":"你押一万？","tone":"疑问","chapter":17,"line_start":130,"line_end":130},{"speaker":"char_zhuang_jia","speaker_name":"庄家","listener":"char_zhao_wu_ji","text":"两万？","tone":"疑问","chapter":17,"line_start":142,"line_end":142},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_zhuang_jia","text":"这是我的习惯，如果一路赢我就一路都把赢的加上去押。","tone":"陈述","chapter":17,"line_start":144,"line_end":146}],"new_entities":{"characters":[],"skills":[{"id":"skill_zhi_tou_ji_qiao","name":"掷骰技巧","type":"暗器","faction":null,"rank":"炉火纯青","one_line":"赵无忌的掷骰绝技，能精准控制骰子连续掷出三个六","techniques":[{"id":"tech_lian_zhu_bao_zi","name":"连掷豹子","type":"special","description":"连续多次掷出三个六点的骰子，需要极其精准的手腕控制和手法"}],"progression":[{"level":"炉火纯青","description":"能连续掷出十多把三个六","chapter":17}],"effects":[{"type":"特殊","description":"精准控制骰子点数，在赌博中必胜"}],"combat_style":"以精准的手腕控制暗器般的骰子旋转和停止","rag_refs":[17],"source_refs":[{"chapter":17,"line_start":56,"line_end":158,"text":"赵无忌能连掷十多把三个六，在和兴号展示掷骰绝技"}]}],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_zhao_wu_ji","updates":{"source_refs":[{"chapter":17,"line_start":99,"line_end":173,"text":"赵无忌以五千两起注，连赢三把将赌注翻至八万两"}]},"relationship_updates":[]}]}
{"segment":4,"line_start":174,"line_end":234,"dialogues":[{"speaker":"char_qian_shao_dong","speaker_name":"钱少东","listener":"char_zhuang_jia","text":"你退下。","tone":"陈述","chapter":17,"line_start":170,"line_end":170},{"speaker":"char_qian_shao_dong","speaker_name":"钱少东","listener":null,"text":"我是这里的少东主，我来陪各位玩玩，各位不介意吧？","tone":"疑问","chapter":17,"line_start":176,"line_end":176},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_shao_dong","text":"当然不会。","tone":"陈述","chapter":17,"line_start":178,"line_end":178},{"speaker":null,"speaker_name":"苏白两人","listener":null,"text":"我们做旁观者好了。","tone":"陈述","chapter":17,"line_start":180,"line_end":180},{"speaker":"char_qian_shao_dong","speaker_name":"钱少东","listener":null,"text":"好。","tone":"陈述","chapter":17,"line_start":182,"line_end":182},{"speaker":"char_qian_shao_dong","speaker_name":"钱少东","listener":"char_zhao_wu_ji","text":"我姓钱，这位大爷贵姓？","tone":"疑问","chapter":17,"line_start":182,"line_end":182},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_shao_dong","text":"我姓赵。","tone":"陈述","chapter":17,"line_start":184,"line_end":184},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_shao_dong","text":"最喜欢刺激的豪赌。","tone":"陈述","chapter":17,"line_start":184,"line_end":184},{"speaker":"char_qian_shao_dong","speaker_name":"钱少东","listener":"char_zhao_wu_ji","text":"那太好了，我也喜欢刺激。","tone":"激动","chapter":17,"line_start":186,"line_end":187},{"speaker":"char_qian_shao_dong","speaker_name":"钱少东","listener":"char_zhao_wu_ji","text":"你还是下这么多？","tone":"疑问","chapter":17,"line_start":186,"line_end":187},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_shao_dong","text":"是的，八万两而已。","tone":"淡然","chapter":17,"line_start":190,"line_end":190}],"new_entities":{"characters":[{"id":"char_qian_shao_dong","name":"钱少东","alias":[],"identity":"和兴号少东主","faction":null,"role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"和兴号的少东主，掷骰技术精湛但与赵无忌相比略逊一筹","personality":{"traits":["年轻气盛","精通赌术","好胜","易紧张","家学渊源"],"speech_style":"自信","temperament":"急躁"},"relationships":[{"target":"char_zhao_wu_ji","type":"对手","intensity":50,"bond_level":2,"dynamic":"赌桌对决失败"}],"known_skills":["skill_zhi_tou_ji_qiao"],"related_skills":[],"rag_refs":[17],"source_refs":[{"chapter":17,"line_start":170,"line_end":229,"text":"钱少东亲自上阵与赵无忌对赌，连输两把"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_zhao_wu_ji","updates":{"source_refs":[{"chapter":17,"line_start":174,"line_end":234,"text":"赵无忌与钱少东对赌，连掷三个六，将八万两翻至六十四万两"}]},"relationship_updates":[{"action":"add","target":"char_qian_shao_dong","type":"对手","intensity":50,"bond_level":2,"dynamic":"赌桌对决"}]}]}
{"segment":5,"line_start":235,"line_end":319,"dialogues":[{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"你姓赵？","tone":"疑问","chapter":17,"line_start":233,"line_end":233},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"听说有一位叫赵无忌的，能够不停的掷出三个六，你是他吗？","tone":"疑问","chapter":17,"line_start":237,"line_end":238},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"你看我像吗？","tone":"调侃","chapter":17,"line_start":243,"line_end":243},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"答得好，你是不是赵无忌并不重要，重要的是，这一把你能不能赢，对不对？","tone":"大笑","chapter":17,"line_start":245,"line_end":247},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"对极了。","tone":"豪迈","chapter":17,"line_start":249,"line_end":249},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"你不介意让我来掷吗？","tone":"疑问","chapter":17,"line_start":251,"line_end":251},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"当然不介意。","tone":"陈述","chapter":17,"line_start":253,"line_end":253},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"假如介意，那就不叫赌了。","tone":"陈述","chapter":17,"line_start":253,"line_end":253},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"很好，你这位年轻人很有意思，我们来换个花样赌，你看怎么样？","tone":"豪迈","chapter":17,"line_start":255,"line_end":257},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"随你意好了。","tone":"淡然","chapter":17,"line_start":259,"line_end":259},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"我们不要光把骰子往碗里掷，这样太死板了。","tone":"陈述","chapter":17,"line_start":261,"line_end":261},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"有道理，那钱老板想怎么掷？","tone":"疑问","chapter":17,"line_start":263,"line_end":263},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"往上掷。","tone":"陈述","chapter":17,"line_start":265,"line_end":265},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"往上？","tone":"疑问","chapter":17,"line_start":267,"line_end":267},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"不错，往上丢，再让骰子下落到碗里。","tone":"陈述","chapter":17,"line_start":269,"line_end":269},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"怎么丢都可以？只要骰子落到碗里就成？","tone":"疑问","chapter":17,"line_start":271,"line_end":271},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"是的，动刀和动剑都可以。","tone":"陈述","chapter":17,"line_start":273,"line_end":273},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"哦？","tone":"疑问","chapter":17,"line_start":275,"line_end":275},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"我的意思是，只要你往上丢，你要用刀去打去接，都成，怎么样？","tone":"疑问","chapter":17,"line_start":277,"line_end":279},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"当然好，这样赌才有意思。","tone":"激动","chapter":17,"line_start":281,"line_end":281},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"还是照你们的老规矩，你先？","tone":"疑问","chapter":17,"line_start":281,"line_end":283},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"假如你不介意的话，我先。","tone":"陈述","chapter":17,"line_start":285,"line_end":285},{"speaker":"char_zhao_wu_ji","speaker_name":"赵无忌","listener":"char_qian_lao_ban","text":"我当然不介意，入境随俗，进了和兴号，当然是照你们的规矩。","tone":"陈述","chapter":17,"line_start":287,"line_end":287},{"speaker":"char_qian_lao_ban","speaker_name":"钱老板","listener":"char_zhao_wu_ji","text":"很好。","tone":"陈述","chapter":17,"line_start":289,"line_end":289},{"speaker":"char_zhao_wu_ji","speaker_name