{"segment":4,"line_start":75,"line_end":91,"dialogues":[],"new_entities":{"characters":[{"id":"char_wei_feng_niang","name":"卫凤娘","alias":[],"identity":"赵无忌未拜堂的妻子，为寻找无忌来到唐家堡","faction":"faction_zhao_jia_zhuang","role":"protagonist","archetype":"scholar","rank":"平平无奇","one_line":"赵无忌未拜堂的妻子，深情坚贞，不惧危难","personality":{"traits":["温柔善良","坚韧不拔","深情专一","细心体贴","勇敢无畏"],"speech_style":"温柔而坚定，日记中情感细腻","temperament":"外柔内刚，内心炽热"},"relationships":[{"target":"char_zhao_wu_ji","type":"恋人","intensity":95,"bond_level":5,"dynamic":"深爱无忌，愿为他牺牲一切"},{"target":"char_xiao_dong_lou","type":"合作者","intensity":40,"bond_level":2,"dynamic":"萧东楼助她寻人"}],"known_skills":[],"related_skills":[],"rag_refs":[7],"source_refs":[{"chapter":7,"line_start":76,"line_end":76,"text":"对于从早上就开始等待的卫凤娘来说"}]},{"id":"char_xiao_dong_lou","name":"萧东楼","alias":[],"identity":"江湖人士，帮助卫凤娘寻找无忌，受伤需靠担架行动","faction":null,"role":"companion","archetype":"warrior","rank":"炉火纯青","one_line":"帮助卫凤娘寻找无忌的江湖高手","personality":{"traits":["老练世故","乐于助人","嘲讽幽默","有办法有门路","深藏不露"],"speech_style":"带嘲讽口吻，世故老练","temperament":"外冷内热，行事果断"},"relationships":[{"target":"char_wei_feng_niang","type":"合作者","intensity":50,"bond_level":3,"dynamic":"帮助凤娘寻找无忌"}],"known_skills":[],"related_skills":[],"rag_refs":[7],"source_refs":[{"chapter":7,"line_start":92,"line_end":92,"text":"萧东楼派人来叫我去吃早餐我也不去"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":92,"line_end":119,"dialogues":[{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_xiao_dong_lou","text":"瞧你急成这个样子，好像那个人一定是赵无忌似的。","tone":"疑问","chapter":7,"line_start":100,"line_end":102},{"speaker":"char_xiao_dong_lou","speaker_name":"萧东楼","listener":"char_wei_feng_niang","text":"唐傲刚刚派人来通知我，约我中午去吃饭，不过，他只约了我一个人。","tone":"陈述","chapter":7,"line_start":106,"line_end":108}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_dong_lou","updates":{"source_refs":[{"chapter":7,"line_start":92,"line_end":92,"text":"萧东楼派人来叫我去吃早餐我也不去"}]}},{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":92,"line_end":119,"text":"萧东楼派人来叫我去吃早餐我也不去，我假装睡了不理会"}]}}]}
{"segment":6,"line_start":120,"line_end":143,"dialogues":[],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":120,"line_end":143,"text":"时间过得好慢好慢啊，好在不管多漫长的等待，还是会等到该来的事情"}]}}]}
{"segment":7,"line_start":144,"line_end":181,"dialogues":[{"speaker":"char_tang_que","speaker_name":"唐缺","listener":"char_tang_ao","text":"我主张先攻赵家庄。","tone":"陈述","chapter":7,"line_start":158,"line_end":158},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_tang_que","text":"为什么？","tone":"疑问","chapter":7,"line_start":160,"line_end":160},{"speaker":"char_tang_que","speaker_name":"唐缺","listener":"char_tang_ao","text":"赵简死了，赵无忌又失了踪，赵家庄一定很乱，先攻赵家庄，一定可以拿下来，第一战先胜，而且胜得容易，会提高士气。","tone":"认真","chapter":7,"line_start":162,"line_end":164},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_tang_que","text":"攻别处就攻不下来？我们的士气还不够高昂？","tone":"疑问","chapter":7,"line_start":166,"line_end":166},{"speaker":"char_tang_que","speaker_name":"唐缺","listener":"char_tang_ao","text":"我不是这个意思。","tone":"陈述","chapter":7,"line_start":168,"line_end":168},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_tang_que","text":"我告诉你，攻赵家庄是没有用的。","tone":"陈述","chapter":7,"line_start":170,"line_end":170},{"speaker":"char_tang_que","speaker_name":"唐缺","listener":"char_tang_ao","text":"为什么没有用？","tone":"疑问","chapter":7,"line_start":170,"line_end":170},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_tang_que","text":"赵家庄是属于大风堂的后方势力，先攻后方，会让前方的各个据点有所防备，而且，长途跋涉，我们的人马会太劳累。","tone":"陈述","chapter":7,"line_start":174,"line_end":176},{"speaker":"char_tang_que","speaker_name":"唐缺","listener":"char_tang_ao","text":"那你要先攻哪里？","tone":"疑问","chapter":7,"line_start":178,"line_end":178},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_tang_que","text":"先攻司空晓风的据点，第一路程近，第二，我们那里收买的人最多，内应外合，会比赵家庄还容易攻下来。","tone":"陈述","chapter":7,"line_start":180,"line_end":181}],"new_entities":{"characters":[{"id":"char_tang_que","name":"唐缺","alias":[],"identity":"唐家堡成员，唐傲的弟弟，体型肥胖","faction":"faction_tang_jia_bao","role":"villain","archetype":"warrior","rank":"登堂入室","one_line":"唐家堡成员，唐傲之弟，体型肥胖的武者","personality":{"traits":["直率冲动","好战急躁","坦诚直言","争强好胜","尊重兄长"],"speech_style":"直白急躁，不加掩饰","temperament":"急躁直爽，容易负气"},"relationships":[{"target":"char_tang_ao","type":"亲属","intensity":70,"bond_level":4,"dynamic":"兄弟关系，唐傲为兄，唐缺虽有分歧但最终听从"}],"known_skills":[],"related_skills":[],"rag_refs":[7],"source_refs":[{"chapter":7,"line_start":154,"line_end":154,"text":"这个人是大胖子，叫唐缺"}]},{"id":"char_zhao_jian","name":"赵简","alias":[],"identity":"赵家庄人物，已去世","faction":"faction_zhao_jia_zhuang","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"赵家庄人物，已去世","personality":{"traits":["刚正","勇毅","重义","沉稳","忠诚"],"speech_style":"不详","temperament":"不详"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[7],"source_refs":[{"chapter":7,"line_start":162,"line_end":162,"text":"赵简死了，赵无忌又失了踪"}]},{"id":"char_si_kong_xiao_feng","name":"司空晓风","alias":[],"identity":"风堡堡主，大风堂的重要据点负责人","faction":"faction_da_feng_tang","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"大风堂风堡堡主，重要的前线据点负责人","personality":{"traits":["老练","稳重","有威望","善守","受人敬重"],"speech_style":"不详","temperament":"稳重老练"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[7],"source_refs":[{"chapter":7,"line_start":180,"line_end":180,"text":"先攻司空晓风的据点，第一路程近"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_da_feng_tang","name":"大风堂","type":"帮派","location":"不详","sub_divisions":[],"one_line":"与唐家堡对立的帮派势力，拥有多个据点","source_refs":[{"chapter":7,"line_start":174,"line_end":174,"text":"赵家庄是属于大风堂的后方势力"}]}],"locations":[{"id":"loc_feng_bao","name":"风堡","region":"不详","one_line":"司空晓风的据点，大风堂的重要前线堡垒","source_refs":[{"chapter":7,"line_start":190,"line_end":190,"text":"唐傲要攻的，是司空晓风的风堡"}]},{"id":"loc_zhao_jia_zhuang","name":"赵家庄","region":"不详","one_line":"赵家的根据地，属于大风堂的后方势力范围","source_refs":[{"chapter":7,"line_start":158,"line_end":158,"text":"我主张先攻赵家庄"}]}],"items":[]},"entity_updates":[{"id":"char_tang_ao","updates":{"source_refs":[{"chapter":7,"line_start":160,"line_end":160,"text":"另一个人：为什么？"}]},"relationship_updates":[{"action":"add","target":"char_tang_que","type":"亲属","intensity":70,"bond_level":4,"dynamic":"兄弟关系，唐傲为兄"}]}]}
{"segment":8,"line_start":182,"line_end":203,"dialogues":[],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":192,"line_end":192,"text":"我已经知道他们的秘密，我赶快走回原来的房间，拿起筷子假装吃饭"}]}},{"id":"char_tang_ao","updates":{"source_refs":[{"chapter":7,"line_start":200,"line_end":200,"text":"我只走到离房门一半的地方，门就被人推了开来"}]}},{"id":"char_xiao_dong_lou","updates":{"source_refs":[{"chapter":7,"line_start":196,"line_end":196,"text":"我想到萧东楼，他是最有办法的人，我必须现在就回客栈找他"}]}}]}
{"segment":9,"line_start":204,"line_end":233,"dialogues":[{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"对不起，我应该先敲门才对。","tone":"陈述","chapter":7,"line_start":204,"line_end":204},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"我叫唐傲。","tone":"陈述","chapter":7,"line_start":208,"line_end":208},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"现在已经不必去证实了，因为那个人已经在他面前，承认他就是赵无忌。","tone":"陈述","chapter":7,"line_start":216,"line_end":216},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"没有怎样，而且还让你去见他。","tone":"微笑","chapter":7,"line_start":220,"line_end":220},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"见完之后，他只能让我们之中一个人离开唐家堡，至于让谁走，由我决定。","tone":"严肃","chapter":7,"line_start":230,"line_end":230}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[{"id":"faction_zhao_jia_zhuang","name":"赵家庄","type":"家族","location":"不详","sub_divisions":[],"one_line":"赵家的根据地，与大风堂有密切关系","source_refs":[{"chapter":7,"line_start":226,"line_end":226,"text":"我就是赵无忌未拜堂的妻子卫凤娘"}]}],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":210,"line_end":210,"text":"他却抢着说，他知道我就是赵无忌未拜堂的妻子卫凤娘"}]}},{"id":"char_tang_ao","updates":{"source_refs":[{"chapter":7,"line_start":204,"line_end":204,"text":"推门的人却对我说对不起，说他应该先敲门才对"}]},"relationship_updates":[{"action":"add","target":"char_wei_feng_niang","type":"合作者","intensity":30,"bond_level":1,"dynamic":"初见，唐傲安排见面"}]}]}
{"segment":10,"line_start":234,"line_end":259,"dialogues":[{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_ao","text":"我留下。","tone":"认真","chapter":7,"line_start":242,"line_end":242},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"无忌就在里面，我不打扰你们了。","tone":"陈述","chapter":7,"line_start":262,"line_end":262}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":234,"line_end":259,"text":"无忌死了，大风堂又被唐家堡消灭了，我活着还有什么意义"}]}},{"id":"char_tang_ao","updates":{"source_refs":[{"chapter":7,"line_start":248,"line_end":248,"text":"他走上凉亭，转动右边的一张石椅，凉亭中的石桌便缓缓移开，露出一个地洞"}]}}]}
{"segment":11,"line_start":260,"line_end":303,"dialogues":[{"speaker":"char_zhao_wu_ji","speaker_name":"无忌","listener":"char_wei_feng_niang","text":"你瘦了。","tone":"温柔","chapter":7,"line_start":284,"line_end":284},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_zhao_wu_ji","text":"你也是。","tone":"温柔","chapter":7,"line_start":286,"line_end":286},{"speaker":"char_zhao_wu_ji","speaker_name":"无忌","listener":"char_wei_feng_niang","text":"我怕唐家堡利用你做人质，只要我们大风堂打败了唐家，他们会反过来利用你来威胁我们。","tone":"担心","chapter":7,"line_start":304,"line_end":306}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_zhao_wu_ji","updates":{"source_refs":[{"chapter":7,"line_start":276,"line_end":276,"text":"我看到无忌，起先看到的是他的双眼"}]}},{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":276,"line_end":276,"text":"我发现他看到我的第一眼，是楞了一楞，继之才是兴奋"}]}}]}
{"segment":12,"line_start":304,"line_end":331,"dialogues":[{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_zhao_wu_ji","text":"你放心，假如他们要利用我做人质，你就要求他们，先看到我才做决定。","tone":"认真","chapter":7,"line_start":308,"line_end":310},{"speaker":"char_zhao_wu_ji","speaker_name":"无忌","listener":"char_wei_feng_niang","text":"为什么？","tone":"疑问","chapter":7,"line_start":312,"line_end":312},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_zhao_wu_ji","text":"到时候，为了大风堂，为了你，我会牺牲，我不会让唐家的人得逞，这样，你就可以全心全意的放在战场上，不必再为我操心。","tone":"认真","chapter":7,"line_start":314,"line_end":316},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_zhao_wu_ji","text":"你别忘了，你还要赶到司空大叔那里去报信。","tone":"认真","chapter":7,"line_start":320,"line_end":322}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":308,"line_end":310,"text":"你放心，假如他们要利用我做人质，你就要求他们，先看到我才做决定"}]}},{"id":"char_zhao_wu_ji","updates":{"source_refs":[{"chapter":7,"line_start":318,"line_end":318,"text":"无忌不说话了，我看到他的眼神很沉痛，他拿起酒杯，喝了一杯又一杯"}]}},{"id":"char_si_kong_xiao_feng","updates":{"source_refs":[{"chapter":7,"line_start":320,"line_end":322,"text":"你别忘了，你还要赶到司空大叔那里去报信"}]}}]}
{"segment":13,"line_start":332,"line_end":363,"dialogues":[{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_zhao_wu_ji","text":"这表示你必须加快脚步才能及时赶到风堡，你知不知道？","tone":"焦急","chapter":7,"line_start":352,"line_end":352},{"speaker":"char_zhao_wu_ji","speaker_name":"无忌","listener":"char_wei_feng_niang","text":"这表示我们必须分手了。","tone":"悲伤","chapter":7,"line_start":354,"line_end":356},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_zhao_wu_ji","text":"只要有缘，我相信我们会重聚的。","tone":"悲伤","chapter":7,"line_start":358,"line_end":360},{"speaker":"char_zhao_wu_ji","speaker_name":"无忌","listener":"char_wei_feng_niang","text":"你保重了！","tone":"沉声","chapter":7,"line_start":362,"line_end":364}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":358,"line_end":360,"text":"只要有缘，我相信我们会重聚的"}]}},{"id":"char_zhao_wu_ji","updates":{"source_refs":[{"chapter":7,"line_start":354,"line_end":356,"text":"这表示我们必须分手了"}]}}]}
{"segment":14,"line_start":364,"line_end":389,"dialogues":[],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":370,"line_end":370,"text":"我的心在狂喊，差点没冲出喉咙叫出声来"}]}},{"id":"char_tang_ao","updates":{"source_refs":[{"chapter":7,"line_start":382,"line_end":382,"text":"我抬头，还好，不是无忌，是唐傲"}]}}]}
{"segment":15,"line_start":390,"line_end":427,"dialogues":[{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"我送你回去。","tone":"陈述","chapter":7,"line_start":388,"line_end":388},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"你把你的东西收拾一下吧！","tone":"陈述","chapter":7,"line_start":402,"line_end":404},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"萧东楼已经走了，我们在花园那里另外准备了更舒服的房子让你住。","tone":"陈述","chapter":7,"line_start":408,"line_end":410},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"因为我对他说，你跟赵无忌已经离开了唐家堡。","tone":"陈述","chapter":7,"line_start":426,"line_end":426}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":396,"line_end":396,"text":"以萧东楼的武功，能不能打赢唐傲"}]}},{"id":"char_tang_ao","updates":{"source_refs":[{"chapter":7,"line_start":402,"line_end":404,"text":"唐傲站在我的房门，把门推开"}]}},{"id":"char_xiao_dong_lou","updates":{"source_refs":[{"chapter":7,"line_start":408,"line_end":410,"text":"萧东楼已经走了"}]}}]}
{"segment":16,"line_start":428,"line_end":455,"dialogues":[{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_ao","text":"你为什么要骗他？","tone":"愤怒","chapter":7,"line_start":428,"line_end":428},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"这样不是很好吗？让他死了这条心，难道你会跟他？","tone":"陈述","chapter":7,"line_start":430,"line_end":430},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":"char_tang_ao","text":"我高兴，我喜欢有人在我身边，不成吗？","tone":"愤怒","chapter":7,"line_start":434,"line_end":436},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"这就好了，我就怕你不高兴。","tone":"大笑","chapter":7,"line_start":438,"line_end":440},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"其实让你搬到花园里住，并不是我的意思。是老祖母的意思。也不完全是老祖宗的意思，是唐花要老祖宗这样做的。","tone":"调侃","chapter":7,"line_start":442,"line_end":448}],"new_entities":{"characters":[{"id":"char_tang_hua","name":"唐花","alias":[],"identity":"唐傲的小表弟，生性喜欢拈花惹草，很少在江湖上走动","faction":"faction_tang_jia_bao","role":"npc","archetype":"scholar","rank":"初窥门径","one_line":"唐傲的小表弟，风流好色，因见卫凤娘画像而痴迷","personality":{"traits":["风流好色","痴迷美色","任性","少涉江湖","执着"],"speech_style":"不详","temperament":"轻浮任性"},"relationships":[{"target":"char_tang_ao","type":"亲属","intensity":50,"bond_level":3,"dynamic":"表兄弟关系"}],"known_skills":[],"related_skills":[],"rag_refs":[7],"source_refs":[{"chapter":7,"line_start":454,"line_end":454,"text":"唐花是我的小表弟"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":434,"line_end":436,"text":"我高兴，我喜欢有人在我身边，不成吗？"}]}},{"id":"char_tang_ao","updates":{"source_refs":[{"chapter":7,"line_start":448,"line_end":448,"text":"是唐花要老祖宗这样做的"}]},"relationship_updates":[{"action":"add","target":"char_tang_hua","type":"亲属","intensity":50,"bond_level":3,"dynamic":"表兄弟关系"}]}]}
{"segment":17,"line_start":456,"line_end":465,"dialogues":[{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":null,"text":"是谁的意思？","tone":"疑问","chapter":7,"line_start":446,"line_end":446},{"speaker":"char_wei_feng_niang","speaker_name":"卫凤娘","listener":null,"text":"唐花？唐花是谁？","tone":"疑问","chapter":7,"line_start":452,"line_end":452},{"speaker":"char_tang_ao","speaker_name":"唐傲","listener":"char_wei_feng_niang","text":"他因为生性喜欢拈花惹草，也很少在江湖上走动，所以你一定没有听过他的名字，不过，他前几天无意中看到你的画像，便整个人痴迷了起来，吵着说非要找到你不可，刚好你来了，他知道了，便去请求老祖母把你留下，你现在知道，我为什么要留你下来的原因了吧？","tone":"陈述","chapter":7,"line_start":454,"line_end":456}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_wei_feng_niang","updates":{"source_refs":[{"chapter":7,"line_start":458,"line_end":458,"text":"我明白，我一切都明白了，我怎么这么倒霉？"}]}},{"id":"char_tang_hua","updates":{"source_refs":[{"chapter":7,"line_start":454,"line_end":456,"text":"唐花是我的小表弟"}]}}]}
