      "chapter": 1,
      "line_start": 998,
      "line_end": 998
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段玉",
      "listener": null,
      "text": "借问两位小师傅，庙里是不是有位姓顾的道人？",
