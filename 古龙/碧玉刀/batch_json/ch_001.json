      "line_start": 872,
      "line_end": 872
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段玉",
      "listener": null,
      "text": "你难道已经忘了你自己都做过什么事？",
      "tone": "疑问",
      "chapter": 1,
      "line_start": 874,
      "line_end": 874
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段玉",
      "listener": null,
      "text": "我做了什么事？",
      "tone": "疑问",
      "chapter": 1,
      "line_start": 876,
      "line_end": 876
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段玉",
      "listener": null,
      "text": "你得罪了个不能得罪，也不该得罪的人。",
