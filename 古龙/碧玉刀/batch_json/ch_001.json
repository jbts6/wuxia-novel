      "chapter": 1,
      "line_start": 974,
      "line_end": 974
    },
    {
      "speaker": "char_zhu_zhu",
      "speaker_name": "华华凤",
      "listener": null,
      "text": "我没有这意思。",
      "tone": "冷笑",
      "chapter": 1,
      "line_start": 976,
      "line_end": 976
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段玉",
      "listener": null,
      "text": "我也没有这意思。",
      "tone": "陈述",
      "chapter": 1,
      "line_start": 982,
      "line_end": 982
    },
    {
      "speaker": "char_duan_yu",
      "speaker_name": "段玉",
      "listener": null,
      "text": "你是什么意思？",
      "tone": "疑问",
      "chapter": 1,
      "line_start": 984,
      "line_end": 984
    },
    {
      "speaker": "char_zhu_zhu",
      "speaker_name": "华华凤",
      "listener": null,
      "text": "这句话虽然没有说错，可是你说话的口气却不对。",
