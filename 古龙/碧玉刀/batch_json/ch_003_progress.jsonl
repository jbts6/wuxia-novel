230,"line_end":1230},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"什么病？","tone":"疑问","chapter":3,"line_start":1232,"line_end":1232},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"饿病。","tone":"苦笑","chapter":3,"line_start":1234,"line_end":1234},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你想吃什么？","tone":"疑问","chapter":3,"line_start":1238,"line_end":1238},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你这里有什么？","tone":"疑问","chapter":3,"line_start":1240,"line_end":1240},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"这里本是栋空房子。","tone":"陈述","chapter":3,"line_start":1242,"line_end":1242},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"连个人都没有？","tone":"疑问","chapter":3,"line_start":1244,"line_end":1244},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"没有。","tone":"陈述","chapter":3,"line_start":1246,"line_end":1246},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你自己会做饭？","tone":"疑问","chapter":3,"line_start":1248,"line_end":1248},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"也不会，可是我会买。","tone":"轻笑","chapter":3,"line_start":1250,"line_end":1250},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"这一定是太和楼的油爆虾。","tone":"轻笑","chapter":3,"line_start":1258,"line_end":1258},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"这大概是奎元馆的排骨面浇头。","tone":"陈述","chapter":3,"line_start":1261,"line_end":1261},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"这是不是又一村的菜肉包？","tone":"疑问","chapter":3,"line_start":1264,"line_end":1264},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"这是得月楼的肋鲞蒸鱼圆儿。","tone":"陈述","chapter":3,"line_start":1272,"line_end":1272},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"这是酥藕。","tone":"陈述","chapter":3,"line_start":1275,"line_end":1275},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"想不到吃你也是专家。","tone":"轻笑","chapter":3,"line_start":1277,"line_end":1277},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"我就算没吃过猪肉，至少还看见过猪走路。","tone":"轻笑","chapter":3,"line_start":1279,"line_end":1279},{"speaker":null,"speaker_name":null,"listener":null,"text":"悬赏纹银五千两。","tone":"轻笑","chapter":3,"line_start":1295,"line_end":1295},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"是谁花五千两银子来找我呢？","tone":"疑问","chapter":3,"line_start":1309,"line_end":1309},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你真想不到？","tone":"疑问","chapter":3,"line_start":1311,"line_end":1311},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"莫非是铁水？","tone":"疑问","chapter":3,"line_start":1313,"line_end":1313},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"对了。","tone":"陈述","chapter":3,"line_start":1315,"line_end":1315},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"她笑了笑，接着道：","tone":"陈述","chapter":3,"line_start":1323,"line_end":1323},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"五千两银子也不算太少。","tone":"陈述","chapter":3,"line_start":1327,"line_end":1327},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"所以现在我已没法子想了。","tone":"陈述","chapter":3,"line_start":1333,"line_end":1333},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你真想不通？","tone":"疑问","chapter":3,"line_start":1343,"line_end":1343},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你再想想，最好从头想起。","tone":"愤怒","chapter":3,"line_start":1347,"line_end":1347},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"然后呢。","tone":"陈述","chapter":3,"line_start":1353,"line_end":1353},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"然后你就跟着她到了她的香闺。","tone":"陈述","chapter":3,"line_start":1359,"line_end":1359},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener"