{"segment":1,"line_start":1,"line_end":1422,"dialogues":[{"speaker":"char_tie_shui","speaker_name":"黑衫僧","listener":null,"text":"酒如何？","tone":"疑问","chapter":3,"line_start":20,"line_end":20},{"speaker":"char_tie_shui","speaker_name":"黑衫僧","listener":null,"text":"好酒。","tone":"陈述","chapter":3,"line_start":22,"line_end":22},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"不错，喝起来果然另有一种滋味。","tone":"轻笑","chapter":3,"line_start":28,"line_end":28},{"speaker":"char_tie_shui","speaker_name":"黑衫僧","listener":null,"text":"你是谁？","tone":"疑问","chapter":3,"line_start":42,"line_end":42},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"贫道顾长青。","tone":"愤怒","chapter":3,"line_start":44,"line_end":44},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"你莫非就是那嗜赌如命，好酒如渴的顾道人？","tone":"疑问","chapter":3,"line_start":46,"line_end":46},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"正是贫道。","tone":"陈述","chapter":3,"line_start":48,"line_end":48},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"好酒。","tone":"愤怒","chapter":3,"line_start":56,"line_end":56},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"虽然是好酒，你却只配喝一杯。","tone":"愤怒","chapter":3,"line_start":58,"line_end":58},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"一杯就已足够，多谢。","tone":"轻笑","chapter":3,"line_start":60,"line_end":60},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"这酒我难道就不配喝？","tone":"疑问","chapter":3,"line_start":62,"line_end":62},{"speaker":"char_tie_shui","speaker_name":"黑衫僧","listener":null,"text":"你是谁？","tone":"疑问","chapter":3,"line_start":64,"line_end":64},{"speaker":"char_tie_shui","speaker_name":"黑衫僧","listener":null,"text":"江南霹雳堂的王飞。","tone":"陈述","chapter":3,"line_start":66,"line_end":66},{"speaker":"char_tie_shui","speaker_name":"黑衫僧","listener":null,"text":"你知道我是谁？","tone":"疑问","chapter":3,"line_start":68,"line_end":68},{"speaker":"char_tie_shui","speaker_name":"黑衫僧","listener":null,"text":"好，就凭你这句话，也只配喝一杯。","tone":"大笑","chapter":3,"line_start":74,"line_end":74},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"好，凭你这句话，还可以再喝一杯。","tone":"大笑","chapter":3,"line_start":84,"line_end":84},{"speaker":"char_wang_fei","speaker_name":"王飞","listener":null,"text":"既然如此，就算是糖水，我也喝了。","tone":"大笑","chapter":3,"line_start":86,"line_end":86},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"想不到你骗酒喝的本事比我还大。","tone":"大笑","chapter":3,"line_start":88,"line_end":88},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"既然如此，这位段公子就当喝三杯。","tone":"愤怒","chapter":3,"line_start":90,"line_end":90},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他凭什么？","tone":"疑问","chapter":3,"line_start":92,"line_end":92},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"你不知他是谁？","tone":"疑问","chapter":3,"line_start":94,"line_end":94},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他是谁？","tone":"疑问","chapter":3,"line_start":96,"line_end":96},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他就是中原大侠段飞熊的大公子，姓段名玉。","tone":"陈述","chapter":3,"line_start":98,"line_end":98},{"speaker":"char_duan_fei_xiong","speaker_name":"段飞熊","listener":null,"text":"这不够。","tone":"淡然","chapter":3,"line_start":100,"line_end":100},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他也就是昨天在画舫上，将你四个徒弟打下水的人。","tone":"淡然","chapter":3,"line_start":102,"line_end":102},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"你为何要将他带来？","tone":"疑问","chapter":3,"line_start":104,"line_end":104},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"我并没有带他来，是他带我来的。","tone":"疑问","chapter":3,"line_start":106,"line_end":106},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他带你来的？","tone":"疑问","chapter":3,"line_start":108,"line_end":108},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他带我来找花夜来。","tone":"陈述","chapter":3,"line_start":110,"line_end":110},{"speaker":"char_hua_ye_lai","speaker_name":"花夜来","listener":null,"text":"那女贼怎会在这里？","tone":"疑问","chapter":3,"line_start":112,"line_end":112},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"她不在？","tone":"疑问","chapter":3,"line_start":114,"line_end":114},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"当然不在。","tone":"陈述","chapter":3,"line_start":116,"line_end":116},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"昨天晚上她也没有来？","tone":"疑问","chapter":3,"line_start":118,"line_end":118},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"有洒家在这里，她怎敢来？","tone":"疑问","chapter":3,"line_start":120,"line_end":120},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"听见了。","tone":"苦笑","chapter":3,"line_start":126,"line_end":126},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"你走吧。","tone":"苦笑","chapter":3,"line_start":128,"line_end":128},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他并不想走，是我叫他走的。","tone":"陈述","chapter":3,"line_start":134,"line_end":134},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"你为什么要叫他走？","tone":"疑问","chapter":3,"line_start":136,"line_end":136},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"因为他是我的朋友。","tone":"陈述","chapter":3,"line_start":138,"line_end":138},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他骗你，你还将他当作朋友？","tone":"疑问","chapter":3,"line_start":140,"line_end":140},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"也许并不是他在骗我，而是别人骗了他。","tone":"陈述","chapter":3,"line_start":142,"line_end":142},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"你相信他？","tone":"疑问","chapter":3,"line_start":144,"line_end":144},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"他本就是个诚实的少年，决不会说谎的。","tone":"陈述","chapter":3,"line_start":146,"line_end":146},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"这酒我也配喝？","tone":"疑问","chapter":3,"line_start":152,"line_end":152},{"speaker":"char_lu_jiu","speaker_name":"卢九","listener":null,"text":"这已配喝三杯。","tone":"轻笑","chapter":3,"line_start":158,"line_end":158},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"敬酒不喝，你莫非要喝罚酒？","tone":"疑问","chapter":3,"line_start":186,"line_end":186},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"这不是酒，是血！","tone":"陈述","chapter":3,"line_start":190,"line_end":190},{"speaker":null,"speaker_name":null,"listener":null,"text":"刚才这里面还明明是酒，怎么会忽然变成了血？","tone":"疑问","chapter":3,"line_start":200,"line_end":200},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"酒化为血，是凶兆。","tone":"陈述","chapter":3,"line_start":202,"line_end":202},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"凶兆？这里难道有什么不祥的事要发生了？","tone":"疑问","chapter":3,"line_start":204,"line_end":204},{"speaker":"char_wang_fei","speaker_name":"王飞","listener":null,"text":"不错，这里只怕已有个人非死不可。","tone":"陈述","chapter":3,"line_start":206,"line_end":206},{"speaker":"char_wang_fei","speaker_name":"王飞","listener":null,"text":"谁？","tone":"疑问","chapter":3,"line_start":208,"line_end":208},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"画舫在哪里？","tone":"疑问","chapter":3,"line_start":224,"line_end":224},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"就在长堤那边。","tone":"陈述","chapter":3,"line_start":226,"line_end":226},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"好刀。","tone":"陈述","chapter":3,"line_start":280,"line_end":280},{"speaker":"char_wang_fei","speaker_name":"王飞","listener":null,"text":"的确是好刀。","tone":"陈述","chapter":3,"line_start":282,"line_end":282},{"speaker":"char_wang_fei","speaker_name":"王飞","listener":null,"text":"你可认得这把刀？","tone":"疑问","chapter":3,"line_start":284,"line_end":284},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"你呢？你可认得这把刀？","tone":"疑问","chapter":3,"line_start":288,"line_end":288},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"你可认得这个人？","tone":"疑问","chapter":3,"line_start":302,"line_end":302},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"卢小云艺出名门，文武双全，当然是你的劲敌。","tone":"陈述","chapter":3,"line_start":332,"line_end":332},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"所以你认为只要杀了他，就没有人能跟你竞争了。","tone":"陈述","chapter":3,"line_start":336,"line_end":336},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"我……我连见都没有见过他。","tone":"陈述","chapter":3,"line_start":338,"line_end":338},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"杀人用的是刀，不是眼睛。","tone":"厉声","chapter":3,"line_start":340,"line_end":340},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"是，但是用这柄刀杀他的人并不是我。","tone":"陈述","chapter":3,"line_start":344,"line_end":344},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"那是我……","tone":"陈述","chapter":3,"line_start":350,"line_end":350},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"但昨天晚上……","tone":"陈述","chapter":3,"line_start":356,"line_end":356},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"昨天晚上，你是不是跟花夜来在一起的？","tone":"疑问","chapter":3,"line_start":358,"line_end":358},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"酒化为血，确是凶兆。","tone":"沉声","chapter":3,"line_start":364,"line_end":364},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"的确是的。","tone":"无奈","chapter":3,"line_start":366,"line_end":366},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"现在这里是不是已有个人非死不可？","tone":"疑问","chapter":3,"line_start":368,"line_end":368},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"是。","tone":"陈述","chapter":3,"line_start":370,"line_end":370},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"他凝视着手里的刀，慢慢地接着道：","tone":"无奈","chapter":3,"line_start":374,"line_end":374},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"你还不知道？","tone":"疑问","chapter":3,"line_start":382,"line_end":382},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"你是要我将这柄刀给你？","tone":"疑问","chapter":3,"line_start":394,"line_end":394},{"speaker":"char_tie_shui","speaker_name":"铁水","listener":null,"text":"好，你既然要，你就拿去。","tone":"大笑","chapter":3,"line_start":400,"line_end":400},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"前辈，你怎么杀我？莫非杀错人了？","tone":"疑问","chapter":3,"line_start":406,"line_end":406},{"speaker":null,"speaker_name":null,"listener":null,"text":"乱披风","tone":"陈述","chapter":3,"line_start":422,"line_end":422},{"speaker":"char_wang_fei","speaker_name":"王飞","listener":null,"text":"我只看出铁水是个残忍好杀的人。","tone":"淡然","chapter":3,"line_start":440,"line_end":440},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"哦。","tone":"淡然","chapter":3,"line_start":442,"line_end":442},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"只要他杀的不是无辜……","tone":"无奈","chapter":3,"line_start":448,"line_end":448},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"你怎知他杀的不是无辜？","tone":"疑问","chapter":3,"line_start":450,"line_end":450},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"事实俱在。","tone":"陈述","chapter":3,"line_start":452,"line_end":452},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"什么事实？那柄刀？","tone":"疑问","chapter":3,"line_start":454,"line_end":454},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"嗯。","tone":"陈述","chapter":3,"line_start":456,"line_end":456},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"你杀了人后，会不会将自己的刀留下？","tone":"疑问","chapter":3,"line_start":458,"line_end":458},{"speaker":"char_wang_fei","speaker_name":"王飞","listener":null,"text":"你说他该杀？","tone":"疑问","chapter":3,"line_start":464,"line_end":464},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"你说不该？","tone":"疑问","chapter":3,"line_start":466,"line_end":466},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"无论如何，等问清了再杀也不迟。","tone":"陈述","chapter":3,"line_start":468,"line_end":468},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"你莫非想救他？","tone":"疑问","chapter":3,"line_start":470,"line_end":470},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"想必是跟着段玉来的。","tone":"陈述","chapter":3,"line_start":508,"line_end":508},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"你知道他是什么人？","tone":"疑问","chapter":3,"line_start":510,"line_end":510},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"迟早总会知道。","tone":"陈述","chapter":3,"line_start":512,"line_end":512},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"大师若是怕他跑了，就请放心……","tone":"淡然","chapter":3,"line_start":518,"line_end":518},{"speaker":"char_gu_dao_ren","speaker_name":"顾道人","listener":null,"text":"我放什么心？","tone":"疑问","chapter":3,"line_start":520,"line_end":520},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你还笑得出？","tone":"疑问","chapter":3,"line_start":586,"line_end":586},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"我只是奇怪，你为什么还没有淹死。","tone":"陈述","chapter":3,"line_start":592,"line_end":592},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你明明应该是条旱鸭子，为什么忽然会游水了呢？","tone":"疑问","chapter":3,"line_start":596,"line_end":596},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你死盯着我看什么？我脸上长了花？","tone":"疑问","chapter":3,"line_start":604,"line_end":604},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"为什么？","tone":"疑问","chapter":3,"line_start":610,"line_end":610},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"因为你在水下面可爱得多了。","tone":"疑问","chapter":3,"line_start":612,"line_end":612},{"speaker":null,"speaker_name":null,"listener":null,"text":"这小子难道忽然抽了筋，上不来了？","tone":"疑问","chapter":3,"line_start":632,"line_end":632},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"疯子，白痴","tone":"陈述","chapter":3,"line_start":638,"line_end":638},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"这箱子好重。","tone":"陈述","chapter":3,"line_start":662,"line_end":662},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"的确不轻。","tone":"陈述","chapter":3,"line_start":664,"line_end":664},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"所以这箱子一定不是空的。","tone":"陈述","chapter":3,"line_start":666,"line_end":666},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你猜里面装的是什么？","tone":"疑问","chapter":3,"line_start":670,"line_end":670},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"我没有千里眼，也不是诸葛亮。","tone":"轻笑","chapter":3,"line_start":672,"line_end":672},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"那么你为什么还不打开来看看呢？","tone":"疑问","chapter":3,"line_start":674,"line_end":674},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"急什么，这箱子也不会跑的。","tone":"陈述","chapter":3,"line_start":676,"line_end":676},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"你还等什么？","tone":"疑问","chapter":3,"line_start":678,"line_end":678},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"至少也该等我们先找个地方去换件衣服。","tone":"轻笑","chapter":3,"line_start":680,"line_end":680},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"女为悦己者容","tone":"陈述","chapter":3,"line_start":744,"line_end":744},{"speaker":"char_duan_yu","speaker_name":"段玉","listener":null,"text":"你以前见过这种箱子没有？","tone":"疑问","chapter":3,"line_start":758,"line_end":758},{"speaker":"char_zhu_zhu","speaker_name":"华华凤","listener":null,"text":"没有。","tone":"喃喃","chapter":3,"line_start":760,"line_e