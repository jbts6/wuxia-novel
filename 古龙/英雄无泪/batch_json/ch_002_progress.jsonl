{"segment":5,"line_start":106,"line_end":138,"dialogues":[{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":"char_ding_xie","text":"\"那有个屁用？\"","tone":"愤怒","chapter":2,"line_start":106,"line_end":106},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":"char_ding_xie","text":"\"他既然想不到老子在这里，会不会把主力都调到这里来？\"","tone":"认真","chapter":2,"line_start":106,"line_end":108},{"speaker":"char_ding_xie","speaker_name":"钉鞋","listener":"char_zhu_meng","text":"\"不会。\"","tone":"陈述","chapter":2,"line_start":110,"line_end":110},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":"char_ding_xie","text":"\"他跟司马会不会来？\"","tone":"认真","chapter":2,"line_start":112,"line_end":112},{"speaker":"char_ding_xie","speaker_name":"钉鞋","listener":"char_zhu_meng","text":"\"也不会。\"","tone":"陈述","chapter":2,"line_start":114,"line_end":114},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":"char_ding_xie","text":"\"所以他派来的人，最多也不过是他身边那两个连胡子都长不出的小兔崽子而已。\"","tone":"冷酷","chapter":2,"line_start":116,"line_end":118},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":"char_ding_xie","text":"\"我料定他派来的不是郭壮，就是孙通。\"","tone":"认真","chapter":2,"line_start":118,"line_end":120},{"speaker":"char_ding_xie","speaker_name":"钉鞋","listener":"char_zhu_meng","text":"\"是。\"","tone":"陈述","chapter":2,"line_start":122,"line_end":122},{"speaker":"char_ding_xie","speaker_name":"钉鞋","listener":"char_zhu_meng","text":"\"一定是的。\"","tone":"陈述","chapter":2,"line_start":122,"line_end":122},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"\"现在你们是不是已经知道我是谁了？\"","tone":"豪迈","chapter":2,"line_start":128,"line_end":130},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"\"我就是朱大太爷。\"","tone":"豪迈","chapter":2,"line_start":134,"line_end":134},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"\"就是司马超群的死对头。\"","tone":"豪迈","chapter":2,"line_start":134,"line_end":136}],"new_entities":{"characters":[{"alias":["孙挡"],"identity":"大镖局年轻好手","faction":"大镖局","role":"np