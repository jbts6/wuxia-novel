{"segment":7,"line_start":166,"line_end":188,"dialogues":[{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"贵姓？\n大名？\"","tone":"好奇","chapter":2,"line_start":182,"line_end":184},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"姓孙，孙通。\"","tone":"陈述","chapter":2,"line_start":186,"line_end":186},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"你好。\"","tone":"平静","chapter":2,"line_start":188,"line_end":188}],"new_entities":{"characters":[{"alias":["高渐飞"],"identity":"落拓少年剑客","faction":"无","role":"protagonist","archetype":"warrior","rank":"出神入化","relationships":[{"target":"char_zhu_meng","type":"挚友","intensity":80,"bond_level":4,"dynamic":"接受朱猛结交并陪他冒险饮酒"},{"target":"char_si_ma_chao_qun","type":"对手","intensity":90,"bond_level":1,"dynamic":"一心想让司马超群死在剑下"}],"known_skills":["skill_xiao_gao_jian_fa","skill_nei_li_re_cha"],"related_skills":["skill_xiao_gao_jian_fa","skill_nei_li_re_cha"],"rag_refs":["ch_002:182-188"],"source_refs":[{"chapter":2,"line_start":182,"line_end":188,"text":"可是小高却走到他面前来了，而且在他对面的椅子上坐下，甚至还对他笑了笑，居然还问他：\"贵姓？\n大名？\"\n他没有笑，可是也没有拒绝回答：\"姓孙，孙通。\"\n\"你好。\""}],"id":"char_xiao_gao","name":"小高","one_line":"携粗布包袱行走江湖的少年剑客，一心想以剑挑战司马超群成名。","traits":["机敏","从容","幽默","重义","好胜","胆大"],"speech":"常以轻松玩笑化解杀机，话锋机巧","temperament":"表面散漫，内心执着","ls":182,"le":188,"personality":{"traits":["机敏","从容","幽默","重义","好胜","胆大"],"speech_style":"常以轻松玩笑化解杀机，话锋机巧","temperament":"表面散漫，内心执着"}}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":190,"line_end":228,"dialogues":[{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"虽然不太好，也不能算太坏。\"","tone":"淡然","chapter":2,"line_start":190,"line_end":190},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"最少我的人头还在脖子上。\"","tone":"淡然","chapter":2,"line_start":190,"line_end":192},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"知道自己的人头还在自己的脖子上，的确是件很愉快的事。\"","tone":"调侃","chapter":2,"line_start":196,"line_end":198},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"如果还能够知道杨坚的人头在哪里，那就更愉快了。\"","tone":"调侃","chapter":2,"line_start":198,"line_end":200},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"你知道？\"","tone":"疑问","chapter":2,"line_start":202,"line_end":202},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"我只知道卓先生一定很不愿意看到杨坚的头颅落入朱猛手里，让他提着它到江湖朋友面前去耀武扬威。\"","tone":"认真","chapter":2,"line_start":204,"line_end":206},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"所以你们才会在这里。\"","tone":"认真","chapter":2,"line_start":206,"line_end":206},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"你知道的好像很不少。\"","tone":"淡然","chapter":2,"line_start":208,"line_end":208},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"只可惜我还是不太明白。\"","tone":"疑问","chapter":2,"line_start":210,"line_end":210},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"要到洛阳去的人，并不一定要走官道的，连我这个外乡人都知道另外最少还有两三条小路。\"","tone":"疑问","chapter":2,"line_start":210,"line_end":212},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"我只管大路，不管小路。\"","tone":"陈述","chapter":2,"line_start":214,"line_end":214},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"为什么？\"","tone":"疑问","chapter":2,"line_start":216,"line_end":216},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"走小路的人，胆子也不会太大，还用不着要我去对付。\"","tone":"冷酷","chapter":2,"line_start":218,"line_end":218},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"说得好！好极了！\"","tone":"欣喜","chapter":2,"line_start":220,"line_end":220},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"你有没有发现什么可疑的人？\"","tone":"低语","chapter":2,"line_start":222,"line_end":224},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"只发现了一个。\"","tone":"冷酷","chapter":2,"line_start":226,"line_end":226},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"谁？\"","tone":"疑问","chapter":2,"line_start":228,"line_end":228}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":9,"line_start":230,"line_end":272,"dialogues":[{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"你！\"","tone":"冷酷","chapter":2,"line_start":230,"line_end":230},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"如果真的是我，那就很不愉快了。\"","tone":"大笑","chapter":2,"line_start":232,"line_end":232},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"谁不愉快？\"","tone":"疑问","chapter":2,"line_start":234,"line_end":234},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"你！\"","tone":"调侃","chapter":2,"line_start":236,"line_end":236},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"如果我要带着杨坚的头颅闯这一关，那么阁下也许就会忽然发现阁下的大好头颅已经不在阁下的脖子上了。\"","tone":"冷酷","chapter":2,"line_start":238,"line_end":240},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"阁下的意思就是你。\"","tone":"调侃","chapter":2,"line_start":242,"line_end":242},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"我也看得出你没有带杨坚的头颅！\"","tone":"认真","chapter":2,"line_start":246,"line_end":246},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"可是我看得出你带了一口剑。\"","tone":"认真","chapter":2,"line_start":246,"line_end":248},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"你没有看错。\"","tone":"平静","chapter":2,"line_start":250,"line_end":250},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"你为什么不拔出你的剑来试一试。\"","tone":"嘲讽","chapter":2,"line_start":252,"line_end":252},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_sun_tong","text":"\"试什么？\"","tone":"疑问","chapter":2,"line_start":254,"line_end":254},{"speaker":"char_sun_tong","speaker_name":"孙通","listener":"char_xiao_gao","text":"\"试试看究竟是谁的头颅会从脖子上落下。\"","tone":"冷酷","chapter":2,"line_start":256,"line_end":256},{"speaker":"char_xiao_gao","speaker_name":"小高","lis