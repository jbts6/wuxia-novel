{"segment":3,"line_start":52,"line_end":76,"dialogues":[{"speaker":"char_da_jiu_gang","speaker_name":"大酒缸","listener":null,"text":"\"可是这个人……\"","tone":"惊讶","chapter":2,"line_start":54,"line_end":54},{"speaker":"char_da_jiu_gang","speaker_name":"大酒缸","listener":null,"text":"\"他简直不是个人，是个酒桶，没有底的酒桶。\"","tone":"惊讶","chapter":2,"line_start":54,"line_end":56},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"\"外面是不是有人来了？\"","tone":"沉声","chapter":2,"line_start":60,"line_end":60},{"speaker":"char_gui_nu","speaker_name":"龟奴","listener":"char_zhu_meng","text":"\"是。\"","tone":"恐惧","chapter":2,"line_start":62,"line_end":62},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":"char_gui_nu","text":"\"是不是来找我的？\"","tone":"沉声","chapter":2,"line_start":64,"line_end":64},{"speaker":"char_gui_nu","speaker_name":"龟奴","listener":"char_zhu_meng","text":"\"是。\"","tone":"恐惧","chapter":2,"line_start":66,"line_end":66},{"speaker":"char_gui_nu","speaker_name":"龟奴","listener":"char_zhu_meng","text":"\"是个名字很怪的人。\"","tone":"恐惧","chapter":2,"line_start":66,"line_end":66},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":"char_gui_nu","text":"\"他叫什么名字？\"","tone":"沉声","chapter":2,"line_start":68,"line_end":68},{"speaker":"char_gui_nu","speaker_name":"龟奴","listener":"char_zhu_meng","text":"\"叫做钉鞋。\"","tone":"恐惧","chapter":2,"line_start":70,"line_end":70},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":"char_gui_nu","text":"\"好小子，总算赶来了，快叫他给我滚进来。\"","tone":"豪迈","chapter":2,"line_start":72,"line_end":72}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
