{"segment":22,"line_start":612,"line_end":644,"dialogues":[{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_zhu_meng","text":"\"朱堂主，我不再敬你了，\"","tone":"微笑","chapter":2,"line_start":628,"line_end":628},{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_zhu_meng","text":"\"此去洛阳，路途仍远，喝太多总是不太好的。\"","tone":"微笑","chapter":2,"line_start":628,"line_end":630},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_zhuo_dong_lai","text":"\"你让他走？\"","tone":"惊讶","chapter":2,"line_start":634,"line_end":634},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_zhuo_dong_lai","text":"\"你真的肯让他走？\"","tone":"惊讶","chapter":2,"line_start":634,"line_end":634},{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_xiao_gao","text":"\"他能交你这个朋友，我为什么不能？\n他能冒险陪你在这里喝酒，我为什么不能为你让他走？\"","tone":"淡然","chapter":2,"line_start":636,"line_end":640},{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_zhu_meng","text":"\"朱堂主，从此一别，后会有期，恕我不能远送了。\"","tone":"淡然","chapter":2,"line_start":642,"line_end":644}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_zhuo_dong_lai","relationship_updates":[{"target":"char_xiao_gao","type":"合作者","intensity":70,"bond_level":2,"dynamic":"因小高而放朱猛离开，试图建立朋友可能"}]}]}
{"segment":23,"line_start":646,"line_end":674,"dialogues":[{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_zhuo_dong_lai","text":"\"现在我才相信江湖中人说的不假，'紫气东来'卓东来果然是个了不起的人物。\"","tone":"无奈","chapter":2,"line_start":650,"line_end":652},{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_xiao_gao","text":"\"可惜我知道你不会交我这个朋友的，因为你一心只想成名，一心只想要司马超群死在你的剑下。\"","tone":"无奈","chapter":2,"line_start":654,"line_end":656},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_zhuo_dong_lai","text":"\"死的也许不是他，是我。\"","tone":"认真","chapter":2,"line_start":658,"line_end":658},{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_xiao_gao","text":"\"是的，死的很可能是你。\"","tone":"淡然","chapter":2,"line_start":660,"line_end":660},{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_xiao_gao","text":"\"如果有人要我打赌，我愿意用十去博一，赌你死。\"","tone":"淡然","chapter":2,"line_start":660,"line_end":662},{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_xiao_gao","text":"\"如果你要跟我赌，我也愿意。\"","tone":"淡然","chapter":2,"line_start":664,"line_end":664},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_zhuo_dong_lai","text":"\"我不愿意。\"","tone":"平静","chapter":2,"line_start":666,"line_end":666},{"speaker":"char_zhuo_dong_lai","speaker_name":"卓东来","listener":"char_xiao_gao","text":"\"为什么？\"","tone":"疑问","chapter":2,"line_start":668,"line_end":668},{"speaker":"char_xiao_gao","speaker_name":"小高","listener":"char_zhuo_dong_lai","text":"\"因为我输不起。\"","tone":"认真","chapter":2,"line_start":670,"line_end":670}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_xiao_gao","attribute_updates":{"goal":"追上忽然消失的提箱人，并继续赴长安死约会"},"relationship_updates":[{"target":"char_si_ma_chao_qun","type":"对手","intensity":90,"bond_level":1,"dynamic":"卓东来点明小高一心要司马超群死在剑下"}]}]}
