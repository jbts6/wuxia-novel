{"segment":25,"line_start":698,"line_end":734,"dialogues":[{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"我明白。","tone":"陈述","chapter":16,"line_start":700,"line_end":700},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"你错了。","tone":"严肃","chapter":16,"line_start":706,"line_end":706},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"为什么？","tone":"疑问","chapter":16,"line_start":710,"line_end":710},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"司马超群道，","tone":"陈述","chapter":16,"line_start":714,"line_end":714},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"今天你就是来还债的？","tone":"疑问","chapter":16,"line_start":716,"line_end":716},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"是。","tone":"陈述","chapter":16,"line_start":718,"line_end":718},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"这笔债你能还得清？","tone":"疑问","chapter":16,"line_start":720,"line_end":720},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"你怎么样才能还得清？","tone":"疑问","chapter":16,"line_start":720,"line_end":720},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"还不清也要还，","tone":"陈述","chapter":16,"line_start":722,"line_end":722},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"你说你那时候还是大镖局的总瓢把子，","tone":"陈述","chapter":16,"line_start":728,"line_end":728},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"现在我无论是个什么样的人，都跟这件事全无关系。","tone":"陈述","chapter":16,"line_start":732,"line_end":732},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"为什么？","tone":"疑问","chapter":16,"line_start":734,"line_end":734}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":26,"line_start":736,"line_end":764,"dialogues":[{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"因为你还是朱猛，我还是司马超群。","tone":"陈述","chapter":16,"line_start":736,"line_end":736},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"就算头断血流，家毁人亡，这一点也不会变。","tone":"悲伤","chapter":16,"line_start":742,"line_end":742},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"朱猛说，","tone":"悲伤","chapter":16,"line_start":754,"line_end":754},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"我明白。","tone":"陈述","chapter":16,"line_start":758,"line_end":758},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"朱猛说，","tone":"陈述","chapter":16,"line_start":762,"line_end":762},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"你司马超群今日请受我朱猛一拜。","tone":"陈述","chapter":16,"line_start":764,"line_end":764}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":27,"line_start":766,"line_end":788,"dialogues":[{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"我拜你是个真正的英雄，是条真正的男子汉。","tone":"嘶声","chapter":16,"line_start":770,"line_end":770},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"因为我还是会杀你，我别无选择余地。","tone":"陈述","chapter":16,"line_start":774,"line_end":774},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"你明白就好。","tone":"陈述","chapter":16,"line_start":780,"line_end":780},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"你明白就好。","tone":"陈述","chapter":16,"line_start":780,"line_end":780},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"这个人就是司马超群，就是毁了我们的雄狮堂的人，","tone":"悲伤","chapter":16,"line_start":784,"line_end":784}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":28,"line_start":790,"line_end":816,"dialogues":[{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"就算我们全都战死，也要化做厉鬼来夺他的魂魄。","tone":"悲伤","chapter":16,"line_start":794,"line_end":794},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"朱猛道：","tone":"严肃","chapter":16,"line_start":798,"line_end":798}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":29,"line_start":818,"line_end":842,"dialogues":[{"speaker":"char_ah_gen","speaker_name":"阿根","listener":null,"text":"老总，我知道你跟我到这里来，就是准备来死的，","tone":"悲伤","chapter":16,"line_start":818,"line_end":818},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"好，好兄弟，","tone":"大笑","chapter":16,"line_start":822,"line_end":822},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"堂主，你知道俺本来做梦都想把这个人的脑袋割下来，可是现在","tone":"陈述","chapter":16,"line_start":834,"line_end":834},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"朱猛的声音更凄厉，","tone":"陈述","chapter":16,"line_start":836,"line_end":836},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"俺还是想，可是叫俺这么样就杀了他，俺实在没有法子动手。","tone":"陈述","chapter":16,"line_start":838,"line_end":838},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"为什么？","tone":"疑问","chapter":16,"line_start":840,"line_end":840},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"俺也不知道为什么，","tone":"疑问","chapter":16,"line_start":842,"line_end":842}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":30,"line_start":844,"line_end":866,"dialogues":[{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"你孬种，你说不出，我说得出。","tone":"嘲讽","chapter":16,"line_start":846,"line_end":846},{"speaker":"char_man_niu","speaker_name":"蛮牛","listener":null,"text":"你说，你心里是不是这么样想的？","tone":"疑问","chapter":16,"line_start":850,"line_end":850},{"speaker":"char_man_niu","speaker_name":"蛮牛","listener":null,"text":"你们呢？","tone":"疑问","chapter":16,"line_start":856,"line_end":856}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":31,"line_start":868,"line_end":896,"dialogues":[{"speaker":"char_man_niu","speaker_name":"蛮牛","listener":null,"text":"他说，","tone":"陈述","chapter":16,"line_start":880,"line_end":880},{"speaker":"char_man_niu","speaker_name":"蛮牛","listener":null,"text":"他说：","tone":"陈述","chapter":16,"line_start":890,"line_end":890}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":32,"line_start":898,"line_end":926,"dialogues":[{"speaker":"char_man_niu","speaker_name":"蛮牛","listener":null,"text":"现在是不是已经到时候了？","tone":"疑问","chapter":16,"line_start":904,"line_end":904},{"speaker":"char_man_niu","speaker_name":"蛮牛","listener":null,"text":"是。","tone":"陈述","chapter":16,"line_start":906,"line_end":906},{"speaker":"char_man_niu","speaker_name":"蛮牛","listener":null,"text":"给司马大侠一把刀。","tone":"陈述","chapter":16,"line_start":908,"line_end":908},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"这把刀不是好刀，","tone":"陈述","chapter":16,"line_start":912,"line_end":912},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"是。","tone":"陈述","chapter":16,"line_start":916,"line_end":916},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"所以我只想要你答应我一件事。","tone":"陈述","chapter":16,"line_start":918,"line_end":918},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"什么事？","tone":"疑问","chapter":16,"line_start":920,"line_end":920},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"如果你能杀我，刀下千万不要留情，","tone":"陈述","chapter":16,"line_start":922,"line_end":922},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"你想不想要我朱猛为你抱憾终生？","tone":"疑问","chapter":16,"line_start":926,"line_end":926}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":33,"line_start":928,"line_end":960,"dialogues":[{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"好，","tone":"大笑","chapter":16,"line_start":932,"line_end":932},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"好极了。","tone":"大笑","chapter":16,"line_start":932,"line_end":932},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"我若死在你的刀下，我的兄弟绝不会再找你。","tone":"悲伤","chapter":16,"line_start":944,"line_end":944},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"朱猛能死在司马超群的刀下，死亦无憾。","tone":"悲伤","chapter":16,"line_start":946,"line_end":946},{"speaker":"char_si_ma_chao_qun","speaker_name":"司马超群","listener":null,"text":"我的妻子儿女？","tone":"疑问","chapter":16,"line_start":956,"line_end":956}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
