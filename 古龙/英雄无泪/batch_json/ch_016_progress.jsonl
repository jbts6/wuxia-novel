{"segment":35,"line_start":1000,"line_end":1042,"dialogues":[{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"朱猛、朱猛，你在不在？","tone":"疑问","chapter":16,"line_start":1012,"line_end":1012},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"我在、我在，我一直都在。","tone":"温柔","chapter":16,"line_start":1014,"line_end":1014},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"朱猛，我错了，你也错了。","tone":"陈述","chapter":16,"line_start":1024,"line_end":1024},{"speaker":"char_zhu_meng","speaker_name":"朱猛","listener":null,"text":"是的，我错了。","tone":"陈述","chapter":16,"line_start":1026,"line_end":1026},{"speaker":"char_die_wu","speaker_name":"蝶舞","listener":null,"text":"蝶舞说，","tone":"陈述","chapter":16,"line_start":1030,"line_end":1030},{"speaker":"char_die_wu","speaker_name":"蝶舞","listener":null,"text":"朱猛，我要死了，你不要死。","tone":"悲伤","chapter":16,"line_start":1038,"line_end":1038}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_zhu_meng","updates":{"source_refs":[{"chapter":16,"line_start":1000,"line_end":1042,"text":"只要她在，他就在。"}]}}]}
{"segment":36,"line_start":1044,"line_end":1074,"dialogues":[{"speaker":"char_die_wu","speaker_name":"蝶舞","listener":null,"text":"我已不能再为你而舞了，但我还可以为你而唱。","tone":"悲伤","chapter":16,"line_start":1044,"line_end":1044},{"speaker":"char_die_wu","speaker_name":"蝶舞","listener":null,"text":"好，你唱，我听。","tone":"大笑","chapter":16,"line_start":1048,"line_end":1048}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_die_wu","updates":{"source_refs":[{"chapter":16,"line_start":1044,"line_end":1074,"text":"我已不能再为你而舞了，但我还可以为你而唱。"}]}},{"id":"char_zhu_meng","updates":{"source_refs":[{"chapter":16,"line_start":1044,"line_end":1074,"text":"朱猛痴痴地站在那里，痴痴地看着她，忽然一口鲜血吐了出来。"}]}}]}
