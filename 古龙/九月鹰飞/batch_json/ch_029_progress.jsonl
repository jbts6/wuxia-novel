{"segment":5,"line_start":401,"line_end":500,"dialogues":[{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"出家人不该幸灾乐祸的。","tone":"陈述","chapter":29,"line_start":412,"line_end":412},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"谁幸灾乐祸？","tone":"陈述","chapter":29,"line_start":414,"line_end":414},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你。","tone":"陈述","chapter":29,"line_start":416,"line_end":416},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你这和尚虽然多话，说的倒好像都是老实话。","tone":"陈述","chapter":29,"line_start":422,"line_end":422},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"老实说，这个庙简直就跟饭馆客栈差不多。","tone":"无奈","chapter":29,"line_start":440,"line_end":440},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你知不知道他是怎么会死的？","tone":"疑问","chapter":29,"line_start":444,"line_end":444},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"就是因为你太多话，所以他才会死。","tone":"陈述","chapter":29,"line_start":448,"line_end":448},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"施主一定是在开玩笑。","tone":"陈述","chapter":29,"line_start":450,"line_end":450},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"我从不在死人面前开玩笑。","tone":"陈述","chapter":29,"line_start":452,"line_end":452},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"施主难道还看不出他是被毒死的？","tone":"陈述","chapter":29,"line_start":454,"line_end":454},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你看得出？","tone":"陈述","chapter":29,"line_start":456,"line_end":456},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"这里的蛇大多数都有毒，何况还有蝎子、蜈蚣。","tone":"陈述","chapter":29,"line_start":458,"line_end":458},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"有些人天生就能吃五毒，有毒的毒蛇也毒不死他。","tone":"陈述","chapter":29,"line_start":460,"line_end":460},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"可是除了他自己抓的那些毒虫外，他并没有吃别的。","tone":"陈述","chapter":29,"line_start":462,"line_end":462},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"那些毒虫既然是他自己抓的，怎么能毒得死他？","tone":"陈述","chapter":29,"line_start":464,"line_end":464},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"看来这件事倒的确有点古怪。","tone":"喃喃","chapter":29,"line_start":466,"line_end":466},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"其实这件事并不古怪。","tone":"陈述","chapter":29,"line_start":468,"line_end":468},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"是谁下的？","tone":"陈述","chapter":29,"line_start":476,"line_end":476},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"死在墙头上的那两个人。","tone":"陈述","chapter":29,"line_start":478,"line_end":478},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"这跟我多话又有什么关系？","tone":"陈述","chapter":29,"line_start":480,"line_end":480},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"有关系。","tone":"陈述","chapter":29,"line_start":482,"line_end":482},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"哦？","tone":"陈述","chapter":29,"line_start":484,"line_end":484},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"若不是你多话，别人怎么会知道他吃的是五毒？","tone":"陈述","chapter":29,"line_start":486,"line_end":486}],"new_entities":{"characters":[{"id":"char_ye_kai","name":"叶开","alias":"小李飞刀传人","identity":"江湖侠客","faction":"无门派","role":"protagonist","archetype":"warrior","rank":"出神入化","one_line":"小李飞刀的传人，性格洒脱机智","personality":{"traits":["洒脱","机智","幽默","重情义","好奇心强"],"speech_style":"轻松随意","temperament":"乐观"},"relationships":[],"known_skills":["skill_fei_dao"],"related_skills":[],"rag_refs":[29],"source_refs":[{"chapter":29,"line_start":10,"line_end":556,"text":"叶开叹道"}]},{"id":"char_mo_jiu_xing","name":"墨九星","alias":"神秘高手","identity":"隐世高手","faction":"无门派","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"神秘的隐世高手，以毒物为食","personality":{"traits":["沉默寡言","冷酷","神秘","武功高强","特立独行"],"