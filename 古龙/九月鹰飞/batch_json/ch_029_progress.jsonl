{"segment":6,"line_start":501,"line_end":565,"dialogues":[{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"活着时是凶人，死了也一定是恶鬼。","tone":"喃喃","chapter":29,"line_start":502,"line_end":502},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"所以你千万要小心些。","tone":"陈述","chapter":29,"line_start":504,"line_end":504},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"我……我小心什么？","tone":"陈述","chapter":29,"line_start":506,"line_end":506},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"我的头疼得很，我也要去睡了。","tone":"陈述","chapter":29,"line_start":512,"line_end":512},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你不能走。","tone":"陈述","chapter":29,"line_start":514,"line_end":514},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"为什么？","tone":"惊讶","chapter":29,"line_start":516,"line_end":516},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你若走了，谁来超度他的亡魂？","tone":"陈述","chapter":29,"line_start":518,"line_end":518},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"他用不着别人超度，这种人反正一定要下地狱的。","tone":"陈述","chapter":29,"line_start":520,"line_end":520},{"speaker":"char_ku_zhu","speaker_name":"苦竹","listener":null,"text":"刀！","tone":"陈述","chapter":29,"line_start":554,"line_end":554},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你要我用刀割下你的舌头？","tone":"陈述","chapter":29,"line_start":556,"line_end":556}],"new_entities":{"characters":[{"id":"char_ye_kai","name":"叶开","alias":"小李飞刀传人","identity":"江湖侠客","faction":"无门派","role":"protagonist","archetype":"warrior","rank":"出神入化","one_line":"小李飞刀的传人，性格洒脱机智","personality":{"traits":["洒脱","机智","幽默","重情义","好奇心强"],"speech_style":"轻松随意","temperament":"乐观"},"relationships":[],"known_skills":["skill_fei_dao"],"related_skills":[],"rag_refs":[29],"source_refs":[{"chapter":29,"line_start":10,"line_end":556,"text":"叶开叹道"}]},{"id":"char_ku_zhu","name":"苦竹","alias":"多嘴和尚","identity":"十方竹林寺僧人","faction":"十方竹林寺