      "speaker_name": "丁灵琳",
      "listener": "char_ye_kai",
      "text": "叶开！",
      "tone": "疑问",
      "chapter": 13,
      "line_start": 218,
      "line_end": 218
    },
    {
      "speaker": "char_ye_kai",
      "speaker_name": "叶开",
      "listener": "char_ding_ling_lin",
      "text": "你难道不认得我了？",
      "tone": "微笑",
