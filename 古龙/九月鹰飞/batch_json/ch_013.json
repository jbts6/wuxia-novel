      "speaker_name": "叶开",
      "listener": "char_guo_ding",
      "text": "不行。",
      "tone": "陈述",
      "chapter": 13,
      "line_start": 62,
      "line_end": 62
    },
    {
      "speaker": "char_guo_ding",
      "speaker_name": "郭定",
      "listener": "char_ye_kai",
      "text": "为什么不行？",
      "tone": "疑问",
      "chapter": 13,
      "line_start": 64,
      "line_end": 64
    },
    {
      "speaker": "char_ye_kai",
      "speaker_name": "叶开",
      "listener": "char_guo_ding",
      "text": "我不想替你收尸。",
