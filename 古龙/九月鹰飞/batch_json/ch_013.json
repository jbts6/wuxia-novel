      "chapter": 13,
      "line_start": 180,
      "line_end": 180
    },
    {
      "speaker": "char_ye_kai",
      "speaker_name": "叶开",
      "listener": "char_cui_yu_zhen",
      "text": "玉箫就算发现她已被救走，也绝不会想到我们的人还在这里。",
