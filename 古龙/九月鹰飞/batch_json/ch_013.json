      "chapter": 13,
      "line_start": 66,
      "line_end": 66
    },
    {
      "speaker": "char_guo_ding",
      "speaker_name": "郭定",
      "listener": "char_ye_kai",
      "text": "你难道想收丁灵琳的尸？",
      "tone": "淡然",
      "chapter": 13,
      "line_start": 70,
      "line_end": 70
    },
    {
      "speaker": "char_ye_kai",
      "speaker_name": "叶开",
      "listener": "char_guo_ding",
      "text": "我有法子，一定有法子的……",
      "tone": "犹豫",
      "chapter": 13,
      "line_start": 72,
      "line_end": 72
    },
    {
      "speaker": "char_yi_ye_ku",
      "speaker_name": "伊夜哭",
      "listener": "char_yu_xiao_dao_ren",
      "text": "你……你这是干什么？",
      "tone": "慌张",
      "chapter": 13,
      "line_start": 90,
      "line_end": 90
    },
    {
      "speaker": "char_yu_xiao_dao_ren",
      "speaker_name": "玉箫道人",
      "listener": "char_yi_ye_ku",
      "text": "我要杀了你。",
      "tone": "冷酷",
      "chapter": 13,
      "line_start": 92,
      "line_end": 92
    },
    {
      "speaker": "char_yi_ye_ku",
      "speaker_name": "伊夜哭",
      "listener": "char_yu_xiao_dao_ren",
      "text": "我好意前来，你竟要杀我？",
      "tone": "惊讶",
      "chapter": 13,
      "line_start": 94,
      "line_end": 94
    },
    {
      "speaker": "char_yu_xiao_dao_ren",
      "speaker_name": "玉箫道人",
      "listener": "char_yi_ye_ku",
      "text": "你将我看成什么人？竟想来利用我，你才是无知的鼠辈，我不杀你杀什么人？",
      "tone": "冷笑",
      "chapter": 13,
      "line_start": 96,
      "line_end": 96
    },
    {
      "speaker": "char_guo_ding",
      "speaker_name": "郭定",
      "listener": "char_nv_dao_ren",
      "text": "丁姑娘在哪里？",
      "tone": "冷酷",
      "chapter": 13,
      "line_start": 144,
      "line_end": 144
    },
    {
      "speaker": "char_guo_ding",
      "speaker_name": "郭定",
      "listener": "char_nv_dao_ren",
      "text": "你再不说，我就将你的人撕成两半。",
      "tone": "冷酷",
      "chapter": 13,
      "line_start": 152,
      "line_end": 152
    },
    {
      "speaker": "char_guo_ding",
      "speaker_name": "郭定",
      "listener": "char_ye_kai",
      "text": "在不在？",
      "tone": "陈述",
      "chapter": 13,
      "line_start": 160,
      "line_end": 160
    },
    {
      "speaker": "char_ye_kai",
      "speaker_name": "叶开",
      "listener": "char_guo_ding",
      "text": "在！",
      "tone": "惊喜",
      "chapter": 13,
      "line_start": 162,
      "line_end": 162
    },
    {
      "speaker": "char_guo_ding",
      "speaker_name": "郭定",
      "listener": "char_nv_dao_ren",
      "text": "你已快发胖了，以后记住千万不能吃肉。",
      "tone": "微笑",
      "chapter": 13,
      "line_start": 166,
      "line_end": 166
    },
    {
      "speaker": "char_cui_yu_zhen",
      "speaker_name": "崔玉真",
      "listener": "char_ye_kai",
      "text": "后面有没有人在追？",
