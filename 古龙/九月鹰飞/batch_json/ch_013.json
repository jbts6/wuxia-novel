      "line_start": 212,
      "line_end": 212
    },
    {
      "speaker": "char_guo_ding",
      "speaker_name": "郭定",
      "listener": "char_ye_kai",
      "text": "现在她已不必再哑下去。",
      "tone": "陈述",
      "chapter": 13,
      "line_start": 214,
      "line_end": 214
    },
    {
