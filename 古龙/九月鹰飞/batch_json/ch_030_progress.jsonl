{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":"char_shang_guan_xiao_xian","speaker_name":"上官小仙","listener":"char_ye_kai","text":"我知道一个地方还有酒喝，你跟不跟我走？","tone":"轻笑","chapter":30,"line_start":28,"line_end":30},{"speaker":"char_shang_guan_xiao_xian","speaker_name":"上官小仙","listener":"char_ye_kai","text":"请进。","tone":"平静","chapter":30,"line_start":68,"line_end":68},{"speaker":"char_shang_guan_xiao_xian","speaker_name":"上官小仙","listener":"char_ye_kai","text":"你不进去？","tone":"疑问","chapter":30,"line_start":72,"line_end":72},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"我为什么要进去？","tone":"疑问","chapter":30,"line_start":74,"line_end":74},{"speaker":"char_shang_guan_xiao_xian","speaker_name":"上官小仙","listener":"char_ye_kai","text":"里面有人在等你。","tone":"陈述","chapter":30,"line_start":76,"line_end":76},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"谁？","tone":"疑问","chapter":30,"line_start":78,"line_end":78},{"speaker":"char_shang_guan_xiao_xian","speaker_name":"上官小仙","listener":"char_ye_kai","text":"你进去看看就知道了。","tone":"陈述","chapter":30,"line_start":80,"line_end":80},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你不进去？","tone":"疑问","chapter":30,"line_start":82,"line_end":82},{"speaker":"char_shang_guan_xiao_xian","speaker_name":"上官小仙","listener":"char_ye_kai","text":"人家等的是你，不是我。","tone":"陈述","chapter":30,"line_start":84,"line_end":84},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"你明明知道我能认得出你，为什么偏偏不肯见我？","tone":"微笑","chapter":30,"line_start":88,"line_end":90},{"speaker":"char_shang_guan_xiao_xian","speaker_name":"上官小仙","listener":"char_ye_kai","text":"你……你认得出我？","tone":"惊讶","chapter":30,"line_start":92,"line_end":92},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":null,"text":"我若认不出，就不仅是个瞎子，而且还是个呆子。","tone":"微笑","chapter":30,"line_start":94,"line_end":96},{"speaker":"char_shang_guan_xiao_xian","speaker_name":"上官小仙","listener":"char_ye_kai","text":"为什么？","tone":"疑问","chapter"