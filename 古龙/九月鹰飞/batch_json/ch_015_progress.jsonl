{"segment":5,"line_start":406,"line_end":505,"dialogues":[{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你这是什么意思？","tone":"疑问","chapter":15,"line_start":406,"line_end":406},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"因为你的手不够长。","tone":"陈述","chapter":15,"line_start":404,"line_end":404},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"我的意思你应该明白。","tone":"陈述","chapter":15,"line_start":408,"line_end":408},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"你是说，我用这柄剑杀了人？","tone":"疑问","chapter":15,"line_start":410,"line_end":410},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"你不承认？","tone":"疑问","chapter":15,"line_start":412,"line_end":412},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"我杀了谁？","tone":"疑问","chapter":15,"line_start":414,"line_end":414},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"你杀人从不问对方的名字？","tone":"疑问","chapter":15,"line_start":416,"line_end":416},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"现在我正在问。","tone":"陈述","chapter":15,"line_start":418,"line_end":418},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"他姓韩，叫韩贞。","tone":"陈述","chapter":15,"line_start":420,"line_end":420},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_dai_gao_gang","text":"韩贞？你知不知道这个人？","tone":"疑问","chapter":15,"line_start":422,"line_end":422},{"speaker":"char_dai_gao_gang","speaker_name":"戴高岗","listener":"char_lv_di","text":"他是卫天鹏的智囊，别人都叫他锥子。","tone":"陈述","chapter":15,"line_start":424,"line_end":424},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"这锥子是你的什么人？","tone":"疑问","chapter":15,"line_start":426,"line_end":426},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"是我的朋友。","tone":"陈述","chapter":15,"line_start":428,"line_end":428},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你想替他复仇？","tone":"疑问","chapter":15,"line_start":430,"line_end":430},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"不错。","tone":"陈述","chapter":15,"line_start":432,"line_end":432},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你认为是我杀了他的？","tone":"疑问","chapter":15,"line_start":434,"line_end":434},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"是不是？","tone":"疑问","chapter":15,"line_start":436,"line_end":436},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"就算是我杀的又如何？这种人莫说只杀了一个，就算杀了十个八个，也不妨一起算在我账上。","tone":"傲然","chapter":15,"line_start":438,"line_end":438},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"你以为你是什么人？","tone":"冷笑","chapter":15,"line_start":442,"line_end":442},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"是个不怕别人来找我麻烦的人，等你的伤好了，随时都可以来找我复仇。","tone":"傲然","chapter":15,"line_start":444,"line_end":444},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"那倒不必。","tone":"陈述","chapter":15,"line_start":448,"line_end":448},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"不必？","tone":"疑问","chapter":15,"line_start":450,"line_end":450},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"不必等。","tone":"陈述","chapter":15,"line_start":452,"line_end":452},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你现在就想动手？","tone":"疑问","chapter":15,"line_start":454,"line_end":454},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"今天的天气不错，这地方也不错。","tone":"陈述","chapter":15,"line_start":456,"line_end":456},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你刚才说要买两口棺材，一口就是给韩贞的？","tone":"疑问","chapter":15,"line_start":458,"line_end":458},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"还有一口呢？","tone":"疑问","chapter":15,"line_start":464,"line_end":464},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"给伊夜哭。","tone":"疑问","chapter":15,"line_start":466,"line_end":466},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"赤魔手？","tone":"疑问","chapter":15,"line_start":468,"line_end":468},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"是的。","tone":"陈述","chapter":15,"line_start":470,"line_end":470},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"他已死在你手下？","tone":"疑问","chapter":15,"line_start":472,"line_end":472},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"我杀人后绝不会忘了替人收尸。","tone":"陈述","chapter":15,"line_start":474,"line_end":474},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"好，你若死了，这两口棺材我就替你买，你的棺材我也买。","tone":"豪迈","chapter":15,"line_start":476,"line_end":476},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"用不着。我若死了，你不妨将我的尸体拿去喂狗。","tone":"豪迈","chapter":15,"line_start":480,"line_end":480},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"好！好极了。","tone":"大笑","chapter":15,"line_start":482,"line_end":482},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"你若死了呢？","tone":"疑问","chapter":15,"line_start":484,"line_end":484},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"我若死了，你不妨将我的尸体一块块割下来，供在韩贞的灵位前，吃一块肉下一口酒。","tone":"豪迈","chapter":15,"line_start":486,"line_end":486},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"好，好极了，男子汉要替朋友复仇，正当如此。","tone":"大笑","chapter":15,"line_start":490,"line_end":490},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"这是你的剑。","tone":"陈述","chapter":15,"line_start":510,"line_end":510}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_yi_ye_ku","updates":{"one_line":"赤魔手伊夜哭，已死于叶开之手。"}},{"id":"char_ye_kai","updates":{"one_line":"飞刀传人叶开，此刻满腔愤怒誓替韩贞复仇。"}}]}
{"segment":6,"line_start":506,"line_end":610,"dialogues":[{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"我说过，我已不用剑。","tone":"傲然","chapter":15,"line_start":520,"line_end":520},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"我听说了。","tone":"陈述","chapter":15,"line_start":522,"line_end":522},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你杀人当然也不用剑。","tone":"陈述","chapter":15,"line_start":524,"line_end":524},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"从来不用。","tone":"陈述","chapter":15,"line_start":526,"line_end":526},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你的刀呢？","tone":"疑问","chapter":15,"line_start":528,"line_end":528},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"刀在。","tone":"冷酷","chapter":15,"line_start":534,"line_end":534},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"好！果然是杀人的刀。","tone":"惊讶","chapter":15,"line_start":546,"line_end":546},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你这是什么意思。","tone":"疑问","chapter":15,"line_start":558,"line_end":558},{"speaker":"char_ye_kai","speaker_name":"叶开","listener":"char_lv_di","text":"你既不用剑，我为何要用刀？","tone":"淡然","chapter":15,"line_start":560,"line_end":560},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你看看我的手。","tone":"陈述","chapter":15,"line_start":562,"line_end":562},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你看清了，这不是手，这是杀人的利器。","tone":"沉声","chapter":15,"line_start":576,"line_end":576},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"你知道家叔？","tone":"疑问","chapter":15,"line_start":582,"line_end":582},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"这就是他昔日练的功夫，我的运气却比他好，因为我七岁时就开始练这种功夫。","tone":"陈述","chapter":15,"line_start":588,"line_end":588},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"他练这种功夫，只因他一向不愿屈居人下。","tone":"陈述","chapter":15,"line_start":594,"line_end":594},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"百晓生作兵器谱后，家叔苦练十年，再出江湖，要以这只手，和排名在他之上的那些人争一日之短长。","tone":"陈述","chapter":15,"line_start":598,"line_end":598},{"speaker":"char_lv_di","speaker_name":"吕迪","listener":"char_ye_kai","text":"家叔也说过，这已不是手，而是杀人的利器，已可列名在兵器谱上。","tone":"陈述","chapter":15,"line_start":608,"line_end":608}],"new_entities":{"characters":[{"id":"char_lv_feng_xian","name":"吕凤先","alias":"温侯银戟","identity":"温侯银戟，吕迪之叔","faction":"none","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"温侯银戟吕凤先，三根手指成名的前辈高手。","personality":{"traits":["孤高","争强好胜","坚韧","执着","狂傲"],"speech_style":"罕见言语","temperament":"刚烈"},"relationships":[{"target":"char_lv_di","type":"亲属","intensity":80,"bond_level":4,"dynamic":"叔侄传承"}],"known_skills":["skill_tie_zhi_gong"],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":582,"line_end":608,"text":"吕凤先以三指成名，败于林仙儿"}]},{"id":"char_lin_xian_er","name":"林仙儿","alias":"林仙儿","identity":"阿飞昔日所爱，曾使吕凤先落败","faction":"none","role":"npc","archetype":"assassin","rank":"出神入化","one_line":"美丽如仙子却专引男人下地狱的女子。","personality":{"traits":["美丽","狠毒","善于操控","神秘","危险"],"speech_style":"神秘低语","temperament":"阴柔"},"relationships":[{"target":"char_lv_feng_xian","type":"宿敌","intensity":60,"bond_level":2,"dynamic":"使吕凤先落败"},{"target":"char_a_fei","type":"恋人","intensity":80,"bond_level":4,"dynamic":"已逝的旧情"}],"known_skills":[],"related_skills":[],"rag_refs":[15],"source_refs":[{"chapter":15,"line_start":604,"line_end":606,"text":"林仙儿使吕凤先败北"}]}],"skills":[{"id":"skill_tie_zhi_gong","name":"铁指功","type":"指法","faction":"none","rank":"出神入化","one_line":"以三根手指修成的近身搏击神功，坚硬如金刚不坏。","techniques":[{"id":"tech_tie_zhi_chu_jia","name":"铁指出击","type":"attack","description":"以金属般的手指贯穿对手骨肉"},{"id":"tech_tie_zhi_kang_bu","name":"铁指抗打","type":"defense","description":"金刚不坏、坚不可摧的手指抗打"}],"progression":[{"level":"出神入化","chapter":15}],"effects":["贯穿骨肉","近身绝杀","近身抗打"],"combat_style":"近身搏击","rag_refs":[15],"source_refs":[{"chapter":15,"line_start":576,"line_end":686,"text":"吕凤先、吕迪家传铁指功"}]}],"techniques":[{"id":"tech_tie_zhi_chu_jia","name":"铁指出击","type":"attack","description":"以三根手指贯穿对方骨肉的攻击方式。","source_skill":"skill_tie_zhi_gong","source_refs":[{"chapter":15,"line_start":582,"line_end":608,"text":"吕凤先三指成名的攻击"}]},{"id":"tech_tie_zhi_kang_bu","name":"铁指抗打","type":"defense","description":"吕迪的手指已接近金刚不坏，坚硬如钢锥，能以一掌断人骨。","source_skill":"skill_tie_zhi_gong","source_refs":[{"chapter":15,"line_start":572,"line_end":686,"text":"吕迪的手如金属般坚硬"}]}],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_ye_kai","updates":{"one_line":"飞刀传人叶开，以徒手与吕迪对峙。"}}]}
