{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"二位老人家受伤极重，误会既已解释开，还是少说话多养神，待伤势复原有什么话再说不迟……","tone":"陈述","chapter":26,"line_start":2,"line_end":2},{"speaker":null,"speaker_name":null,"listener":null,"text":"你以为我们两个老不死还会活吗？","tone":"疑问","chapter":26,"line_start":4,"line_end":4},{"speaker":null,"speaker_name":null,"listener":null,"text":"对呀！我爹存了很多灵药，什么千年何首乌啦，成形参王啦，灵芝仙液啦……好多好多，只要我们回家去向我爹要，便可以拿来救活两位老人家，而且，还有'诸稽神医'梁老伯也住在我家中……","tone":"陈述","chapter":26,"line_start":18,"line_end":18},{"speaker":null,"speaker_name":null,"listener":null,"text":"女娃娃，你父亲是谁？","tone":"疑问","chapter":26,"line_start":20,"line_end":20},{"speaker":null,"speaker_name":null,"listener":null,"text":"摘星手慕容涵！","tone":"陈述","chapter":26,"line_start":22,"line_end":22},{"speaker":null,"speaker_name":null,"listener":null,"text":"可是当年'江南七侠'的老三？","tone":"疑问","chapter":26,"line_start":24,"line_end":24},{"speaker":null,"speaker_name":null,"listener":null,"text":"不是他还有谁？","tone":"疑问","chapter":26,"line_start":26,"line_end":26},{"speaker":null,"speaker_name":null,"listener":null,"text":"你认识我爹？","tone":"疑问","chapter":26,"line_start":28,"line_end":28},{"speaker":null,"speaker_name":null,"listener":null,"text":"四大豪门四大公子两码事是一档子事。","tone":"陈述","chapter":26,"line_start":46,"line_end":46},{"speaker":null,"speaker_name":null,"listener":null,"text":"展云天已死在数十个武林高手围攻之下……","tone":"陈述","chapter":26,"line_start":58,"line_end":58},{"speaker":null,"speaker_name":null,"listener":null,"text":"尚请老前辈明示晚辈，杀死先父的仇人姓名，也好让晚辈为先父报仇……","tone":"陈述","chapter":26,"line_start":60,"line_end":60},{"speaker":null,"speaker_name":null,"listener":null,"text":"展云天当真死了吗？","tone":"疑问","chapter":26,"line_start":62,"line_end":62},{"speaker":null,"speaker_name":null,"listener":null,"text":"霹雳剑","tone":"陈述","chapter":26,"line_start":76,"line_end":76},{"speaker":null,"speaker_name":null,"listener":null,"text":"这话我倒相信，假如展云天活到现在，连我不一定打得过他……","tone":"陈述","chapter":26,"line_start":92,"line_end":92}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
