{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"大约不会超过百天。","tone":"陈述","chapter":26,"line_start":214,"line_end":214},{"speaker":null,"speaker_name":null,"listener":null,"text":"一言为定，来！我们三击掌吧！","tone":"陈述","chapter":26,"line_start":220,"line_end":220},{"speaker":null,"speaker_name":null,"listener":null,"text":"小伙子，随我来吧！","tone":"陈述","chapter":26,"line_start":230,"line_end":230},{"speaker":null,"speaker_name":null,"listener":null,"text":"我不要！在又黑又脏的洞里住三个月，我可不干！","tone":"陈述","chapter":26,"line_start":256,"line_end":256},{"speaker":null,"speaker_name":null,"listener":null,"text":"那么，你不要学绝世武功了？","tone":"疑问","chapter":26,"line_start":258,"line_end":258},{"speaker":null,"speaker_name":null,"listener":null,"text":"就在这石台上不也是很好吗？","tone":"疑问","chapter":26,"line_start":260,"line_end":260},{"speaker":null,"speaker_name":null,"listener":null,"text":"你愿不愿学？……","tone":"疑问","chapter":26,"line_start":270,"line_end":270},{"speaker":null,"speaker_name":null,"listener":null,"text":"我不学了！","tone":"陈述","chapter":26,"line_start":272,"line_end":272},{"speaker":null,"speaker_name":null,"listener":null,"text":"呃！呃！","tone":"陈述","chapter":26,"line_start":276,"line_end":276},{"speaker":null,"speaker_name":null,"listener":null,"text":"那么就要依我，就在这石台上……","tone":"陈述","chapter":26,"line_start":280,"line_end":280},{"speaker":null,"speaker_name":null,"listener":null,"text":"噗哧！","tone":"陈述","chapter":26,"line_start":296,"line_end":296},{"speaker":null,"speaker_name":null,"listener":null,"text":"这个洞还比不上先前找到的那两个，而且，洞口风这样大，说不定是个漏底洞，我看……","tone":"陈述","chapter":26,"line_start":298,"line_end":298}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
