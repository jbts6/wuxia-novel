    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "尔是何人门下……",
      "tone": "陈述",
      "chapter": 38,
      "line_start": 62,
      "line_end": 62
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "完了……",
      "tone": "陈述",
      "chapter": 38,
      "line_start": 66,
      "line_end": 66
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "红姑，那青脸红发之人，要活不要死，其余之人，可以格杀勿论……",
      "tone": "陈述",
      "chapter": 38,
      "line_start": 78,
