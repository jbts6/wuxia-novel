{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"好极，好极，想不到非但我的房间，我自己不能安排，竟连我的手下，都要劳动你来替我教训了，好，好——","tone":"陈述","chapter":6,"line_start":8,"line_end":8},{"speaker":null,"speaker_name":null,"listener":null,"text":"凌风公子","tone":"陈述","chapter":6,"line_start":26,"line_end":26},{"speaker":null,"speaker_name":null,"listener":null,"text":"你晕过去了好多天，此刻身子一定虚弱得很，等一会我叫人送些东西来——","tone":"陈述","chapter":6,"line_start":64,"line_end":64}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"他不由暗","tone":"陈述","chapter":6,"line_start":106,"line_end":106},{"speaker":null,"speaker_name":null,"listener":null,"text":"展白呆呆地望着这少女，心里更加迷惑，他不用费心思索，便知道自己和这少女根本连面都未见过，但这少女此刻对自己说起话来，却像是多年知交似的，既关怀又亲热，","tone":"陈述","chapter":6,"line_start":134,"line_end":134},{"speaker":null,"speaker_name":null,"listener":null,"text":"真的有恩于在下，真的，在下……","tone":"陈述","chapter":6,"line_start":148,"line_end":148},{"speaker":null,"speaker_name":null,"listener":null,"text":"玉手轻抬，一只春葱般的手指，笔直地指到展白面前：","tone":"陈述","chapter":6,"line_start":150,"line_end":150},{"speaker":null,"speaker_name":null,"listener":null,"text":"如此说来，刚才那黑衣少女，便是受她所托了……","tone":"陈述","chapter":6,"line_start":154,"line_end":154},{"speaker":null,"speaker_name":null,"listener":null,"text":"武林四公子","tone":"陈述","chapter":6,"line_start":158,"line_end":158},{"speaker":null,"speaker_name":null,"listener":null,"text":"但是，我该如何来回答她的话呢？","tone":"疑问","chapter":6,"line_start":164,"line_end":164},{"speaker":null,"speaker_name":null,"listener":null,"text":"你听到我说的话没有？","tone":"疑问","chapter":6,"line_start":184,"line_end":184},{"speaker":null,"speaker_name":null,"listener":null,"text":"你怕不怕他？","tone":"疑问","chapter":6,"line_start":194,"line_end":194},{"speaker":null,"speaker_name":null,"listener":null,"text":"他是谁？我为什么要怕他？","tone":"疑问","chapter":6,"line_start":196,"line_end":196}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"她语声微顿，又道：","tone":"陈述","chapter":6,"line_start":202,"line_end":202},{"speaker":null,"speaker_name":null,"listener":null,"text":"三翅粉蝶","tone":"陈述","chapter":6,"line_start":218,"line_end":218},{"speaker":null,"speaker_name":null,"listener":null,"text":"噗嗤","tone":"陈述","chapter":6,"line_start":222,"line_end":222},{"speaker":null,"speaker_name":null,"listener":null,"text":"真奇怪，自从妈妈把你带回来那天，我第一眼看见你，就喜欢……","tone":"陈述","chapter":6,"line_start":224,"line_end":224},{"speaker":null,"speaker_name":null,"listener":null,"text":"令堂大人，高贵慈祥，有她慈航普渡，她老人家对我的恩情，实在使我铭感，姑娘如不见怪的话，不知可否将她老人家的名讳告诉我，也让我……","tone":"陈述","chapter":6,"line_start":254,"line_end":254},{"speaker":null,"speaker_name":null,"listener":null,"text":"姑娘想必也是姓慕容了。","tone":"陈述","chapter":6,"line_start":266,"line_end":266},{"speaker":null,"speaker_name":null,"listener":null,"text":"如此我当然猜不出了。","tone":"陈述","chapter":6,"line_start":272,"line_end":272},{"speaker":null,"speaker_name":null,"listener":null,"text":"原来那位夫人与我竟是同姓。","tone":"陈述","chapter":6,"line_start":274,"line_end":274},{"speaker":null,"speaker_name":null,"listener":null,"text":"太太。","tone":"陈述","chapter":6,"line_start":286,"line_end":286}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
