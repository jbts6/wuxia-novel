{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"此乃先父遗物，老前辈请恕晚辈不能","tone":"陈述","chapter":4,"line_start":10,"line_end":10},{"speaker":null,"speaker_name":null,"listener":null,"text":"你是给还是不给?","tone":"疑问","chapter":4,"line_start":12,"line_end":12},{"speaker":null,"speaker_name":null,"listener":null,"text":"怎的我今日遇着的尽是这些不可理解之事，不可理喻之人?","tone":"疑问","chapter":4,"line_start":16,"line_end":16},{"speaker":null,"speaker_name":null,"listener":null,"text":"晚辈有事，恕不奉陪了!","tone":"陈述","chapter":4,"line_start":20,"line_end":20},{"speaker":null,"speaker_name":null,"listener":null,"text":"娃娃，你想跑?你不问问，有谁逃得过我费一童的!","tone":"疑问","chapter":4,"line_start":22,"line_end":22},{"speaker":null,"speaker_name":null,"listener":null,"text":"费一童","tone":"陈述","chapter":4,"line_start":24,"line_end":24},{"speaker":null,"speaker_name":null,"listener":null,"text":"费一童","tone":"陈述","chapter":4,"line_start":26,"line_end":26},{"speaker":null,"speaker_name":null,"listener":null,"text":"费一童目光一凛，望着地上的影子，缓缓扬起手掌来，展白心中自暗喜，哪知这","tone":"陈述","chapter":4,"line_start":30,"line_end":30},{"speaker":null,"speaker_name":null,"listener":null,"text":"辣手童心","tone":"陈述","chapter":4,"line_start":38,"line_end":38},{"speaker":null,"speaker_name":null,"listener":null,"text":"辣手童心","tone":"陈述","chapter":4,"line_start":42,"line_end":42},{"speaker":null,"speaker_name":null,"listener":null,"text":"辣手童心","tone":"陈述","chapter":4,"line_start":44,"line_end":44},{"speaker":null,"speaker_name":null,"listener":null,"text":"扑","tone":"陈述","chapter":4,"line_start":50,"line_end":50},{"speaker":null,"speaker_name":null,"listener":null,"text":"辣手童心","tone":"陈述","chapter":4,"line_start":56,"line_end":56},{"speaker":null,"speaker_name":null,"listener":null,"text":"死人提","tone":"陈述","chapter":4,"line_start":60,"line_end":60},{"speaker":null,"speaker_name":null,"listener":null,"text":"展白呀展白，你这还算得什么男子汉，遇着一点困难，便畏首畏尾起来，将来还能成什么大事?不如死了算了!","tone":"疑问","chapter":4,"line_start":64,"line_end":64},{"speaker":null,"speaker_name":null,"listener":null,"text":"噗","tone":"陈述","chapter":4,"line_start":72,"line_end":72},{"speaker":null,"speaker_name":null,"listener":null,"text":"燕云五霸天","tone":"陈述","chapter":4,"line_start":82,"line_end":82},{"speaker":null,"speaker_name":null,"listener":null,"text":"朝露晨风，如此之重，你睡在这里，也不怕着了凉吗?","tone":"疑问","chapter":4,"line_start":92,"line_end":92}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"我……我没有家!","tone":"陈述","chapter":4,"line_start":112,"line_end":112},{"speaker":null,"speaker_name":null,"listener":null,"text":"我一生之中，从没有见过像夫人这样的好人，所以忍不住——","tone":"陈述","chapter":4,"line_start":114,"line_end":114},{"speaker":null,"speaker_name":null,"listener":null,"text":"其实生命有什么值得珍惜的，我若不是还有父仇未报，就算立刻死了也不可惜，只是我连杀父仇人是谁都不知道，父亲的遗物也被我弄掉了!","tone":"陈述","chapter":4,"line_start":122,"line_end":122},{"speaker":null,"speaker_name":null,"listener":null,"text":"你年纪还轻，但言词之中，却怎的像是有着许多悲怆难解之事?唉!你们少年人总是这样，还未识得愁滋味，就已如此忧郁了，等到你像我这样的年纪，心里就是有忧愁烦闷之事，也不会说出来了，唉!欲说还休，却道天凉好个秋!唉，少年人，还不笑一笑?大好生命，黛绿年华，都在等着你去好好享受哩!","tone":"疑问","chapter":4,"line_start":124,"line_end":124},{"speaker":null,"speaker_name":null,"listener":null,"text":"这位妇人衣衫丽都，风姿华贵，显见不是达官贵人家眷，便是巨商富贾妻室，正是极有福气之人，怎地却有着如许烦恼?","tone":"疑问","chapter":4,"line_start":126,"line_end":126},{"speaker":null,"speaker_name":null,"listener":null,"text":"她和我素昧生平，就已如此对我，想见她平日必是极为慈祥的好人，她若真是烦恼，我岂能不为她解决?","tone":"疑问","chapter":4,"line_start":128,"line_end":128},{"speaker":null,"speaker_name":null,"listener":null,"text":"我与你素不相识，你为什么要帮我的忙呢?","tone":"疑问","chapter":4,"line_start":134,"line_end":134},{"speaker":null,"speaker_name":null,"listener":null,"text":"唉，傻孩子，我只是乘车经过这里，看到你睡在朝露之下，怕你着了凉，是以便下车招呼你一声，这又有什么了不起?我若真有什么困难之事，要你去做，那你岂不是太呆了些吗?","tone":"疑问","chapter":4,"line_start":142,"line_end":142},{"speaker":null,"speaker_name":null,"listener":null,"text":"我不会说话，心里想着的事，常常无法说出来!","tone":"陈述","chapter":4,"line_start":144,"line_end":144},{"speaker":null,"speaker_name":null,"listener":null,"text":"……大好生命，黛绿年华，都在等着你去享受……生命中一些美好之事，是要自己去创造的……","tone":"陈述","chapter":4,"line_start":150,"line_end":150},{"speaker":null,"speaker_name":null,"listener":null,"text":"这些人看来似要加害于我，但我却一个也不认得，天下事怎的如此奇怪，总是要让我遇着些无谓的烦恼!","tone":"陈述","chapter":4,"line_start":160,"line_end":160},{"speaker":null,"speaker_name":null,"listener":null,"text":"霸王卸甲","tone":"陈述","chapter":4,"line_start":162,"line_end":162},{"speaker":null,"speaker_name":null,"listener":null,"text":"我和你们又有何冤何仇?你们怎的什么话不说，就要我的命?","tone":"疑问","chapter":4,"line_start":168,"line_end":168},{"speaker":null,"speaker_name":null,"listener":null,"text":"砰","tone":"陈述","chapter":4,"line_start":170,"line_end":170},{"speaker":null,"speaker_name":"大汉","listener":null,"text":"南拳北腿","tone":"陈述","chapter":4,"line_start":172,"line_end":172},{"speaker":null,"speaker_name":null,"listener":null,"text":"陈清、陈平，你们还不给我住手!","tone":"陈述","chapter":4,"line_start":190,"line_end":190},{"speaker":null,"speaker_name":null,"listener":null,"text":"小伙子你再敢对我们夫人……","tone":"陈述","chapter":4,"line_start":192,"line_end":192},{"speaker":null,"speaker_name":null,"listener":null,"text":"啪","tone":"陈述","chapter":4,"line_start":194,"line_end":194},{"speaker":null,"speaker_name":null,"listener":null,"text":"你们近来也越来越不像话了，动不动就要杀人，这少年才和青少爷一样大，算老爷子亲眼看见我和他说话，也不会怎的，你们这些狗仗人势的奴才，却来多什么事?若不是我一发现你们不在就赶了来，人家年纪轻轻，岂非要被你们伤了性命?","tone":"疑问","chapter":4,"line_start":198,"line_end":198},{"speaker":null,"speaker_name":null,"listener":null,"text":"还不远远地滚开去!","tone":"陈述","chapter":4,"line_start":200,"line_end":200}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":249,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"惭愧","tone":"陈述","chapter":4,"line_start":204,"line_end":204},{"speaker":null,"speaker_name":null,"listener":null,"text":"多谢夫人搭救，不然……","tone":"陈述","chapter":4,"line_start":210,"line_end":210},{"speaker":null,"speaker_name":null,"listener":null,"text":"哎哟","tone":"陈述","chapter":4,"line_start":212,"line_end":212},{"speaker":null,"speaker_name":null,"listener":null,"text":"你们年轻人真是……你知不知道你自己有病了?","tone":"疑问","chapter":4,"line_start":214,"line_end":214},{"speaker":null,"speaker_name":null,"listener":null,"text":"方才我还没有看出来，但觉就算你身子是好好的，在这凌晨露重的时候睡在这里，已是极为不妥，现在……唉!要是风寒入骨，内外交侵，那……","tone":"陈述","chapter":4,"line_start":216,"line_end":216},{"speaker":null,"speaker_name":null,"listener":null,"text":"那中年美妇轻轻摇了摇头，道：","tone":"陈述","chapter":4,"line_start":230,"line_end":230},{"speaker":null,"speaker_name":null,"listener":null,"text":"难道我真的伤得不轻……","tone":"陈述","chapter":4,"line_start":234,"line_end":234},{"speaker":null,"speaker_name":null,"listener":null,"text":"我一时大意，不知道那些蠢汉竟是如此无聊，害得你受了伤，唉……我虽然知道你不会怪我，但我心里还是难受得很，这粒药丸我保存了许多年，对你也许有些用，你拿去吃了吧!","tone":"陈述","chapter":4,"line_start":242,"line_end":242},{"speaker":null,"speaker_name":null,"listener":null,"text":"心胸之中，悲怆不已!热血翻涌，但觉眼前这粒赤红丹丸，越滚越快，竟变得一片赤红，像是有一团火，在自己四周燃烧着，","tone":"陈述","chapter":4,"line_start":246,"line_end":246}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
