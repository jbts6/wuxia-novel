{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"此语当真？","tone":"疑问","chapter":35,"line_start":122,"line_end":122},{"speaker":null,"speaker_name":"少女","listener":null,"text":"怎么？你害怕了吗？","tone":"疑问","chapter":35,"line_start":124,"line_end":124},{"speaker":null,"speaker_name":null,"listener":null,"text":"你真好……","tone":"陈述","chapter":35,"line_start":142,"line_end":142},{"speaker":null,"speaker_name":null,"listener":null,"text":"呀！","tone":"陈述","chapter":35,"line_start":144,"line_end":144},{"speaker":null,"speaker_name":null,"listener":null,"text":"'银扇子'柳崇厚，我叫翠翠。","tone":"陈述","chapter":35,"line_start":168,"line_end":168},{"speaker":null,"speaker_name":"少女","listener":null,"text":"当年'江南七侠'的老七。","tone":"陈述","chapter":35,"line_start":170,"line_end":170},{"speaker":null,"speaker_name":null,"listener":null,"text":"正是。","tone":"陈述","chapter":35,"line_start":172,"line_end":172}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":275,"dialogues":[{"speaker":null,"speaker_name":null,"listener":null,"text":"莫非是你？","tone":"疑问","chapter":35,"line_start":206,"line_end":206},{"speaker":null,"speaker_name":null,"listener":null,"text":"难道你的父亲远在海外，也被他们所害？","tone":"疑问","chapter":35,"line_start":212,"line_end":212},{"speaker":null,"speaker_name":null,"listener":null,"text":"看来我们上一代的人被害详情，你不大知道，这是父亲告诉我的，当初你父亲加上当今四大豪门与镇江樊非，原是结义金兰，号称'江南七侠'……","tone":"陈述","chapter":35,"line_start":214,"line_end":214},{"speaker":null,"speaker_name":null,"listener":null,"text":"这个我知道。","tone":"陈述","chapter":35,"line_start":216,"line_end":216},{"speaker":null,"speaker_name":null,"listener":null,"text":"你知道，我就不必说了。","tone":"陈述","chapter":35,"line_start":218,"line_end":218},{"speaker":null,"speaker_name":null,"listener":null,"text":"那就别打岔。","tone":"陈述","chapter":35,"line_start":224,"line_end":224},{"speaker":null,"speaker_name":null,"listener":null,"text":"江南七侠","tone":"陈述","chapter":35,"line_start":232,"line_end":232},{"speaker":null,"speaker_name":null,"listener":null,"text":"避水玉璧","tone":"陈述","chapter":35,"line_start":238,"line_end":238},{"speaker":null,"speaker_name":null,"listener":null,"text":"青蚨神","tone":"陈述","chapter":35,"line_start":240,"line_end":240},{"speaker":null,"speaker_name":null,"listener":null,"text":"银扇子","tone":"陈述","chapter":35,"line_start":242,"line_end":242},{"speaker":null,"speaker_name":null,"listener":null,"text":"还有一件，我至今不明白，父亲临死之前，除了交给我这一柄","tone":"陈述","chapter":35,"line_start":252,"line_end":252},{"speaker":null,"speaker_name":null,"listener":null,"text":"你不知道，我却知道。","tone":"陈述","chapter":35,"line_start":262,"line_end":262},{"speaker":null,"speaker_name":null,"listener":null,"text":"我早就看着像。","tone":"陈述","chapter":35,"line_start":268,"line_end":268},{"speaker":null,"speaker_name":null,"listener":null,"text":"这一粒钢珠，是'霸王鞭'樊非的绝门暗器，名为'弹指银丸'，这一枚青铜钮扣是'混元指'司空晋的，这一段丝绦是'乾坤掌'云宗龙的，而且还拿来绑过我，至于这一团乱发，却是我头上的……","tone":"陈述","chapter":35,"line_start":270,"line_end":270}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
