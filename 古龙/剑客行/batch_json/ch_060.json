      "tone": "陈述",
      "chapter": 60,
      "line_start": 54,
      "line_end": 54
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "千里传音",
      "tone": "陈述",
      "chapter": 60,
      "line_start": 56,
      "line_end": 56
    },
    {
      "speaker": null,
      "speaker_name": null,
