      "line_start": 492,
      "line_end": 492
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "我的孩子……",
      "tone": "陈述",
      "chapter": 60,
      "line_start": 502,
      "line_end": 502
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "剑虽无情，却斩不断柔丝万种。",
      "tone": "陈述",
      "chapter": 60,
      "line_start": 518,
      "line_end": 518
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "随你们的便吧。",
      "tone": "陈述",
      "chapter": 60,
      "line_start": 520,
      "line_end": 520
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "小恩公！……",
      "tone": "陈述",
      "chapter": 60,
      "line_start": 524,
      "line_end": 524
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "可惜，小弟已吃斋了。",
      "tone": "陈述",
      "chapter": 60,
      "line_start": 534,
      "line_end": 534
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
