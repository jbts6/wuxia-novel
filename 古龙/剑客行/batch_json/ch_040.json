    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "老鬼！你以为章兄还会跟你说谎吗？",
      "tone": "疑问",
      "chapter": 40,
      "line_start": 456,
      "line_end": 456
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
