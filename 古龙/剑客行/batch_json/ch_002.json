    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "他又强笑了一声，接着往下说道：",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 250,
      "line_end": 250
    },
    {
