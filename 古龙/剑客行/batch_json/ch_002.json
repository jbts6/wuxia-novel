      "text": "追风无影",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 284,
      "line_end": 284
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "不说又怎地？快还剑来！",
      "tone": "疑问",
