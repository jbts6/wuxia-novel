      "line_end": 254
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "咔嚓",
      "tone": "陈述",
      "chapter": 2,
      "line_start": 258,
      "line_end": 258
    },
    {
      "speaker": null,
      "speaker_name": null,
      "listener": null,
      "text": "摩云神手",
      "tone": "陈述",
