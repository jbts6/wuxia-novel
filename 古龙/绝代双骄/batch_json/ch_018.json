      "tone": "恐惧",
      "chapter": 18,
      "line_start": 28,
      "line_end": 28
    },
    {
      "speaker": "char_mu_rong_jiu_mei",
      "speaker_name": "九姐娘",
      "listener": "char_bi_she_shen_jun",
      "text": "现在你知道了么？",
