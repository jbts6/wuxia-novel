{"segment":2,"line_start":101,"line_end":194,"dialogues":[{"speaker":"char_xiao_nu_shi","speaker_name":"萧女史","listener":"char_tie_zhan","text":"你也莫要太笃定了，我看那小鱼儿并不是好对付的人，何况，他还有燕南天在后面支持他。","tone":"轻笑","chapter":125,"line_start":104,"line_end":104},{"speaker":"char_tie_zhan","speaker_name":"铁战","listener":"char_xiao_nu_shi","text":"那有个屁用，燕南天又不能替他动手的。他就算再聪明，但李大嘴、屠娇娇那几个调教出来的徒弟，强也强得有限。","tone":"冷笑","chapter":125,"line_start":106,"line_end":106},{"speaker":"char_xiao_nu_shi","speaker_name":"萧女史","listener":"char_tie_zhan","text":"哦？我还以为他是燕南天的徒弟哩，早知他武功只不过是你那些恶朋友教出来的，这一战我连看都懒得看了。","tone":"嘲讽","chapter":125,"line_start":108,"line_end":108},{"speaker":"char_yan_nan_tian","speaker_name":"燕南天","listener":"char_xiao_yu_er","text":"时候已到了，你去吧！","tone":"严肃","chapter":125,"line_start":110,"line_end":110},{"speaker":"char_hua_wu_que","speaker_name":"花无缺","listener":"char_yao_yue_gong_zhu","text":"师父还有什么吩咐？","tone":"陈述","chapter":125,"line_start":114,"line_end":114},{"speaker":"char_yao_yue_gong_zhu","speaker_name":"邀月宫主","listener":"char_hua_wu_que","text":"没有了，你去吧，我知道你绝不会令我失望的。","tone":"淡然","chapter":125,"line_start":116,"line_end":116},{"speaker":"char_tie_xin_lan","speaker_name":"铁心兰","listener":null,"text":"我也一定不会辜负你的，你放心吧！","tone":"悲伤","chapter":125,"line_start":192,"line_end":192}],"new_entities":{},"entity_updates":[{"id":"char_hua_wu_que","updates":{"source_refs":[{"chapter":125,"line_start":114,"line_end":114,"text":"花无缺也站了起来"}]},"relationship_updates":[{"action":"update","target":"char_tie_xin_lan","type":"恋人","intensity":90,"bond_level":5,"dynamic":"甘愿为她牺牲"}]}]}
