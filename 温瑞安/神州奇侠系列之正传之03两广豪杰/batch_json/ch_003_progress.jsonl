{"segment":1,"line_start":1,"line_end":20,"dialogues":[{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"屈兄请了。","tone":"陈述","chapter":3,"line_start":5,"line_end":5},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_gu_jun_shan","text":"顾兄请说。","tone":"陈述","chapter":3,"line_start":9,"line_end":9},{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"今日我等来贵亭叨扰，又先行出手，无疑是破坏了屈兄清规，真是罪过。","tone":"无奈","chapter":3,"line_start":13,"line_end":14},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_gu_jun_shan","text":"顾兄为人，弟甚敬重，虽未深交，却为相知，顾兄不必多虑。","tone":"微笑","chapter":3,"line_start":19,"line_end":19}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_yi_gong_ting","name":"一公亭","region":"广西阳朔","one_line":"屈寒山的亭子，广西武林人物聚会之地","source_refs":[{"chapter":3,"line_start":1,"line_end":1,"text":"屈寒山出面调停"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":21,"line_end":38,"dialogues":[{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"屈兄豪侠，弟深感佩；屈兄与五羊城梁斗梁大侠，合称'东西二侠'，但在广西境内，人道是'广西三山'，屈兄当知指的是什么？","tone":"陈述","chapter":3,"line_start":24,"line_end":26},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_gu_jun_shan","text":"若指名山，则是指柳象山、大明山与大容山，若指闻人，则指君山兄，檬江杜月山兄，以及兄弟我。","tone":"淡然","chapter":3,"line_start":30,"line_end":32},{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"正是，虽然月山兄已失踪，但我们之所以能受武林人中同称道为'三山'，除我们的名号恰好都有'山'字外，更重要的是我们不作伪，不行诈，敢急人之难，仗人之义。","tone":"认真","chapter":3,"line_start":34,"line_end":34}],"new_entities":{"characters":[{"id":"char_gu_jun_shan","name":"顾君山","alias":["广西三山之一"],"identity":"广西武林名宿，四绝一君之首","faction":"faction_si_jue_yi_jun","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"广西三山之一，为人正直豪侠，与屈寒山、杜月山齐名","personality":{"traits":["正直","豪侠","重义","刚烈","悲愤"],"speech_style":"豪迈直率，侠义之气","temperament":"刚烈悲壮"},"relationships":[{"target":"char_qu_han_shan","type":"对手","intensity":70,"bond_level":3,"dynamic":"同列三山但互不深交"},{"target":"char_bi_tian_tong","type":"挚友","intensity":90,"bond_level":5,"dynamic":"同生共死十余年"},{"target":"char_yao_du_wu","type":"挚友","intensity":90,"bond_level":5,"dynamic":"同生共死十余年"},{"target":"char_huang_yuan_yong","type":"挚友","intensity":90,"bond_level":5,"dynamic":"同生共死十余年"},{"target":"char_wen_bin_shuang","type":"挚友","intensity":90,"bond_level":5,"dynamic":"四绝一君兄弟"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":3,"line_end":3,"text":"顾君山冷冷脱了江易海一眼，即向屈寒山拱手道"}]},{"id":"char_qu_han_shan","name":"屈寒山","alias":["威震阳朔"],"identity":"权力帮八大天王之一剑王，伪装为广西三山之一","faction":"faction_quan_li_bang","role":"villain","archetype":"assassin","rank":"登峰造极","one_line":"伪装为广西名宿的权力帮剑王，阴险狡诈","personality":{"traits":["阴险","狡诈","深沉","伪善","冷酷"],"speech_style":"温文尔雅，笑里藏刀","temperament":"深沉阴鸷"},"relationships":[{"target":"char_gu_jun_shan","type":"宿敌","intensity":80,"bond_level":2,"dynamic":"伪装同列三山，实为敌人"},{"target":"char_yu_ku_yu","type":"同僚","intensity":60,"bond_level":3,"dynamic":"同为权力帮天王"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":8,"line_end":8,"text":"屈寒山忙欠身道"}]},{"id":"char_du_yue_shan","name":"杜月山","alias":["檬江"],"identity":"广西三山之一，已失踪","faction":null,"role":"npc","archetype":"warrior","rank":"出神入化","one_line":"广西三山之一，檬江人，已失踪","personality":{"traits":["正直","豪侠","神秘","忠义","刚强"],"speech_style":"未知","temperament":"神秘"},"relationships":[{"target":"char_gu_jun_shan","type":"挚友","intensity":70,"bond_level":4,"dynamic":"同列三山"},{"target":"char_qu_han_shan","type":"挚友","intensity":70,"bond_level":4,"dynamic":"同列三山"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":31,"line_end":31,"text":"檬江杜月山兄"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_si_jue_yi_jun","name":"四绝一君","type":"武林门派","location":"广西阳朔","sub_divisions":[],"one_line":"广西武林四位绝顶高手和一位君主的联盟","source_refs":[{"chapter":3,"line_start":1,"line_end":1,"text":"四绝一君指责康出渔"}]}],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":39,"line_end":55,"dialogues":[{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"今日我之所以斗胆借兄之雅地剪除贼党，一方面乃敬重'一公亭'之正义，一方面亦表达对屈大侠之崇敬。","tone":"认真","chapter":3,"line_start":40,"line_end":40},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_gu_jun_shan","text":"何敬之有？顾兄更为一代人杰风范……只是，顾兄可知不会杀错？","tone":"疑问","chapter":3,"line_start":44,"line_end":44},{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"绝不会。近三个月来，我们一直在调查追查这几人的行踪，我可以断言的是：康出渔就是权力帮中'几天十地，十九人魔'中的'无名入魔'，柳千变就是'无影神魔'，屠滚就是'千手神魔'，彭九则是'独脚神魔'，只剩下这江易海，亦是权力帮的人，身份地位尚未清楚而已，绝不会有杀错。","tone":"严肃","chapter":3,"line_start":48,"line_end":49}],"new_entities":{"characters":[{"id":"char_kang_chu_yu","name":"康出渔","alias":["无名入魔","观日神剑"],"identity":"权力帮十九人魔之一，伪装为武林七大名剑","faction":"faction_quan_li_bang","role":"villain","archetype":"warrior","rank":"出神入化","one_line":"权力帮'无名入魔'，观日神剑，名列武林七大名剑","personality":{"traits":["阴险","伪善","凶狠","老练","虚伪"],"speech_style":"表面上温文，实际阴狠","temperament":"阴险狡诈"},"relationships":[{"target":"char_qu_han_shan","type":"同僚","intensity":60,"bond_level":3,"dynamic":"同为权力帮成员"},{"target":"char_xiao_qiu_shui","type":"宿敌","intensity":80,"bond_level":1,"dynamic":"生死仇敌"}],"known_skills":["skill_guan_ri_jian"],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":48,"line_end":48,"text":"康出渔就是权力帮中'几天十地，十九人魔'中的'无名入魔'"}]},{"id":"char_liu_qian_bian","name":"柳千变","alias":["无影神魔"],"identity":"权力帮十九人魔之一","faction":"faction_quan_li_bang","role":"villain","archetype":"assassin","rank":"出神入化","one_line":"权力帮'无影神魔'，身法多变，擅长地马行天","personality":{"traits":["狡猾","多变","阴险","狠毒","老练"],"speech_style":"阴沉","temperament":"阴险"},"relationships":[{"target":"char_qu_han_shan","type":"同僚","intensity":60,"bond_level":3,"dynamic":"同为权力帮成员"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":48,"line_end":48,"text":"柳千变就是'无影神魔'"}]},{"id":"char_tu_gun","name":"屠滚","alias":["千手神魔","千手人魔"],"identity":"权力帮十九人魔之一","faction":"faction_quan_li_bang","role":"villain","archetype":"assassin","rank":"出神入化","one_line":"权力帮'千手神魔'，暗器高手，身法奇特会滚地","personality":{"traits":["阴狠","狂妄","残忍","狡猾","自大"],"speech_style":"阴森","temperament":"阴狠"},"relationships":[{"target":"char_qu_han_shan","type":"同僚","intensity":60,"bond_level":3,"dynamic":"同为权力帮成员"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":48,"line_end":48,"text":"屠滚就是'千手神魔'"}]},{"id":"char_peng_jiu","name":"彭九","alias":["独脚神魔"],"identity":"权力帮十九人魔之一","faction":"faction_quan_li_bang","role":"villain","archetype":"warrior","rank":"出神入化","one_line":"权力帮'独脚神魔'，独腿，镔铁杖重九十三斤","personality":{"traits":["凶猛","刚硬","狂傲","老练","凶悍"],"speech_style":"粗豪","temperament":"凶悍"},"relationships":[{"target":"char_qu_han_shan","type":"同僚","intensity":60,"bond_level":3,"dynamic":"同为权力帮成员"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":48,"line_end":48,"text":"彭九则是'独脚神魔'"}]},{"id":"char_jiang_yi_hai","name":"江易海","alias":["九指擒龙"],"identity":"权力帮成员，身份地位尚未清楚","faction":"faction_quan_li_bang","role":"villain","archetype":"warrior","rank":"炉火纯青","one_line":"权力帮成员，九指擒龙，擒拿手高手","personality":{"traits":["谨慎","犹豫","胆怯","狡猾","老练"],"speech_style":"阴沉","temperament":"谨慎胆怯"},"relationships":[{"target":"char_qu_han_shan","type":"同僚","intensity":50,"bond_level":2,"dynamic":"权力帮成员"}],"known_skills":[],"related_skills":[],"rag_refs":[3],"source_refs":[{"chapter":3,"line_start":48,"line_end":48,"text":"只剩下这江易海，亦是权力帮的人"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_quan_li_bang","name":"权力帮","type":"帮派","location":"武林各地","sub_divisions":["十九人魔","八大天王"],"one_line":"武林中最大的邪恶势力，组织庞大，高手如云","source_refs":[{"chapter":3,"line_start":48,"line_end":48,"text":"权力帮中'几天十地，十九人魔'"}]}],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":56,"line_end":74,"dialogues":[{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_jiang_yi_hai","text":"没有杀错，那就好了。","tone":"淡然","chapter":3,"line_start":62,"line_end":62},{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"绝不会杀错的，可惜我们还未找出他们在武林中的联络人，以及那手段残毒的'瘟疫人魔'余哭余，否则一并杀了！","tone":"激动","chapter":3,"line_start":64,"line_end":64},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":null,"text":"一并杀了，正是人生一快！","tone":"豪迈","chapter":3,"line_start":68,"line_end":68},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_jiang_yi_hai","text":"你就认命吧！","tone":"冷笑","chapter":3,"line_start":74,"line_end":74}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
