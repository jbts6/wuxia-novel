{"segment":7,"line_start":131,"line_end":158,"dialogues":[{"speaker":"char_yu_ku_yu","speaker_name":"余哭余","listener":"char_qu_han_shan","text":"屈剑王圣福。","tone":"陈述","chapter":3,"line_start":136,"line_end":136},{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"你……你究竟是谁？！","tone":"愤怒","chapter":3,"line_start":152,"line_end":152},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_gu_jun_shan","text":"顾兄，实不相瞒，小弟就是权力帮中'八大天王'中的'剑王'。","tone":"无奈","chapter":3,"line_start":156,"line_end":157}],"new_entities":{"characters":[],"skills":[{"id":"skill_quan_li_bang_zu_zhi","name":"权力帮组织","type":"特殊","faction":"faction_quan_li_bang","rank":"登峰造极","one_line":"权力帮的组织体系，包括八大天王和十九人魔","techniques":[{"id":"tech_ba_da_tian_wang","name":"八大天王","type":"special","description":"权力帮最高战力，八位天王各镇一方"},{"id":"tech_shi_jiu_ren_mo","name":"十九人魔","type":"special","description":"权力帮十九位人魔，执行各种任务"}],"progression":"已完成","effects":["控制","增益"],"combat_style":"组织作战","rag_refs":[3],"source_refs":[{"chapter":3,"line_start":156,"line_end":157,"text":"权力帮中'八大天王'中的'剑王'"}]}],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":8,"line_start":159,"line_end":185,"dialogues":[{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"好，好，我追查这一干人，居然就没想到你，还借你的地方来……我竟然与你同列'广西三山'！","tone":"苦笑","chapter":3,"line_start":160,"line_end":160},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_gu_jun_shan","text":"顾兄何需如此悲观……权力帮要用的是人才。","tone":"微笑","chapter":3,"line_start":164,"line_end":166},{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_qu_han_shan","text":"屈兄真是风趣，先杀我三名兄弟，再来说这话……","tone":"冷笑","chapter":3,"line_start":168,"line_end":168},{"speaker":"char_gu_jun_shan","speaker_name":"顾君山","listener":"char_wen_bin_shuang","text":"我困住他，你走！","tone":"焦急","chapter":3,"line_start":170,"line_end":170},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_gu_jun_shan","text":"这又何苦……","tone":"无奈","chapter":3,"line_start":174,"line_end":174},{"speaker":"char_qu_han_shan","speaker_name":"屈寒山","listener":"char_gu_jun_shan","text":"顾兄又何必太固执呢","tone":"微笑","chapter":3,"line_start":180,"line_end":180}],"new_entities":{"characters":[],"skills":[{"id":"skill_qu_han_shan_jian","name":"屈寒山剑法","type":"剑法","faction":"faction_quan_li_bang","rank":"登峰造极","one_line":"屈寒山的绝世剑法，凡铁在手亦可发挥极致","techniques":[{"id":"tech_fan_jian_jue_sha","name":"凡剑绝杀","type":"attack","description":"用平凡铁剑施展的致命剑法，杀过人即弃剑"},{"id":"tech_duo_jian_bian","name":"夺剑变式","type":"feint","description":"剑在空中改变角度、高低、劲道、方向的诡异身法"}],"progression":"登峰造极","effects":["伤害"],"combat_style":"诡异多变，笑里藏刀","rag_refs":[3],"source_refs":[{"chapter":3,"line_start":180,"line_end":180,"text":"一面腾、挪、闪、避，一面笑道"}]}],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
