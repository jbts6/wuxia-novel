{
  "chapter": 16,
  "title": "第十六回　仗势欺人　膏粱劫美　佯狂玩世　侠士惩凶",
  "total_lines": 947,
  "dialogues_raw": [
    {"line": 84, "speaker_raw": "楚天虹", "verb": "道", "text": "反正已经有哥哥替我服侍爹爹了，我乐得松一口气。不过，徐姐姐，你却又是因何不愿到镖局去呢？"},
    {"line": 86, "speaker_raw": "徐锦瑶", "verb": "道", "text": "镖局里人多嘴杂，不是谈话的好地方。嗯，楚姐姐，我有麻烦的事情，却找不到人商量，只好不辞冒昧，交浅言深了。"},
    {"line": 92, "speaker_raw": "徐锦瑶", "verb": "道", "text": "这固然是我的麻烦事情，但和你也有关系的。妹子，你是聪明人，想必也能猜到几分了？"},
    {"line": 98, "speaker_raw": "徐锦瑶", "verb": "道", "text": "正是。穆志遥那两个宝贝儿子调戏咱们，我气愤不过，回去就告诉爹爹，哪知，哪知，当真是爹爹，有，有……"},
    {"line": 100, "speaker_raw": "楚天虹", "verb": "道", "text": "是你爹有意把你许配给穆家的大少爷的？"},
    {"line": 112, "speaker_raw": "徐锦瑶", "verb": "道", "text": "你还取笑我呢，我若不是假意答允他，我焉能跑来会你？"},
    {"line": 114, "speaker_raw": "楚天虹", "verb": "道", "text": "但若给你爹知道，你就做不成孝顺的女儿了。"},
    {"line": 120, "speaker_raw": "楚天虹", "verb": "道", "text": "若呀，既然你不是与他同流合污，那么清者自清，浊者自浊，你也不必因他羞愧了。"},
    {"line": 122, "speaker_raw": "徐锦瑶", "verb": "道", "text": "话虽如此，但目前我可还是跟着爹爹住在他们穆家的呀。就像住在狼窝一样，我真是有点提心吊胆。要是我不肯依从他们，只怕，只怕！"},
    {"line": 128, "speaker_raw": "徐锦瑶", "verb": "道", "text": "亏你还有心情说笑，事情已经找到咱们头上，总得想个法子对付呀。你打算怎样？"},
    {"line": 130, "speaker_raw": "楚天虹", "verb": "道", "text": "我不相信他们敢来抢我，我爹虽然卧病在床，也决不会让别人欺负我的。"},
    {"line": 138, "speaker_raw": "楚天虹", "verb": "道", "text": "别急，别急。你把我当作妹妹，我的哥哥也就是你的哥哥，我们不会不理你的。你说吧，你希望我们怎样帮你的忙？"},
    {"line": 150, "speaker_raw": "楚天虹", "verb": "道", "text": "哥哥，你来得正好。"},
    {"line": 160, "speaker_raw": "徐锦瑶", "verb": "说道", "text": "什么人？"},
    {"line": 162, "speaker_raw": "楚天舒", "verb": "道", "text": "迟些再告诉你。你们既然决定离开京城，那就事不宜迟，我给你们准备车辆，妹妹！你也得收拾行装了。"},
    {"line": 164, "speaker_raw": "楚天虹", "verb": "道", "text": "且慢，急也不急在这一时，我想知道爹爹为何要我马上离京，难道他也知道了这件事？"},
    {"line": 170, "speaker_raw": "楚天舒", "verb": "道", "text": "爹爹要咱们回家，不是为这件事情。他是不想咱们留在这是非之地。爹爹的病有汤伯伯照料，用不着咱们操心。所以他认为咱们还是早日回家的好。"},
    {"line": 172, "speaker_raw": "楚天虹", "verb": "道", "text": "既然爹爹有命，那我马上准备行装。"},
    {"line": 192, "speaker_raw": "郭元宰", "verb": "道", "text": "我也想不到在这里能碰上你，我到震远镖局打听消息的时候，还以为你是和师父住在穆府的呢。"},
    {"line": 194, "speaker_raw": "徐锦瑶", "verb": "道", "text": "我是称爹爹住在穆家的，如今正是为了不想在穆家住下去才要离开的。我的事情，楚大哥已经告诉了你吧？"},
    {"line": 196, "speaker_raw": "郭元宰", "verb": "道", "text": "已经告诉了，所以我也不打算去见师父了，马上就和你离开！"},
    {"line": 198, "speaker_raw": "楚天舒", "verb": "道", "text": "郭兄多多拜托你了。"},
    {"line": 200, "speaker_raw": "楚天虹", "verb": "道", "text": "哥哥你不走么？"},
    {"line": 202, "speaker_raw": "楚天舒", "verb": "道", "text": "有郭大哥送你们回去，我想留下来服侍爹爹。"},
    {"line": 204, "speaker_raw": "楚天虹", "verb": "道", "text": "这样也好，那么我称徐姐姐先走一步，只盼爹爹早点用药，你们也能够赶快回来。"},
    {"line": 206, "speaker_raw": "徐锦瑶", "verb": "道", "text": "家父不见我回去，恐怕会来找我的。还有穆家那两个少爷，恐怕也会来找麻烦，楚大哥，你最好避开他们。"},
    {"line": 208, "speaker_raw": "楚天舒", "verb": "道", "text": "我理会得，你们走吧。"},
    {"line": 224, "speaker_raw": "郭元宰", "verb": "道", "text": "这份地图，是一位热心的老镖师给我的。他们镖局绘制的地图，比市面出售的一般地图详细得多。"},
    {"line": 252, "speaker_raw": "徐锦瑶", "verb": "道", "text": "是呀，就是前天在西山碰上的。"},
    {"line": 254, "speaker_raw": "郭元宰", "verb": "道", "text": "就只他一个人么？"},
    {"line": 268, "speaker_raw": "徐锦瑶", "verb": "道", "text": "你相不相信？"},
    {"line": 274, "speaker_raw": "徐锦瑶", "verb": "道", "text": "他们私奔是真是假，我也不知。但即使姜雪君跟飞天神龙私奔，她也不敢和飞天神龙一起来京师的。她的武功远不及飞天神龙，他不怕我的爹爹把她捉回去吗？"},
    {"line": 290, "speaker_raw": "彭大遒", "verb": "赞道", "text": "佟大哥，你号称大力神，果然名不虚传！"},
    {"line": 292, "speaker_raw": "穆良驹", "verb": "赞道", "text": "彭总管，你真是料事如神，他们果然是走小路！"},
    {"line": 352, "speaker_raw": "楚天虹", "verb": "骂道", "text": "下流胚子，你莫恃着你爹是御林军统领，须知我们楚家也不是好欺负的。好，你不许我走，我就回去叫爹爹与你们评理！"},
    {"line": 354, "speaker_raw": "佟开甲", "verb": "道", "text": "彭总管，你拿个主意。"},
    {"line": 376, "speaker_raw": "徐锦瑶", "verb": "道", "text": "那就请你转告我的爹爹，你说我是决意不回去的了！"},
    {"line": 378, "speaker_raw": "彭大遒", "verb": "道", "text": "这我管不着，我只知奉命而为。你一定要走，你和大公子说吧。只要大公子点头，我们做下人的自当遵命。"},
    {"line": 380, "speaker_raw": "穆良驹", "verb": "道", "text": "待我打发了这小子再和她说！"},
    {"line": 386, "speaker_raw": "穆良驹", "verb": "道", "text": "笑话，凭你这小子我还怕你不成！用不着他们帮手，我和你比划比划！"},
    {"line": 392, "speaker_raw": "郭元宰", "verb": "道", "text": "要比划就比划，谁还怕你不成！"},
    {"line": 396, "speaker_raw": "穆良驹", "verb": "道", "text": "好小子，你敢打我？"},
    {"line": 404, "speaker_raw": "佟开甲", "verb": "道", "text": "大公子，让属下来收拾这小子！"},
    {"line": 408, "speaker_raw": "楚天虹", "verb": "道", "text": "你们以多欺少，要不要脸？"},
    {"line": 416, "speaker_raw": "彭大遒", "verb": "道", "text": "楚姑娘，你别多管闲事。这是穆大公子和郭元宰之间的事。"},
    {"line": 426, "speaker_raw": "楚天舒", "verb": "道", "text": "且慢！"},
    {"line": 430, "speaker_raw": "楚天舒", "verb": "道", "text": "穆大公子，你和郭元宰的过节，我不管。但你调戏我的妹妹，这笔帐我可要和你算算。"},
    {"line": 436, "speaker_raw": "穆良驹", "verb": "道", "text": "你妹妹？你妹妹是谁？"},
    {"line": 438, "speaker_raw": "楚天舒", "verb": "道", "text": "你昨天在西山调戏的那位姑娘，就是我的妹妹楚天虹。"},
    {"line": 442, "speaker_raw": "穆良驹", "verb": "道", "text": "那又怎样？你敢动我一根毫毛，我爹爹穆志遥饶不了你！"},
    {"line": 444, "speaker_raw": "楚天舒", "verb": "道", "text": "穆大公子，我不想和你打架。但你必须向我的妹妹赔礼道歉。"},
    {"line": 450, "speaker_raw": "穆良驹", "verb": "道", "text": "笑话！要我向一个小丫头赔礼道歉？"},
    {"line": 458, "speaker_raw": "彭大遒", "verb": "道", "text": "楚公子，得饶人处且饶人，何必为了这点小事伤了和气？"},
    {"line": 462, "speaker_raw": "楚天舒", "verb": "道", "text": "彭总管，这不是小事。穆大公子调戏良家妇女，若不赔礼，天理何在？"},
    {"line": 470, "speaker_raw": "穆良驹", "verb": "道", "text": "好，你要打就打，我穆良驹还怕了你不成！"},
    {"line": 482, "speaker_raw": "佟开甲", "verb": "道", "text": "大公子，让属下来对付他！"},
    {"line": 488, "speaker_raw": "楚天舒", "verb": "道", "text": "佟开甲，你号称大力神，我倒要看看你的力气有多大。"},
    {"line": 502, "speaker_raw": "彭大遒", "verb": "道", "text": "楚公子的武功果然了得，佟大哥不是他的对手。"},
    {"line": 508, "speaker_raw": "穆良驹", "verb": "道", "text": "彭总管，你还不快上！"},
    {"line": 512, "speaker_raw": "彭大遒", "verb": "道", "text": "大公子，楚公子的武功远在你我之上，咱们还是走吧。"},
    {"line": 520, "speaker_raw": "穆良驹", "verb": "道", "text": "走？没那么容易！楚天舒，你给我记着，我爹爹穆志遥不会放过你的！"},
    {"line": 534, "speaker_raw": "卫天元", "verb": "道", "text": "穆大少爷，你想走？没那么容易吧？"},
    {"line": 538, "speaker_raw": "穆良驹", "verb": "道", "text": "你，你是谁？"},
    {"line": 540, "speaker_raw": "卫天元", "verb": "道", "text": "你不认识我了？我就是你要抓的飞天神龙卫天元！"},
    {"line": 546, "speaker_raw": "穆良驹", "verb": "道", "text": "你，你想怎样？"},
    {"line": 548, "speaker_raw": "卫天元", "verb": "道", "text": "我不想怎样，只是想请穆大少爷跟我走一趟。"},
    {"line": 556, "speaker_raw": "彭大遒", "verb": "道", "text": "卫天元，你别乱来！穆大公子是御林军统领穆大人的公子，你敢动他？"},
    {"line": 558, "speaker_raw": "卫天元", "verb": "道", "text": "彭大遒，你也别走。你回去告诉穆志遥，他的儿子在我手上，要想他平安无事，就拿齐漱玉来交换。"},
    {"line": 564, "speaker_raw": "彭大遒", "verb": "道", "text": "齐漱玉？我不知道你在说什么。"},
    {"line": 566, "speaker_raw": "卫天元", "verb": "道", "text": "你不知道？那你就回去问穆志遥吧。"},
    {"line": 572, "speaker_raw": "楚天舒", "verb": "道", "text": "卫兄，你抓穆良驹是为了救齐漱玉？"},
    {"line": 574, "speaker_raw": "卫天元", "verb": "道", "text": "不错。我的师妹齐漱玉被白驼山的妖人骗走了，穆志遥和白驼山主是一伙的，我要用穆良驹来交换师妹。"},
    {"line": 580, "speaker_raw": "楚天虹", "verb": "道", "text": "卫大哥，齐姐姐被白驼山妖人骗走了？"},
    {"line": 582, "speaker_raw": "卫天元", "verb": "道", "text": "是的。天虹，你知道这件事？"},
    {"line": 584, "speaker_raw": "楚天虹", "verb": "道", "text": "我也是刚刚才知道的。是徐姐姐告诉我的。"},
    {"line": 590, "speaker_raw": "卫天元", "verb": "道", "text": "徐姑娘，你当时在场？"},
    {"line": 592, "speaker_raw": "徐锦瑶", "verb": "道", "text": "是的。当时齐姑娘和一个年轻人在一起，那年轻人说是白驼山主的弟子。"},
    {"line": 598, "speaker_raw": "卫天元", "verb": "道", "text": "齐漱玉是自愿跟他走的？"},
    {"line": 600, "speaker_raw": "徐锦瑶", "verb": "道", "text": "看样子是的。不过楚天虹说白驼山妖人有一种神仙丸，可令人迷失本性，齐姑娘可能是受了迷惑。"},
    {"line": 608, "speaker_raw": "楚天虹", "verb": "道", "text": "汤叔叔说的，白驼山妖人有一种神仙丸，可令人迷失本性，齐姐姐当然是受他骗的，否则怎会跟他混在一起。"},
    {"line": 618, "speaker_raw": "卫天元", "verb": "道", "text": "不管她是自愿还是受骗，我都要把她找回来。"},
    {"line": 628, "speaker_raw": "楚天舒", "verb": "道", "text": "卫兄，要不要我帮忙？"},
    {"line": 630, "speaker_raw": "卫天元", "verb": "道", "text": "多谢楚兄好意，但这件事我必须自己解决。"},
    {"line": 638, "speaker_raw": "楚天虹", "verb": "道", "text": "卫大哥，你一个人去太危险了。白驼山主武功高强，又有穆志遥撑腰，你一个人怎么对付得了？"},
    {"line": 640, "speaker_raw": "卫天元", "verb": "道", "text": "我有穆良驹在手，不怕穆志遥不就范。至于白驼山主，我自有办法对付。"},
    {"line": 648, "speaker_raw": "楚天舒", "verb": "道", "text": "卫兄，你要小心。穆志遥手下高手如云，你一个人势单力薄。"},
    {"line": 650, "speaker_raw": "卫天元", "verb": "道", "text": "我会小心的。楚兄，你也要小心，穆良驹不会善罢甘休的。"},
    {"line": 658, "speaker_raw": "楚天虹", "verb": "道", "text": "卫大哥，你一定要把齐姐姐救回来啊！"},
    {"line": 660, "speaker_raw": "卫天元", "verb": "道", "text": "我会的。天虹，你和徐姑娘先跟郭兄走，路上小心。"},
    {"line": 668, "speaker_raw": "郭元宰", "verb": "道", "text": "卫兄放心，我会保护好她们的。"},
    {"line": 676, "speaker_raw": "卫天元", "verb": "道", "text": "穆大少爷，委屈你了，请上车吧。"},
    {"line": 680, "speaker_raw": "穆良驹", "verb": "道", "text": "卫天元，你敢绑架我？我爹爹不会放过你的！"},
    {"line": 682, "speaker_raw": "卫天元", "verb": "道", "text": "你放心，只要你爹拿齐漱玉来交换，我保证你毫发无伤。"},
    {"line": 748, "speaker_raw": "卫天元", "verb": "道", "text": "楚兄，我走了。后会有期。"},
    {"line": 750, "speaker_raw": "楚天舒", "verb": "道", "text": "卫兄，保重。"},
    {"line": 756, "speaker_raw": "卫天元", "verb": "道", "text": "穆大少爷，你是不是有个师妹叫齐漱玉？"},
    {"line": 758, "speaker_raw": "穆良驹", "verb": "道", "text": "你问这个干什么？"},
    {"line": 760, "speaker_raw": "卫天元", "verb": "道", "text": "你只管回答我，有还是没有？"},
    {"line": 766, "speaker_raw": "穆良驹", "verb": "道", "text": "有又怎样？"},
    {"line": 768, "speaker_raw": "卫天元", "verb": "道", "text": "她现在在哪里？"},
    {"line": 774, "speaker_raw": "穆良驹", "verb": "道", "text": "我不知道。"},
    {"line": 776, "speaker_raw": "卫天元", "verb": "道", "text": "你不知道？你爹和白驼山主是一伙的，你会不知道？"},
    {"line": 782, "speaker_raw": "穆良驹", "verb": "道", "text": "我真的不知道。我只知道白驼山主想要齐漱玉做他的儿媳妇，但具体的事情我爹没有告诉我。"},
    {"line": 790, "speaker_raw": "卫天元", "verb": "道", "text": "白驼山主的儿子是谁？"},
    {"line": 792, "speaker_raw": "穆良驹", "verb": "道", "text": "叫宇文浩。"},
    {"line": 800, "speaker_raw": "卫天元", "verb": "道", "text": "宇文浩？他现在在哪里？"},
    {"line": 802, "speaker_raw": "穆良驹", "verb": "道", "text": "应该是在白驼山吧。"},
    {"line": 810, "speaker_raw": "卫天元", "verb": "道", "text": "白驼山在什么地方？"},
    {"line": 812, "speaker_raw": "穆良驹", "verb": "道", "text": "我不知道。我真的不知道，你别问了。"},
    {"line": 876, "speaker_raw": "卫天元", "verb": "道", "text": "你说可以手下留情的，如今我也是怎样做法，你记错了吧？"},
    {"line": 878, "speaker_raw": "穆良驹", "verb": "道", "text": "你说什么？"},
    {"line": 880, "speaker_raw": "卫天元", "verb": "道", "text": "我是说可以按照你的尺寸给你留下余地，亦即是说刚才你是怎样做法，如今我也是怎样做法。"},
    {"line": 888, "speaker_raw": "卫天元", "verb": "道", "text": "穆大少爷，你还有什么话要说？"},
    {"line": 890, "speaker_raw": "穆良驹", "verb": "道", "text": "卫天元，你饶了我吧，我以后不敢了。"},
    {"line": 898, "speaker_raw": "卫天元", "verb": "道", "text": "你放心，我不会杀你的。你对我还有用处。"},
    {"line": 910, "speaker_raw": "楚天虹", "verb": "道", "text": "卫大哥，你怎么又回来了？"},
    {"line": 912, "speaker_raw": "卫天元", "verb": "道", "text": "我有件事要问你们。齐漱玉在哪里？"},
    {"line": 914, "speaker_raw": "楚天虹", "verb": "道", "text": "齐姐姐？她不是和你在一起吗？"},
    {"line": 916, "speaker_raw": "卫天元", "verb": "道", "text": "她不见了。我到处找她都找不到。"},
    {"line": 918, "speaker_raw": "楚天虹", "verb": "道", "text": "她被白驼山的妖人骗走了！"},
    {"line": 920, "speaker_raw": "卫天元", "verb": "道", "text": "她怎会给白驼山的妖人骗走的？"},
    {"line": 922, "speaker_raw": "楚天虹", "verb": "道", "text": "你问徐姐姐吧，徐姐姐当时在场。"},
    {"line": 924, "speaker_raw": "徐锦瑶", "verb": "道", "text": "是否受骗，恐怕尚难断定。当时，那小子倒是来帮她的忙的，依我所见，她似乎也是心甘情愿跟那小子走的。"},
    {"line": 926, "speaker_raw": "楚天虹", "verb": "道", "text": "汤叔叔说，白驼山妖人有一种神仙丸，可令人迷失本性，齐姐姐当然是受他骗的，否则怎会跟他混在一起。"},
    {"line": 928, "speaker_raw": "卫天元", "verb": "道", "text": "好，待我亲自去查个明白，你们这辆马车给我，你们骑马如何？"},
    {"line": 934, "speaker_raw": "楚天虹", "verb": "道", "text": "你是先到震远镖局吧？"},
    {"line": 934, "speaker_raw": "卫天元", "verb": "道", "text": "是。"},
    {"line": 934, "speaker_raw": "楚天虹", "verb": "道", "text": "那你可得多加小心啊，汤总镖头虽然是好人，镖局里也有穆志遥的耳目的，听说他请来了许多好手对付你呢！"},
    {"line": 936, "speaker_raw": "卫天元", "verb": "笑道", "text": "我会小心的。我有穆志遥的儿子在手，也不怕他将我难为。"}
  ]
}
