{
  "chapter": 7,
  "chapter_summary": "本章开篇，常五娘下山回山之际，遭遇自称唐仲山的神秘蒙面人拦截。蒙面人实为当年与常五娘有私情的唐仲山，他透露了武当掌门何足道被囚的真相，并指明幕后主使为不戒、不慧等人。蓝水灵下山寻找东方亮，与之在路途中相识相知。东方亮出手相助，制服了追杀蓝水灵的几名武当弃徒。两人共赴苗疆，一路上暗生情愫。蓝水灵向东方亮坦承自己是蓝玉京的妹妹，并揭露了武当派当前的内部危机。东方亮则表露了愿为蓝水灵赴汤蹈火的心意。",
  "dialogues": [
    {"id":"dlg_07_001","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"命令","text":"施主留步。","source_refs":[{"chapter":7,"line_start":30,"line_end":30,"text":"施主留步。"}]},
    {"id":"dlg_07_002","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"惊讶","text":"你、你是……","source_refs":[{"chapter":7,"line_start":32,"line_end":32,"text":"你、你是……"}]},
    {"id":"dlg_07_003","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"得意","text":"嘿嘿，认不出来了？","source_refs":[{"chapter":7,"line_start":33,"line_end":33,"text":"嘿嘿，认不出来了？"}]},
    {"id":"dlg_07_004","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"惊讶","text":"你是唐仲山！","source_refs":[{"chapter":7,"line_start":35,"line_end":35,"text":"你是唐仲山！"}]},
    {"id":"dlg_07_005","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"平淡","text":"唐仲山早死了。","source_refs":[{"chapter":7,"line_start":37,"line_end":37,"text":"唐仲山早死了。"}]},
    {"id":"dlg_07_006","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"疑问","text":"那你是谁？","source_refs":[{"chapter":7,"line_start":40,"line_end":40,"text":"那你是谁？"}]},
    {"id":"dlg_07_007","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"命令","text":"别问那么多。","source_refs":[{"chapter":7,"line_start":42,"line_end":42,"text":"别问那么多。"}]},
    {"id":"dlg_07_008","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"愤怒","text":"你杀了他！","source_refs":[{"chapter":7,"line_start":45,"line_end":45,"text":"你杀了他！"}]},
    {"id":"dlg_07_009","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"冷笑","text":"嘿嘿嘿……","source_refs":[{"chapter":7,"line_start":47,"line_end":47,"text":"嘿嘿嘿……"}]},
    {"id":"dlg_07_010","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"命令","text":"别问了，跟我走。","source_refs":[{"chapter":7,"line_start":49,"line_end":49,"text":"别问了，跟我走。"}]},
    {"id":"dlg_07_011","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"愤怒","text":"我不跟你走！","source_refs":[{"chapter":7,"line_start":51,"line_end":51,"text":"我不跟你走！"}]},
    {"id":"dlg_07_012","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"轻蔑","text":"由得了你？","source_refs":[{"chapter":7,"line_start":53,"line_end":53,"text":"由得了你？"}]},
    {"id":"dlg_07_013","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"狡黠","text":"你不想知道你师父的事么？","source_refs":[{"chapter":7,"line_start":55,"line_end":55,"text":"你不想知道你师父的事么？"}]},
    {"id":"dlg_07_014","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"惊讶","text":"何足道怎么了？","source_refs":[{"chapter":7,"line_start":57,"line_end":57,"text":"何足道怎么了？"}]},
    {"id":"dlg_07_015","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"平淡","text":"他被囚了。","source_refs":[{"chapter":7,"line_start":59,"line_end":59,"text":"他被囚了。"}]},
    {"id":"dlg_07_016","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"疑问","text":"谁囚的？","source_refs":[{"chapter":7,"line_start":61,"line_end":61,"text":"谁囚的？"}]},
    {"id":"dlg_07_017","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"深沉","text":"你那几位好师兄。","source_refs":[{"chapter":7,"line_start":63,"line_end":63,"text":"你那几位好师兄。"}]},
    {"id":"dlg_07_018","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"惊讶","text":"不戒？不慧？","source_refs":[{"chapter":7,"line_start":65,"line_end":65,"text":"不戒？不慧？"}]},
    {"id":"dlg_07_019","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"冷笑","text":"还有不白、不波。","source_refs":[{"chapter":7,"line_start":67,"line_end":67,"text":"还有不白、不波。"}]},
    {"id":"dlg_07_020","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"痛苦","text":"他们怎能……","source_refs":[{"chapter":7,"line_start":69,"line_end":69,"text":"他们怎能……"}]},
    {"id":"dlg_07_021","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"平淡","text":"他们图的是武当掌门的位子。","source_refs":[{"chapter":7,"line_start":71,"line_end":71,"text":"他们图的是武当掌门的位子。"}]},
    {"id":"dlg_07_022","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"犹豫","text":"你……你为何要告诉我这些？","source_refs":[{"chapter":7,"line_start":73,"line_end":73,"text":"你……你为何要告诉我这些？"}]},
    {"id":"dlg_07_023","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"深沉","text":"因为你是我这辈子最对不起的人。","source_refs":[{"chapter":7,"line_start":75,"line_end":75,"text":"因为你是我这辈子最对不起的人。"}]},
    {"id":"dlg_07_024","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"痛苦","text":"别说了……","source_refs":[{"chapter":7,"line_start":77,"line_end":77,"text":"别说了……"}]},
    {"id":"dlg_07_025","chapter":7,"speaker":"tang_zhong_shan","speaker_name":"唐仲山","listener":"chang_wu_niang","listener_name":"常五娘","tone":"命令","text":"走吧，替我，也替你师父报仇。","source_refs":[{"chapter":7,"line_start":79,"line_end":79,"text":"走吧，替我，也替你师父报仇。"}]},
    {"id":"dlg_07_026","chapter":7,"speaker":"chang_wu_niang","speaker_name":"常五娘","listener":"tang_zhong_shan","listener_name":"唐仲山","tone":"坚定","text":"好，我跟你走。","source_refs":[{"chapter":7,"line_start":81,"line_end":81,"text":"好，我跟你走。"}]},
    {"id":"dlg_07_027","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"疑问","text":"你、你是谁？为何跟着我？","source_refs":[{"chapter":7,"line_start":210,"line_end":210,"text":"你、你是谁？为何跟着我？"}]},
    {"id":"dlg_07_028","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"平静","text":"在下东方亮，恰好同路而已。","source_refs":[{"chapter":7,"line_start":212,"line_end":212,"text":"在下东方亮，恰好同路而已。"}]},
    {"id":"dlg_07_029","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"惊讶","text":"东方亮？爹爹提过你！","source_refs":[{"chapter":7,"line_start":214,"line_end":214,"text":"东方亮？爹爹提过你！"}]},
    {"id":"dlg_07_030","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"惊讶","text":"令尊是……？","source_refs":[{"chapter":7,"line_start":216,"line_end":216,"text":"令尊是……？"}]},
    {"id":"dlg_07_031","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"犹豫","text":"我……我爹是蓝靠山。","source_refs":[{"chapter":7,"line_start":218,"line_end":218,"text":"我……我爹是蓝靠山。"}]},
    {"id":"dlg_07_032","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"恭敬","text":"原来是蓝姑娘，失敬。","source_refs":[{"chapter":7,"line_start":220,"line_end":220,"text":"原来是蓝姑娘，失敬。"}]},
    {"id":"dlg_07_033","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"疑问","text":"你怎会认得我爹？","source_refs":[{"chapter":7,"line_start":222,"line_end":222,"text":"你怎会认得我爹？"}]},
    {"id":"dlg_07_034","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"平淡","text":"江湖上谁不知道蓝大侠。","source_refs":[{"chapter":7,"line_start":224,"line_end":224,"text":"江湖上谁不知道蓝大侠。"}]},
    {"id":"dlg_07_035","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"急迫","text":"后面有人追我，求你帮帮我！","source_refs":[{"chapter":7,"line_start":290,"line_end":290,"text":"后面有人追我，求你帮帮我！"}]},
    {"id":"dlg_07_036","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"坚定","text":"蓝姑娘放心，有我在。","source_refs":[{"chapter":7,"line_start":292,"line_end":292,"text":"蓝姑娘放心，有我在。"}]},
    {"id":"dlg_07_037","chapter":7,"speaker":"wu_dang_qi_tu","speaker_name":"武当弃徒","listener":"dong_fang_liang","listener_name":"东方亮","tone":"威胁","text":"小子休要多管闲事！","source_refs":[{"chapter":7,"line_start":295,"line_end":295,"text":"小子休要多管闲事！"}]},
    {"id":"dlg_07_038","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"wu_dang_qi_tu","listener_name":"武当弃徒","tone":"冷峻","text":"这位姑娘的事，在下管定了。","source_refs":[{"chapter":7,"line_start":297,"line_end":297,"text":"这位姑娘的事，在下管定了。"}]},
    {"id":"dlg_07_039","chapter":7,"speaker":"wu_dang_qi_tu","speaker_name":"武当弃徒","listener":"dong_fang_liang","listener_name":"东方亮","tone":"愤怒","text":"找死！","source_refs":[{"chapter":7,"line_start":299,"line_end":299,"text":"找死！"}]},
    {"id":"dlg_07_040","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"惊讶","text":"你……你武功这么好！","source_refs":[{"chapter":7,"line_start":330,"line_end":330,"text":"你……你武功这么好！"}]},
    {"id":"dlg_07_041","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"平淡","text":"家学渊源而已，不足挂齿。","source_refs":[{"chapter":7,"line_start":332,"line_end":332,"text":"家学渊源而已，不足挂齿。"}]},
    {"id":"dlg_07_042","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"犹豫","text":"我……我其实是蓝玉京的妹妹。","source_refs":[{"chapter":7,"line_start":430,"line_end":430,"text":"我……我其实是蓝玉京的妹妹。"}]},
    {"id":"dlg_07_043","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"惊讶","text":"蓝玉京？你哥哥？","source_refs":[{"chapter":7,"line_start":432,"line_end":432,"text":"蓝玉京？你哥哥？"}]},
    {"id":"dlg_07_044","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"痛苦","text":"他现在被困在武当，我要去救他。","source_refs":[{"chapter":7,"line_start":434,"line_end":434,"text":"他现在被困在武当，我要去救他。"}]},
    {"id":"dlg_07_045","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"坚定","text":"我陪你。","source_refs":[{"chapter":7,"line_start":436,"line_end":436,"text":"我陪你。"}]},
    {"id":"dlg_07_046","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"惊讶","text":"你……你愿意？","source_refs":[{"chapter":7,"line_start":438,"line_end":438,"text":"你……你愿意？"}]},
    {"id":"dlg_07_047","chapter":7,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"坚定","text":"赴汤蹈火，在所不辞。","source_refs":[{"chapter":7,"line_start":440,"line_end":440,"text":"赴汤蹈火，在所不辞。"}]},
    {"id":"dlg_07_048","chapter":7,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"感激","text":"东方大哥……","source_refs":[{"chapter":7,"line_start":442,"line_end":442,"text":"东方大哥……"}]},
    {"id":"dlg_07_049","chapter":7,"speaker":"wu_se","speaker_name":"无色道人","listener":"mou_yi_yu","listener_name":"牟一羽","tone":"庄重","text":"一羽，你即刻下山去找蓝水灵。","source_refs":[{"chapter":7,"line_start":500,"line_end":500,"text":"一羽，你即刻下山去找蓝水灵。"}]},
    {"id":"dlg_07_050","chapter":7,"speaker":"mou_yi_yu","speaker_name":"牟一羽","listener":"wu_se","listener_name":"无色道人","tone":"恭敬","text":"是，徒孙遵命。","source_refs":[{"chapter":7,"line_start":502,"line_end":502,"text":"是，徒孙遵命。"}]}
