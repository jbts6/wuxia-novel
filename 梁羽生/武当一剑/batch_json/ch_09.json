{
  "chapter": 9,
  "chapter_summary": "本章承前章，蓝水灵、东方亮、西门一家西行至嵩山少林寺。少林方丈本无大师率众僧接待，引出蓝玉京已到少林的消息。蓝水灵与兄长重逢，悲喜交加。蓝玉京坦言已决意出家，并揭示武当内乱的真相。西门燕初见蓝玉京，心生好感，又因蓝水灵之故吃醋。少林高僧慧可、痛禅上人相继登场，展示少林绝技。达摩院、十八罗汉堂纷纷出场。众人在少林共议如何应对武当危局。",
  "dialogues": [
    {"id":"dlg_09_001","chapter":9,"speaker":"benwu_dashi","speaker_name":"本无大师","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"庄重","text":"施主远道而来，本寺不胜荣幸。","source_refs":[{"chapter":9,"line_start":30,"line_end":30,"text":"施主远道而来，本寺不胜荣幸。"}]},
    {"id":"dlg_09_002","chapter":9,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"benwu_dashi","listener_name":"本无大师","tone":"恭敬","text":"大师言重了，小女子冒昧打扰。","source_refs":[{"chapter":9,"line_start":32,"line_end":32,"text":"大师言重了，小女子冒昧打扰。"}]},
    {"id":"dlg_09_003","chapter":9,"speaker":"benwu_dashi","speaker_name":"本无大师","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"平静","text":"蓝玉京施主已在敝寺挂单，施主请。","source_refs":[{"chapter":9,"line_start":34,"line_end":34,"text":"蓝玉京施主已在敝寺挂单，施主请。"}]},
    {"id":"dlg_09_004","chapter":9,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"benwu_dashi","listener_name":"本无大师","tone":"惊讶","text":"哥哥他……他在少林？","source_refs":[{"chapter":9,"line_start":36,"line_end":36,"text":"哥哥他……他在少林？"}]},
    {"id":"dlg_09_005","chapter":9,"speaker":"lan_yu_jing","speaker_name":"蓝玉京","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"温柔","text":"灵妹，你来了。","source_refs":[{"chapter":9,"line_start":50,"line_end":50,"text":"灵妹，你来了。"}]},
    {"id":"dlg_09_006","chapter":9,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"lan_yu_jing","listener_name":"蓝玉京","tone":"悲伤","text":"哥哥！你怎的……你怎的剃度了？","source_refs":[{"chapter":9,"line_start":52,"line_end":52,"text":"哥哥！你怎的……你怎的剃度了？"}]},
    {"id":"dlg_09_007","chapter":9,"speaker":"lan_yu_jing","speaker_name":"蓝玉京","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"平淡","text":"尘缘已了，何必执着。","source_refs":[{"chapter":9,"line_start":54,"line_end":54,"text":"尘缘已了，何必执着。"}]},
    {"id":"dlg_09_008","chapter":9,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"lan_yu_jing","listener_name":"蓝玉京","tone":"痛苦","text":"哥哥！爹爹他……","source_refs":[{"chapter":9,"line_start":56,"line_end":56,"text":"哥哥！爹爹他……"}]},
    {"id":"dlg_09_009","chapter":9,"speaker":"lan_yu_jing","speaker_name":"蓝玉京","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"痛苦","text":"爹的事我都知道了。","source_refs":[{"chapter":9,"line_start":58,"line_end":58,"text":"爹的事我都知道了。"}]},
    {"id":"dlg_09_010","chapter":9,"speaker":"xi_men_yan","speaker_name":"西门燕","listener":"xi_men_fu_ren","listener_name":"西门夫人","tone":"好奇","text":"娘，这人就是蓝姑娘的哥哥么？","source_refs":[{"chapter":9,"line_start":60,"line_end":60,"text":"娘，这人就是蓝姑娘的哥哥么？"}]},
    {"id":"dlg_09_011","chapter":9,"speaker":"xi_men_fu_ren","speaker_name":"西门夫人","listener":"xi_men_yan","listener_name":"西门燕","tone":"平淡","text":"嗯，正是。","source_refs":[{"chapter":9,"line_start":62,"line_end":62,"text":"嗯，正是。"}]},
    {"id":"dlg_09_012","chapter":9,"speaker":"xi_men_yan","speaker_name":"西门燕","listener":"lan_yu_jing","listener_name":"蓝玉京","tone":"好奇","text":"蓝公子，你……你当真出了家？","source_refs":[{"chapter":9,"line_start":64,"line_end":64,"text":"蓝公子，你……你当真出了家？"}]},
    {"id":"dlg_09_013","chapter":9,"speaker":"lan_yu_jing","speaker_name":"蓝玉京","listener":"xi_men_yan","listener_name":"西门燕","tone":"平淡","text":"小僧已是佛门中人，施主称呼贫僧即可。","source_refs":[{"chapter":9,"line_start":66,"line_end":66,"text":"小僧已是佛门中人，施主称呼贫僧即可。"}]},
    {"id":"dlg_09_014","chapter":9,"speaker":"xi_men_yan","speaker_name":"西门燕","listener":"xi_men_fu_ren","listener_name":"西门夫人","tone":"撒娇","text":"娘，他好生无趣！","source_refs":[{"chapter":9,"line_start":68,"line_end":68,"text":"娘，他好生无趣！"}]},
    {"id":"dlg_09_015","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"benwu_dashi","listener_name":"本无大师","tone":"庄重","text":"方丈，贫僧有事禀报。","source_refs":[{"chapter":9,"line_start":120,"line_end":120,"text":"方丈，贫僧有事禀报。"}]},
    {"id":"dlg_09_016","chapter":9,"speaker":"benwu_dashi","speaker_name":"本无大师","listener":"hike","listener_name":"慧可","tone":"平静","text":"慧可师弟请讲。","source_refs":[{"chapter":9,"line_start":122,"line_end":122,"text":"慧可师弟请讲。"}]},
    {"id":"dlg_09_017","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"benwu_dashi","listener_name":"本无大师","tone":"急迫","text":"武当不戒等人正往少室山而来。","source_refs":[{"chapter":9,"line_start":124,"line_end":124,"text":"武当不戒等人正往少室山而来。"}]},
    {"id":"dlg_09_018","chapter":9,"speaker":"benwu_dashi","speaker_name":"本无大师","listener":"hike","listener_name":"慧可","tone":"平静","text":"知道了，传痛禅师弟来。","source_refs":[{"chapter":9,"line_start":126,"line_end":126,"text":"知道了，传痛禅师弟来。"}]},
    {"id":"dlg_09_019","chapter":9,"speaker":"tongchan_shangren","speaker_name":"痛禅上人","listener":"benwu_dashi","listener_name":"本无大师","tone":"恭敬","text":"方丈师兄召见，不知有何吩咐？","source_refs":[{"chapter":9,"line_start":140,"line_end":140,"text":"方丈师兄召见，不知有何吩咐？"}]},
    {"id":"dlg_09_020","chapter":9,"speaker":"benwu_dashi","speaker_name":"本无大师","listener":"tongchan_shangren","listener_name":"痛禅上人","tone":"庄重","text":"师弟即刻率众罗汉堂弟子布防。","source_refs":[{"chapter":9,"line_start":142,"line_end":142,"text":"师弟即刻率众罗汉堂弟子布防。"}]},
    {"id":"dlg_09_021","chapter":9,"speaker":"tongchan_shangren","speaker_name":"痛禅上人","listener":"benwu_dashi","listener_name":"本无大师","tone":"坚定","text":"贫僧遵命。","source_refs":[{"chapter":9,"line_start":144,"line_end":144,"text":"贫僧遵命。"}]},
    {"id":"dlg_09_022","chapter":9,"speaker":"yuanzhen","speaker_name":"圆真","listener":"hike","listener_name":"慧可","tone":"恭敬","text":"慧可师叔，弟子已探得贼人行踪。","source_refs":[{"chapter":9,"line_start":200,"line_end":200,"text":"慧可师叔，弟子已探得贼人行踪。"}]},
    {"id":"dlg_09_023","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"yuanzhen","listener_name":"圆真","tone":"平静","text":"速速报来。","source_refs":[{"chapter":9,"line_start":202,"line_end":202,"text":"速速报来。"}]},
    {"id":"dlg_09_024","chapter":9,"speaker":"yuanzhen","speaker_name":"圆真","listener":"hike","listener_name":"慧可","tone":"急迫","text":"不戒等三十余人，已过断魂谷。","source_refs":[{"chapter":9,"line_start":204,"line_end":204,"text":"不戒等三十余人，已过断魂谷。"}]},
    {"id":"dlg_09_025","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"yuanzhen","listener_name":"圆真","tone":"惊讶","text":"断魂谷？来得好快。","source_refs":[{"chapter":9,"line_start":206,"line_end":206,"text":"断魂谷？来得好快。"}]},
    {"id":"dlg_09_026","chapter":9,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"hike","listener_name":"慧可","tone":"恭敬","text":"慧可大师，可有在下效劳之处？","source_refs":[{"chapter":9,"line_start":230,"line_end":230,"text":"慧可大师，可有在下效劳之处？"}]},
    {"id":"dlg_09_027","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"dong_fang_liang","listener_name":"东方亮","tone":"庄重","text":"东方施主好意，少林尚可应付。","source_refs":[{"chapter":9,"line_start":232,"line_end":232,"text":"东方施主好意，少林尚可应付。"}]},
    {"id":"dlg_09_028","chapter":9,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"hike","listener_name":"慧可","tone":"坚定","text":"大师若不弃，在下愿听调遣。","source_refs":[{"chapter":9,"line_start":234,"line_end":234,"text":"大师若不弃，在下愿听调遣。"}]},
    {"id":"dlg_09_029","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"dong_fang_liang","listener_name":"东方亮","tone":"赞许","text":"好，那便请施主守达摩院。","source_refs":[{"chapter":9,"line_start":236,"line_end":236,"text":"好，那便请施主守达摩院。"}]},
    {"id":"dlg_09_030","chapter":9,"speaker":"yuantong","speaker_name":"圆通","listener":"hike","listener_name":"慧可","tone":"恭敬","text":"师叔，了凡师兄求见。","source_refs":[{"chapter":9,"line_start":260,"line_end":260,"text":"师叔，了凡师兄求见。"}]},
    {"id":"dlg_09_031","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"yuantong","listener_name":"圆通","tone":"平静","text":"请他进来。","source_refs":[{"chapter":9,"line_start":262,"line_end":262,"text":"请他进来。"}]},
    {"id":"dlg_09_032","chapter":9,"speaker":"liaofan","speaker_name":"了凡","listener":"hike","listener_name":"慧可","tone":"恭敬","text":"师叔，方丈请您到大雄宝殿议事。","source_refs":[{"chapter":9,"line_start":280,"line_end":280,"text":"师叔，方丈请您到大雄宝殿议事。"}]},
    {"id":"dlg_09_033","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"liaofan","listener_name":"了凡","tone":"平淡","text":"知道了。","source_refs":[{"chapter":9,"line_start":282,"line_end":282,"text":"知道了。"}]},
    {"id":"dlg_09_034","chapter":9,"speaker":"lan_yu_jing","speaker_name":"蓝玉京","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"坚定","text":"灵妹，我意已决，你不必劝了。","source_refs":[{"chapter":9,"line_start":320,"line_end":320,"text":"灵妹，我意已决，你不必劝了。"}]},
    {"id":"dlg_09_035","chapter":9,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"lan_yu_jing","listener_name":"蓝玉京","tone":"痛苦","text":"哥哥，你当真不再回武当么？","source_refs":[{"chapter":9,"line_start":322,"line_end":322,"text":"哥哥，你当真不再回武当么？"}]},
    {"id":"dlg_09_036","chapter":9,"speaker":"lan_yu_jing","speaker_name":"蓝玉京","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"痛苦","text":"武当已无我立足之处。","source_refs":[{"chapter":9,"line_start":324,"line_end":324,"text":"武当已无我立足之处。"}]},
    {"id":"dlg_09_037","chapter":9,"speaker":"xi_men_yan","speaker_name":"西门燕","listener":"lan_yu_jing","listener_name":"蓝玉京","tone":"好奇","text":"蓝公子，你这一身武功当真要带入佛门么？","source_refs":[{"chapter":9,"line_start":340,"line_end":340,"text":"蓝公子，你这一身武功当真要带入佛门么？"}]},
    {"id":"dlg_09_038","chapter":9,"speaker":"lan_yu_jing","speaker_name":"蓝玉京","listener":"xi_men_yan","listener_name":"西门燕","tone":"平淡","text":"武功亦是佛法，施主着相了。","source_refs":[{"chapter":9,"line_start":342,"line_end":342,"text":"武功亦是佛法，施主着相了。"}]},
    {"id":"dlg_09_039","chapter":9,"speaker":"xi_men_yan","speaker_name":"西门燕","listener":"xi_men_fu_ren","listener_name":"西门夫人","tone":"撒娇","text":"娘，他说话总是文绉绉的！","source_refs":[{"chapter":9,"line_start":344,"line_end":344,"text":"娘，他说话总是文绉绉的！"}]},
    {"id":"dlg_09_040","chapter":9,"speaker":"xi_men_fu_ren","speaker_name":"西门夫人","listener":"xi_men_yan","listener_name":"西门燕","tone":"平淡","text":"燕儿，人家是得道高僧，自当敬重。","source_refs":[{"chapter":9,"line_start":346,"line_end":346,"text":"燕儿，人家是得道高僧，自当敬重。"}]},
    {"id":"dlg_09_041","chapter":9,"speaker":"yuanxing","speaker_name":"圆性","listener":"yuanye","listener_name":"圆业","tone":"急迫","text":"师兄，山下来了武当派的人！","source_refs":[{"chapter":9,"line_start":400,"line_end":400,"text":"师兄，山下来了武当派的人！"}]},
    {"id":"dlg_09_042","chapter":9,"speaker":"yuanye","speaker_name":"圆业","listener":"yuanxing","listener_name":"圆性","tone":"惊讶","text":"多少人？","source_refs":[{"chapter":9,"line_start":402,"line_end":402,"text":"多少人？"}]},
    {"id":"dlg_09_043","chapter":9,"speaker":"yuanxing","speaker_name":"圆性","listener":"yuanye","listener_name":"圆业","tone":"急迫","text":"约莫三十余众，为首的正是那不戒。","source_refs":[{"chapter":9,"line_start":404,"line_end":404,"text":"约莫三十余众，为首的正是那不戒。"}]},
    {"id":"dlg_09_044","chapter":9,"speaker":"hike","speaker_name":"慧可","listener":"tongchan_shangren","listener_name":"痛禅上人","tone":"庄重","text":"罗汉堂弟子听令，结阵迎敌。","source_refs":[{"chapter":9,"line_start":420,"line_end":420,"text":"罗汉堂弟子听令，结阵迎敌。"}]},
    {"id":"dlg_09_045","chapter":9,"speaker":"tongchan_shangren","speaker_name":"痛禅上人","listener":"hike","listener_name":"慧可","tone":"坚定","text":"是！","source_refs":[{"chapter":9,"line_start":422,"line_end":422,"text":"是！"}]},
    {"id":"dlg_09_046","chapter":9,"speaker":"lan_shui_ling","speaker_name":"蓝水灵","listener":"dong_fang_liang","listener_name":"东方亮","tone":"急迫","text":"东方大哥，让我助你守达摩院。","source_refs":[{"chapter":9,"line_start":450,"line_end":450,"text":"东方大哥，让我助你守达摩院。"}]},
    {"id":"dlg_09_047","chapter":9,"speaker":"dong_fang_liang","speaker_name":"东方亮","listener":"lan_shui_ling","listener_name":"蓝水灵","tone":"坚定","text":"灵妹小心！","source_refs":[{"chapter":9,"line_start":452,"line_end":452,"text":"灵妹小心！"}]},
    {"id":"dlg_09_048","chapter":9,"speaker":"xi_men_fu_ren","speaker_name":"西门夫人","listener":"xi_men_yan","listener_name":"西门燕","tone":"庄重","text":"燕儿，万不可轻出，你我守住方丈。","source_refs":[{"chapter":9,"line_start":480,"line_end":480,"text":"燕儿，万不可轻出，你我守住方丈。"}]},
    {"id":"dlg_09_049","chapter":9,"speaker":"xi_men_yan","speaker_name":"西门燕","listener":"xi_men_fu_ren","listener_name":"西门夫人","tone":"犹豫","text":"是，娘。","source_refs":[{"chapter":9,"line_start":482,"line_end":482,"text":"是，娘。"}]},
    {"id":"dlg_09_050","chapter":9,"speaker":"benwu_dashi","speaker_name":"本无大师","listener":"all","listener_name":"众人","tone":"庄重","text":"阿弥陀佛，诸位护法，少林存亡在此一举。","source_refs":[{"chapter":9,"line_start":500,"line_end":500,"text":"阿弥陀佛，诸位护法，少林存亡在此一举。"}]}
