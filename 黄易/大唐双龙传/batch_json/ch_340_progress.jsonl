{"segment":1,"line_start":1,"line_end":78,"dialogues":[],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_kou_zhong","updates":{"source_refs":[{"chapter":340,"line_start":3,"line_end":11,"text":"寇仲排除杂念，提升精气神至巅峰状态迎战婠婠。"},{"chapter":340,"line_start":19,"line_end":27,"text":"寇仲以正反之气化解天魔劲，破屋脱出婠婠包围。"},{"chapter":340,"line_start":35,"line_end":39,"text":"寇仲以正反之气反制天魔飘带吸收真气的特性。"},{"chapter":340,"line_start":47,"line_end":49,"text":"寇仲险被天魔劲反噬，临危肋斗翻腾避过婠婠追击。"},{"chapter":340,"line_start":55,"line_end":57,"text":"寇仲横刀而立，调整至最佳状态准备反扑。"},{"chapter":340,"line_start":61,"line_end":61,"text":"寇仲瞧婠婠天魔带化球网，头皮发麻下斜掠劈出。"}]}},{"id":"char_wan_wan","updates":{"source_refs":[{"chapter":340,"line_start":7,"line_end":9,"text":"婠婠不知寇仲近日突破，寇仲以此有利条件周旋。"},{"chapter":340,"line_start":15,"line_end":17,"text":"婠婠秀发飘扬如毒蛇，天魔袖化网笼罩寇仲。"},{"chapter":340,"line_start":23,"line_end":23,"text":"婠婠天魔劲透刀入侵寇仲经脉。"},{"chapter":340,"line_start":29,"line_end":33,"text":"婠婠凌空追杀寇仲，天魔带索喉，天魔大法扭曲空间。"},{"chapter":340,"line_start":37,"line_end":45,"text":"婠婠被寇仲正反之气所惑，天魔带化十多圈影继续追击。"},{"chapter":340,"line_start":51,"line_end":53,"text":"婠婠天魔飘带一化为二夹击，轻拂寇仲左腿但被逸出。"}]}},{"id":"char_xu_zi_ling","updates":{"source_refs":[{"chapter":340,"line_start":63,"line_end":73,"text":"徐子陵被祝玉妍以说话拖延，目睹天魁派弟子被屠。"},{"chapter":340,"line_start":75,"line_end":77,"text":"徐子陵心内滴血却只能对弟子惨状视而不见。"}]}},{"id":"char_zhu_yu_yan","updates":{"source_refs":[{"chapter":340,"line_start":63,"line_end":73,"text":"祝玉妍以荆州南阳地理形势之语拖延时间，让手下屠杀天魁弟子。"}]}},{"id":"skill_tian_mo_da_fa","updates":{"source_refs":[{"chapter":340,"line_start":29,"line_end":33,"text":"婠婠全力施展天魔大法，天魔带索喉，扭曲空间令人无法用力。"},{"chapter":340,"line_start":41,"line_end":45,"text":"天魔气以无形之力盗取敌人有实之质，婠婠加送真气并鬼魅移位的天魔飘带攻击。"}]}}]}
{"segment":2,"line_start":79,"line_end":156,"dialogues":[{"speaker":"char_zhu_yu_yan","speaker_name":"祝玉妍","listener":"char_xu_zi_ling","text":"荆州一地，在南北分裂时向为南方政权必争之地，故有'南方之命，悬于荆州'之语，实乃南方盛衷之关键。南阳乃荆州北部要塞，交通便利，地势险固，户口繁盛。我们既得襄阳，若再取南阳，将成犄角之势，互为呼应。你两人不知好歹，竟敢来坏我们的大事，实咎由自取，勿怪我们不顾协定。","tone":"柔声","chapter":340,"line_start":63,"line_end":71},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_zhu_yu_yan","text":"徐某人今日若幸能突围逃生，日后对祝宗主今晚的残酷手段，必有回报。","tone":"沉声","chapter":340,"line_start":81,"line_end":83},{"speaker":"char_zhu_yu_yan","speaker_name":"祝玉妍","listener":"char_xu_zi_ling","text":"好胆！你们妄想可像以前般风光吗？","tone":"冷笑","chapter":340,"line_start":85,"line_end":85},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_wan_wan","text":"涫美人中计啦！","tone":"大笑","chapter":340,"line_start":117,"line_end":117},{"speaker":"char_wan_wan","speaker_name":"婠婠","listener":"char_kou_zhong","text":"看你还有甚么伎俩。","tone":"嘲讽","chapter":340,"line_start":121,"line_end":121}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_kou_zhong","updates":{"source_refs":[{"chapter":340,"line_start":99,"line_end":99,"text":"寇仲刀锋画带化解婠婠飘带杀着。"},{"chapter":340,"line_start":105,"line_end":109,"text":"寇仲想起李元吉回马枪法，井中月生拖扯之力。"},{"chapter":340,"line_start":117,"line_end":117,"text":"寇仲笑称涫美人中计，顺劲逸出飘带纠缠。"},{"chapter":340,"line_start":123,"line_end":127,"text":"寇仲被婠婠欺入怀里，骇然疾退，刀挑刀柄挫开双斩。"},{"chapter":340,"line_start":137,"line_end":145,"text":"寇仲以新悟身法周旋婠婠天魔双斩，背肌被秀发打出血痕，断线抛跌。"},{"chapter":340,"line_start":147,"line_end":153,"text":"寇仲灵光一闪贴地附于马车底逸走。"}]}},{"id":"char_wan_wan","updates":{"source_refs":[{"chapter":340,"line_start":101,"line_end":109,"text":"婠婠吃惊寇仲刀法变化，施展纤手驭龙杀着，被寇仲拖刀力破解。"},{"chapter":340,"line_start":121,"line_end":141,"text":"婠婠娇哼嘲讽，旋身欺入，天魔双斩水银泻地贴身攻击，秀发亦可为武器。"},{"chapter":340,"line_start":143,"line_end":145,"text":"婠婠秀发挥打寇仲背肌造成数十道血痕。"},{"chapter":340,"line_start":147,"line_end":155,"text":"婠婠天魔双斩当头罩下，误中寇仲车底计，怒叱追赶马车。"}]}},{"id":"char_xu_zi_ling","updates":{"source_refs":[{"chapter":340,"line_start":81,"line_end":83,"text":"徐子陵沉声警告祝玉妍若不死必有回报。"}]}},{"id":"char_zhu_yu_yan","updates":{"source_refs":[{"chapter":340,"line_start":85,"line_end":95,"text":"祝玉妍冷笑回应，伸出玉手遥点，天魔音魔相魔功齐发。"}]}},{"id":"skill_tian_mo_da_fa","updates":{"source_refs":[{"chapter":340,"line_start":91,"line_end":95,"text":"祝玉妍全力展开天魔大法，天魔音化为天籁妙韵，无隙不入进攻。"}]}},{"id":"tech_qian_shou_yu_long","updates":{"source_refs":[{"chapter":340,"line_start":109,"line_end":109,"text":"婠婠施出天魔带最凌厉杀着纤手驭龙。"}]}}]}
{"segment":3,"line_start":157,"line_end":233,"dialogues":[],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_kou_zhong","updates":{"source_refs":[{"chapter":340,"line_start":157,"line_end":171,"text":"寇仲解马分离引开婠婠，反手刀扫飘带，借马力逸走，婠婠颓然放弃。"}]}},{"id":"char_wan_wan","updates":{"source_refs":[{"chapter":340,"line_start":157,"line_end":171,"text":"婠婠天魔带电射卷马腿被寇仲反刀扫中，力战后真元损耗过大，速度减缓，无奈放弃追击。"}]}},{"id":"char_xu_zi_ling","updates":{"source_refs":[{"chapter":340,"line_start":173,"line_end":181,"text":"徐子陵暗捏不动根本印，破解祝玉妍魔音魔相，以澄明心境应对。"},{"chapter":340,"line_start":185,"line_end":189,"text":"徐子陵以大金刚轮印、外狮子印、内狮子印硬挡祝玉妍三袖，狠拼一掌被震伤吐血。"},{"chapter":340,"line_start":189,"line_end":193,"text":"徐子陵闪过祝玉妍裙底脚，闪至其身后千万掌影反攻，被拂退。"},{"chapter":340,"line_start":201,"line_end":205,"text":"徐子陵因扮岳山时见过祝玉妍真容，假装被惑，暗捏不动根本印等待反击机会。"},{"chapter":340,"line_start":209,"line_end":223,"text":"徐子陵一拳击出震退祝玉妍，勉力倒纵运转真气恢复视听。"},{"chapter":340,"line_start":229,"line_end":233,"text":"徐子陵自知无力回天，准备撤离，祝玉妍飞临头顶全力下击。"}]}},{"id":"char_zhu_yu_yan","updates":{"source_refs":[{"chapter":340,"line_start":173,"line_end":173,"text":"祝玉妍天魔音魔相魔功被徐子陵不动根本印破解。"},{"chapter":340,"line_start":191,"line_end":199,"text":"祝玉妍旋身拂袖驱散徐子陵掌影，吹香气，扬起重纱露出玉容，舞动吟唱施展天魔大法魅惑。"},{"chapter":340,"line_start":213,"line_end":221,"text":"祝玉妍指化掌劈中徐子陵拳侧，被震横飘，所发天魔功惊天动地。"},{"chapter":340,"line_start":233,"line_end":233,"text":"祝玉妍飞临徐子陵头顶，双掌全力下击。"}]}},{"id":"skill_jiu_zi_zhen_yin","updates":{"source_refs":[{"chapter":340,"line_start":173,"line_end":173,"text":"徐子陵暗捏不动根本印破解祝玉妍天魔音魔相。"},{"chapter":340,"line_start":181,"line_end":185,"text":"徐子陵以大金刚轮印、外狮子印、内狮子印硬挡祝玉妍三袖。"},{"chapter":340,"line_start":205,"line_end":221,"text":"徐子陵暗捏不动根本印假装被惑，一拳震退祝玉妍。"}]}},{"id":"skill_tian_mo_da_fa","updates":{"source_refs":[{"chapter":340,"line_start":187,"line_end":187,"text":"天魔功如狂涛怒潮冲来，徐子陵喷血后退。"},{"chapter":340,"line_start":195,"line_end":199,"text":"祝玉妍天魔大法魅惑术：玉容表情、吟唱舞动、空气中直钻心脾的清香，能惑佛门高僧。"},{"chapter":340,"line_s