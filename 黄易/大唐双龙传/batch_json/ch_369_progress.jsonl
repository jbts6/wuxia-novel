{"segment":4,"line_start":47,"line_end":107,"dialogues":[{"speaker":"char_lao_fu_ren","speaker_name":"老夫人","listener":"char_sha_tian_nan","text":"老爷觉得怎样呢？","tone":"担心","chapter":369,"line_start":49,"line_end":49},{"speaker":"char_sha_tian_nan","speaker_name":"沙天南","listener":"char_kou_zhong","text":"莫先生真是老夫的救命恩人，我现在的感觉就像从没患过病般，天下间竟真有这么神奇的医术。","tone":"欣慰","chapter":369,"line_start":55,"line_end":57},{"speaker":"char_lao_fu_ren","speaker_name":"老夫人","listener":null,"text":"谢天谢地！老爷真的好了啦！","tone":"激动","chapter":369,"line_start":63,"line_end":63},{"speaker":"char_sha_zhi_jing","speaker_name":"沙芷菁","listener":"char_lao_fu_ren","text":"娘啊！该先谢莫先生才对！","tone":"欣喜","chapter":369,"line_start":65,"line_end":65},{"speaker":"char_lao_fu_ren","speaker_name":"老夫人","listener":null,"text":"是的！啊！该先谢天地让我们遇上莫神医才对。","tone":"激动","chapter":369,"line_start":67,"line_end":69},{"speaker":"char_kou_zhong","speaker_name":"寇仲(莫一心)","listener":"char_sha_tian_nan","text":"老爷请稍作休息，一心失陪了啦！","tone":"陈述","chapter":369,"line_start":71,"line_end":73},{"speaker":"char_sha_zhi_jing","speaker_name":"沙芷菁","listener":"char_kou_zhong","text":"这是拜师之礼，师傅万勿推却。","tone":"微笑","chapter":369,"line_start":77,"line_end":79},{"speaker":"char_kou_zhong","speaker_name":"寇仲(莫一心)","listener":"char_sha_zhi_jing","text":"五小姐说笑了，我只是碰巧治好令尊的病吧！","tone":"苦笑","chapter":369,"line_start":83,"line_end":85},{"speaker":"char_sha_zhi_jing","speaker_name":"沙芷菁","listener":"char_kou_zhong","text":"难道昨晚你治好二嫂也是碰巧吗？","tone":"调侃","chapter":369,"line_start":89,"line_end":89},{"speaker":"char_cheng_bi_su","speaker_name":"程碧素","listener":"char_kou_zhong","text":"莫先生就像他叔叔般，都是从不肯邀功的谦谦君子。济世救人的大医师。","tone":"欣慰","chapter":369,"line_start":91,"line_end":93},{"speaker":"char_chen_lai_man","speaker_name":"陈来满","listener":"char_kou_zhong","text":"莫先生真是目光如炬，那艘只是途经的船，越过我们迳徙关中驶去。船上的人还向我们问好。","tone":"陈述","chapter":369,"line_start":95,"line_end":97},{"speaker":"char_kou_zhong","speaker_name":"寇仲(莫一心)","listener":"char_chen_lai_man","text":"只是凑巧猜中吧！","tone":"陈述","chapter":369,"line_start":99,"line_end":101},{"speaker":"char_chen_lai_man","speaker_name":"陈来满","listener":"char_kou_zhong","text":"来！我们到厅中喝酒，毛老师在等待哩！","tone":"微笑","chapter":369,"line_start":103,"line_end":105}],"new_entities":{"characters":[{"id":"char_sha_tian_nan","name":"沙天南","alias":[],"identity":"关中富商，沙家之主","faction":"沙家","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"关中富商，被寇仲以莫一心身份治愈顽疾","personality":{"traits":["豪爽","感恩","精明","讲信誉","重家庭"],"speech_style":"豪迈","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":53,"line_end":55,"text":"沙天南在床沿坐直身体"}]},{"id":"char_lao_fu_ren","name":"老夫人","alias":["沙夫人","老夫人"],"identity":"沙天南之妻，沙家老夫人","faction":"沙家","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"沙天南之妻，对丈夫康复感激涕零","personality":{"traits":["慈祥","感恩","热情","重感情","虔诚"],"speech_style":"激动","temperament":"外向"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":49,"line_end":49,"text":"老夫人关切的道"}]},{"id":"char_sha_zhi_jing","name":"沙芷菁","alias":["五小姐"],"identity":"沙家五小姐","faction":"沙家","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"沙家五小姐，拜寇仲（莫一心）为师","personality":{"traits":["聪慧","活泼","好学","热情","细心"],"speech_style":"欣喜","temperament":"外向"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":51,"line_end":51,"text":"沙芷菁"}]},{"id":"char_cheng_bi_su","name":"程碧素","alias":["二嫂","二少夫人"],"identity":"沙家二少夫人","faction":"沙家","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"沙家二少夫人，儿子被徐子陵所救","personality":{"traits":["温婉","感恩","善良","谦和","知礼"],"speech_style":"柔声","temperament":"温柔"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":51,"line_end":51,"text":"参夫人程碧素"}]},{"id":"char_chen_lai_man","name":"陈来满","alias":[],"identity":"沙家随从武师","faction":"沙家","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"沙家随从，负责护送寇仲入关中","personality":{"traits":["热情","豪爽","忠厚","善交际","乐观"],"speech_style":"豪迈","temperament":"外向"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":95,"line_end":95,"text":"陈来满搭上他肩头"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[{"id":"char_kou_zhong","updates":{"alias":["莫一心"],"one_line":"以莫一心身份在长安行医的神医","source_refs":[{"chapter":369,"line_start":53,"line_end":55,"text":"莫先生真是老夫的救命恩人"}]},"relationship_updates":[]},{"id":"char_xu_zi_ling","updates":{"source_refs":[{"chapter":369,"line_start":3,"line_end":5,"text":"徐子陵为熟知环境"}]},"relationship_updates":[]}]}
{"segment":5,"line_start":108,"line_end":199,"dialogues":[{"speaker":"char_mao_shi_chang","speaker_name":"毛世昌","listener":null,"text":"乾杯！终到关中哩！过了河防，再个把时辰工夫，可在长安继续喝酒！兄弟们！饮酒！","tone":"豪迈","chapter":369,"line_start":115,"line_end":117},{"speaker":"char_lei_jiu_zhi","speaker_name":"雷九指","listener":"char_xu_zi_ling","text":"这一杯是老哥我贺你安然抵达长安的。","tone":"微笑","chapter":369,"line_start":125,"line_end":125},{"speaker":"char_lei_jiu_zhi","speaker_name":"雷九指","listener":"char_xu_zi_ling","text":"不怕告诉老弟你，我曾在明堂窝'大仙'胡佛手上吃过大亏，论赌技，找和他只在伯仲之间，但他却占上地头之利，加上赌本雄厚，所以我以一着之差败走。今趟重来，除了要把香贵父子引出来，还要向胡佛洗雪前耻。","tone":"无奈","chapter":369,"line_start":131,"line_end":135},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_lei_jiu_zhi","text":"雷老哥是否准备和'大仙'胡佛再一较高下。","tone":"疑问","chapter":369,"line_start":137,"line_end":139},{"speaker":"char_lei_jiu_zhi","speaker_name":"雷九指","listener":"char_xu_zi_ling","text":"在赌桌上我对他失了信心和锐气，这心理上的阴影，将使我难以再挥自如，所以只能把报仇的希望，寄托在你这青出于蓝的高徒身上。你怎么也要为找出这口鸟气。","tone":"苦笑","chapter":369,"line_start":139,"line_end":141},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_lei_jiu_zhi","text":"我怎么行！雷老哥在说笑吧！","tone":"惊讶","chapter":369,"line_start":143,"line_end":143},{"speaker":"char_lei_jiu_zhi","speaker_name":"雷九指","listener":"char_xu_zi_ling","text":"怎会是说笑。你就当是赴考科举试场，只要你能赢得关中赌界第一名家'大仙'胡佛，立即声名鹊起，再挟馀威斗垮香贵父子在这开设的另一间与'明堂窝'齐名的'六福赌馆'，香贵将不得不现身来会你。如不能把你击败，他会以重金将你收买作手下，那时你可混进他的窝里去。","tone":"严肃","chapter":369,"line_start":145,"line_end":149},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_lei_jiu_zhi","text":"这怎么行，我根本就不是赌钱的料了。","tone":"无奈","chapter":369,"line_start":151,"line_end":151},{"speaker":"char_lei_jiu_zhi","speaker_name":"雷九指","listener":"char_xu_zi_ling","text":"我从末见过有人像你般在赌桌上仍能保持冰雪般的冷静，论灵活变化，随机应变更是无人能及。加上我传授的技艺，再增添些临场经验，保证明堂窝也要给你赢回来。现在万事俱备，只欠赌本。不过若能起出杨公宝藏，还怕没本钱去赌吗？","tone":"微笑","chapter":369,"line_start":153,"line_end":159},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_lei_jiu_zhi","text":"你这如意算盘未必打得响，照我看能找到宝藏的机会微乎其微，一切待寇仲来到才说吧。","tone":"苦笑","chapter":369,"line_start":161,"line_end":163},{"speaker":"char_lei_jiu_zhi","speaker_name":"雷九指","listener":"char_xu_zi_ling","text":"照我看你气色甚佳，时来运到下，何事不成。不如我们今晚先去明堂窝踩踩场子，长安的达官贵人、公子贵介，谁不到那里趁热闹？","tone":"微笑","chapter":369,"line_start":165,"line_end":169},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_lei_jiu_zhi","text":"今晚不行！我想先去见李渊。","tone":"陈述","chapter":369,"line_start":171,"line_end":171},{"speaker":"char_lei_jiu_zhi","speaker_name":"雷九指","listener":"char_xu_zi_ling","text":"甚么？","tone":"惊讶","chapter":369,"line_start":173,"line_end":173},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_lei_jiu_zhi","text":"究竟怎样才见得到皇宫内苑的皇帝呢？登门求见肯定是不成，只是徒给李建成、晃公错等一个布局杀我的机会。","tone":"无奈","chapter":369,"line_start":175,"line_end":179},{"speaker":"char_lei_jiu_zhi","speaker_name":"雷九指","listener":"char_xu_zi_ling","text":"这事我真的没法帮你忙，皇宫内岗哨重重，要偷进去根本无此可能。就算你有本领潜人去，偌大的里宫到那里去找李渊？","tone":"无奈","chapter":369,"line_start":181,"line_end":183},{"speaker":"char_xiao_xiu_ming","speaker_name":"肖修明","listener":"char_xu_zi_ling","text":"幸好莫兄真的在这里喝茶，否则都不知该到那里找你。","tone":"欣喜","chapter":369,"line_start":185,"line_end":187},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_xiao_xiu_ming","text":"有甚么急事？","tone":"疑问","chapter":369,"line_start":189,"line_end":189},{"speaker":"char_xiao_xiu_ming","speaker_name":"肖修明","listener":"char_xu_zi_ling","text":"封大人要见你啊！","tone":"陈述","chapter":369,"line_start":191,"line_end":191}],"new_entities":{"characters":[{"id":"char_lei_jiu_zhi","name":"雷九指","alias":[],"identity":"赌术高手，徐子陵赌术师父","faction":"无","role":"npc","archetype":"scholar","rank":"略有小成","one_line":"赌术高手，曾败于大仙胡佛，欲借徐子陵之手复仇","personality":{"traits":["豪爽","精明","执着","好胜","足智多谋"],"speech_style":"豪迈","temperament":"外向"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":125,"line_end":125,"text":"雷九指低笑道"}]},{"id":"char_mao_shi_chang","name":"毛世昌","alias":[],"identity":"沙家武师头目","faction":"沙家","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"沙家武师头目，护送寇仲入关中","personality":{"traits":["豪迈","忠厚","好酒","直爽","热情"],"speech_style":"豪迈","temperament":"外向"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":109,"line_end":109,"text":"毛世昌和二位较有地位的武师"}]},{"id":"char_xiao_xiu_ming","name":"肖修明","alias":[],"identity":"封德彝的信使","faction":"唐朝","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"封德彝的信使，称徐子陵为莫兄","personality":{"traits":["机灵","热情","忠诚","周到","善言"],"speech_style":"欣喜","temperament":"外向"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":185,"line_end":185,"text":"肖修明匆匆而来"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_ming_tang_wo","name":"明堂窝","type":"帮派","location":"长安","sub_divisions":[],"one_line":"关中第一名家赌馆，由大仙胡佛主持","source_refs":[{"chapter":369,"line_start":131,"line_end":133,"text":"明堂窝'大仙'胡佛"}]}],"locations":[],"items":[]},"entity_updates":[{"id":"char_xu_zi_ling","updates":{"source_refs":[{"chapter":369,"line_start":127,"line_end":129,"text":"徐子陵把入关前后的情况迅速述说一遍"}]},"relationship_updates":[]}]}
{"segment":6,"line_start":200,"line_end":243,"dialogues":[{"speaker":"char_sha_fu","speaker_name":"沙福","listener":"char_kou_zhong","text":"要见你的是四姑爷，当他听到莫先生医术如神，立即要把你请来相会。","tone":"低语","chapter":369,"line_start":199,"line_end":201},{"speaker":"char_sha_tian_nan","speaker_name":"沙天南","listener":null,"text":"来！大家坐好再详谈。","tone":"豪迈","chapter":369,"line_start":207,"line_end":209},{"speaker":"char_sha_tian_nan","speaker_name":"沙天南","listener":"char_kou_zhong","text":"得少婿告知后，莫先生今次到长安，必能大展悬壶济世的抱负。","tone":"欣慰","chapter":369,"line_start":219,"line_end":221},{"speaker":"char_chang_he","speaker_name":"常何","listener":"char_kou_zhong","text":"事情是这样的，皇上的宠妃张娘娘忽罹患怪疾，这个月来茶饭不思，日渐消瘦，群医束手，连有关中医神之称的'活华陀'韦正兴也治不好她的病，使得皇上终日愁眉不展。幸好莫神医来了，只要能治好张娘娘的病，不但是我们沙家莫人的荣耀，莫先生更可有享不尽的富贵荣华呢。","tone":"陈述","chapter":369,"line_start":223,"line_end":227},{"speaker":"char_kou_zhong","speaker_name":"寇仲(莫一心)","listener":"char_chang_he","text":"多谢常爷给鄙人这天大的良机，鄙人必尽心尽力，治好张娘娘的病，不负常爷之托。","tone":"陈述","chapter":369,"line_start":233,"line_end":235},{"speaker":"char_sha_cheng_jiu","speaker_name":"沙成就","listener":null,"text":"这一杯就祝莫神医妙手回春，治好娘娘的病。","tone":"豪迈","chapter":369,"line_start":237,"line_end":239}],"new_entities":{"characters":[{"id":"char_sha_fu","name":"沙福","alias":[],"identity":"沙家仆人","faction":"沙家","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"沙家仆人，负责传话引见","personality":{"traits":["忠诚","恭敬","细心","谨慎","周到"],"speech_style":"低语","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":199,"line_end":199,"text":"沙福低声道"}]},{"id":"char_chang_he","name":"常何","alias":["四姑爷"],"identity":"禁卫军官，沙家四姑爷","faction":"唐朝","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"禁卫军官，沙家四姑爷，举荐寇仲入宫医治张贵妃","personality":{"traits":["年轻有为","进取","恭敬","自信","重情"],"speech_style":"温和","temperament":"自信"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":211,"line_end":213,"tex