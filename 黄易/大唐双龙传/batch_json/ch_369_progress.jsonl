{"segment":1,"line_start":1,"line_end":100,"dialogues":[],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_xi_shi","name":"西市","region":"长安","one_line":"长安西市","source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"西市"}]},{"id":"loc_zhu_que_da_jie","name":"朱雀大街","region":"长安","one_line":"长安朱雀大街","source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"朱雀大街"}]},{"id":"loc_wang_xian","name":"望仙","region":"长安","one_line":"长安望仙街","source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"望仙"}]},{"id":"loc_qi_yu","name":"启与","region":"长安","one_line":"长安启与街","source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"启与"}]},{"id":"loc_he_an","name":"和安","region":"长安","one_line":"长安和安街","source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"和安"}]},{"id":"loc_dong_shi","name":"东市","region":"长安","one_line":"长安东市","source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"东市"}]},{"id":"loc_xing_an_long","name":"兴安隆","region":"关中","one_line":"兴安隆总堂","source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"兴安隆"}]},{"id":"loc_guan_zhong","name":"关中","region":"关中","one_line":"关中地区","source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"关中"}]}],"items":[{"id":"item_jiu_zhi_jiu_zhen","name":"九枝灸针","type":"special","owner":"char_kou_zhong","one_line":"装有九枝灸针的铜盒，沙家拜师礼","description":"装有九枝灸针的铜盒，寇仲冒充神医莫一心时在沙家获得的重要工具，是他在长安行医谋生的关键道具","effects":["用于针灸治疗"],"origin":"沙家赠送","rarity":"稀世珍品","related_characters":["char_kou_zhong"],"related_skills":[],"rag_refs":[369],"source_refs":[{"chapter":369,"line_start":1,"line_end":100,"text":"九枝灸针的铜盒"}]}]},"entity_updates":[]}
