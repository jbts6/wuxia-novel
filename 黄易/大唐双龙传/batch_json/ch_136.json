      "line_end": 21
    },
    {
      "speaker": "char_ba_feng_han",
      "speaker_name": "跋锋寒",
      "listener": null,
      "text": "徐师傅教训得好。",
      "tone": "大笑",
      "chapter": 136,
      "line_start": 27,
      "line_end": 27
    },
    {
      "speaker": "char_kou_zhong",
      "speaker_name": "寇仲",
      "listener": null,
      "text": "怎么走？",
      "tone": "大笑",
      "chapter": 136,
      "line_start": 79,
      "line_end": 79
    },
    {
      "speaker": "char_kou_zhong",
      "speaker_name": "寇仲",
      "listener": null,
      "text": "不若我们先去偃师吧！",
      "tone": "陈述",
      "chapter": 136,
      "line_start": 93,
      "line_end": 93
    },
    {
      "speaker": "char_ba_feng_han",
      "speaker_name": "跋锋寒",
      "listener": null,
      "text": "你不是要赶着到洛阳去吗？",
      "tone": "疑问",
      "chapter": 136,
      "line_start": 97,
      "line_end": 97
    },
    {
      "speaker": "char_kou_zhong",
      "speaker_name": "寇仲",
      "listener": null,
      "text": "想不到你这么够朋友。",
      "tone": "陈述",
      "chapter": 136,
      "line_start": 109,
      "line_end": 109
    },
    {
      "speaker": "char_ba_feng_han",
      "speaker_name": "跋锋寒",
      "listener": null,
      "text": "村内有人！",
      "tone": "低语",
      "chapter": 136,
      "line_start": 115,
      "line_end": 115
    },
    {
      "speaker": "char_xu_zi_ling",
      "speaker_name": "徐子陵",
      "listener": null,
      "text": "我也感到有点不妥当，老跋你有甚么发现呢？",
      "tone": "疑问",
      "chapter": 136,
      "line_start": 119,
      "line_end": 119
    },
    {
      "speaker": "char_kou_zhong",
      "speaker_name": "寇仲",
      "listener": null,
      "text": "会是谁呢？",
      "tone": "疑问",
      "chapter": 136,
      "line_start": 125,
      "line_end": 125
    },
    {
      "speaker": "char_kou_zhong",
      "speaker_name": "寇仲",
      "listener": null,
      "text": "小陵说得有理。怎么样？我们是否该绕道走呢？",
      "tone": "疑问",
      "chapter": 136,
      "line_start": 131,
      "line_end": 131
    },
    {
      "speaker": "char_kou_zhong",
      "speaker_name": "寇仲",
      "listener": null,
      "text": "恁多废话，走便走吧！",
      "tone": "大笑",
      "chapter": 136,
      "line_start": 137,
      "line_end": 137
    },
    {
      "speaker": "char_kou_zhong",
      "speaker_name": "寇仲",
      "listener": null,
      "text": "相当不错",
      "tone": "陈述",
