hetype":"scholar","rank":"登堂入室","one_line":"李世民心腹谋士，护卫左右","personality":{"traits":["智谋","沉稳","忠诚","谨慎","博学"],"speech_style":"温和","temperament":"沉稳"},"relationships":[{"target":"char_li_shi_min","type":"合作者","intensity":85,"bond_level":4,"dynamic":"辅佐"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":33,"line_end":33,"text":"陪坐在李世民身后半丈许外的庞玉，长孙无忌和尉迟敬德"}]},{"id":"char_yu_chi_jing_de","name":"尉迟敬德","alias":[],"identity":"李世民麾下猛将","faction":"李阀","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"李世民麾下猛将，勇武过人","personality":{"traits":["勇猛","刚直","忠诚","豪爽","暴烈"],"speech_style":"豪迈","temperament":"刚烈"},"relationships":[{"target":"char_li_shi_min","type":"主仆","intensity":80,"bond_level":4,"dynamic":"忠心"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":33,"line_end":33,"text":"长孙无忌和尉迟敬德"}]},{"id":"char_lang_feng","name":"郎奉","alias":[],"identity":"王世充麾下将领","faction":"王世充势力","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"王世充麾下将领","personality":{"traits":["忠诚","勇猛","沉稳","果断","务实"],"speech_style":"严肃","temperament":"沉稳"},"relationships":[{"target":"char_wang_shi_chong","type":"主仆","intensity":70,"bond_level":3,"dynamic":"效力"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":55,"line_end":55,"text":"郎奉、宋蒙秋、王玄应等先后纵身而起"}]},{"id":"char_song_meng_qiu","name":"宋蒙秋","alias":[],"identity":"王世充麾下将领","faction":"王世充势力","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"王世充麾下将领","personality":{"traits":["忠诚","勇猛","务实","沉稳","果断"],"speech_style":"严肃","temperament":"沉稳"},"relationships":[{"target":"char_wang_shi_chong","type":"主仆","intensity":70,"bond_level":3,"dynamic":"效力"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":55,"line_end":55,"text":"郎奉、宋蒙秋、王玄应等先后纵身而起"}]},{"id":"char_wang_xuan_ying","name":"王玄应","alias":["太子"],"identity":"王世充之子，太子","faction":"王世充势力","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"王世充之子，被寇仲徐子陵擒获","personality":{"traits":["怯懦","无能","跋扈","贪生怕死","外强中干"],"speech_style":"慌张","temperament":"暴躁"},"relationships":[{"target":"char_wang_shi_chong","type":"亲属","intensity":80,"bond_level":4,"dynamic":"父子"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":85,"line_end":91,"text":"王玄应不住踉跄，脸上血色尽退"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":102,"line_end":200,"dialogues":[{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":null,"text":"全部给我住手。","tone":"厉声","chapter":225,"line_start":107,"line_end":109},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"世充小儿，世民小子，今趟服输了吧！","tone":"大笑","chapter":225,"line_start":111,"line_end":113},{"speaker":"char_li_shi_min","speaker_name":"李世民","listener":null,"text":"仲兄和子陵兄鬼神莫测的手段，确令人不得不服。","tone":"微笑","chapter":225,"line_start":123,"line_end":125},{"speaker":"char_li_shi_min","speaker_name":"李世民","listener":"char_shang_xiu_fang","text":"尚小姐受惊了，请回座位稍息。","tone":"温柔","chapter":225,"line_start":127,"line_end":127},{"speaker":"char_rong_feng_xiang","speaker_name":"荣凤祥","listener":null,"text":"你们是如何进来的？","tone":"冷笑","chapter":225,"line_start":131,"line_end":133},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"何来这么多废话！","tone":"淡然","chapter":225,"line_start":137,"line_end":137},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_wang_shi_chong","text":"不用我说圣上你也该知道怎办吧！小弟一向都是没有耐性的人哩！","tone":"嘲讽","chapter":225,"line_start":139,"line_end":141},{"speaker":"char_wang_shi_chong","speaker_name":"王世充","listener":null,"text":"把虚行之抓来！","tone":"愤怒","chapter":225,"line_start":143,"line_end":143},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_wang_shi_chong","text":"快给小弟找条像样点的快船，船过偃师后我便放人，其他条件均不会接受，明白吗？","tone":"严肃","chapter":225,"line_start":147,"line_end":149},{"speaker":"char_xu_xing_zhi","speaker_name":"虚行之","listener":null,"text":"我从王世充大封亲族部下，却独漏了仲爷，便知他要施展毒手加害两位爷儿，于是趁着出差金墉，乘机溜往偃师找你们，岂知却是失诸交臂。","tone":"陈述","chapter":225,"line_start":161,"line_end":163},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_xu_xing_zhi","text":"照我看王世充仍想重用虚先生，否则以他豺狼之性，该命人把你就地处决。","tone":"认真","chapter":225,"line_start":165,"line_end":167},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"那他的宝贝太子也完了。","tone":"冷笑","chapter":225,"line_start":169,"line_end":169},{"speaker":"char_xu_xing_zhi","speaker_name":"虚行之","listener":null,"text":"对这种刻薄寡恩的人，我宁死也不会为他出力。像仲爷和陵爷的义薄云天，为了别人而不顾自身安危的英雄豪杰，我虚行之就算要赔上小命，也心甘情愿。","tone":"认真","chapter":225,"line_start":171,"line_end":174},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"今趟其实险至极点，荣凤祥的武功不但高得离奇，还有种诡异邪秘的味道，非是正宗的路子，差点便教我们功亏一篑。","tone":"陈述","chapter":225,"line_start":177,"line_end":179},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":null,"text":"我还以为是自己的错觉，想不到你也有同感。表面看他的手法大开大阖，但其中暗含诡邪的招数，且有所保留，像在隐瞒甚么的样子，其中当有不可告人的秘密。","tone":"陈述","chapter":225,"line_start":181,"line_end":184},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"我和他动手时，虽只是两个照面，但却感到他的眼神有似曾相识的感觉。此事非常奇怪，为何我以前遇上他时，并没有这种感觉呢？","tone":"疑问","chapter":225,"line_start":187,"line_end":190},{"speaker":"char_xu_xing_zhi","speaker_name":"虚行之","listener":null,"text":"那应是他平时蓄意敛藏眼内光芒，动手时由于真气运行，再藏不住。如此推之，仲爷以前定曾遇过他，只不过不是他现在这副脸孔而已。","tone":"认真","chapter":225,"line_start":193,"line_end":196},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":null,"text":"虚先生这番话很有道理，荣凤祥这人根本没有立场，似乎何方势大便靠向何方，心怀叵测。","tone":"陈述","chapter":225,"line_start":199,"line_end":200}],"new_entities":{"characters":[{"id":"char_rong_feng_xiang","name":"荣凤祥","alias":[],"identity":"洛阳豪商，实为辟尘伪装","faction":"辟尘势力","role":"villain","archetype":"assassin","rank":"出神入化","one_line":"洛阳豪商，武功诡异邪秘，实为辟尘妖道伪装","personality":{"traits":["狡诈","阴险","深藏不露","心怀叵测","伪装高手"],"speech_style":"冷笑","temperament":"阴沉"},"relationships":[{"target":"char_pi_chen","type":"亲属","intensity":100,"bond_level":5,"dynamic":"同一人"},{"target":"char_rong_jiao_jiao","type":"亲属","intensity":70,"bond_level":3,"dynamic":"父女（伪）"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":57,"line_end":67,"text":"动作最快的是居于王玄应邻席的荣凤祥"}]},{"id":"char_xu_xing_zhi","name":"虚行之","alias":["虚先生"],"identity":"谋士，投奔寇仲","faction":"双龙帮","role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"王世充旧部谋士，弃暗投明追随寇仲","personality":{"traits":["智谋","忠诚","果断","识人","义气"],"speech_style":"温和","temperament":"沉稳"},"relationships":[{"target":"char_kou_zhong","type":"合作者","intensity":80,"bond_level":4,"dynamic":"投效"},{"target":"char_wang_shi_chong","type":"宿敌","intensity":60,"bond_level":3,"dynamic":"决裂"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":161,"line_end":163,"text":"虚行之道"}]},{"id":"char_rong_jiao_jiao","name":"荣姣姣","alias":[],"identity":"荣凤祥之女（伪）","faction":"辟尘势力","role":"npc","archetype":"assassin","rank":"登堂入室","one_line":"荣凤祥之女，武功高明","personality":{"traits":["狡诈","武功高强","神秘","机敏","狠辣"],"speech_style":"冷酷","temperament":"阴沉"},"relationships":[{"target":"char_rong_feng_xiang","type":"亲属","intensity":70,"bond_level":3,"dynamic":"父女（伪）"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":81,"line_end":81,"text":"荣姣姣高明的身手"}]},{"id":"char_yang_xu_yan","name":"杨虚彦","alias":[],"identity":"身份可疑的刺客","faction":"辟尘势力","role":"villain","archetype":"assassin","rank":"出神入化","one_line":"身份可疑，与辟尘势力有关","personality":{"traits":["神秘","阴险","武功高强","城府深","野心"],"speech_style":"冷酷","temperament":"阴沉"},"relationships":[{"target":"char_pi_chen","type":"合作者","intensity":60,"bond_level":3,"dynamic":"同党"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":219,"line_end":219,"text":"杨虚彦的出身更是可疑"}]},{"id":"char_dong_shu_ni","name":"董淑妮","alias":[],"identity":"身份复杂的女子","faction":"未知","role":"npc","archetype":"assassin","rank":"登堂入室","one_line":"身份复杂，与多方势力有关","personality":{"traits":["狡诈","神秘","城府深","机敏","多面"],"speech_style":"温柔","temperament":"阴沉"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":219,"line_end":219,"text":"甚至连董淑妮都大不简单"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_yan_shi","name":"偃师","region":"河南","one_line":"洛阳附近城池，寇仲释放王玄应之处","source_refs":[{"chapter":225,"line_start":153,"line_end":153,"text":"风帆远离京都，顺流朝偃师而去"}]},{"id":"loc_jin_yong","name":"金墉","region":"河南","one_line":"王世充势力范围内的城池","source_refs":[{"chapter":225,"line_start":161,"line_end":161,"text":"趁着出差金墉"}]}],"items":[{"id":"item_jing_zhong_yue","name":"井中月","type":"weapon","owner":"char_kou_zhong","one_line":"寇仲随身宝刀，刀法凌厉","description":"寇仲随身宝刀，刀身泛起眩目黄芒，配合螺旋劲可发挥惊天动地的威力，是寇仲争霸天下的倚仗之一。","effects":["攻击","破防"],"origin":"不知","rarity":"绝世神兵","related_characters":["char_kou_zhong"],"related_skills":["skill_jing_zhong_yue_dao_fa"],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":31,"line_end":31,"text":"井中月化为眩目黄芒"}]}]},"entity_updates":[{"id":"char_kou_zhong","updates":{"source_refs":[{"chapter":225,"line_start":31,"line_end":77,"text":"寇仲破入殿内，井中月化为眩目黄芒"}]}},{"id":"char_xu_zi_ling","updates":{"source_refs":[{"chapter":225,"line_start":49,"line_end":95,"text":"徐子陵已斜越殿堂上三丈多的空间"}]}},{"id":"char_li_shi_min","updates":{"source_refs":[{"chapter":225,"line_start":123,"line_end":127,"text":"李世民踏前一步，风度依然的微笑道"}]}}]}
{"segment":3,"line_start":201,"line_end":279,"dialogues":[{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"若是如此，那荣凤祥的真正身份该不难猜，有谁是接近祝玉妍那种级数，又曾和我碰过头的？噢！","tone":"疑问","chapter":225,"line_start":203,"line_end":205},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_kou_zhong","text":"是谁？","tone":"疑问","chapter":225,"line_start":209,"line_end":209},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"我记起！我的娘啊！定是辟尘那妖道，真是厉害。","tone":"激动","chapter":225,"line_start":211,"line_end":213},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":null,"text":"怎会是他，不过也有点道理，今次王世充有难了。","tone":"惊讶","chapter":225,"line_start":215,"line_end":217},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"好家伙，这么看来，荣姣姣怕亦非是他女儿，而杨虚彦的出身更是可疑，甚至连董淑妮都大不简单，李小子可能中计都不晓得。","tone":"沉声","chapter":225,"line_start":219,"line_end":221},{"speaker":"char_xu_xing_zhi","speaker_name":"虚行之","listener":null,"text":"到底是什么事呢？","tone":"疑问","chapter":225,"line_start":223,"line_end":223},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"阴癸派想争天下，辟尘妖道的甚么派亦想混水摸鱼，手段虽异，其心一也，若辟尘知道这么一动手便给我们看破，定会非常后悔。","tone":"陈述","chapter":225,"line_start":225,"line_end":227},{"speaker":"char_xu_xing_zhi","speaker_name":"虚行之","listener":null,"text":"过了偃师后，我便登岸赶赴飞马牧场，两位爷儿最紧要小心点，李子通这人也不是好相与的，他手下白信、秦文超和左孝友三人，都是有名的猛将。","tone":"担心","chapter":225,"line_start":229,"line_end":231},{"speaker":"char_xu_xing_zhi","speaker_name":"虚行之","listener":null,"text":"杜伏威和沈法兴只是利益的结合，其中定是矛盾重重，若两位爷儿能巧妙利用，说不定可不费吹灰之力，便破掉他们的联军。","tone":"认真","chapter":225,"line_start":235,"line_end":237},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_xu_xing_zhi","text":"先生的提议隐含至理，我必谨记于心，到时再因势而施。","tone":"激动","chapter":225,"line_start":239,"line_end":241},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_yang_gong_qing","text":"杨大将军果是有胆有识，竟敢孤身登船。","tone":"大笑","chapter":225,"line_start":251,"line_end":251},{"speaker":"char_yang_gong_qing","speaker_name":"杨公卿","listener":null,"text":"尚书大人今趟是咎由自取，我杨公卿无话可说。","tone":"无奈","chapter":225,"line_start":253,"line_end":255},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_yang_gong_qing","text":"顺便告诉大将军两件事，若大将军欢喜的话，可转告世充小儿。","tone":"陈述","chapter":225,"line_start":257,"line_end":259},{"speaker":"char_yang_gong_qing","speaker_name":"杨公卿","listener":null,"text":"甚么事呢？","tone":"疑问","chapter":225,"line_start":261,"line_end":261},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"不害得他们提心吊胆，难有宁日，我如何可下这口气。","tone":"得意","chapter":225,"line_start":263,"line_end":265},{"speaker":"char_yang_gong_qing","speaker_name":"杨公卿","listener":null,"text":"这两件事均非同小可，我须立即以飞鸽传书，向王世充报告。","tone":"焦急","chapter":225,"line_start":267,"line_end":269},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_yang_gong_qing","text":"大将军即管把人拿回去，不过须谨记王世充可这样待我，异日也可以用同样方法对待大将军，侍候虎狼之君，是不会有好结果的。","tone":"低语","chapter":225,"line_start":273,"line_end":275},{"speaker":"char_yang_gong_qing","speaker_name":"杨公卿","listener":null,"text":"我早明白了！三位好好保重。","tone":"苦笑","chapter":225,"line_start":277,"line_end":277}],"new_entities":{"characters":[{"id":"char_pi_chen","name":"辟尘","alias":["辟尘妖道"],"identity":"魔门妖道，疑为荣凤祥真身","faction":"辟尘势力","role":"villain","archetype":"assassin","rank":"登峰造极","one_line":"魔门妖道，武功接近祝玉妍级数，疑以荣凤祥面目混迹江湖","personality":{"traits":["狡诈","深藏不露","武功高强","城府极深","野心勃勃"],"speech_style":"冷笑","temperament":"阴沉"},"relationships":[{"target":"char_rong_feng_xiang","type":"合作者","intensity":100,"bond_level":5,"dynamic":"同一人"},{"target":"char_zhu_yu_yan","type":"对手","intensity":60,"bond_level":3,"dynamic":"同门"}],"known_skills":[],"related_skills":[],"rag_refs":[225],"source_refs":[{"chapter":225,"line_start":211,"line_end":213,"text":"定是辟尘那妖道"}]},{"id":"char_zhu_yu_yan","name":"祝玉妍","alias":[],"identity":"阴癸派宗主","faction":"阴癸派","role":"villain","archetype":"assassin","rank":"返璞归真","one_line":"阴癸派宗主，武功绝顶","personality":{"traits":["高傲","武功绝顶","城府深","威严","冷酷"],"speech_style":"冷酷