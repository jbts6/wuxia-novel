{"segment":3,"line_start":201,"line_end":275,"dialogues":[{"speaker":"char_chu_chu","speaker_name":"楚楚","listener":"char_kou_zhong","text":"但婢子又有大段日子不能侍候寇爷了。","tone":"悲伤","chapter":216,"line_start":203,"line_end":203},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_chu_chu","text":"看！你不是时刻都贴身侍候我吗？","tone":"微笑","chapter":216,"line_start":205,"line_end":207},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_chu_chu","text":"不要哭，只要我们能在这乱世好好活下去，总有一天会有快乐和不用分开的日子过的。","tone":"温柔","chapter":216,"line_start":211,"line_end":213},{"speaker":"char_chu_chu","speaker_name":"楚楚","listener":"char_kou_zhong","text":"楚楚失态了！","tone":"慌张","chapter":216,"line_start":217,"line_end":217},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_chu_chu","text":"记住！我寇仲从没有认为你是下人，将来也不会。","tone":"认真","chapter":216,"line_start":221,"line_end":223},{"speaker":"char_chu_chu","speaker_name":"楚楚","listener":"char_kou_zhong","text":"寇爷好好保重自己。","tone":"悲伤","chapter":216,"line_start":225,"line_end":225},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_xu_zi_ling","text":"只要找虚行之，我们立即便走，就算要翻脸打出去，我也要走。","tone":"认真","chapter":216,"line_start":249,"line_end":251},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_kou_zhong","text":"王世充绝不敢公然拿你怎样的，否则如何服众，何况李密仍死而未僵，他不会笨得动摇军心呢。","tone":"淡然","chapter":216,"line_start":253,"line_end":255},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_xu_zi_ling","text":"有道理！我也是这么想。","tone":"陈述","chapter":216,"line_start":257,"line_end":257},{"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":null,"text":"我便像发了一场梦，到现在仍不相信曾威震天下的李密会被我们击败。","tone":"无奈","chapter":216,"line_start":261,"line_end":263},{"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":null,"text":"总有一天你会发觉人生只是大梦一场，帝皇霸业都毫不真实。","tone":"无奈","chapter":216,"line_start":265,"line_end":267}],"new_entities":{"characters":[{"id":"char_xu_xing_zhi","name":"虚行之","alias":[],"identity":"寇仲欲寻找之人","faction":"双龙帮","role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"寇仲欲在洛阳寻找后立即南下","personality":{"traits":["忠诚","有谋略","可靠","务实","低调"],"speech_style":"不详","temperament":"稳重"},"relationships":[{"target":"char_kou_zhong","type":"合作者","intensity":60,"bond_level":3,"dynamic":"上下级"}],"known_skills":[],"related_skills":[],"rag_refs":[216],"source_refs":[{"chapter":216,"line_start":249,"line_end":249,"text":"只要找虚行之"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_fei_ma_mu_chang","name":"飞马牧场","region":"南方","one_line":"寇仲欲南下助其反危为安","source_refs":[{"chapter":216,"line_start":137,"line_end":137,"text":"先助飞马牧场反危为安"}]}],"items":[{"id":"item_zhui","name":"坠","type":"special","owner":"char_kou_zhong","one_line":"寇仲贴身佩戴之物，楚楚所赠","description":"寇仲挂在颈上的坠子，贴身佩戴，象征与楚楚的情感纽带，楚楚见到后喜极而泣。","effects":[],"origin":"楚楚所赠","rarity":"寻常凡品","related_characters":["char_kou_zhong","char_chu_chu"],"related_skills":[],"rag_refs":[216],"source_refs":[{"chapter":216,"line_start":205,"line_end":207,"text":"寇仲忍不住掏出挂在颈上的坠"}]}]},"entity_updates":[{"id":"char_chu_chu","updates":{"source_refs":[{"chapter":216,"line_start":193,"line_end":203,"text":"楚楚深情告别寇仲"}]},"relationship_updates":[{"action":"update","target":"char_kou_zhong","type":"恋人","intensity":85,"bond_level":4,"dynamic":"情深难舍，依依惜别"}]},{"id":"char_kou_zhong","updates":{"source_refs":[{"chapter":216,"line_start":249,"line_end":251,"text":"只要找虚行之，我们立即便走"}]},"relationship_updates":[{"action":"add","target":"char_xu_xing_zhi","type":"合作者","intensity":60,"bond_level":3,"dynamic":"上下级"}]}]}
