{"segment":1,"line_start":1,"line_end":100,"dialogues":[{"line_start":41,"line_end":43,"speaker":"char_chang_shu_mou","speaker_name":"长叔谋","listener":null,"text":"如此绝色，确是人间极品。","tone":"微笑","chapter":94},{"line_start":47,"line_end":49,"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_chang_shu_mou","text":"你是否长叔谋那家伙？这两个金牌子相当趣致呢。","tone":"调侃","chapter":94},{"line_start":53,"line_end":55,"speaker":"char_fang_ze_tao","speaker_name":"方泽滔","listener":"char_chang_shu_mou","text":"长叔谋若你敢伤害她，休想有命离开。","tone":"厉声","chapter":94},{"line_start":57,"line_end":59,"speaker":"char_chang_shu_mou","speaker_name":"长叔谋","listener":"char_kou_zhong","text":"你们可知任少名是甚么人？","tone":"疑问","chapter":94},{"line_start":61,"line_end":61,"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_chang_shu_mou","text":"听说是你师傅的野种，对吗？","tone":"调侃","chapter":94},{"line_start":63,"line_end":65,"speaker":"char_chang_shu_mou","speaker_name":"长叔谋","listener":"char_kou_zhong","text":"果然有种，不过有一天你定要后悔说过这番话。","tone":"冷笑","chapter":94},{"line_start":67,"line_end":69,"speaker":"char_chang_shu_mou","speaker_name":"长叔谋","listener":"char_xu_zi_ling","text":"你的拳脚功夫相当了得，罗刹女尚教不出这样的徒弟，难道是从长生诀学来的吗？","tone":"疑问","chapter":94},{"line_start":71,"line_end":73,"speaker":"char_xu_zi_ling","speaker_name":"徐子陵","listener":"char_chang_shu_mou","text":"我学的只是东拼西凑而来的取巧功夫，那及得上长叔兄有明师指点。","tone":"平静","chapter":94},{"line_start":75,"line_end":77,"speaker":"char_chang_shu_mou","speaker_name":"长叔谋","listener":null,"text":"让我先杀此女，大家才放手一搏，如何！","tone":"冷酷","chapter":94},{"line_start":79,"line_end":79,"speaker":"char_fang_ze_tao","speaker_name":"方泽滔","listener":"char_chang_shu_mou","text":"你敢！","tone":"愤怒","chapter":94},{"line_start":81,"line_end":81,"speaker":"char_kou_zhong","speaker_name":"寇仲","listener":"char_chang_shu_mou","text":"好主意！","tone":"大笑","chapter":94}],"new_entities":{"characters":[{"id":"char_chang_shu_mou","name":"长叔谋","alias":[],"identity":"铁勒飞鹰曲傲之徒","faction":"铁勒","role":"villain","archetype":"warrior","rank":"出神入化","one_line":"铁勒高手，曲傲之徒，持双金盾追杀婠婠","personality":{"traits":["阴沉","自负","狡猾","冷酷","果断"],"speech_style":"冷淡","temperament":"阴鸷"},"relationships":[],"known_skills":["skill_shuang_dun_shu"],"related_skills":[],"rag_refs":[94],"source_refs":[{"chapter":94,"line_start":37,"line_end":43,"text":"一个白衣如雪，漂亮修长，年约三十的男子，天神般落到骡车上"}]}],"skills":[{"id":"skill_shuang_dun_shu","name":"双盾术","type":"掌法","faction":"铁勒","rank":"出神入化","one_line":"以双金盾攻守兼备的独特武学","techniques":[{"id":"tech_shuang_dun_po_dao","name":"双盾破刀","type":"attack","description":"以双盾夹击破刀的招式"}],"progression":"精熟","effects":["防御","攻击"],"combat_style":"攻守兼备","rag_refs":[94],"source_refs":[{"chapter":94,"line_start":17,"line_end":19,"text":"原来对方持的竟是两个长只两尺，上阔下尖，盾绿像刃锋般锐利、金光闪闪的怪盾牌"}]}],"techniques":[{"id":"tech_shuang_dun_po_dao","name":"双盾破刀","type":"attack","description":"以双金盾夹击敌人兵器并反击的招式","source_skill":"skill_shuang_dun","source_refs":[{"chapter":94,"line_start":155,"line_end":157,"text":"金盾四分五裂"}]}],"factions":[],"locations":[],"items":[{"id":"item_shuang_jin_dun","name":"双金盾","type":"weapon","owner":"char_chang_shu_mou","one_line":"长叔谋的标志性兵器，一对金色怪盾牌","description":"一对长约两尺、上阔下尖的金色怪盾牌，盾面布满尖刺，锋缘锐利如刃，可攻可守，不惧攻坚武器","effects":["防御","攻击","震退"],"origin":"铁勒","rarity":"上乘佳品","related_characters":["char_chang_shu_mou"],"related_skills":["skill_shuang_dun_shu"],"rag_refs":[94],"source_refs":[{"chapter":94,"line_start":17,"line_end":19,"text":"原来对方持的竟是两个长只两尺，上阔下尖，盾绿像刃锋般锐利、金光闪闪的怪盾牌"}]}]},"entity_updates":[{"id":"char_kou_zhong","updates":{"source_refs":[{"chapter":94,"line_start":7,"line_end":8,"text":"寇仲横移一步，井中月离背而出，望空劈去"}]},"relationship_updates":[]},{"id":"char_xu_zi_ling","updates":{"source_refs":[{"chapter":94,"line_start":9,"line_end":9,"text":"徐子陵低腰坐马，双掌上托"}]},"relationship_updates":[]},{"id":"char_fang_ze_tao","updates":{"source_refs":[{"chapter":94,"line_start":11,"line_end":11,"text":"方泽滔也是了得，掣出长剑"}]},"relationship_updates":[]},{"id":"char_duan_yu_cheng","updates":{"source_refs":[{"chapter":94,"line_start":3,"line_e