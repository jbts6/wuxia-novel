{"segment":1,"line_start":1,"line_end":88,"dialogues":[{"speaker":"char_zhang_quan","speaker_name":"张泉","listener":"char_xiang_shao_long","text":"凤小姐要用车，你去准备一下。","tone":"陈述","chapter":240,"line_start":4,"line_end":6},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":null,"text":"车在哪里？","tone":"疑问","chapter":240,"line_start":8,"line_end":8},{"speaker":"char_zhang_quan","speaker_name":"张泉","listener":"char_xiang_shao_long","text":"你的眼睛长出来是用来瞧屁股吗？码头上不见停着辆马车吗？","tone":"愤怒","chapter":240,"line_start":10,"line_end":12},{"speaker":"char_fu_yan","speaker_name":"富严","listener":"char_xiang_shao_long","text":"看沈良你个子高大结实，原来是银样蜡枪头，中看不中用。给我们巫循大哥无意轻碰一下便跌个四脚朝天，还说什么精通武技。","tone":"嘲讽","chapter":240,"line_start":26,"line_end":30},{"speaker":"char_zhang_quan","speaker_name":"张泉","listener":"char_gu_ming","text":"什么事？","tone":"愤怒","chapter":240,"line_start":34,"line_end":34},{"speaker":"char_gu_ming","speaker_name":"谷明","listener":"char_zhang_quan","text":"他两人连走路都不会，怪得谁来。","tone":"淡然","chapter":240,"line_start":36,"line_end":36},{"speaker":null,"speaker_name":null,"listener":"char_xiang_shao_long","text":"没用的家伙","tone":"愤怒","chapter":240,"line_start":40,"line_end":40},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"我的腿断了！","tone":"痛苦","chapter":240,"line_start":42,"line_end":44},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_fang_sheng","text":"是我害了你！","tone":"悲伤","chapter":240,"line_start":46,"line_end":48},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"他们原是要弄伤你，教你不能驾车，唉！今晚我和你都不用去寻乐子了。","tone":"无奈","chapter":240,"line_start":50,"line_end":52},{"speaker":null,"speaker_name":null,"listener":null,"text":"你们在弄什么鬼，竟敢阻着凤小姐的路。","tone":"愤怒","chapter":240,"line_start":56,"line_end":58},{"speaker":"char_xiao_ping_er","speaker_name":"小屏儿","listener":null,"text":"发生什么事？","tone":"愤怒","chapter":240,"line_start":64,"line_end":64},{"speaker":"char_sha_li","speaker_name":"沙立","listener":null,"text":"只是发生无意的碰撞。","tone":"陈述","chapter":240,"line_start":66,"line_end":68},{"speaker":"char_sha_li","speaker_name":"沙立","listener":"char_xiang_shao_long","text":"你就是那新来的家伙吗？真没用！还不快滚下去，难道要大小姐等你吗？","tone":"愤怒","chapter":240,"line_start":70,"line_end":72},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_sha_li","text":"沙副管事！","tone":"严肃","chapter":240,"line_start":76,"line_end":76},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"以后小心点，扶房生回房后，再下来给我套车吧！","tone":"淡然","chapter":240,"line_start":82,"line_end":84}],"new_entities":{"characters":[{"id":"char_xiang_shao_long","name":"项少龙","alias":["沈良"],"identity":"秦国逃亡者，假扮御者","faction":"秦国","role":"protagonist","archetype":"warrior","rank":"出神入化","one_line":"秦国逃亡者，假扮御者潜伏在歌舞姬团","personality":{"traits":["机智","勇敢","重义气","善于观察","临危不乱"],"speech_style":"沉稳有力","temperament":"冷静"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":1,"line_end":88,"text":"本章主角，假扮沈良潜伏"}]},{"id":"char_fang_sheng","name":"房生","alias":[],"identity":"歌舞姬团御者","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团御者，被项少龙救助","personality":{"traits":["忠诚","直率","感恩","冲动","朴实"],"speech_style":"朴实直白","temperament":"急躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":2,"line_end":52,"text":"与项少龙同行的御者"}]},{"id":"char_zhang_quan","name":"张泉","alias":[],"identity":"歌舞姬团管事","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团管事，负责管理御者","personality":{"traits":["严厉","现实","自私","多疑","势利"],"speech_style":"严厉","temperament":"暴躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":4,"line_end":40,"text":"歌舞姬团管事"}]},{"id":"char_gu_ming","name":"谷明","alias":[],"identity":"歌舞姬团御者首领","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团御者首领，与沙立一党","personality":{"traits":["狡猾","欺软怕硬","阴险","势利","小人"],"speech_style":"阴险","temperament":"阴险"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":24,"line_end":38,"text":"谷明等一众御者"}]},{"id":"char_fu_yan","name":"富严","alias":[],"identity":"歌舞姬团御者","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"谷明一党御者，嘲讽项少龙","personality":{"traits":["谄媚","刻薄","势利","小人","跟风"],"speech_style":"刻薄","temperament":"刻薄"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":26,"line_end":30,"text":"谷明一党御者"}]},{"id":"char_wu_xun","name":"巫循","alias":[],"identity":"歌舞姬团家将","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团家将，矮横力士型壮汉","personality":{"traits":["勇猛","蛮横","力大","粗鲁","直接"],"speech_style":"粗鲁","temperament":"暴躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":24,"line_end":29,"text":"矮横力士型的壮汉"}]},{"id":"char_feng_fei","name":"凤菲","alias":[],"identity":"鲁国公主，著名歌舞家","faction":"歌舞姬团","role":"npc","archetype":"scholar","rank":"出神入化","one_line":"鲁国公主，色艺双绝的歌舞家","personality":{"traits":["高贵","忧郁","智慧","优雅","感伤"],"speech_style":"优雅","temperament":"忧郁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":62,"line_end":124,"text":"鲁国公主，著名歌舞家"}]},{"id":"char_xiao_ping_er","name":"小屏儿","alias":[],"identity":"凤菲近身婢女","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"凤菲近身婢女，穿男装","personality":{"traits":["忠诚","泼辣","直率","勇敢","护主"],"speech_style":"泼辣","temperament":"急躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":62,"line_end":64,"text":"凤菲近身婢女"}]},{"id":"char_sha_li","name":"沙立","alias":[],"identity":"歌舞姬团副管事","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团副管事，与小玲姊勾搭","personality":{"traits":["野心","阴险","谄媚","势利","小人"],"speech_style":"阴险","temperament":"阴险"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":66,"line_end":80,"text":"歌舞姬团副管事"}]},{"id":"char_ao_xiang","name":"敖向","alias":[],"identity":"魏兵指挥偏将","faction":"魏国","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"魏兵指挥偏将，护送凤菲","personality":{"traits":["恭敬","圆滑","谨慎","势利","谄媚"],"speech_style":"恭敬","temperament":"谨慎"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":96,"line_end":130,"text":"魏兵指挥偏将"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_ge_wu_ji_tuan","name":"歌舞姬团","type":"帮派","location":"各国","sub_divisions":[],"one_line":"凤菲领导的歌舞姬团，周游列国表演","source_refs":[{"chapter":240,"line_start":1,"line_end":88,"text":"项少龙潜伏的歌舞姬团"}]}],"locations":[{"id":"loc_gu_cheng","name":"谷城","region":"魏国","one_line":"鲁国故地，现属魏国，文化气息浓厚","source_refs":[{"chapter":240,"line_start":1,"line_end":140,"text":"船抵谷城城外的码头"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":89,"line_end":162,"dialogues":[{"speaker":"char_ao_xiang","speaker_name":"敖向","listener":"char_feng_fei","text":"昔年旧晋韩宣子来到鲁国，看到鲁太史所藏典籍，大叹'周礼尽在鲁矣'，凤小姐故地重游，当有所感。","tone":"恭敬","chapter":240,"line_start":114,"line_end":116},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_ao_xiang","text":"也正因此坏事，若非我们鲁人顽固守旧，抱着典籍礼乐不放，也不致始受制于齐，继受制于吴、越；虽得君子之邦的称誉，还不是空余亡国之恨。敖大人过誉了。","tone":"无奈","chapter":240,"line_start":122,"line_end":124},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_fang_sheng","text":"怎样了？","tone":"疑问","chapter":240,"line_start":152,"line_end":152},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"若我的脚好不了，就要找他们拼命。","tone":"愤怒","chapter":240,"line_start":154,"line_end":154},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_fang_sheng","text":"只是脚踝移了位，来！忍点痛。","tone":"认真","chapter":240,"line_start":156,"line_end":158},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"沈兄确有一手。","tone":"欣喜","chapter":240,"line_start":162,"line_end":162},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_fang_sheng","text":"坐下来，我有些话想和房兄说。","tone":"认真","chapter":240,"line_start":164,"line_end":164},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"沈兄请说！","tone":"欣喜","chapter":240,"line_start":166,"line_end":166},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":null,"text":"天！这是黄金。","tone":"惊讶","chapter":240,"line_start":170,"line_end":170},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_fang_sheng","text":"这是你的了。","tone":"陈述","chapter":240,"line_start":174,"line_end":174},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"我怎可受沈兄的金子呢？","tone":"犹豫","chapter":240,"line_start":176,"line_end":176},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_fang_sheng","text":"我共有十块这样的黄金，是无忌公子自知大难难逃的时候分赠给我的，房兄尽管要了它们，然后诈作跌断了腿，离开这小人当道的歌舞姬团，追求自己的理想生活。","tone":"认真","chapter":240,"line_start":178,"line_end":180},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"沈兄身家如此丰厚，何用来到我们这里混日子？","tone":"疑问","chapter":240,"line_start":182,"line_end":184},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_fang_sheng","text":"实不相瞒，我这次是借机离开大梁，自无忌公子死后，我们这些旧人无人敢用，我又不甘于平淡，遂趁机到齐国去碰碰运气的。","tone":"陈述","chapter":240,"line_start":186,"line_end":188},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"大恩不言谢，有了这两块金子，加上两年来的积蓄，明早我立即向小姐请辞。","tone":"感激","chapter":240,"line_start":190,"line_end":192},{"speaker":"char_fang_sheng","speaker_name":"房生","listener":"char_xiang_shao_long","text":"不若我们一起走吧！沙立那人心胸狭窄，定不肯放过你，张泉则只是利用你，就算沈兄死了，他也不会掉半滴眼泪。","tone":"担心","chapter":240,"line_start":194,"line_end":196},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_fang_sheng","text":"房兄走了，我再无后顾之忧，我们那一跤绝不会是白摔的。","tone":"自信","chapter":240,"line_start":198,"line_end":200}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_gold_ingot","name":"黄金","type":"special","owner":"char_xiang_shao_long","one_line":"无忌公子赠予项少龙的黄金","description":"两块金子，足够普通人一世无忧，是无忌公子自知大难难逃时分赠给项少龙的。","effects":["财富","自由"],"origin":"无忌公子赠予","rarity":"稀世珍品","related_characters":["char_xiang_shao_long"],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":168,"line_end":174,"text":"项少龙由怀里掏出那两块黄金"}]}]},"entity_updates":[]}
{"segment":3,"line_start":210,"line_end":268,"dialogues":[{"speaker":"char_xiao_ling_zi","speaker_name":"小玲姊","listener":"char_xiang_shao_long","text":"你就是那爱闹事的沈良？","tone":"愤怒","chapter":240,"line_start":230,"line_end":232},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xiao_ling_zi","text":"小玲姊过奖，没有人起哄，哪闹得出什么事来呢？","tone":"调侃","chapter":240,"line_start":234,"line_end":236},{"speaker":"char_xiao_ling_zi","speaker_name":"小玲姊","listener":"char_xiang_shao_long","text":"好大胆！你知不知道在和谁说话？","tone":"愤怒","chapter":240,"line_start":238,"line_end":240},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xiao_ling_zi","text":"国有国法，家有家规，万事都逃不过一个理字，我现在孤身一人，人家却是成群成党，小玲姊给我来评评看，谁才有闹事的资格？","tone":"认真","chapter":240,"line_start":242,"line_end":244},{"speaker":"char_xiao_ling_zi","speaker_name":"小玲姊","listener":"char_xiang_shao_long","text":"你是否不想干了！","tone":"愤怒","chapter":240,"line_start":246,"line_end":248},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xiao_ling_zi","text":"这怕该由张管事或凤小姐决定吧？","tone":"淡然","chapter":240,"line_start":250,"line_end":250},{"speaker":"char_xu_ran","speaker_name":"许然","listener":"char_xiang_shao_long","text":"张爷要见你！","tone":"陈述","chapter":240,"line_start":260,"line_end":260},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xu_ran","text":"这位大哥怎么称呼？","tone":"疑问","chapter":240,"line_start":262,"line_end":262},{"speaker":"char_xu_ran","speaker_name":"许然","listener":"char_xiang_shao_long","text":"我叫许然，随我来吧！","tone":"陈述","chapter":240,"line_start":266,"line_end":268}],"new_entities":{"characters":[{"id":"char_xiao_ling_zi","name":"小玲姊","alias":[],"identity":"董淑贞近身宠婢","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"二小姐董淑贞的近身宠婢，与沙立勾搭","personality":{"traits":["泼辣","势利","霸道","嫉妒","小人"],"speech_style":"泼辣","temperament":"暴躁"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":228,"line_end":252,"text":"董淑贞的近身宠婢小玲姊"}]},{"id":"char_dong_shu_zhen","name":"董淑贞","alias":[],"identity":"歌舞姬团二小姐","faction":"歌舞姬团","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"歌舞姬团二小姐，小玲姊的主子","personality":{"traits":["高贵","有权势","幕后操控","野心","精明"],"speech_style":"高贵","temperament":"精明"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":228,"line_end":256,"text":"二小姐董淑贞"}]},{"id":"char_xu_ran","name":"许然","alias":[],"identity":"歌舞姬团家将","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团家将，传张泉之命","personality":{"traits":["谨慎","沉默","忠诚","胆小","服从"],"speech_style":"沉默","temperament":"谨慎"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[],"source_refs":[{"chapter":240,"line_start":258,"line_end":268,"text":"歌舞姬团家将许然"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
