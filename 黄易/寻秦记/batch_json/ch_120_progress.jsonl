ity":85,"bond_level":1,"dynamic":"暗中对抗"},{"target":"char_tu_xian","type":"主仆","intensity":40,"bond_level":2,"dynamic":"猜忌"},{"target":"char_zhu_ji","type":"合作者","intensity":60,"bond_level":3,"dynamic":"利益同盟"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":32,"line_end":35,"text":"我再也不能忍受以笑脸迎对那奸贼"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_qin_guo","name":"秦国","type":"武林门派","location":"咸阳","sub_divisions":["吕族"],"one_line":"战国七雄之一，项少龙效力的国家","source_refs":[{"chapter":120,"line_start":2,"line_end":2,"text":"与秦军断绝联络"}]},{"id":"faction_lv_zu","name":"吕族","type":"家族","location":"咸阳","sub_divisions":[],"one_line":"吕不韦的家族势力，横龙岭一役损失惨重","source_refs":[{"chapter":120,"line_start":32,"line_end":35,"text":"以他吕族的人代之"}]}],"locations":[{"id":"loc_han_jing","name":"韩境","region":"韩国","one_line":"韩国境内，项少龙出使途中经过之地","source_refs":[{"chapter":120,"line_start":2,"line_end":2,"text":"二十天后，重返韩境"}]},{"id":"loc_hong_song_lin","name":"红松林","region":"韩国","one_line":"项少龙出使途中遇袭之地，财物文牒尽失","source_refs":[{"chapter":120,"line_start":2,"line_end":2,"text":"根本所有财物和文牒均在红松林一役失去"}]},{"id":"loc_xian_yang","name":"咸阳","region":"秦国","one_line":"秦国都城，项少龙等人返回之地","source_refs":[{"chapter":120,"line_start":80,"line_end":80,"text":"项少龙回到咸阳"}]},{"id":"loc_heng_long_ling","name":"横龙岭","region":"秦国","one_line":"吕族与敌军交战之地，诸萌可能丧命于此","source_refs":[{"chapter":120,"line_start":60,"line_end":60,"text":"若诸萌在横龙岭一役果然丧命"}]}],"items":[{"id":"item_zhu_tong_xin_han","name":"竹筒信函","type":"special","owner":"char_xiang_shao_long","one_line":"肖月潭托项少龙转交给图先的密封信函","description":"一个封了漆的竹筒，内藏帛卷，是肖月潭写给图先的信函，说明诈死隐退之事","effects":"传递肖月潭诈死的消息","origin":"肖月潭","rarity":"寻常凡品","related_characters":["char_xiao_yue_tan","char_tu_xian"],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":36,"line_end":36,"text":"由枕下掏出一个封了漆的竹筒，塞入项少龙手中"}]}]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"是我不好，想不到有燕人徐夷乱这招伏兵，否则不致教少龙落至这等田地，妻丧婢亡，待我在府内精挑几个美女予你，以前的事，忘记它算了。","tone":"无奈","chapter":120,"line_start":106,"line_end":108},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lv_bu_wei","text":"吕相万勿如此，是了！东周的事如何？","tone":"陈述","chapter":120,"line_start":110,"line_end":112},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"区区东周，还不是手到擒来，在我提议下，大王已把东、西二周故地合并为三川郡，三川即河、洛、伊三条大河，还封我作文信侯，负责管治此郡，食邑十万户。","tone":"得意","chapter":120,"line_start":114,"line_end":116},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"阳泉君此人当然不可放过，韩人与他勾结，亦是罪无可恕，现在再无东周妨碍阻挠，我立即请大王对韩用兵，际此六国自顾不暇之时，尽量占领韩人土地，然后轮到赵、魏两国了。","tone":"得意","chapter":120,"line_start":118,"line_end":120},{"speaker":"char_zhu_ji","speaker_name":"朱姬","listener":"char_zhuang_xiang_wang","text":"阳泉君如此胆大妄为，害得少龙痛失娇妻，损兵折将，大王定要为他讨回这笔血债。","tone":"愤怒","chapter":120,"line_start":130,"line_end":132},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_zhuang_xiang_wang","text":"老臣一直遵照大王吩咐，对左丞相抱着以和为贵的态度，怎知人心难测，纵使他对大王有恩在先，但大王对他已是仁至义尽，他竟敢如此以怨报德，唉！臣下真不知说什么话才好了。","tone":"无奈","chapter":120,"line_start":136,"line_end":138},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_xiang_shao_long","text":"今天出使，所有殉难的人，家属都可得十镒黄金。唉！人死不能复生，少龙你一定要节哀顺变，先是婷芳氏病逝，继而是倩公主遇害，寡人感同身受，少龙有什么请求尽管说出来，寡人会设法为你办到。","tone":"无奈","chapter":120,"line_start":142,"line_end":146},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhuang_xiang_wang","text":"少龙一无所求，只希望暂时退隐山林，悼念亡妻。","tone":"恳求","chapter":120,"line_start":150,"line_end":152},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_xiang_shao_long","text":"少龙先休息一下也好，但这事上寡人绝不肯就此不闻不问，待会儿去见太后，先向她打个招呼。","tone":"认真","chapter":120,"line_start":164,"line_end":166},{"speaker":"char_zhu_ji","speaker_name":"朱姬","listener":"char_zhuang_xiang_wang","text":"大王千万勿如此做，太后虽不喜阳泉君，说到底仍有骨肉之情，若惊动阳泉君，蓦地发难，只会害苦百姓。","tone":"担心","chapter":120,"line_start":168,"line_end":170},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_zhuang_xiang_wang","text":"成大事者不拘小节，大王请立即下令，由臣下指挥，把奸党一网打尽，为大王立威。","tone":"激动","chapter":120,"line_start":172,"line_end":174},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_lv_bu_wei","text":"好！此事就交给相国去办，但须留左丞相一命，待我禀知太后后，再作定夺。","tone":"认真","chapter":120,"line_start":176,"line_end":180}],"new_entities":{"characters":[{"id":"char_meng_ao","name":"蒙骜","alias":[],"identity":"秦国将军，蒙武蒙恬之父","faction":"faction_qin_guo","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"秦国老将，刚直忠诚，即将出征韩国","personality":{"traits":["刚直忠诚","勇猛善战","爱子心切","正直坦荡","重义轻利"],"speech_style":"直率坦荡","temperament":"刚直"},"relationships":[{"target":"char_meng_wu","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父子"},{"target":"char_meng_tian","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父子"},{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":3,"dynamic":"感激"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":84,"line_end":84,"text":"同来的还有蒙骜"},{"chapter":120,"line_start":98,"line_end":98,"text":"蒙骜向项少龙表示衷心的感激"}]},{"id":"char_zhuang_xiang_wang","name":"庄襄王","alias":["大王"],"identity":"秦国国王","faction":"faction_qin_guo","role":"npc","archetype":"scholar","rank":"初窥门径","one_line":"秦国国君，信任项少龙，欲为其讨回公道","personality":{"traits":["仁厚宽和","信任臣下","优柔寡断","重情重义","体恤下属"],"speech_style":"威严中带温情","temperament":"温和"},"relationships":[{"target":"char_xiang_shao_long","type":"主仆","intensity":70,"bond_level":4,"dynamic":"信任器重"},{"target":"char_zhu_ji","type":"恋人","intensity":60,"bond_level":4,"dynamic":"夫妻"},{"target":"char_lv_bu_wei","type":"主仆","intensity":50,"bond_level":3,"dynamic":"倚重"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":128,"line_end":128,"text":"庄襄王在后宫书斋内接见项少龙"}]},{"id":"char_zhu_ji","name":"朱姬","alias":["姬后"],"identity":"秦国太后","faction":"faction_qin_guo","role":"npc","archetype":"scholar","rank":"初窥门径","one_line":"秦国太后，与吕不韦有利益同盟，为项少龙痛失娇妻而愤怒","personality":{"traits":["心思缜密","善于权谋","重情重义","果断刚毅","外柔内刚"],"speech_style":"语气急切，善于察言观色","temperament":"果断"},"relationships":[{"target":"char_lv_bu_wei","type":"合作者","intensity":60,"bond_level":3,"dynamic":"利益同盟"},{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":3,"dynamic":"关心"},{"target":"char_zhuang_xiang_wang","type":"恋人","intensity":60,"bond_level":4,"dynamic":"夫妻"},{"target":"char_xiao_pan","type":"亲属","intensity":80,"bond_level":5,"dynamic":"母子"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":130,"line_end":132,"text":"与小盘居于右席的朱姬悲呼道"}]},{"id":"char_xiao_pan","name":"小盘","alias":["政太子","嬴政"],"identity":"秦国太子，项少龙弟子","faction":"faction_qin_guo","role":"companion","archetype":"scholar","rank":"初窥门径","one_line":"秦国太子，项少龙弟子，对赵倩有着母子姊弟般的深刻感情","personality":{"traits":["聪慧过人","重情重义","少年老成","隐忍坚毅","尊师重道"],"speech_style":"年幼但沉稳","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"师徒","intensity":80,"bond_level":4,"dynamic":"师徒情深"},{"target":"char_zhu_ji","type":"亲属","intensity":80,"bond_level":5,"dynamic":"母子"},{"target":"char_zhao_qian","type":"亲属","intensity":70,"bond_level":4,"dynamic":"母子姊弟之情"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":134,"line_end":134,"text":"小盘亦双目喷出怒火，紧握小拳"},{"chapter":120,"line_start":162,"line_end":162,"text":"小盘则大感错愕，暗忖难道师父不再理我了"}]},{"id":"char_yang_quan_jun","name":"阳泉君","alias":["左丞相"],"identity":"秦国左丞相","faction":"faction_qin_guo","role":"npc","archetype":"scholar","rank":"略有小成","one_line":"秦国左丞相，因与韩人勾结被吕不韦利用，最终被囚禁","personality":{"traits":["野心勃勃","不自量力","心怀不轨","刚愎自用","贪权恋势"],"speech_style":"未直接出场，通过他人叙述","temperament":"阴沉"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":56,"line_end":56,"text":"阳泉君的野心虽给吕不韦夸大"},{"chapter":120,"line_start":118,"line_end":118,"text":"阳泉君此人当然不可放过"}]},{"id":"char_lv_xiong","name":"吕雄","alias":[],"identity":"吕族成员","faction":"faction_lv_zu","role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"吕族成员，横龙岭一役幸存归来","personality":{"traits":["忠诚于吕族","勇猛好斗","鲁莽冲动","依附权贵","不善谋略"],"speech_style":"未直接对话","temperament":"沉稳"},"relationships":[{"target":"char_lv_bu_wei","type":"主仆","intensity":50,"bond_level":3,"dynamic":"依附"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":84,"line_end":84,"text":"吕雄则刚回来"}]},{"id":"char_zhu_meng","name":"诸萌","alias":[],"identity":"吕族成员","faction":"faction_lv_zu","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"吕族成员，横龙岭一役后下落不明，疑已丧命","personality":{"traits":["勇猛善战","忠诚不二","刚烈果断","武艺高强","不畏强敌"],"speech_style":"未直接对话","temperament":"刚烈"},"relationships":[{"target":"char_lv_bu_wei","type":"主仆","intensity":50,"bond_level":3,"dynamic":"依附"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":60,"line_end":60,"text":"若诸萌在横龙岭一役果然丧命"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_gong_men","name":"宫门","region":"咸阳","one_line":"秦国王宫正门，宏伟壮丽","source_refs":[{"chapter":120,"line_start":124,"line_end":124,"text":"宏伟的宫门出现眼前"}]},{"id":"loc_hou_gong_shu_zhai","name":"后宫书斋","region":"咸阳","one_line":"庄襄王接见项少龙的场所","source_refs":[{"chapter":120,"line_start":128,"line_end":128,"text":"庄襄王在后宫书斋内接见项少龙"}]}],"items":[]},"entity_updates":[{"id":"char_meng_wu","updates":{"source_refs":[{"chapter":120,"line_start":86,"line_end":86,"text":"蒙武和蒙恬两人脱难归来"}],"rag_refs":[120]}},{"id":"char_meng_tian","updates":{"source_refs":[{"chapter":120,"line_start":86,"line_end":86,"text":"蒙武和蒙恬两人脱难归来"}],"rag_refs":[120]}}]}
{"segment":3,"line_start":201,"line_end":292,"dialogues":[{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_tao_fang","text":"她不是死了吧？","tone":"惊讶","chapter":120,"line_start":195,"line_end":195},{"speaker":"char_tao_fang","speaker_name":"陶方","listener":"char_xiang_shao_long","text":"死倒没有死，只不过和信陵君旧情复炽，这种水性杨花的女人，忘掉她算了。","tone":"苦笑","chapter":120,"line_start":196,"line_end":198},{"speaker":"char_tao_fang","speaker_name":"陶方","listener":"char_xiang_shao_long","text":"韩晶当上太后，掌握赵国的大权，竟派人知会魏王，要他将赵雅处决，幸好龙阳君通知赵雅逃走，赵雅于是避到信陵君府内，得他维护逃过难关，赵雅感恩图报，暂时不会离开信陵君。但她却使人来告诉你，她真正爱的人只有你一个，希望你能体谅她。","tone":"陈述","chapter":120,"line_start":204,"line_end":208},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_tao_fang","text":"赵致呢？","tone":"疑问","chapter":120,"line_start":212,"line_end":213},{"speaker":"char_tao_fang","speaker_name":"陶方","listener":"char_xiang_shao_long","text":"她早回来了，现正在府内。","tone":"陈述","chapter":120,"line_start":214,"line_end":215},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_tao_fang","text":"我还以为是什么事，陶公刚才你的神色差点吓坏我。咦！为何你的脸色仍是那么难看？","tone":"疑问","chapter":120,"line_start":216,"line_end":218},{"speaker":"char_tao_fang","speaker_name":"陶方","listener":"char_xiang_shao_long","text":"翠绿和翠桐两人听得三公主遇害，一起偷偷上吊，我们发现时刚断了气，身子仍是暖的。","tone":"悲伤","chapter":120,"line_start":220,"line_end":222},{"speaker":"char_tu_xian","speaker_name":"图先","listener":"char_xiang_shao_long","text":"十多年来，我图先从没有把肖月潭当作是下属，甚至比亲兄弟更要好。只是大家心照不宣，没有说出来，只有他去办的事，我才会放心。到了这个时候，他仍肯给我这一封信，我总算没有错交这好兄弟。","tone":"感慨","chapter":120,"line_start":230,"line_end":236},{"speaker":"char_tu_xian","speaker_name":"图先","listener":"char_xiang_shao_long","text":"鸟尽弓藏，此乃古今不移的至理，共患难容易，共富贵则难若雪中送炭，我们这群老臣子，错在知道太多吕爷的事，尤其关乎到他和姬后之间的事。其实在看这封信前，我已找李斯问清楚一切，所以一点不觉惊奇。","tone":"淡然","chapter":120,"line_start":240,"line_end":244},{"speaker":"char_tu_xian","speaker_name":"图先","listener":"char_xiang_shao_long","text":"吕不韦虽然有手段，我图先又岂是好惹的人，诸萌到现在仍未回来，应是凶多吉少，吕雄则刚回来。你小心点蒙骜，若让他知道真相，以他刚直的性格绝藏不住心事，徒教他给吕不韦害死。现在阳泉君被囚禁起来，株连者达万人之众，秦国军方大半人已向吕不韦投诚，若是明刀明枪，我和你都斗不过他半个指头。","tone":"冷酷","chapter":120,"line_start":248,"line_end":254},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_tu_xian","text":"图兄准备怎么做？","tone":"疑问","chapter":120,"line_start":256,"line_end":257},{"speaker":"char_tu_xian","speaker_name":"图先","listener":"char_xiang_shao_long","text":"和你一样，在等待最好的机会。","tone":"淡然","chapter":120,"line_start":258,"line_end":260},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"吕相教我来劝你，他正在用人之时，蒙骜将军马上要出征韩国，少龙肯做他的副将吗？","tone":"陈述","chapter":120,"line_start":266,"line_end":268},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_wu_ying_yuan","text":"岳丈信任我吗？","tone":"认真","chapter":120,"line_start":270,"line_end":271},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"还用说吗？我对你比自己的亲儿更信任。","tone":"认真","chapter":120,"line_start":272,"line_end":274},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_wu_ying_yuan","text":"我每件事都是为乌家着想，包括这次退隐山林，终有一天岳丈会明白小婿为何这样做，但现在却请千万勿追问原因。","tone":"恳求","chapter":120,"line_start":276,"line_end":278},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"你有什么事在瞒着我？","tone":"疑问","chapter":120,"line_start":280,"line_end":281},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_wu_ying_yuan","text":"岳丈不是想为乌爷爷在咸阳建一个风风光光的衣冠冢吗？假若十年后我项少龙仍有命在，必可完成岳丈这心愿。","tone":"认真","chapter":120,"line_start":282,"line_end":286},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"我明白了！明天我们立即迁出咸阳，无论如何，我们岳婿之情，永不会改变。","tone":"欣慰","chapter":120,"line_start":288,"line_end":292}],"new_entities":{"characters":[{"id":"char_tao_fang","name":"陶方","alias":["陶公"],"identity":"乌家管事","faction":"faction_wu_jia","role":"companion","archetype":"scholar","rank":"初窥门径","one_line":"乌家管事，忠心耿耿，向项少龙转达各方消息","personality":{"traits":["忠心耿耿","老成持重","善察言观色","重情重义","谨小慎微"],"speech_style":"语调沉稳，时而欲言又止","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":3,"dynamic":"主仆兼朋友"},{"target":"char_wu_ying_yuan","type":"主仆","intensity":60,"bond_level":3,"dynamic":"忠仆"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":188,"line_end":188,"text":"陶方在大门处截着他，拉他到花园里"}]},{"id":"char_tu_xian","name":"图先","alias":["图爷"],"identity":"吕不韦手下谋士首领","faction":"faction_lv_zu","role":"companion","archetype":"scholar","rank":"登堂入室","one_line":"吕不韦手下谋士首领，与肖月潭亲如兄弟，暗中等待反击吕不韦的机会","personality":{"traits":["深谋远虑","沉着冷静","重情重义","隐忍坚毅","洒脱豁达"],"speech_style":"淡然中带冷意","temperament":"冷静"},"relationships":[{"target":"char_xiao_yue_tan","type":"挚友","intensity":80,"bond_level":5,"dynamic":"亲如兄弟"},{"target":"char_lv_bu_wei","type":"主仆","intensity":30,"bond_level":2,"dynamic":"暗中对抗"},{"target":"char_xiang_shao_long","type":"合作者","intensity":60,"bond_level":3,"dynamic":"同仇敌忾"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":226,"line_end":226,"text":"项少龙把肖月潭嘱托的信函交给来吊祭赵倩和诸婢的图先"}]},{"id":"char_wu_ying_yuan","name":"乌应元","alias":["岳丈"],"identity":"乌家家主，项少龙岳父","faction":"faction_wu_jia","role":"companion","archetype":"scholar","rank":"初窥门径","one_line":"乌家家主，项少龙岳父，最终决定信任女婿迁出咸阳","personality":{"traits":["深谋远虑","信任女婿","果断决绝","重情重义","顾全大局"],"speech_style":"语调诚恳，时而震惊","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"亲属","intensity":70,"bond_level":4,"dynamic":"岳婿情深"},{"target":"char_wu_ting_fang","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父女"}],"known_skills":[],"related_skills":[],"rag_refs":[120],"source_refs":[{"chapter":120,"line_start":264,"line_end":264,"text":"乌应元来到他旁坐下"}]},{"id":"char_zhao_ya","name":"赵雅","alias":["雅夫人"],"identity":"赵国公主","faction":"faction_zhao_guo","role":"npc","archetype":"healer","rank":"初窥门径","one_line":"赵国公主，放荡多情，为避韩晶追杀投靠信陵君，但心中真爱项少龙","personality":