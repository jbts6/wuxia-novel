{"segment":1,"line_start":1,"line_end":95,"dialogues":[{"speaker":"char_xu_ran","speaker_name":"许然","listener":"char_xiang_shao_long","text":"张爷在里面，你自己进去吧！","tone":"陈述","chapter":241,"line_start":4,"line_end":6},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":null,"text":"你们真不知自己做了什么错事吗？","tone":"无奈","chapter":241,"line_start":20,"line_end":21},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xiao_ling_zi","text":"小玲姊你好！\n\n还不去告小人一状，好革掉小人的御者之职？","tone":"调侃","chapter":241,"line_start":72,"line_end":74}],"new_entities":{"characters":[{"id":"char_xiang_shao_long","name":"项少龙","alias":["沈良"],"identity":"穿越者，假扮歌舞姬团御者沈良","faction":"歌舞姬团","role":"protagonist","archetype":"warrior","rank":"出神入化","one_line":"穿越时空的现代格斗高手，化名沈良混入歌舞姬团","personality":{"traits":["机智","勇猛","果断","冷静","幽默"],"speech_style":"伪装低调，真性情时豪迈洒脱","temperament":"临危不乱"},"relationships":[{"target":"char_feng_fei","type":"合作者","intensity":50,"bond_level":3,"dynamic":"被其庇护"},{"target":"char_zhang_quan","type":"对手","intensity":60,"bond_level":2,"dynamic":"揭穿其阴谋"},{"target":"char_sha_li","type":"宿敌","intensity":70,"bond_level":1,"dynamic":"正面冲突"}],"known_skills":["skill_qin_na_shou_fa","skill_rou_dao_shen_fa"],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":2,"line_end":2,"text":"项少龙跟着许然，举步进入船舱"}]},{"id":"char_xu_ran","name":"许然","alias":[],"identity":"歌舞姬团御者","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团御者，被项少龙反算计挨打","personality":{"traits":["莽撞","忠诚","粗心","胆小","顺从"],"speech_style":"简短直接","temperament":"急躁"},"relationships":[{"target":"char_xiang_shao_long","type":"对手","intensity":40,"bond_level":2,"dynamic":"被算计"}],"known_skills":[],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":2,"line_end":6,"text":"许然停下来，把门向内推开少许"}]},{"id":"char_gu_ming","name":"谷明","alias":[],"identity":"歌舞姬团御者","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团御者，参与围攻项少龙被打","personality":{"traits":["凶狠","冲动","好斗","鲁莽","怯懦"],"speech_style":"粗声大气","temperament":"暴躁"},"relationships":[{"target":"char_xiang_shao_long","type":"对手","intensity":50,"bond_level":1,"dynamic":"被击败"}],"known_skills":[],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":12,"line_end":12,"text":"谷明、富严等四、五名御者"}]},{"id":"char_fu_yan","name":"富严","alias":[],"identity":"歌舞姬团御者","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"歌舞姬团御者，参与围攻项少龙被打","personality":{"traits":["冲动","好斗","鲁莽","胆小","顺从"],"speech_style":"粗声","temperament":"急躁"},"relationships":[{"target":"char_xiang_shao_long","type":"对手","intensity":40,"bond_level":1,"dynamic":"被击败"}],"known_skills":[],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":12,"line_end":12,"text":"谷明、富严等四、五名御者"}]},{"id":"char_wu_xun","name":"巫循","alias":[],"identity":"歌舞姬团家将之首","faction":"歌舞姬团","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"歌舞姬团家将之首，身材矮壮力大，被项少龙首先击倒","personality":{"traits":["勇猛","笨拙","耿直","忠诚","不善言辞"],"speech_style":"迟钝结巴","temperament":"憨厚"},"relationships":[{"target":"char_xiang_shao_long","type":"对手","intensity":40,"bond_level":1,"dynamic":"被击倒"}],"known_skills":[],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":22,"line_end":26,"text":"欺到巫循矮壮的身侧，一记膝撞，顶在他腹下"}]},{"id":"char_xiao_ling_zi","name":"小玲姊","alias":[],"identity":"歌舞姬团董淑贞的侍女","faction":"歌舞姬团","role":"npc","archetype":"assassin","rank":"平平无奇","one_line":"董淑贞的贴身侍女，策划暗害项少龙反被吓跑","personality":{"traits":["阴险","胆小","谄媚","狡诈","懦弱"],"speech_style":"尖声","temperament":"心虚"},"relationships":[{"target":"char_dong_shu_zhen","type":"主仆","intensity":70,"bond_level":4,"dynamic":"受宠"},{"target":"char_xiang_shao_long","type":"宿敌","intensity":60,"bond_level":1,"dynamic":"策划暗害"}],"known_skills":[],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":68,"line_end":76,"text":"舱门倏地推开来，接着是小玲姊的尖叫声"}]},{"id":"char_feng_fei","name":"凤菲","alias":["大小姐"],"identity":"歌舞姬团首领","faction":"歌舞姬团","role":"npc","archetype":"scholar","rank":"出神入化","one_line":"歌舞姬团大小姐，精明果断，绝世容颜","personality":{"traits":["精明","果断","威严","聪慧","深沉"],"speech_style":"柔和中带威严","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":3,"dynamic":"庇护"},{"target":"char_dong_shu_zhen","type":"合作者","intensity":60,"bond_level":4,"dynamic":"上下级"},{"target":"char_zhang_quan","type":"主仆","intensity":50,"bond_level":3,"dynamic":"降级处分"},{"target":"char_sha_li","type":"宿敌","intensity":80,"bond_level":1,"dynamic":"驱逐"}],"known_skills":[],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":88,"line_end":88,"text":"凤菲仍戴着轻纱"}]},{"id":"char_dong_shu_zhen","name":"董淑贞","alias":["二小姐"],"identity":"歌舞姬团第二号人物","faction":"歌舞姬团","role":"npc","archetype":"scholar","rank":"出神入化","one_line":"歌舞姬团二小姐，美貌精明，首次亮相","personality":{"traits":["精明","厉害","美貌","果断","威严"],"speech_style":"清越嘹亮","temperament":"强势"},"relationships":[{"target":"char_feng_fei","type":"合作者","intensity":60,"bond_level":4,"dynamic":"副手"},{"target":"char_xiao_ling_zi","type":"主仆","intensity":70,"bond_level":4,"dynamic":"宠爱"},{"target":"char_xiang_shao_long","type":"对手","intensity":40,"bond_level":2,"dynamic":"审问"}],"known_skills":[],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":88,"line_end":90,"text":"歌舞姬团的第二号人物董淑贞首次亮相"}]},{"id":"char_yun_niang","name":"云娘","alias":[],"identity":"歌舞姬团乐师之首","faction":"歌舞姬团","role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"歌舞姬团乐师之首，半老徐娘风韵犹存","personality":{"traits":["成熟","稳重","温婉","精明","从容"],"speech_style":"温和劝解","temperament":"沉稳"},"relationships":[{"target":"char_feng_fei","type":"合作者","intensity":50,"bond_level":3,"dynamic":"同僚"}],"known_skills":[],"related_skills":[],"rag_refs":[241],"source_refs":[{"chapter":241,"line_start":92,"line_end":92,"text":"乐师之首云娘亦在场"}]},{"id":"char_zhang_quan","name":"张泉","alias":["张爷"],"ident