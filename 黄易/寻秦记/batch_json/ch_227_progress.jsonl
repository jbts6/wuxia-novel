efs":[{"chapter":227,"line_start":1,"line_end":62,"text":"秦国政治斗争"}]},{"id":"faction_zhao_guo","name":"赵国","type":"武林门派","location":"邯郸","sub_divisions":[],"one_line":"战国七雄之一","source_refs":[{"chapter":227,"line_start":36,"line_end":58,"text":"赵境作战"}]}],"locations":[{"id":"loc_zui_feng_lou","name":"醉风楼","region":"咸阳","one_line":"咸阳知名青楼","source_refs":[{"chapter":227,"line_start":1,"line_end":4,"text":"项少龙与十八铁卫来到醉风楼"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":63,"line_end":100,"dialogues":[{"speaker":"char_xiao_pan","speaker_name":"小盘","listener":"char_xiang_shao_long","text":"此计确是歹毒之极，可见一天不除成蟜，寡人仍是地位难稳。","tone":"愤怒","chapter":227,"line_start":66,"line_end":68},{"speaker":"char_xiao_pan","speaker_name":"小盘","listener":"char_xiang_shao_long","text":"若王上将军发生不幸，我们立即对付成蟜和杜璧，好去此心腹之患，那时寡人就要看吕不韦怎样收场。","tone":"冷酷","chapter":227,"line_start":72,"line_end":74},{"speaker":"char_xiao_pan","speaker_name":"小盘","listener":"char_xiang_shao_long","text":"储妃有喜了！","tone":"欣喜","chapter":227,"line_start":76,"line_end":76},{"speaker":"char_xiao_pan","speaker_name":"小盘","listener":"char_xiang_shao_long","text":"趁现在吕不韦和太后都不在咸阳，最好先帮这孩子取个好名字，那就轮不到他们来取了，师父有什么提议？","tone":"认真","chapter":227,"line_start":80,"line_end":82},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xiao_pan","text":"那定是叫扶苏了。","tone":"陈述","chapter":227,"line_start":84,"line_end":84},{"speaker":"char_xiao_pan","speaker_name":"小盘","listener":"char_xiang_shao_long","text":"名字倒也特别。但还须一个女儿的名字才成，那时无论生男生女，都有名字了。","tone":"认真","chapter":227,"line_start":86,"line_end":90},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xiao_pan","text":"我只想到男孩的名字，看来这胎该是男婴，所以不用另想女名。","tone":"陈述","chapter":227,"line_start":92,"line_end":94},{"speaker":"char_xiao_pan","speaker_name":"小盘","listener":"char_xiang_shao_long","text":"若生的是儿子，就叫扶苏吧！","tone":"欣喜","chapter":227,"line_start":96,"line_end":98}],"new_entities":{"characters":[{"id":"char_fu_su","name":"扶苏","alias":[],"identity":"秦国公子（未出生）","faction":"秦国","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"小盘与储妃之子，未来秦公子","personality":{"traits":["聪慧","仁厚","正直","宽仁","理想主义"],"speech_style":"温和","temperament":"宽厚"},"relationships":[{"target":"char_xiao_pan","type":"亲属","intensity":80,"bond_level":5,"dynamic":"父子"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":84,"line_end":98,"text":"那定是叫扶苏了"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_qin_guo_gong_dian","name":"秦国宫殿","region":"咸阳","one_line":"秦国皇宫内廷","source_refs":[{"chapter":227,"line_start":64,"line_end":64,"text":"小盘正和爱妃王美秀下棋取乐"}]}],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":101,"line_end":150,"dialogues":[{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":null,"text":"再喝下去，恐怕项某要立即给抬走，请各位格外开恩，饶了我这趟吧！","tone":"恳求","chapter":227,"line_start":112,"line_end":114},{"speaker":"char_wang_wan","speaker_name":"王绾","listener":"char_xiang_shao_long","text":"昨晚项大人喝了超过二十杯才倒下来，今晚怎都要再喝七杯，我们或可饶你迟来之罪。","tone":"调侃","chapter":227,"line_start":116,"line_end":118},{"speaker":"char_bai_ya_ya","speaker_name":"白雅雅","listener":"char_xiang_shao_long","text":"让雅雅代上将军喝这几杯罚酒吧！","tone":"温柔","chapter":227,"line_start":120,"line_end":122},{"speaker":"char_cai_ze","speaker_name":"蔡泽","listener":"char_xiang_shao_long","text":"罚酒必须先进项上将军之口，然后由我们的雅雅代喝。","tone":"调侃","chapter":227,"line_start":126,"line_end":128},{"speaker":"char_ying_ao","speaker_name":"嬴傲","listener":null,"text":"听说庞煖战败后，其他合纵国均指他冒失深进，白白错失挫败我大秦的良机，以致声威大跌，看来他们很难再组成另一次合纵。","tone":"陈述","chapter":227,"line_start":138,"line_end":140},{"speaker":"char_ying_lou","speaker_name":"嬴楼","listener":null,"text":"输了败仗，人人均推卸责任，今趟蕞城会战，走得最快的是楚人，也成了其他人责难的目标，弄得很不开心，五国该有好一段日子难以协调了。","tone":"陈述","chapter":227,"line_start":142,"line_end":144},{"speaker":"char_li_si","speaker_name":"李斯","listener":null,"text":"今晚只谈风月，不谈公事。太尉为少龙安排的一场玲珑燕舞，该可开始吧！","tone":"欣喜","chapter":227,"line_start":146,"line_end":148},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":null,"text":"只看我们廷尉大人比三哥还紧张，当知凤菲的吸引力哩！","tone":"调侃","chapter":227,"line_start":152,"line_end":154}],"new_entities":{"characters":[{"id":"char_bai_ya_ya","name":"白雅雅","alias":["雅雅"],"identity":"越国美女，醉风楼四花之首","faction":"中立","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"越国美女，醉风楼新四花之首","personality":{"traits":["温婉可人","甜美","聪慧","善解人意","妩媚"],"speech_style":"温柔甜美","temperament":"温婉"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":40,"bond_level":2,"dynamic":"暧昧"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":108,"line_end":110,"text":"越国美女白雅雅"}]},{