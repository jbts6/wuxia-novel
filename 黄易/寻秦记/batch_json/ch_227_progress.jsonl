c":"志同道合"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":102,"line_end":148,"text":"李斯在列"}]},{"id":"char_jing_jun","name":"荆俊","alias":["三哥"],"identity":"项少龙随从","faction":"秦国","role":"companion","archetype":"warrior","rank":"炉火纯青","one_line":"项少龙结义兄弟","personality":{"traits":["豪爽","勇猛","重义气","直率","活泼"],"speech_style":"豪爽","temperament":"豪迈"},"relationships":[{"target":"char_xiang_shao_long","type":"挚友","intensity":80,"bond_level":5,"dynamic":"兄弟情深"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":102,"line_end":154,"text":"荆俊在列"}]},{"id":"char_gui_yan","name":"归燕","alias":[],"identity":"醉风楼名妓","faction":"中立","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"醉风楼名妓","personality":{"traits":["美貌","善舞","机敏","多情","善妒"],"speech_style":"温柔","temperament":"多情"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":106,"line_end":106,"text":"杨豫、归燕和白蕾"}]},{"id":"char_bai_lei","name":"白蕾","alias":[],"identity":"醉风楼名妓","faction":"中立","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"醉风楼名妓","personality":{"traits":["美貌","善舞","温顺","灵巧","柔媚"],"speech_style":"温柔","temperament":"温和"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":106,"line_end":106,"text":"杨豫、归燕和白蕾"}]},{"id":"char_teng_yi","name":"滕翼","alias":[],"identity":"项少龙挚友","faction":"秦国","role":"companion","archetype":"warrior","rank":"出神入化","one_line":"项少龙结义兄弟","personality":{"traits":["沉稳","忠义","勇武","寡言","可靠"],"speech_style":"简洁","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"挚友","intensity":85,"bond_level":5,"dynamic":"兄弟情深"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":104,"line_end":104,"text":"滕翼因要陪伴妻儿"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":4,"line_start":151,"line_end":210,"dialogues":[{"speaker":"char_bai_ya_ya","speaker_name":"白雅雅","listener":"char_xiang_shao_long","text":"项爷不念旧恶，助美美小姐去当她的魏后，我们醉风楼的姊妹都非常感激呢！","tone":"温柔","chapter":227,"line_start":160,"line_end":162},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_bai_ya_ya","text":"此事岂非全城皆知了？","tone":"疑问","chapter":227,"line_start":164,"line_end":164},{"speaker":"char_bai_ya_ya","speaker_name":"白雅雅","listener":"char_xiang_shao_long","text":"好事传千里嘛！现在只要项爷勾勾指头，人人都会争着来为项爷侍寝哩！","tone":"调侃","chapter":227,"line_start":166,"line_end":168},{"speaker":"char_bai_ya_ya","speaker_name":"白雅雅","listener":"char_xiang_shao_long","text":"只不知雅雅能否得项爷恩宠？","tone":"娇声","chapter":227,"line_start":172,"line_end":172},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_bai_ya_ya","text":"今晚不行，待我看看吧！","tone":"犹豫","chapter":227,"line_start":174,"line_end":176},{"speaker":"char_bai_ya_ya","speaker_name":"白雅雅","listener":"char_xiang_shao_long","text":"白天也可以的，那项爷的夫人就不会知晓了。","tone":"娇声","chapter":227,"line_start":178,"line_end":178},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_wu_fu","text":"美人儿是否怪我们迟到？","tone":"疑问","chapter":227,"line_start":184,"line_end":184},{"speaker":"char_wu_fu","speaker_name":"伍孚","listener":"char_chang_ping_jun","text":"看来是这样子。菲小姐回了别院睡觉，小人说尽好话也不起作用。","tone":"无奈","chapter":227,"line_start":186,"line_end":188},{"speaker":"char_chang_wen_jun","speaker_name":"昌文君","listener":"char_xiang_shao_long","text":"都是少龙惹出来的祸，开罪了我们的玲珑美人儿，我提议由少龙去道歉，把她哄回来。","tone":"调侃","chapter":227,"line_start":192,"line_end":194},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_chang_wen_jun","text":"什么？","tone":"惊讶","chapter":227,"line_start":196,"line_end":196},{"speaker":"char_li_si","speaker_name":"李斯","listener":"char_xiang_shao_long","text":"玲珑美人明天便要到魏国去，少龙你快去设法。","tone":"认真","chapter":227,"line_start":198,"line_end":200},{"speaker":"char_huan_yi","speaker_name":"桓齮","listener":null,"text":"你们究竟是贺项上将军还是只为见玲珑燕？","tone":"疑问","chapter":227,"line_start":202,"line_end":204},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":null,"text":"小弟尽管去试试看，若给轰回来，你们可不能怪我。","tone":"无奈","chapter":227,"line_start":206,"line_end":208}],"new_entities":{"characters":[{"id":"char_chang_ping_jun","name":"昌平君","alias":[],"identity":"秦国大臣","faction":"秦国","role":"companion","archetype":"scholar","rank":"登堂入室","one_line":"秦国重臣","personality":{"traits":["稳重","善谋","忠诚","有担当","老练"],"speech_style":"沉稳","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"挚友","intensity":70,"bond_level":4,"dynamic":"友好合作"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":102,"line_end":184,"text":"昌平君兄弟"}]},{"id":"char_chang_wen_jun","name":"昌文君","alias":[],"identity":"秦国大臣","faction":"秦国","role":"companion","archetype":"scholar","rank":"登堂入室","one_line":"昌平君之弟","personality":{"traits":["活泼","善谈","忠诚","风趣","机敏"],"speech_style":"豪爽","temperament":"豪迈"},"relationships":[{"target":"char_xiang_shao_long","type":"挚友","intensity":65,"bond_level":3,"dynamic":"友好"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":192,"line_end":194,"text":"昌文君笑道"}]},{"id":"char_huan_yi","name":"桓齮","alias":[],"identity":"秦国将领","faction":"秦国","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"秦国将领","personality":{"traits":["勇猛","直率","忠诚","善战","豪爽"],"speech_style":"豪迈","temperament":"豪迈"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":102,"line_end":204,"text":"桓齮在列"}]},{"id":"char_wu_guo","name":"乌果","alias":[],"identity":"项少龙随从","faction":"秦国","role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"项少龙铁卫之一","personality":{"traits":["忠诚","勇武","沉稳","可靠","寡言"],"speech_style":"简洁","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"主仆","intensity":75,"bond_level":4,"dynamic":"忠心耿耿"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":102,"line_end":210,"text":"乌果在列"}]},{"id":"char_zhou_liang","name":"周良","alias":[],"identity":"秦国将领","faction":"秦国","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"秦国将领","personality":{"traits":["勇猛","忠诚","稳重","善战","朴实"],"speech_style":"沉稳","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":102,"line_end":102,"text":"周良在列"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":5,"line_start":211,"line_end":280,"dialogues":[{"speaker":"char_wu_fu","speaker_name":"伍孚","listener":"char_xiang_shao_long","text":"凤菲就住在那里，她的贴身小婢很凶，刚才便是她把我挡着的。","tone":"无奈","chapter":227,"line_start":216,"line_end":218},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_wu_fu","text":"她难道不知你是大老板吗？怎敢对楼主不客气？","tone":"惊讶","chapter":227,"line_start":220,"line_end":220},{"speaker":"char_wu_fu","speaker_name":"伍孚","listener":"char_jing_jun","text":"她是储妃特别请回来在太后寿宴上表演助兴的，小人怎敢开罪她们？","tone":"无奈","chapter":227,"line_start":222,"line_end":224},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":null,"text":"你们看我的！","tone":"豪迈","chapter":227,"line_start":226,"line_end":226},{"speaker":"char_chang_wen_jun","speaker_name":"昌文君","listener":"char_xiang_shao_long","text":"听说凤菲身轻如燕，颇有两下子的，上将军莫要被她踢落池塘。","tone":"调侃","chapter":227,"line_start":228,"line_end":230},{"speaker":"char_xiao_mei","speaker_name":"小妹","listener":"char_xiang_shao_long","text":"谁？","tone":"疑问","chapter":227,"line_start":240,"line_end":240},{"speaker":"char_xiao_mei","speaker_name":"小妹","listener":"char_xiang_shao_long","text":"你是谁，怎可随便闯入人家小姐闺房？","tone":"愤怒","chapter":227,"line_start":256,"line_end":256},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xiao_mei","text":"在下项少龙，特来向凤小姐请罪。","tone":"认真","chapter":227,"line_start":258,"line_end":260},{"speaker":"char_xiao_mei","speaker_name":"小妹","listener":"char_feng_fei","text":"小姐！是项少龙呢！","tone":"惊讶","chapter":227,"line_start":262,"line_end":264},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_xiao_mei","text":"若姑娘肯让路，我便进去见凤小姐；但若姑娘不允许，在下只好立即离开。","tone":"认真","chapter":227,"line_start":272,"line_end":274},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"小妹请让项大人进来一叙吧！","tone":"温柔","chapter":227,"line_start":280,"line_end":280}],"new_entities":{"characters":[{"id":"char_feng_fei","name":"凤菲","alias":["玲珑美人"],"identity":"三大名姬之首","faction":"中立","role":"npc","archetype":"healer","rank":"登峰造极","one_line":"三大名姬之首，玲珑燕舞名动天下","personality":{"traits":["聪慧","有见识","楚楚动人","善谋","独立"],"speech_style":"温柔中带锋芒","temperament":"优雅"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":3,"dynamic":"惺惺相惜"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":152,"line_end":280,"text":"玲珑燕舞"}]},{"id":"char_xiao_mei","name":"小妹","alias":["俏童子"],"identity":"凤菲贴身小婢","faction":"中立","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"凤菲贴身小婢，女扮男装","personality":{"traits":["忠心","泼辣","机敏","勇敢","娇俏"],"speech_style":"清脆","temperament":"活泼"},"relationships":[{"target":"char_feng_fei","type":"主仆","intensity":80,"bond_level":4,"dynamic":"忠心护卫"}],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":240,"line_end":284,"text":"俏童子"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_feng_fei_bie_yuan","name":"凤菲别院","region":"咸阳","one_line":"醉风楼后院凤菲住处","source_refs":[{"chapter":227,"line_start":214,"line_end":214,"text":"醉风楼后院一个幽静的角落，池塘旁有座小木楼"}]}],"items":[]},"entity_updates":[]}
{"segment":6,"line_start":281,"line_end":384,"dialogues":[{"speaker":"char_xiao_mei","speaker_name":"小妹","listener":"char_xiang_shao_long","text":"小姐！要茶还是酒呢？","tone":"疑问","chapter":227,"line_start":300,"line_end":302},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_feng_fei","text":"不用客气，我是特来向小姐请罪，不敢打扰小姐的清净心。","tone":"认真","chapter":227,"line_start":304,"line_end":306},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"清净心？人在尘世，何来清净心呢？项大人请坐。小妹给客人奉茶。","tone":"轻笑","chapter":227,"line_start":308,"line_end":310},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"项大人今趟来请罪，并不似大人一向作风，不知是被人逼来，还是自愿要来呢？","tone":"疑问","chapter":227,"line_start":312,"line_end":314},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_feng_fei","text":"我和小姐乃初次见面，为何小姐却像对项某非常熟悉？","tone":"惊讶","chapter":227,"line_start":316,"line_end":318},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"项少龙乃东方六国权贵间最多人谈论的人物，凤菲早耳熟能详。何况来秦前又曾听魏国美美夫人提起大人，怎都该对大人有个印象吧！","tone":"陈述","chapter":227,"line_start":320,"line_end":324},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_feng_fei","text":"凤小姐今趟故意拒绝表演，是否……嘿！是否……","tone":"犹豫","chapter":227,"line_start":326,"line_end":328},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"大人何必吞吞吐吐？有什么放胆直言好了。","tone":"鼓励","chapter":227,"line_start":330,"line_end":332},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_feng_fei","text":"我想问小姐是否故意使手段引我前来一见，我因怕唐突佳人，所以才会欲言又止，教小姐见笑了。","tone":"苦笑","chapter":227,"line_start":334,"line_end":334},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"项大人猜得没错，但怕仍估不到凤菲此来是不安好心。这银戒乃魏国巧匠所制，能弹出毒针，把毒液注入人体，若部位恰当，中针者迅即毒发身亡。","tone":"淡然","chapter":227,"line_start":338,"line_end":342},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_feng_fei","text":"既是如此，凤小姐为何要告诉我？","tone":"惊讶","chapter":227,"line_start":344,"line_end":344},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"因为我改变主意哩！直至来秦见过嬴政后，妾身才明白为何先后有商鞅、公孙衍、张仪、甘茂、楼缓、范睢、蔡泽、吕不韦、项少龙、李斯等众多人才，甘为秦室所用。而赵国空有李牧、廉颇而仍连场失利，信陵君落得饮毒酒而死，韩非则在韩国投闲置散，燕人无自知之明，齐人奢华空想，楚人耽于逸乐。东方六国大势去矣，我凤菲何必要枉做小人，还得赔上性命？","tone":"认真","chapter":227,"line_start":346,"line_end":354},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_feng_fei","text":"凤小姐确是奇女子。不过我仍不明白小姐为何如此坦白，若小姐不说出来，此事谁都不会知晓。","tone":"认真","chapter":227,"line_start":356,"line_end":360},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"你这大傻瓜，因为人家已看上你，所以才提醒你。现在项大人乃东方诸国欲杀之而后快的对象，所以千万不要相信任何人，包括你曾施以恩惠的朋友在内。","tone":"认真","chapter":227,"line_start":362,"line_end":366},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"大人切勿误会，看上你并不等于倾心于你，只是觉得你确是名不虚传的英雄人物，日后我亦很难忘记你，就是那样罢了！","tone":"微笑","chapter":227,"line_start":370,"line_end":372},{"speaker":"char_feng_fei","speaker_name":"凤菲","listener":"char_xiang_shao_long","text":"夜了！项大人除非要凤菲侍寝，否则妾身就要到梦乡寻找在乱世所欠的美梦。明天清晨，我将起程离秦了。","tone":"温柔","chapter":227,"line_start":376,"line_end":378},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_xiang_shao_long","text":"蒙骜过世了！","tone":"悲伤","chapter":227,"line_start":384,"line_end":384}],"new_entities":{"characters":[{"id":"char_meng_ao","name":"蒙骜","alias":[],"identity":"秦国老将","faction":"秦国","role":"npc","archetype":"warrior","rank":"出神入化","one_line":"秦国老将，蒙恬蒙毅之祖","personality":{"traits":["忠勇","善战","刚毅","老当益壮","忠诚"],"speech_style":"豪迈","temperament":"刚毅"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":384,"line_end":384,"text":"蒙骜过世了"}]},{"id":"char_shi_su_fang","name":"石素芳","alias":["三绝女"],"identity":"三大名姬之一","faction":"中立","role":"npc","archetype":"healer","rank":"登峰造极","one_line":"三大名姬之一","personality":{"traits":["才艺双绝","清高","聪慧","独立","冷傲"],"speech_style":"淡然","temperament":"清冷"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":298,"line_end":298,"text":"在诱惑男人这一项上，她确胜过石素芳和兰宫媛"}]},{"id":"char_lan_gong_yuan","name":"兰宫媛","alias":[],"identity":"三大名姬之一","faction":"中立","role":"npc","archetype":"healer","rank":"登峰造极","one_line":"三大名姬之一","personality":{"traits":["才艺双绝","妩媚","聪慧","善于交际","高雅"],"speech_style":"温柔","temperament":"优雅"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":298,"line_end":298,"text":"在诱惑男人这一项上，她确胜过石素芳和兰宫媛"}]}],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[{"id":"item_du_zhen_yin_jie","name":"毒针银戒","type":"hidden_weapon","owner":"char_feng_fei","one_line":"魏国巧匠所制的暗杀银戒","description":"魏国巧匠精心打造的银质戒指，内藏机关可弹出毒针，将毒液注入人体，若部位恰当可致人于死地，做工精巧外表与普通银戒无异","effects":["暗杀","中毒"],"origin":"魏国","rarity":"稀世珍品","related_characters":["char_feng_fei"],"related_skills":[],"rag_refs":[227],"source_refs":[{"chapter":227,"line_start":338,"line_end":342,"text":"这银戒乃魏国巧匠所制，能弹出毒针"}]}]},"entity_updates":[]}
