{"segment":3,"line_start":79,"line_end":121,"dialogues":[{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"还以为你不来了。","tone":"埋怨","chapter":235,"line_start":116,"line_end":117},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"少奶奶不是要你驾车送她回娘家吗？竟这么快回来了。","tone":"埋怨","chapter":235,"line_start":118,"line_end":120}],"new_entities":{},"entity_updates":[]}
{"segment":4,"line_start":122,"line_end":170,"dialogues":[{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"你不是史龄，你是刘杰，休想骗我。","tone":"嘲讽","chapter":235,"line_start":126,"line_end":128},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"你这死人，平时已色迷迷地打量人家，也不知你给了史龄什么好处，竟让你代他到这里来欺负人家，还不快来。","tone":"娇声","chapter":235,"line_start":160,"line_end":162},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"喜欢我吗？","tone":"疑问","chapter":235,"line_start":166,"line_end":166}],"new_entities":{},"entity_updates":[]}
{"segment":5,"line_start":171,"line_end":210,"dialogues":[{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"我也不是刘杰！","tone":"陈述","chapter":235,"line_start":172,"line_end":174},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"你是谁？","tone":"惊讶","chapter":235,"line_start":176,"line_end":176},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"我叫陈武，是随骡车队送粮来的人，想进仓内看看情况，却遇上大姊你，老天爷对我太好了。大姊你叫什么名字？","tone":"柔声","chapter":235,"line_start":178,"line_end":180},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"你这死人呢！竟占了人家的大便宜。我叫秋琳，是大少爷的小婢。唉！你这人哩！不过你比大少爷和史龄都好多了，刘杰看来也没你那么壮健。","tone":"大笑","chapter":235,"line_start":182,"line_end":188},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"有没有办法弄点吃喝的东西来，千万不要让人晓得。","tone":"认真","chapter":235,"line_start":190,"line_end":192},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"放心吧！若让人知道这事，我也要没命呢！","tone":"柔声","chapter":235,"line_start":194,"line_end":196},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"我从未见过像你那么威武英俊的人呢！只是瘦了点。","tone":"温柔","chapter":235,"line_start":208,"line_end":210}],"new_entities":{"characters":[{"id":"char_qiu_lin","name":"秋琳","alias":[],"identity":"魏国大官府婢女","faction":"魏国权贵","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"魏国大官府上的年轻婢女，与府中多人有私情","personality":{"traits":["风骚","热情","单纯","大胆","依恋","轻浮","直率"],"speech_style":"娇媚放浪","temperament":"热情奔放"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":70,"bond_level":3,"dynamic":"一夜之情"},{"target":"char_shi_ling","type":"恋人","intensity":40,"bond_level":2,"dynamic":"偷情"},{"target":"char_liu_jie","type":"恋人","intensity":30,"bond_level":2,"dynamic":"偷情"}],"known_skills":[],"related_skills":[],"rag_refs":[235],"source_refs":[{"chapter":235,"line_start":184,"line_end":184,"text":"我叫秋琳，是大少爷的小婢"}]},{"id":"char_shi_ling","name":"史龄","alias":[],"identity":"魏国大官府中人","faction":"魏国权贵","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"与秋琳有私情的府中人物","personality":{"traits":["好色","轻浮","大胆","普通","平庸"],"speech_style":"普通","temperament":"平庸"},"relationships":[{"target":"char_qiu_lin","type":"恋人","intensity":40,"bond_level":2,"dynamic":"偷情"}],"known_skills":[],"related_skills":[],"rag_refs":[235],"source_refs":[{"chapter":235,"line_start":126,"line_end":126,"text":"你不是史龄，你是刘杰"}]},{"id":"char_liu_jie","name":"刘杰","alias":[],"identity":"魏国大官府中人","faction":"魏国权贵","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"与秋琳有私情的府中人物，被项少龙冒充","personality":{"traits":["好色","普通","平庸","轻浮","懦弱"],"speech_style":"普通","temperament":"平庸"},"relationships":[{"target":"char_qiu_lin","type":"恋人","intensity":30,"bond_level":2,"dynamic":"偷情"}],"known_skills":[],"related_skills":[],"rag_refs":[235],"source_refs":[{"chapter":235,"line_start":126,"line_end":126,"text":"你不是史龄，你是刘杰"}]}]},"entity_updates":[]}
{"segment":6,"line_start":211,"line_end":260,"dialogues":[{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"有什么吃的好东西带来？","tone":"疑问","chapter":235,"line_start":212,"line_end":214},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"你这个连着腰带的钩子是做什么用的？","tone":"好奇","chapter":235,"line_start":218,"line_end":220},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"是用来搬货的。","tone":"陈述","chapter":235,"line_start":222,"line_end":222},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"你这样溜进来，赶粮的谢老大不会怪你吗？","tone":"疑问","chapter":235,"line_start":224,"line_end":226},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"我告诉他去找朋友，该不会有问题的。","tone":"陈述","chapter":235,"line_start":228,"line_end":228},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"哪是找什么朋友，你想去嫖才真，只是碰巧嫖上人家。","tone":"调侃","chapter":235,"line_start":230,"line_end":232},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"以后我不理史龄，只盼能永远和你相好！","tone":"幽怨","chapter":235,"line_start":236,"line_end":238},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"你不想和我好也不成。","tone":"调侃","chapter":235,"line_start":240,"line_end":240},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"大少爷快回来了，我要走了呢！你……","tone":"焦急","chapter":235,"line_start":244,"line_end":244},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"什么时候你可再来？","tone":"疑问","chapter":235,"line_start":246,"line_end":246},{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"要看情况才行，但怎样告诉你呢？","tone":"犹豫","chapter":235,"line_start":248,"line_end":248},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_qiu_lin","text":"为了秋琳姊，我陈武什么都肯干，横竖没事，我就在这里等你，有机会秋琳姊便来找我。但记紧要带些吃喝的东西来，若有衣服更好。","tone":"认真","chapter":235,"line_start":250,"line_end":252}],"new_entities":{},"entity_updates":[]}
{"segment":7,"line_start":261,"line_end":306,"dialogues":[{"speaker":"char_qiu_lin","speaker_name":"秋琳","listener":"char_xiang_shao_long","text":"武郎你将就一点吧！大少爷的衣服又不合你穿，像你那么高大的人很少有呢！","tone":"柔声","chapter":235,"line_start":274,"line_end":276},{"speaker":"char_xiao_hai","speaker_name":"小孩","listener":null,"text":"强盗来了！","tone":"恐惧","chapter":235,"line_start":302,"line_end":302}],"new_entities":{"characters":[{"id":"char_da_shao_ye","name":"大少爷","alias":[],"identity":"魏国大官府主人","faction":"魏国权贵","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"魏国大官府上的少爷，秋琳的主人","personality":{"traits":["权贵","普通","威严","平庸","富足"],"speech_style":"普通","temperament":"威严"},"relationships":[{"target":"char_qiu_lin","type":"主仆","intensity":50,"bond_level":3,"dynamic":"主仆关系"}],"known_skills":[],"related_skills":[],"rag_refs":[235],"source_refs":[{"chapter":235,"line_start":184,"line_end":184,"text":"我叫秋琳，是大少爷的小婢"}]},{"id":"char_xie_lao_da","name":"谢老大","alias":[],"identity":"赶粮队负责人","faction":"魏国","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"负责赶粮队的头领","personality":{"traits":["务实","普通","严厉","平凡","勤劳"],"speech_style":"普通","temperament":"严肃"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[235],"source_refs":[{"chapter":235,"line_start":224,"line_end":224,"text":"赶粮的谢老大不会怪你吗"}]},{"id":"char_xiao_hai","name":"小孩","alias":[],"identity":"大梁城中孩童","faction":"魏国","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"大梁城中踢毽子的孩童，认出项少龙","personality":{"traits":["天真","活泼","胆小","直率","好奇"],"speech_style":"稚嫩","temperament":"活泼"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[235],"source_refs":[{"chapter":235,"line_start":302,"line_end":302,"text":"其中一个小孩瞥见他，忽地脸色大变，高呼道：强盗来了"}]}]},"entity_updates":[]}
