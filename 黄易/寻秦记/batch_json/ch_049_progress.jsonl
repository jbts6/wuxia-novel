lls":[],"related_skills":[],"rag_refs":[49],"source_refs":[{"chapter":49,"line_start":110,"line_end":111,"text":"又想起远在大梁的纪嫣然"}]},{"id":"char_yan_ping","name":"严平","alias":[],"identity":"赵国武术宗师","faction":null,"role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"赵国武术宗师，被项少龙击败","personality":{"traits":["高傲","武艺高强","有地位","自视甚高","记仇"],"speech_style":"威严","temperament":"高傲"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[49],"source_refs":[{"chapter":49,"line_start":168,"line_end":169,"text":"昨晚项少龙大胜在邯郸有崇高武术地位的宗师级人物严平"}]},{"id":"char_zhao_ba","name":"赵霸","alias":[],"identity":"赵国武术名家","faction":null,"role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"赵国武术名家，赵致之师","personality":{"traits":["有地位","谨慎","识时务","护短","圆滑"],"speech_style":"沉稳","temperament":"稳重"},"relationships":[{"target":"char_zhao_zhi","type":"师徒","intensity":50,"bond_level":2,"dynamic":"师徒"}],"known_skills":[],"related_skills":[],"rag_refs":[49],"source_refs":[{"chapter":49,"line_start":170,"line_end":171,"text":"一向自视甚高的赵霸亦生出怯意"}]},{"id":"char_lian_jin","name":"连晋","alias":[],"identity":"赵国武士","faction":null,"role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"赵国武士，赵致旧爱，已死于项少龙剑下","personality":{"traits":["高傲","武艺高强","阴险","善用阴谋","记仇"],"speech_style":"傲慢","temperament":"阴险"},"relationships":[{"target":"char_zhao_zhi","type":"恋人","intensity":50,"bond_level":2,"dynamic":"已断"},{"target":"char_zhao_mu","type":"合作者","intensity":60,"bond_level":3,"dynamic":"合作"}],"known_skills":[],"related_skills":[],"rag_refs":[49],"source_refs":[{"chapter":49,"line_start":176,"line_end":177,"text":"不是连晋死就是我项少龙亡"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_sang_lin_cun","name":"桑林村","region":"赵国","one_line":"美蚕娘曾居住的村庄","source_refs":[{"chapter":49,"line_start":108,"line_end":109,"text":"走到桑林村去看个究竟"}]}],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":199,"line_end":280,"dialogues":[{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_qian","text":"想不到这孩子变得这么懂事。","tone":"陈述","chapter":49,"line_start":226,"line_end":228},{"speaker":"char_zhao_qian","speaker_name":"赵倩","listener":"char_xiang_shao_long","text":"他最爱的人是妮姨，现在他心中充满仇恨，不但恨赵穆，也恨父王，所以他要以你这个师父为榜样，学得智勇双全，好为妮姨报仇雪恨。","tone":"悲伤","chapter":49,"line_start":230,"line_end":232},{"speaker":"char_zhao_qian","speaker_name":"赵倩","listener":"char_xiang_shao_long","text":"他肯接受我，一方面因为我是你的人，另一方面是因我和他一样，都痛恨父王和赵穆。","tone":"陈述","chapter":49,"line_start":238,"line_end":240},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_qian","text":"你父王不是最敬重妮夫人吗？为何竟会这么坐看赵穆行凶？至少应彻查此事，何况此事已惹起军方的不满，使赵国面临长平之战以来最大的危机。","tone":"疑问","chapter":49,"line_start":242,"line_end":246},{"speaker":"char_zhao_qian","speaker_name":"赵倩","listener":"char_xiang_shao_long","text":"没有人能明白父王的，以前他并不是这个样子。自长平之战后，他整个人变了，优柔寡断，凡事三心两意，甚至有点怕面对朝臣，尤其是军方的将领，任得赵穆大权独揽，只手遮天。像妮夫人这件事，他本应严责禁卫彻查，但赵穆介入后，三招两式便大事化小，小事化无，教宫内所有人都对他心淡了。","tone":"无奈","chapter":49,"line_start":248,"line_end":254},{"speaker":"char_zhao_qian","speaker_name":"赵倩","listener":"char_xiang_shao_long","text":"我仍在怀念当时逃出大梁的日子，希望每晚有你疼爱人家。少龙啊！什么时候我们离开这丑恶的地方，找个无人的荒野，让倩儿为你生火炊饭，你则打猎来维持生活？","tone":"恳求","chapter":49,"line_start":268,"line_end":272}],"new_entities":{"characters":[{"id":"char_zhao_qian","name":"赵倩","alias":["倩儿","三公主"],"identity":"赵国公主","faction":"faction_zhao_guo_chao_ting","role":"companion","archetype":"scholar","rank":"平平无奇","one_line":"赵国公主，温柔善良，深爱项少龙","personality":{"traits":["温柔","善良","聪慧","坚强","深情"],"speech_style":"柔声","temperament":"温柔"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":70,"bond_level":3,"dynamic":"相爱"},{"target":"char_zhao_pan","type":"亲属","intensity":50,"bond_level":2,"dynamic":"表姊弟"}],"known_skills":[],"related_skills":[],"rag_refs":[49],"source_refs":[{"chapter":49,"line_start":218,"line_end":219,"text":"夫人府内只有赵倩和公子盘"}]},{"id":