s":[{"id":"item_lu_gong_mi_lu","name":"鲁公秘录","type":"special","owner":null,"one_line":"鲁公所著秘录，被项少龙从信陵君府偷走","description":"鲁公所著的珍贵典籍，记载了重要的军事和政治秘密，被项少龙从信陵君府偷龙转凤盗走，引发信陵君暴怒","effects":[],"origin":"鲁国","rarity":"稀世珍品","related_characters":["char_xiang_shao_long","char_xin_ling_jun"],"related_skills":[],"rag_refs":[49],"source_refs":[{"chapter":49,"line_start":72,"line_end":73,"text":"又发觉《鲁公秘录》除了头一截外，被人偷龙转凤盗走"}]}]},"entity_updates":[]}
{"segment":2,"line_start":94,"line_end":198,"dialogues":[{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_teng_yi","text":"你看看我的提议是否可行？在这两千子弟兵中，拣出大约一百个最优秀的，名之为'精兵团'，把他们带往农场隔离起来操练，学习各种不同技能，假若人人学得你和荆俊的一半身手，那时要强闯进质子府救人，亦非没有可能的事了。","tone":"陈述","chapter":49,"line_start":95,"line_end":98},{"speaker":"char_teng_yi","speaker_name":"滕翼","listener":"char_xiang_shao_long","text":"如此训练方式我尚是首次听到，少龙你实是无可比拟的军事天才，战争到了你手上已变成一种艺术。","tone":"激动","chapter":49,"line_start":100,"line_end":102},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_xiang_shao_long","text":"小俊很感谢项大哥和滕大哥，没有你们把我带到这么刺激好玩的地方来，生活不知怎么过才好。","tone":"欣慰","chapter":49,"line_start":112,"line_end":114},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_jing_jun","text":"但也可能会害你丢了小命！","tone":"调侃","chapter":49,"line_start":116,"line_end":116},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_xiang_shao_long","text":"那就只好认命！正是因为有随时丢命的危险，和美女玩起来时才特别有味道，那种感觉就像我五岁那年，首次帮着爹一起去猎虎的情景！","tone":"豪迈","chapter":49,"line_start":118,"line_end":120},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_jing_jun","text":"五岁的小孩走路都不稳妥，你能够帮什么忙？","tone":"疑问","chapter":49,"line_start":122,"line_end":122},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_xiang_shao_long","text":"这我就忘记哩！只记得当猛虎掉进陷阱时，那可怕的吼啸声，吓得我把尿撒到裤裆里去哩！","tone":"大笑","chapter":49,"line_start":124,"line_end":126},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_zhi","text":"致姑娘要到哪里去？","tone":"疑问","chapter":49,"line_start":136,"line_end":136},{"speaker":"char_zhao_zhi","speaker_name":"赵致","listener":"char_xiang_shao_long","text":"兵卫要到哪里去？","tone":"淡然","chapter":49,"line_start":138,"line_end":140},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_zhao_zhi","text":"致姑娘还未回答项大哥的话哩！","tone":"调侃","chapter":49,"line_start":142,"line_end":142},{"speaker":"char_zhao_zhi","speaker_name":"赵致","listener":"char_jing_jun","text":"大人说话，没有你插嘴的余地！","tone":"愤怒","chapter":49,"line_start":144,"line_end":146},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_zhi","text":"姑娘错了，小俊是我的好兄弟，他的话就是我的话。","tone":"陈述","chapter":49,"line_start":148,"line_end":150},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_zhao_zhi","text":"我还以为致姑娘是来找我荆俊的哩！","tone":"调侃","chapter":49,"line_start":152,"line_end":154},{"speaker":"char_zhao_zhi","speaker_name":"赵致","listener":"char_jing_jun","text":"谁要找你？","tone":"愤怒","chapter":49,"line_start":156,"line_end":156},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_zhao_zhi","text":"那你来找谁啊？","tone":"调侃","chapter":49,"line_start":160,"line_end":160},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_zhi","text":"当时在那种被迫分出生死的决战里，不是连晋死就是我项少龙亡，而且连晋和赵穆使弄阴谋诡计在先，我则是光明正大和他比拼高下，谁能怪我呢？","tone":"陈述","chapter":49,"line_start":176,"line_end":178},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_zhi","text":"致姑娘，让荆俊送你回家好吗？","tone":"陈述","chapter":49,"line_start":190,"line_end":192},{"speaker":"char_zhao_zhi","speaker_name":"赵致","listener":"char_xiang_shao_long","text":"我不用人送！","tone":"慌张","chapter":49,"line_start":194,"line_end":194},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_zhao_zhi","text":"致姑娘等等我！","tone":"焦急","chapter":49,"line_start":196,"line_end":198}],"new_entities":{"characters":[{"id":"char_teng_yi","name":"滕翼","alias":[],"identity":"项少龙的好兄弟","faction":"faction_wu_jia","role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"项少龙的好兄弟，经验丰富的猛将，正在训练乌家子弟兵","personality":{"traits":["勇猛","忠诚","经验丰富","沉稳","重义气"],"speech_style":"沉稳","temperament":"刚毅"},"relationships":[{"target":"char_xiang_shao_long","type":"挚友","intensity":80,"bond_level":4,"dynamic":"兄弟"}],"known_skills":[],"related_skills":[],"rag_refs":[49],"source_refs":[{"chapter":49,"line_start":94,"line_end":95,"text":"往找滕翼，见他正训练乌家的子弟兵"}]},{"id":"char_jing_jun","name":"荆俊","alias":["小俊"],"identity":"项少龙的好兄弟","faction":