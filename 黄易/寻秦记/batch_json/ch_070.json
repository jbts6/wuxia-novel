      {
        "id": "loc_liu_hua_sheng_fu",
        "name": "刘华生府",
        "region": "邯郸",
        "one_line": "邯郸著名大儒刘华生的府第，纪嫣然寄居之处，与项少龙住处仅隔两条街。",
        "source_refs": [
          {
