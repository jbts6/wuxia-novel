      {
        "id": "loc_xue_di_fang_wu",
        "name": "雪地房屋",
        "region": "韩境",
        "one_line": "韩境雪原上的废弃房屋群，项少龙和滕翼在此设伏伏击嚣魏牟的追兵。",
        "source_refs": [
          {
            "chapter": 42,
            "line_start": 2,
            "line_end": 2,
            "text": "项少龙与滕翼挨坐在屋内窗子两旁的墙脚"
