],"rag_refs":[123],"source_refs":[{"chapter":123,"line_start":172,"line_end":172,"text":"义渠君嬴楼"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_qin_gong","name":"秦宫","region":"咸阳","one_line":"秦国宫殿，庄襄王处理政务之所","source_refs":[{"chapter":123,"line_start":136,"line_end":136,"text":"秦宫的禁卫统领安谷傒"}]},{"id":"loc_han_gu_guan","name":"函谷关","region":"秦国","one_line":"秦国险要关隘，抵御东方联军的屏障","source_refs":[{"chapter":123,"line_start":54,"line_end":54,"text":"蒙大将军败返函谷关"}]}],"items":[]},"entity_updates":[{"id":"char_long_yang_jun","updates":{"source_refs":[{"chapter":123,"line_start":92,"line_end":94,"text":"董马痴怎会这么不明不白地轻易死掉"}]}}]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_zhuang_xiang_wang","text":"我们今趟之败，实因敌人来得突然，以致措手不及，此次既有备而战，将完全是另一番情况。","tone":"冷酷","chapter":123,"line_start":202,"line_end":204},{"speaker":"char_lu_gong","speaker_name":"鹿公","listener":"char_lv_bu_wei","text":"信陵君乃足智多谋的人，当年曾破我军于邯郸城外，前车可鉴，右相国怎可说得这般容易。","tone":"嘲讽","chapter":123,"line_start":206,"line_end":208},{"speaker":"char_xu_xian","speaker_name":"徐先","listener":"char_zhuang_xiang_wang","text":"我军新败，锐气已挫，纵是孙武复生，怕亦要暂且收敛，大王请三思。","tone":"沉声","chapter":123,"line_start":210,"line_end":212},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_zhuang_xiang_wang","text":"太原郡、三川郡、上党郡关系我大秦霸业的盛衰，若任由无忌小儿陈兵关外，三郡一旦失守，彼长我消，更是不利，大王明察。","tone":"焦急","chapter":123,"line_start":216,"line_end":218},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":null,"text":"寡人意已决，就任命……","tone":"陈述","chapter":123,"line_start":220,"line_end":220},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":null,"text":"不杀此人，难消我心头之恨！","tone":"愤怒","chapter":123,"line_start":224,"line_end":224},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhuang_xiang_wang","text":"大王请听微臣一言。","tone":"恳求","chapter":123,"line_start":226,"line_end":228},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_xiang_shao_long","text":"少龙想说什么？","tone":"疑问","chapter":123,"line_start":238,"line_end":238},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhuang_xiang_wang","text":"微臣刚才听到的，无论主攻主守，均有得失风险，所以想出一个两全其美之法，让大王不费一兵一卒，立可解去函谷关之危。","tone":"认真","chapter":123,"line_start":240,"line_end":242},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_xiang_shao_long","text":"快说出来给寡人参详。","tone":"欣喜","chapter":123,"line_start":246,"line_end":248},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhuang_xiang_wang","text":"今天五国之所以合纵成功，兵临关下，关键处全系于无忌公子一人身上，此人若去，联军之围不战自解，太原三郡可保安然。","tone":"陈述","chapter":123,"line_start":250,"line_end":252},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhuang_xiang_wang","text":"当日微臣曾到大梁……","tone":"陈述","chapter":123,"line_start":256,"line_end":256},{"speaker":"char_xu_xian","speaker_name":"徐先","listener":"char_xiang_shao_long","text":"项太傅的提议精彩之极，可是本相仍有一事不解，若这样明着放魏增回去说出这番话来，那岂非谁都知道我们在用反间计吗？","tone":"疑问","chapter":123,"line_start":268,"line_end":270},{"speaker":"char_du_bi","speaker_name":"杜璧","listener":"char_xiang_shao_long","text":"此计虽好，却很难奏效。","tone":"淡然","chapter":123,"line_start":272,"line_end":272},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhuang_xiang_wang","text":"三天前，魏国的龙阳君派人来游说微臣，希望微臣为太子增美言两句，保他性命。假若微臣卖个人情与龙阳君的人合作，助太子增偷离咸阳，同时又把信陵君之事诈作无意中泄露与他知道，这反间之计，便可望成功。","tone":"陈述","chapter":123,"line_start":278,"line_end":282},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_xiang_shao_long","text":"少龙果不负寡人期望，此计妙绝，就如你所说，由你全权去办。","tone":"欣慰","chapter":123,"line_start":284,"line_end":286}],"new_entities":{},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":366,"dialogues":[{"speaker":"char_lu_gong","speaker_name":"鹿公","listener":"char_xiang_shao_long","text":"你为何向大王举荐徐大将军呢？","tone":"疑问","chapter":123,"line_start":302,"line_end":302},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lu_gong","text":"只因徐将军乃不畏权势的好汉子，就是这样。","tone":"陈述","chapter":123,"line_start":304,"line_end":306},{"speaker":"char_xu_xian","speaker_name":"徐先","listener":"char_xiang_shao_long","text":"项少龙才是真正的英雄好汉，我徐先至少学不到太傅视功名权位如浮云的胸襟，当日只要你肯点头，就是我大秦的左丞相，今天你若肯点头，现在已是三军之帅了。","tone":"豪迈","chapter":123,"line_start":308,"line_end":310},{"speaker":"char_long_yang_jun","speaker_name":"龙阳君","listener":"char_xiang_shao_long","text":"既是反间之计，为何却要说出来给我听？","tone":"疑问","chapter":123,"line_start":332,"line_end":334},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_long_yang_jun","text":"君上这么信任我，我怎忍心骗你。","tone":"温柔","chapter":123,"line_start":336,"line_end":336},{"speaker":"char_long_yang_jun","speaker_name":"龙阳君","listener":"char_xiang_shao_long","text":"信陵君想刺杀大王，是否确有其事？","tone":"疑问","chapter":123,"line_start":338,"line_end":338},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_long_yang_jun","text":"这倒是不假。","tone":"陈述","chapter":123,"line_start":340,"line_end":340},{"speaker":"char_long_yang_jun","speaker_name":"龙阳君","listener":"char_xiang_shao_long","text":"那就成了，你虽说是反间计，却极有可能发生，秦人既闭关不出，信陵君迟早无功而退，迟些早点，没有分别。经此一役后，天下应有一段平静的日子，眼下当务之急，就是要把太子弄回大梁去，少龙你定要做得似模似样，那你我都可立个大功了。","tone":"陈述","chapter":123,"line_start":342,"line_end":346},{"speaker":"char_long_yang_jun","speaker_name":"龙阳君","listener":"char_xiang_shao_long","text":"无忌公子名震六国，大王怎也不敢处死他，且亦非那么容易，只会夺他兵权，让他投闲置散，无论如何，我会保着赵雅。","tone":"陈述","chapter":123,"line_start":352,"line_end":354},{"speaker":"char_tu_xian","speaker_name":"图先","listener":"char_xiang_shao_long","text":"今天糟了！","tone":"无奈","chapter":123,"line_start":366,"line_end":366}],"new_entities":{"characters":[{"id":"char_shan_lan","name":"善兰","alias":[],"identity":"项少龙之妻","faction":"乌家","role":"companion","archetype":"healer","rank":"平平无奇","one_line":"项少龙的妻子，产下一子过继给项少龙","personality":{"traits":["温柔","贤淑","善良","勤劳","体贴"],"speech_style":"未开口","temperament":"温柔"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":80,"bond_level":4,"dynamic":"夫妻"}],"known_skills":[],"related_skills":[],"rag_refs":[123],"source_refs":[{"chapter":123,"line_start":362,"line_end":362,"text":"善兰瓜熟蒂落，产下一子"}]},{"id":"char_tu_xian","name":"图先","alias":[],"identity":"相府大管家","faction":"秦国朝堂","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"相府大管家，神情凝重地来报不好的消息","personality":{"traits":["谨慎","忠心","精明","低调","可靠"],"speech_style":"叹气","temperament":"无奈"},"relationships":[{"target":"char_lv_bu_wei","type":"主仆","intensity":50,"bond_level":3,"dynamic":"效忠"}],"known_skills":[],"related_skills":[],"rag_refs":[123],"source_refs":[{"chapter":123,"line_start":364,"line_end":364,"text":"赫然是图先"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_mu_chang","name":"牧场","region":"秦国","one_line":"项少龙的牧场，远离咸阳的家宅","source_refs":[{"chapter":123,"line_start":358,"line_end":358,"text":"连夜溜回牧场"}]}],"items":[]},"entity_updates":[{"id":"char_tai_zi_zeng","updates":{"source_refs":[{"chapter":123,"line_start":290,"line_end":294,"text":"庄襄王把太子增召进来，痛斥一顿"}]}},{"id":"char_long_yang_jun","updates":{"source_refs":[{"chapter":123,"line_start":332,"line_end":334,"text":"既是反间之计，为何却要说出来给我听"}]}}]}
