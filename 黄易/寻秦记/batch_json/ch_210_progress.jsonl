_refs":[{"chapter":210,"line_start":4,"line_end":4,"text":"桓齮、李斯、杨端和等人"}]},{"id":"char_lu_dan_er","name":"鹿丹儿","alias":[],"identity":"贵族少女","faction":"秦国","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"偷偷溜来参加宴会的少女，成为众人调笑对象","personality":{"traits":["活泼大胆","不拘礼节","青春可爱","顽皮好动","率真直爽"],"speech_style":"天真烂漫","temperament":"活泼开朗"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":6,"line_end":6,"text":"最妙是鹿丹儿偷偷溜来参加，自然成为众人调笑的对象"}]},{"id":"char_ji_yan_ran","name":"纪嫣然","alias":["纪才女"],"identity":"天下才女","faction":"秦国","role":"companion","archetype":"scholar","rank":"登堂入室","one_line":"名著天下的才女，项少龙之妻，曾在大梁长居","personality":{"traits":["才思敏捷","洞察力强","温婉大方","博学多识","细腻敏感"],"speech_style":"言辞优雅，分析透彻","temperament":"沉静聪慧"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":90,"bond_level":5,"dynamic":"夫妻"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":70,"line_end":74,"text":"惟纪嫣然若有所思"},{"chapter":210,"line_start":78,"line_end":82,"text":"纪嫣然香唇轻吐道"}]},{"id":"char_tao_fang","name":"陶方","alias":[],"identity":"乌府总管","faction":"秦国","role":"companion","archetype":"scholar","rank":"平平无奇","one_line":"乌府总管，项少龙的得力助手","personality":{"traits":["精明能干","善于管理","忠诚可靠","见多识广","细心周到"],"speech_style":"言辞谨慎，善析利弊","temperament":"沉稳老练"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":60,"bond_level":3,"dynamic":"信任"},{"target":"char_wu_ying_yuan","type":"主仆","intensity":65,"bond_level":3,"dynamic":"效忠"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":64,"line_end":68,"text":"陶方亦讶道"}]},{"id":"char_lv_bu_wei","name":"吕不韦","alias":[],"identity":"秦国相邦","faction":"秦国","role":"villain","archetype":"scholar","rank":"登堂入室","one_line":"秦国权臣，紧抓财政控制军队，与项少龙势不两立","personality":{"traits":["老奸巨猾","权谋深沉","心狠手辣","善于布局","贪婪专权"],"speech_style":"语调阴沉，善用权术","temperament":"阴险狡诈"},"relationships":[{"target":"char_xiang_shao_long","type":"宿敌","intensity":90,"bond_level":1,"dynamic":"势不两立"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":2,"line_end":2,"text":"狠狠挫败吕不韦的诡谋"},{"chapter":210,"line_start":28,"line_end":28,"text":"他仍借口为建郑国渠，只允逐步增加速援师的经费"}]},{"id":"char_bai_qi","name":"白起","alias":["武安君"],"identity":"秦国名将","faction":"秦国","role":"npc","archetype":"warrior","rank":"登峰造极","one_line":"秦国一代名将，长平之战主将，一生战无不胜，手段残酷","personality":{"traits":["狠辣奇诡","用兵如神","求胜不择手段","铁血无情","军事天才"],"speech_style":"沉默寡言","temperament":"冷酷果决"},"relationships":[{"target":"char_wang_he","type":"师徒","intensity":80,"bond_level":4,"dynamic":"主将与裨将"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":46,"line_end":50,"text":"白起狠辣奇诡"},{"chapter":210,"line_start":100,"line_end":102,"text":"当年长平之战，白起为主将"}]},{"id":"char_lian_po","name":"廉颇","alias":[],"identity":"赵国名将","faction":"赵国","role":"npc","archetype":"warrior","rank":"登峰造极","one_line":"赵国老将，稳重深沉，长平之战时以守代攻，现寄居信陵君府","personality":{"traits":["稳重深沉","老而弥坚","善于防守","谋略深远","坚韧不拔"],"speech_style":"沉稳老练","temperament":"沉稳内敛"},"relationships":[{"target":"char_wang_he","type":"对手","intensity":60,"bond_level":2,"dynamic":"沙场对手"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":46,"line_end":50,"text":"廉颇稳重深沉"},{"chapter":210,"line_start":110,"line_end":112,"text":"廉颇确是老而弥坚"}]},{"id":"char_li_mu","name":"李牧","alias":[],"identity":"赵国名将","faction":"赵国","role":"npc","archetype":"warrior","rank":"登峰造极","one_line":"赵国第一名将，用兵如神，连王龁都自认不如","personality":{"traits":["用兵如神","从容大度","高深难测","威震四方","令人折服"],"speech_style":"沉稳威严","temperament":"沉稳大气"},"relationships":[{"target":"char_wang_he","type":"对手","intensity":60,"bond_level":2,"dynamic":"令敌方折服"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":46,"line_end":50,"text":"用兵如神、高深难测者，仍以李牧为首"}]},{"id":"char_xin_ling_jun","name":"信陵君","alias":["无忌公子","魏无忌"],"identity":"魏国公子","faction":"魏国","role":"npc","archetype":"scholar","rank":"炉火纯青","one_line":"魏国公子，收留廉颇，安厘王病危后性命堪忧","personality":{"traits":["礼贤下士","深谋远虑","广纳人才","权势显赫","处境危险"],"speech_style":"温文尔雅","temperament":"儒雅深沉"},"relationships":[{"target":"char_lian_po","type":"合作者","intensity":70,"bond_level":3,"dynamic":"收留庇护"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":64,"line_end":68,"text":"廉颇现正寄居信陵君府内"},{"chapter":210,"line_start":78,"line_end":82,"text":"信陵君亦命不久矣"}]},{"id":"char_an_li_wang","name":"安厘王","alias":[],"identity":"魏国国王","faction":"魏国","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"魏国国王，病危之际，必会先逼死信陵君以保太子","personality":{"traits":["猜忌多疑","心狠手辣","维护王位","权力至上","冷酷无情"],"speech_style":"威严霸道","temperament":"阴沉多疑"},"relationships":[{"target":"char_xin_ling_jun","type":"宿敌","intensity":80,"bond_level":1,"dynamic":"猜忌逼害"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":56,"line_end":58,"text":"安厘王病倒了"},{"chapter":210,"line_start":86,"line_end":86,"text":"以魏安厘王的性格，必会在病逝前施辣手先逼死信陵君"}]},{"id":"char_zhao_kuo","name":"赵括","alias":[],"identity":"赵国将领","faction":"赵国","role":"npc","archetype":"warrior","rank":"初窥门径","one_line":"赵奢之子，鲁莽轻敌，长平之战中替代廉颇致赵军大败","personality":{"traits":["鲁莽轻敌","高傲自恃","纸上谈兵","不自量力","缺乏实战"],"speech_style":"狂妄自大","temperament":"浮躁轻率"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":120,"line_end":124,"text":"改以鲁莽轻敌、高傲自恃的赵括代廉颇"}]},{"id":"char_zhao_xiao_cheng_wang","name":"赵孝成王","alias":[],"identity":"赵国国王","faction":"赵国","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"赵国国王，年轻气盛，中反间计阵前换将导致长平之败","personality":{"traits":["年轻气盛","刚愎自用","不善用人","急躁冒进","决策失误"],"speech_style":"威严自恃","temperament":"急躁冲动"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":120,"line_end":124,"text":"赵孝成王年轻气盛，以为廉颇老而怯战"}]},{"id":"char_guo_kai","name":"郭开","alias":[],"identity":"赵国权臣","faction":"赵国","role":"villain","archetype":"scholar","rank":"平平无奇","one_line":"赵国权臣，全力压制李牧","personality":{"traits":["善于弄权","嫉贤妒能","排挤忠良","自私自利","阴险狡诈"],"speech_style":"阴险狡猾","temperament":"阴险刻薄"},"relationships":[{"target":"char_li_mu","type":"宿敌","intensity":70,"bond_level":1,"dynamic":"猜忌压制"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":158,"line_end":160,"text":"无论晶王后和郭开如何猜忌李牧"}]},{"id":"char_jing_wang_hou","name":"晶王后","alias":[],"identity":"赵国王后","faction":"赵国","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"赵国王后，与郭开一同猜忌李牧","personality":{"traits":["猜忌多疑","维护权势","善于宫廷斗争","排斥异己","心胸狭窄"],"speech_style":"威严霸道","temperament":"多疑善妒"},"relationships":[{"target":"char_li_mu","type":"对手","intensity":60,"bond_level":1,"dynamic":"猜忌"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":158,"line_end":160,"text":"无论晶王后和郭开如何猜忌李牧"}]},{"id":"char_si_ma_shang","name":"司马尚","alias":[],"identity":"赵国将领","faction":"赵国","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"赵国主将之一，与庞煖并列","personality":{"traits":["善战勇猛","忠诚赵国","能力出众","沉稳可靠","独当一面"],"speech_style":"沉稳果断","temperament":"刚毅果决"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":162,"line_end":164,"text":"尚有司马尚和庞煖两大主将"}]},{"id":"char_pang_xuan","name":"庞煖","alias":[],"identity":"赵国将领","faction":"赵国","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"赵国主将之一，与司马尚并列","personality":{"traits":["善战勇猛","忠诚赵国","经验丰富","独当一面","沉稳可靠"],"speech_style":"沉稳果断","temperament":"刚毅果决"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":162,"line_end":164,"text":"尚有司马尚和庞煖两大主将"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_qin_guo","name":"秦国","type":"国家","location":"关中","sub_divisions":["速援师"],"one_line":"战国七雄之一，由秦王嬴政统一天下","source_refs":[{"chapter":210,"line_start":2,"line_end":2,"text":"狠狠挫败吕不韦的诡谋"}]},{"id":"faction_zhao_guo","name":"赵国","type":"国家","location":"河北","sub_divisions":[],"one_line":"战国七雄之一，有李牧等名将镇守","source_refs":[{"chapter":210,"line_start":46,"line_end":50,"text":"赵国纵去了廉颇，但一天有李牧此人在，我大秦仍未可轻言亡赵"}]},{"id":"faction_wei_guo","name":"魏国","type":"国家","location":"中原","sub_divisions":[],"one_line":"战国七雄之一，安厘王病危，内斗激烈","source_refs":[{"chapter":210,"line_start":56,"line_end":58,"text":"由魏国传来的消息，安厘王病倒了"}]}],"locations":[{"id":"loc_wu_fu","name":"乌府","region":"咸阳","one_line":"乌应元府邸，项少龙的据点","source_refs":[{"chapter":210,"line_start":2,"line_end":2,"text":"是夜乌府大排筵席"}]},{"id":"loc_chang_ping","name":"长平","region":"赵国","one_line":"秦赵长平之战古战场，拥有天险的坚固要冲","source_refs":[{"chapter":210,"line_start":112,"line_end":112,"text":"要知长平坐拥天险，实是无可比拟的坚固要冲"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":113,"line_end":224,"dialogues":[{"speaker":"char_wang_ling","speaker_name":"王陵","listener":"char_wang_he","text":"廉颇确是有谋略的人，弄到我方大军不但面对坚城而无用武之地，还因其不断派人扰乱我们的粮援部队，使我方出现军需补给困难的危机，当时就是由我负补给后援之责。反之廉颇却是以逸待劳，在长平城东侧建立了一个非常坚固的阵地，巩固防军和首都邯郸的联络，使我们陷于非常不利的境地。若非赵孝成王年轻气盛，以为廉颇老而怯战，遂中了武安君反间之计，改以鲁莽轻敌、高傲自恃的赵括代廉颇，败的大有可能是我们。所以长平之胜，败因在于赵孝成王阵前换将的错着，武安君的运筹帷幄只属次要。","tone":"陈述","chapter":210,"line_start":116,"line_end":124},{"speaker":"char_wang_he","speaker_name":"王龁","listener":null,"text":"老夫对白大将军也非常钦佩，但有名主始有名臣，当年先王打从开始便破格重用白起，由左庶长起，隔两年已升为大良造，而武安君亦没有令先王失望，领军的第二年，在伊阙之战中，以他名震天下的铁骑冲锋军，凭不到三分一的兵力，一举攻破韩、魏二十四万联军，擒杀其帅公孙喜，使魏国西方五镇全部沦陷，接着的一年更连续攻占魏人旧都安邑和附近六十一座城池，至此本是最强大的魏国只落得苟延残喘的份儿。","tone":"陈述","chapter":210,"line_start":126,"line_end":128},{"speaker":"char_chang_wen_jun","speaker_name":"昌文君","listener":"char_wang_he","text":"如此功业，世所罕有，为何仍及不上李牧？","tone":"疑问","chapter":210,"line_start":130,"line_end":132},{"speaker":"char_wang_he","speaker_name":"王龁","listener":null,"text":"武安君之所以有此史无前例的战果，皆因手段之残酷亦是史无前例，每次战胜，必尽屠对方降军，以削弱对方实力。这虽是最有效的方法，却非其他人办得到，且有伤天和，远及不上李牧之从容大度，故比起上来，仍是差了一点。","tone":"苦笑","chapter":210,"line_start":134,"line_end":138},{"speaker":"char_li_si","speaker_name":"李斯","listener":null,"text":"长平一战，实是我大秦强弱的转折点，谁想得到当年曾大破我军的赵奢之子，竟是如此不济。赵奢那一战该是武安君唯一的败绩。","tone":"无奈","chapter":210,"line_start":144,"line_end":146},{"speaker":"char_huan_yi","speaker_name":"桓齮","listener":null,"text":"我一直没有把该战当是白起的败仗。","tone":"陈述","chapter":210,"line_start":148,"line_end":148},{"speaker":"char_wang_he","speaker_name":"王龁","listener":"char_xiang_shao_long","text":"老夫今趟向储君提议升少龙做大将军，就是针对李牧而发，眼下环顾我大秦诸将，只有你和王翦可与李牧争一日之短长，我和蒙骜名分虽高，却缺乏了你那种能使将士效死命的本领。","tone":"沉声","chapter":210,"line_start":150,"line_end":152},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":null,"text":"大将军的话非是无的放矢，李牧最近歼灭匈奴十余万骑兵，又降服东胡、林胡多个部落，赶得匈奴王单于狼狈北窜，短期内再无力犯赵，际此天下大乱的时刻，无论晶王后和郭开如何猜忌李牧，亦逼得要把他调回来守卫西疆。","tone":"陈述","chapter":210,"line_start":158,"line_end":160},{"speaker":"char_li_si","speaker_name":"李斯","listener":null,"text":"本来赵国除李牧外，尚有司马尚和庞煖两大主将，故现时郭开虽全力压制李牧，可是当司马尚和庞煖两人都吃败仗时，应是李牧出马的时刻了。","tone":"淡然","chapter":210,"line_start":162,"line_end":164},{"speaker":"char_lao_ai","speaker_name":"嫪毐","listener":"char_xiang_shao_long","text":"项大人昨晚设宴欢饮，为何竟然漏了小弟呢？","tone":"疑问","chapter":210,"line_start":188,"line_end":190},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lao_ai","text":"那算什么宴会，只是昌平君临时要为我弄个祝捷宴，还把两位王大将军似拉伕般拉来，吃的却是由我提供的酒菜，占尽便宜，所以嫪大人勿要怪我，要怪就怪左相那小子吧！","tone":"微笑","chapter":210,"line_start":192,"line_end":194},{"speaker":"char_lao_ai","speaker_name":"嫪毐","listener":"char_xiang_shao_long","text":"项大人的词锋可比得上苏秦和张仪，教小弟再难兴问罪之师。顺道向项大人道个歉，前晚邱日升胆大妄为，自作主张，已给小弟严责，希望项大人不要放在心上。","tone":"大笑","chapter":210,"line_start":198,"line_end":202},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lao_ai","text":"下边的人有时是不会那么听话的，对了！为何仍未见国兴来向我报到呢？","tone":"陈述","chapter":210,"line_start":204,"line_end":206},{"speaker":"char_han_jie","speaker_name":"韩竭","listener":"char_xiang_shao_long","text":"这事问我就最清楚，没有十天半月，休想做好官服、印绶等物，他怎敢妄去报到呢？","tone":"微笑","chapter":210,"line_start":208,"line_end":210},{"speaker":"char_lao_ai","speaker_name":"嫪毐","listener":"char_xiang_shao_long","text":"长话短说，醉风楼最近来了个集天下美色的歌舞姬团，项大人今晚定要和我到醉风楼欢醉一宵，若是推搪就不当我嫪毐是朋友了。","tone":"陈述","chapter":210,"line_start":212,"line_end":214},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lao_ai","text":"若项某人的娇妻因在下夜归而揍我一顿，要惟内史大人是问了。","tone":"苦笑","chapter":210,"line_start":216,"line_end":218},{"speaker":"char_lao_ai","speaker_name":"嫪毐","listener":"char_xiang_shao_long","text":"原来项大人说话这般风趣，唉！真恨不得快点入夜，好能与项大人把盏言欢，今晚黄昏小弟在醉风楼恭候大驾。","tone":"大笑","chapter":210,"line_start":220,"line_end":222}],"new_entities":{"characters":[{"id":"char_chang_wen_jun","name":"昌文君","alias":[],"identity":"秦国宗室重臣","faction":"faction_qin","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"秦国宗室成员，朝中大臣，与昌平君为兄弟。","personality":{"traits":["沉稳","忠诚","好学","崇敬英雄","善于思考"],"speech_style":"恭敬有礼","temperament":"沉稳"},"relationships":[{"target":"char_chang_ping_jun","type":"亲属","intensity":80,"bond_level":4,"dynamic":"兄弟"},{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":3,"dynamic":"同盟"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":130,"line_end":132,"text":"昌文君双目射出崇敬之色，叹道：“如此功业，世所罕有，为何仍及不上李牧？”"}]},{"id":"char_lao_ai","name":"嫪毐","alias":["内史大人"],"identity":"秦国权臣","faction":"faction_qin","role":"villain","archetype":"scholar","rank":"登堂入室","one_line":"秦国权臣，善于逢迎拉拢，与吕不韦争权，刻意结交项少龙以对抗吕不韦。","personality":{"traits":["圆滑","善于逢迎","野心勃勃","虚伪","机敏","善于拉拢"],"speech_style":"客套殷勤","temperament":"圆滑"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":40,"bond_level":2,"dynamic":"刻意拉拢"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":188,"line_end":190,"text":"嫪毐转瞬来到他旁，笑道：“项大人昨晚设宴欢饮，为何竟然漏了小弟呢？”"}]},{"id":"char_han_jie","name":"韩竭","alias":[],"identity":"嫪毐亲随","faction":"faction_qin","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"嫪毐的亲随下属，善于言辞，负责为嫪毐传达消息。","personality":{"traits":["机灵","善言辞","忠诚","圆滑","随和"],"speech_style":"轻松随意","temperament":"随和"},"relationships":[{"target":"char_lao_ai","type":"主仆","intensity":60,"bond_level":3,"dynamic":"下属"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":208,"line_end":210,"text":"后侧的韩竭笑道：“这事问我就最清楚，没有十天半月，休想做好官服、印绶等物，他怎敢妄去报到呢？”"}]},{"id":"char_ling_qi","name":"令齐","alias":[],"identity":"嫪毐亲随","faction":"faction_qin","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"嫪毐的亲随下属，随嫪毐出行的随从之一。","personality":{"traits":["沉默","忠诚","谨慎","服从","低调"],"speech_style":"寡言少语","temperament":"沉稳"},"relationships":[{"target":"char_lao_ai","type":"主仆","intensity":60,"bond_level":3,"dynamic":"下属"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":184,"line_end":184,"text":"原来是嫪毐来了，后面跟着韩竭、令齐两人和大群前后开道的亲随。"}]},{"id":"char_guo_xing","name":"国兴","alias":[],"identity":"秦国武将","faction":"faction_qin","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"新任秦国武将，正在筹备官服印绶等物，尚未正式向项少龙报到。","personality":{"traits":["谨慎","守规矩","认真","服从","务实"],"speech_style":"正式","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"主仆","intensity":40,"bond_level":2,"dynamic":"新任下属"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":204,"line_end":206,"text":"为何仍未见国兴来向我报到呢？"}]},{"id":"char_zhao_kuo","name":"赵括","alias":[],"identity":"赵国将领","faction":"faction_zhao","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"赵国名将赵奢之子，长平之战中替代廉颇为主将，因鲁莽轻敌致赵军大败。","personality":{"traits":["鲁莽","轻敌","自恃","高傲","纸上谈兵"],"speech_style":"自大","temperament":"急躁"},"relationships":[{"target":"char_zhao_she","type":"亲属","intensity":70,"bond_level":4,"dynamic":"父子"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":116,"line_end":124,"text":"若非赵孝成王年轻气盛，以为廉颇老而怯战，遂中了武安君反间之计，改以鲁莽轻敌、高傲自恃的赵括代廉颇"}]},{"id":"char_zhao_she","name":"赵奢","alias":[],"identity":"赵国名将","faction":"faction_zhao","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"赵国名将，赵括之父，曾大败秦军，是白起罕见的败绩之一。","personality":{"traits":["英勇","善战","沉稳","老练","深谋远虑"],"speech_style":"沉稳","temperament":"沉稳"},"relationships":[{"target":"char_zhao_kuo","type":"亲属","intensity":80,"bond_level":4,"dynamic":"父子"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":144,"line_end":146,"text":"谁想得到当年曾大破我军的赵奢之子，竟是如此不济。赵奢那一战该是武安君唯一的败绩。"}]},{"id":"char_gong_sun_xi","name":"公孙喜","alias":[],"identity":"韩魏联军统帅","faction":"faction_han_wei","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"伊阙之战中韩魏联军统帅，被白起擒杀，魏国西方五镇因此全部沦陷。","personality":{"traits":["刚直","勇猛","不善应变","忠诚","固执"],"speech_style":"刚直","temperament":"刚直"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":126,"line_end":128,"text":"一举攻破韩、魏二十四万联军，擒杀其帅公孙喜"}]},{"id":"char_si_ma_shang","name":"司马尚","alias":[],"identity":"赵国主将","faction":"faction_zhao","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"赵国主将之一，与李牧、庞煖并列为赵国三大主将。","personality":{"traits":["沉稳","善守","忠诚","务实","不善张扬"],"speech_style":"沉稳","temperament":"沉稳"},"relationships":[{"target":"char_li_mu","type":"合作者","intensity":50,"bond_level":3,"dynamic":"同僚"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":162,"line_end":164,"text":"本来赵国除李牧外，尚有司马尚和庞煖两大主将"}]},{"id":"char_pang_nuan","name":"庞煖","alias":[],"identity":"赵国主将","faction":"faction_zhao","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"赵国主将之一，与李牧、司马尚并列为赵国三大主将。","personality":{"traits":["沉稳","善谋","忠诚","务实","不善张扬"],"speech_style":"沉稳","temperament":"沉稳"},"relationships":[{"target":"char_li_mu","type":"合作者","intensity":50,"bond_level":3,"dynamic":"同僚"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":162,"line_end":164,"text":"尚有司马尚和庞煖两大主将"}]},{"id":"char_jing_wang_hou","name":"晶王后","alias":[],"identity":"赵国王后","faction":"faction_zhao","role":"npc","archetype":"scholar","rank":"初窥门径","one_line":"赵国王后，与郭开勾结猜忌压制名将李牧。","personality":{"traits":["多疑","善妒","短视","自私","猜忌"],"speech_style":"阴柔","temperament":"多疑"},"relationships":[{"target":"char_guo_kai","type":"合作者","intensity":60,"bond_level":3,"dynamic":"勾结"},{"target":"char_li_mu","type":"对手","intensity":40,"bond_level":2,"dynamic":"猜忌"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":158,"line_end":160,"text":"无论晶王后和郭开如何猜忌李牧"}]},{"id":"char_guo_kai","name":"郭开","alias":[],"identity":"赵国权臣","faction":"faction_zhao","role":"villain","archetype":"scholar","rank":"初窥门径","one_line":"赵国权臣，与晶王后勾结，全力压制名将李牧。","personality":{"traits":["阴险","贪婪","自私","善妒","狡诈"],"speech_style":"阴险","temperament":"阴险"},"relationships":[{"target":"char_jing_wang_hou","type":"合作者","intensity":60,"bond_level":3,"dynamic":"勾结"},{"target":"char_li_mu","type":"宿敌","intensity":70,"bond_level":2,"dynamic":"压制"}],"known_skills":[],"related_skills":[],"rag_refs":[210],"source_refs":[{"chapter":210,"line_start":158,"line_end":160,"text":"无论晶王后和郭开如何猜忌李牧"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_zui_feng_lou","name":"醉风楼","region":"咸阳","one_line":"咸阳城内的风月场所，嫪毐邀项少龙前往饮宴之地，近日新来歌舞姬团。","source_refs":[{"chapter":210,"line_start":212,"line_end":214,"text":"醉风楼最近来了个集天下美色的歌舞姬团"}]}],"items":[]},"entity_updates":[]}