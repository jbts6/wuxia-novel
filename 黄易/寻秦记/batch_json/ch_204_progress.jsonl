":"char_ying_ying","type":"恋人","intensity":30,"bond_level":2,"dynamic":"旧情已逝"}]},{"id":"char_teng_yi","updates":{"source_refs":[{"chapter":204,"line_start":150,"line_end":150,"text":"桓齮、滕翼等自然识趣"}]},"relationship_updates":[]},{"id":"char_jing_jun","updates":{"source_refs":[{"chapter":204,"line_start":68,"line_end":68,"text":"鹿丹儿不知从哪里钻出来，隔远勾着手指示意荆俊过去"}]},"relationship_updates":[{"action":"add","target":"char_lu_dan_er","type":"恋人","intensity":70,"bond_level":3,"dynamic":"热恋"}]}]}
{"segment":2,"line_start":93,"line_end":188,"dialogues":[{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_ying_ying","text":"今晚无论发生什么事，对你而言都应该是告一段落，以后你心中只该有端和兄，好好相夫教子，安分守己做个贤妻良母吧！","tone":"淡然","chapter":204,"line_start":96,"line_end":98},{"speaker":"char_ying_ying","speaker_name":"嬴盈","listener":"char_xiang_shao_long","text":"告诉我，若没有管中邪，你是否会娶我呢？","tone":"柔声","chapter":204,"line_start":100,"line_end":102},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_ying_ying","text":"到了此时此刻，我们似乎不应再说这种话吧！","tone":"苦笑","chapter":204,"line_start":104,"line_end":105},{"speaker":"char_ying_ying","speaker_name":"嬴盈","listener":"char_xiang_shao_long","text":"不！我若不问个清楚，绝不甘心。","tone":"恳求","chapter":204,"line_start":107,"line_end":107},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_ying_ying","text":"我确曾欢喜过你。","tone":"无奈","chapter":204,"line_start":109,"line_end":109},{"speaker":"char_ying_ying","speaker_name":"嬴盈","listener":"char_xiang_shao_long","text":"今晚若你有不测，我会为你守……噢！我不说了。啊！","tone":"悲伤","chapter":204,"line_start":110,"line_end":113},{"speaker":"char_ying_ying","speaker_name":"嬴盈","listener":"char_xiang_shao_long","text":"项大人！","tone":"陈述","chapter":204,"line_start":116,"line_end":118},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_chang_ping_jun","text":"没有什么。","tone":"陈述","chapter":204,"line_start":120,"line_end":120},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"怎会没有什么？她虽说肯嫁给端和，但对管中邪仍是难舍难离，又说你非是他对手，真气死人。","tone":"愤怒","chapter":204,"line_start":122,"line_end":123},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"今夜我吕不韦可算双喜临门，既贺寿诞，又将得佳婿，人生至此，尚有何憾？","tone":"得意","chapter":204,"line_start":138,"line_end":140},{"speaker":"char_lv_niang_rong","speaker_name":"吕娘蓉","listener":"char_xiang_shao_long","text":"项大人，娘蓉有几句私话和你说。","tone":"淡然","chapter":204,"line_start":146,"line_end":148},{"speaker":"char_lv_niang_rong","speaker_name":"吕娘蓉","listener":"char_xiang_shao_long","text":"项大人请随我来！","tone":"淡然","chapter":204,"line_start":152,"line_end":152},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lv_niang_rong","text":"在这里说好吗？否则恐怕会惹人闲言。","tone":"陈述","chapter":204,"line_start":154,"line_end":156},{"speaker":"char_lv_niang_rong","speaker_name":"吕娘蓉","listener":"char_xiang_shao_long","text":"项少龙的胆子何时变得这么小，竟会怕惹闲言，何况今晚项大人若有命在，娘蓉就是你的人，还有什么好顾忌的。","tone":"嘲讽","chapter":204,"line_start":160,"line_end":162},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lv_niang_rong","text":"三小姐唤在下来此，应不会只是揶揄一番吧！","tone":"冷笑","chapter":204,"line_start":164,"line_end":166},{"speaker":"char_lv_niang_rong","speaker_name":"吕娘蓉","listener":"char_xiang_shao_long","text":"当然！本小姐并没有那种心情，只是想问项大人两句话，你既然对娘蓉没有意思，为何却要接受中邪的挑战？","tone":"沉声","chapter":204,"line_start":168,"line_end":170},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lv_niang_rong","text":"待会儿只要三小姐当众宣布只愿下嫁管大人，那我项少龙无论如何厚颜无耻，也不至于仍要坚持动手比试吧！","tone":"冷笑","chapter":204,"line_start":172,"line_end":173},{"speaker":"char_lv_niang_rong","speaker_name":"吕娘蓉","listener":"char_xiang_shao_long","text":"好！就让我吕娘蓉看看今晚你怎样收场。","tone":"愤怒","chapter":204,"line_start":177,"line_end":178}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":189,"line_end":276,"dialogues":[{"speaker":"char_pu_hu","speaker_name":"蒲鶮","listener":"char_xiang_shao_long","text":"项大人果是威武不凡，天下罕有，难怪乌爷敢在你身上押下重注。若站在朋友立场，自是希望大人旗开得胜，但若以做生意的立场，却是另一番盘算，蒲某心中矛盾得要命呢！","tone":"陈述","chapter":204,"line_start":210,"line_end":214},{"speaker":"char_du_bi","speaker_name":"杜璧","listener":"char_xiang_shao_long","text":"乌大爷词锋凌厉，若项大人的剑也是这么了得，今晚必可稳胜无疑，那时蒲爷恐怕要把田地卖了，才能偿还赌债。","tone":"调侃","chapter":204,"line_start":224,"line_end":226},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_du_bi","text":"到今晚才知大将军这么爱说笑，蒲爷富甲天下，只要随便往囊中一探，已够我等晚晚到醉风楼做大豪客。","tone":"调侃","chapter":204,"line_start":228,"line_end":230},{"speaker":null,"speaker_name":"门官","listener":null,"text":"太后、储君圣驾到！","tone":"厉声","chapter":204,"line_start":234,"line_end":234},{"speaker":"char_jing_jun","speaker_name":"荆俊","listener":"char_xiang_shao_long","text":"坐在嫪毐和韩竭间那人，就是渭南武士行馆的馆主邱日升。","tone":"低语","chapter":204,"line_start":244,"line_end":246},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"今夜我吕不韦可算双喜临门，既贺寿诞，又将得佳婿，人生至此，尚有何憾？","tone":"得意","chapter":204,"line_start":138,"line_end":140}],"new_entities":{"characters":[{"id":"char_qiu_ri_sheng","name":"邱日升","alias":["馆主"],"identity":"渭南武士行馆馆主","faction":"渭南武士行馆","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"咸阳宗师级剑手，渭南武士行馆馆主，气度不凡","personality":{"traits":["沉稳","威严","精明","谨慎","自重","善谋"],"speech_style":"不怒自威，言简意赅","temperament":"沉稳"},"relationships":[{"target":"char_lao_ai","type":"合作者","intensity":50,"bond_level":3,"dynamic":"被笼络"}],"known_skills":[],"related_skills":[],"rag_refs":[204],"source_refs":[{"chapter":204,"line_start":252,"line_end":252,"text":"在咸阳有宗师级地位的剑手相貌清奇，手足均比一般人修长"}]},{"id":"char_han_jie","name":"韩竭","alias":[],"identity":"嫪毐麾下剑手","faction":"嫪党","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"嫪毐麾下剑手，与邱日升同席","personality":{"traits":["沉默","冷厉","忠心","坚韧","寡言","果断"],"speech_style":"寡言","temperament":"冷厉"},"relationship