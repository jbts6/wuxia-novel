l":4,"dynamic":"宠爱"},{"target":"char_ying_zheng","type":"亲属","intensity":70,"bond_level":4,"dynamic":"母子"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":30,"line_end":31,"text":"太后"}]},{"id":"char_ji_yan_ran","name":"纪嫣然","alias":["纪才女","嫣然妹"],"identity":"项少龙之妻","faction":"秦国","role":"companion","archetype":"scholar","rank":"登堂入室","one_line":"项少龙的妻子之一，才貌双全的才女，与琴清交好","personality":{"traits":["才貌双全","聪慧","善解人意","大方","有主见"],"speech_style":"文雅聪慧","temperament":"温婉"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":80,"bond_level":4,"dynamic":"夫妻"},{"target":"char_qin_qing","type":"挚友","intensity":60,"bond_level":3,"dynamic":"闺蜜"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":2,"line_end":3,"text":"嫣然妹她们到城外试马"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_qin_guo","name":"秦国","type":"家族","location":"咸阳","sub_divisions":["禁卫军","都骑军","都卫军"],"one_line":"战国七雄之一，国力最强，都城咸阳","source_refs":[{"chapter":145,"line_start":14,"line_end":14,"text":"秦国"}]},{"id":"faction_zhao_guo","name":"赵国","type":"家族","location":"邯郸","sub_divisions":[],"one_line":"战国七雄之一，与秦国对抗","source_refs":[{"chapter":145,"line_start":18,"line_end":18,"text":"赵国使臣"}]},{"id":"faction_wei_guo","name":"魏国","type":"家族","location":"大梁","sub_divisions":[],"one_line":"战国七雄之一","source_refs":[{"chapter":145,"line_start":18,"line_end":18,"text":"龙阳君"}]}],"locations":[{"id":"loc_qin_fu","name":"琴府","region":"咸阳","one_line":"琴清在咸阳的府邸，项少龙常来拜访之处","source_refs":[{"chapter":145,"line_start":2,"line_end":2,"text":"赶到琴府"}]},{"id":"loc_xian_yang","name":"咸阳","region":"秦国","one_line":"秦国都城，政治中心","source_refs":[{"chapter":145,"line_start":10,"line_end":10,"text":"到咸阳来参加田猎"}]}],"items":[]},"entity_updates":[]}
{"segment":2,"line_start":87,"line_end":170,"dialogues":[{"speaker":"char_tu_xian","speaker_name":"图先","listener":"char_xiang_shao_long","text":"太原郡发生民变，相国接到消息，立即赶入王宫见太后和储君。","tone":"陈述","chapter":145,"line_start":100,"line_end":102},{"speaker":"char_guan_zhong_xie","speaker_name":"管中邪","listener":"char_xiang_shao_long","text":"太原郡出事，储君、太后正和吕相等举行紧急会议。","tone":"陈述","chapter":145,"line_start":128,"line_end":130},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_guan_zhong_xie","text":"管大人要到哪里去？","tone":"疑问","chapter":145,"line_start":134,"line_end":134},{"speaker":"char_guan_zhong_xie","speaker_name":"管中邪","listener":"char_xiang_shao_long","text":"两位小姐要到西郊视察场地，下属陪她们去打个转，顺道探访昌文君他们。天气这么暖，出城走走亦是乐事。","tone":"陈述","chapter":145,"line_start":136,"line_end":138},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_guan_zhong_xie","text":"有美相伴，自然是乐事。","tone":"大笑","chapter":145,"line_start":140,"line_end":140},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"你见到嬴盈吗？","tone":"疑问","chapter":145,"line_start":148,"line_end":148},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"是否和管大人在一起？","tone":"疑问","chapter":145,"line_start":152,"line_end":152},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_chang_ping_jun","text":"听说是要到西郊视察田猎场的地势。","tone":"陈述","chapter":145,"line_start":154,"line_end":154},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"今早我给左相国徐大将军找去训话，要我管教妹子，不要和吕不韦的人这么亲近，今趟我是左右做人难，项大人能否救救我？","tone":"无奈","chapter":145,"line_start":156,"line_end":158},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_chang_ping_jun","text":"你该知管中邪是个对女人很有办法的人，本身条件又好，无论体魄、外貌、剑术、谈吐均无可挑剔，明刀明枪我亦未必胜得过他，何况现在贵妹子视我如大仇人，这事还是听天由命吧！","tone":"苦笑","chapter":145,"line_start":160,"line_end":161},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"怎能听天由命？我们这一辈的年轻将领，最佩服是徐先的眼光，他看的事绝错不了，若嬴盈嫁了给管中邪，将来受到株连怎办才好？吕不韦现在的地位还及不上以前的商鞅君，他不是也要在闹市中受车裂之刑吗？外人在我大秦没多少个有好收场的，官愈大，死得愈惨。","tone":"激动","chapter":145,"line_start":164,"line_end":170}],"new_entities":{"characters":[{"id":"char_tu_xian","name":"图先","alias":[],"identity":"相府管事","faction":"秦国","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"吕不韦相府管事，暗中与项少龙有秘密联络","personality":{"traits":["机敏","忠诚","谨慎","有情报意识","办事利落"],"speech_style":"简洁明了","temperament":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":40,"bond_level":2,"dynamic":"秘密联络"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":100,"line_end":100,"text":"接见他的是图先"}]},{"id":"char_guan_zhong_xie","name":"管中邪","alias":["管大人"],"identity":"吕不韦麾下将领","faction":"秦国","role":"villain","archetype":"warrior","rank":"登堂入室","one_line":"吕不韦麾下年轻将领，剑术高超，善于应付女人，与项少龙争夺嬴盈","personality":{"traits":["潇洒从容","剑术高超","善于交际","自信","有城府"],"speech_style":"从容得体","temperament":"自信沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"对手","intensity":60,"bond_level":2,"dynamic":"竞争"},{"target":"char_ying_ying","type":"恋人","intensity":50,"bond_level":2,"dynamic":"追求中"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":126,"line_end":126,"text":"管中邪自不能学她们的态度"}]},{"id":"char_chang_ping_jun","name":"昌平君","alias":[],"identity":"秦国年轻将领","faction":"秦国","role":"companion","archetype":"warrior","rank":"略有小成","one_line":"秦国年轻将领，嬴盈之兄，性格稳重多智，与项少龙交好","personality":{"traits":["稳重","多智","关心妹妹","直率","有远见"],"speech_style":"直率诚恳","temperament":"稳重"},"relationships":[{"target":"char_xiang_shao_long","type":"挚友","intensity":60,"bond_level":3,"dynamic":"好友"},{"target":"char_ying_ying","type":"亲属","intensity":70,"bond_level":4,"dynamic":"兄妹"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":148,"line_end":148,"text":"昌平君把项少龙拉到一角"}]},{"id":"char_ying_ying","name":"嬴盈","alias":[],"identity":"秦国贵族少女","faction":"秦国","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"昌平君之妹，腿长腰细，容貌出众，与项少龙有误会，视其如仇人","personality":{"traits":["活泼倔强","好胜","外冷内热","任性","爱面子"],"speech_style":"刁蛮任性","temperament":"活泼"},"relationships":[{"target":"char_chang_ping_jun","type":"亲属","intensity":70,"bond_level":4,"dynamic":"兄妹"},{"target":"char_xiang_shao_long","type":"对手","intensity":50,"bond_level":2,"dynamic":"误会敌视"},{"target":"char_guan_zhong_xie","type":"恋人","intensity":50,"bond_level":2,"dynamic":"交往中"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":118,"line_end":118,"text":"嬴盈和鹿丹儿两女"}]},{"id":"char_lu_dan_er","name":"鹿丹儿","alias":[],"identity":"秦国贵族少女","faction":"秦国","role":"npc","archetype":"warrior","rank":"平平无奇","one_line":"嬴盈的闺蜜，活泼少女，与嬴盈形影不离","personality":{"traits":["活泼","好动","仗义","爱热闹","直率"],"speech_style":"活泼直率","temperament":"活泼"},"relationships":[{"target":"char_ying_ying","type":"挚友","intensity":60,"bond_level":3,"dynamic":"闺蜜"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":118,"line_end":118,"text":"鹿丹儿两女"}]},{"id":"char_xu_xian","name":"徐先","alias":["徐大将军","左相国"],"identity":"秦国左相国兼大将军","faction":"秦国","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"秦国左相国兼大将军，眼光独到，警告昌平君管教嬴盈","personality":{"traits":["眼光独到","直言不讳","有威望","果断","忠诚"],"speech_style":"严肃直接","temperament":"刚正"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":156,"line_end":156,"text":"左相国徐大将军"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_xiang_fu","name":"相府","region":"咸阳","one_line":"吕不韦的丞相府，项少龙来此探听消息","source_refs":[{"chapter":145,"line_start":100,"line_end":100,"text":"项少龙来到相府"}]},{"id":"loc_wang_gong","name":"王宫","region":"咸阳","one_line":"秦国王宫，举行紧急会议之地","source_refs":[{"chapter":145,"line_start":146,"line_end":146,"text":"抵达王宫时"}]}],"items":[]},"entity_updates":[{"id":"char_xiang_shao_long","updates":{"source_refs":[{"chapter":145,"line_start":100,"line_end":100,"text":"项少龙来到相府"}]},"relationship_updates":[{"action":"add","target":"char_tu_xian","type":"合作者","intensity":40,"bond_level":2,"dynamic":"秘密联络"},{"action":"add","target":"char_guan_zhong_xie","type":"对手","intensity":60,"bond_level":2,"dynamic":"竞争"},{"action":"add","target":"char_chang_ping_jun","type":"挚友","intensity":60,"bond_level":3,"dynamic":"好友"}]}]}
{"segment":3,"line_start":171,"line_end":258,"dialogues":[{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"像你说得那么简单就好，假若吕不韦为管中邪来说亲，甚或出动太后，我们两个小卒儿可以说不吗？","tone":"愤怒","chapter":145,"line_start":188,"line_end":190},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_chang_ping_jun","text":"你说这么多话，都是想我去追求令妹罢了！何不试试先行巧妙及婉转地警告管中邪，鹿公已这么做了。","tone":"无奈","chapter":145,"line_start":192,"line_end":196},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"鹿公可倚老卖老，不讲道理，四十年后我或者可学他那一套，现在却是十万个行不通。嘿！难道你对我妹子没有半点意思吗？在咸阳，寡妇清外就轮到她了，当然，还有我们尚未得一见的纪才女。","tone":"苦笑","chapter":145,"line_start":198,"line_end":202},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_chang_ping_jun","text":"你倒懂得算账。","tone":"调侃","chapter":145,"line_start":204,"line_end":204},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"不要顾左右而言他，怎么样？","tone":"焦急","chapter":145,"line_start":206,"line_end":207},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"少龙你长得非常粗壮。","tone":"陈述","chapter":145,"line_start":208,"line_end":208},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_chang_ping_jun","text":"我试试看！却不敢担保会成功。","tone":"无奈","chapter":145,"line_start":210,"line_end":212},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"少龙该知发生什么事，现经商议后，决定由蒙骜率兵到太原郡平定民变。王龁则另领大军，陈兵东疆，一方面向三川、上党两郡的人示威，亦可警告三晋的人不可妄动。","tone":"沉声","chapter":145,"line_start":218,"line_end":222},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"这事来得真巧，仓促间驻在咸阳的大军都给抽空，又碰上田猎大典，少龙你有什么想法？","tone":"疑问","chapter":145,"line_start":224,"line_end":226},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lv_bu_wei","text":"高陵君想谋反！","tone":"淡然","chapter":145,"line_start":228,"line_end":228},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"什么？","tone":"惊讶","chapter":145,"line_start":230,"line_end":230},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"高陵君凭什么策反太原郡的乱民呢？","tone":"疑问","chapter":145,"line_start":234,"line_end":235},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lv_bu_wei","text":"高陵君当然没有这本领，但若勾结赵将庞煖，便可做到他能力以外的事。","tone":"陈述","chapter":145,"line_start":238,"line_end":239},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"难怪庞煖在大王葬礼后匆匆溜掉，原来有此一招。","tone":"惊讶","chapter":145,"line_start":242,"line_end":243},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_gao_ling_jun","text":"高陵君！我看你是活得不耐烦。","tone":"冷酷","chapter":145,"line_start":246,"line_end":247},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"他若要动手，必趁田猎的大好良机，这事就交给少龙去处置，若我猜得不错，高陵君的人将会趁今、明两天四周兵马调动的混乱形势，潜到咸阳附近来，高陵君身边的人亦不可不防，那可交给中邪去应付。","tone":"沉声","chapter":145,"line_start":248,"line_end":249},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"我要见太后和储君，少龙要不时向我报告，使我清楚局势的发展。","tone":"陈述","chapter":145,"line_start":254,"line_end":255},{"speaker":"char_chang_ping_jun","speaker_name":"昌平君","listener":"char_xiang_shao_long","text":"枉你还可以笑出来，都不知我多么烦恼。","tone":"无奈","chapter":145,"line_start":182,"line_end":182},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_chang_ping_jun","text":"只是听你说得有趣吧！说到婚嫁，总要你们两位兄长点头才能成事，管中邪胆子还没有那么大吧。","tone":"轻笑","chapter":145,"line_start":184,"line_end":186}],"new_entities":{"characters":[{"id":"char_lv_bu_wei","name":"吕不韦","alias":["吕相","相国"],"identity":"秦国丞相","faction":"秦国","role":"villain","archetype":"scholar","rank":"登堂入室","one_line":"秦国丞相，权倾朝野，老谋深算，与项少龙既是对手又暂时合作","personality":{"traits":["老谋深算","权欲熏心","果断狠辣","多疑","有政治手腕"],"speech_style":"沉稳威严，偶尔流露杀机","temperament":"阴沉果断"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":2,"dynamic":"暂时合作"},{"target":"char_gao_ling_jun","type":"宿敌","intensity":70,"bond_level":1,"dynamic":"敌对"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":218,"line_end":218,"text":"吕不韦"}]},{"id":"char_meng_ao","name":"蒙骜","alias":[],"identity":"秦国大将","faction":"秦国","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"秦国大将，奉命率兵前往太原郡平定民变","personality":{"traits":["骁勇善战","忠诚","有谋略","沉稳","经验丰富"],"speech_style":"简洁有力","temperament":"沉稳刚毅"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":214,"line_end":214,"text":"蒙骜"}]},{"id":"char_wang_he","name":"王龁","alias":[],"identity":"秦国大将","faction":"秦国","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"秦国大将，奉命领大军陈兵东疆威慑三晋","personality":{"traits":["善战","忠诚","有战略眼光","沉稳","果断"],"speech_style":"简洁","temperament":"沉稳"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":214,"line_end":214,"text":"王龁"}]},{"id":"char_chang_wen_jun","name":"昌文君","alias":[],"identity":"秦国年轻将领","faction":"秦国","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"昌平君之弟，性格胸无城府，比较爱闹事","personality":{"traits":["胸无城府","爱闹事","直率","活泼","豪爽"],"speech_style":"直率豪爽","temperament":"活泼"},"relationships":[{"target":"char_chang_ping_jun","type":"亲属","intensity":60,"bond_level":3,"dynamic":"兄弟"}],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":138,"line_end":138,"text":"昌文君他们"}]},{"id":"char_lu_gong","name":"鹿公","alias":[],"identity":"秦国老将","faction":"秦国","role":"npc","archetype":"warrior","rank":"炉火纯青","one_line":"秦国德高望重的老将，曾警告管中邪远离嬴盈","personality":{"traits":["德高望重","倚老卖老","直言不讳","有威望","护短"],"speech_style":"直接不讲理","temperament":"刚直"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[145],"source_refs":[{"chapter":145,"line_start":194,"line_end":194,"text":"鹿公已这么做了"}]}],"skills":[]