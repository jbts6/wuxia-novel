nt":"沉稳"},"relationships":[{"target":"char_wu_ting_fang","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父女情深"},{"target":"char_xiang_shao_long","type":"合作者","intensity":80,"bond_level":4,"dynamic":"翁婿同盟"},{"target":"char_lv_bu_wei","type":"合作者","intensity":60,"bond_level":3,"dynamic":"政治依附"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":34,"line_end":34,"text":"乌廷芳父女相见，既欢欣若狂，恍若隔世"},{"chapter":57,"line_start":150,"line_end":152,"text":"乌应元由衷地致谢道：'我们乌家能有此再生机会，全赖各位协力同心，不顾生死争取回来的。'"}]},{"id":"char_tao_fang","name":"陶方","alias":[],"identity":"乌家谋士","faction":"faction_wu_jia","role":"npc","archetype":"scholar","rank":"略有小成","one_line":"乌家谋士，精通秦国政局，为乌家在咸阳的生存出谋划策。","personality":{"traits":["精明干练","消息灵通","善于谋划","务实","忠诚"],"speech_style":"条理清晰","temperment":"沉稳"},"relationships":[{"target":"char_wu_ying_yuan","type":"主仆","intensity":70,"bond_level":4,"dynamic":"谋士辅佐"},{"target":"char_lv_bu_wei","type":"合作者","intensity":50,"bond_level":3,"dynamic":"政治依附"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":148,"line_end":148,"text":"与会的还有陶方、乌卓、滕翼和荆俊"},{"chapter":57,"line_start":154,"line_end":155,"text":"陶方道：'今天我们真的可安居乐业，王后和太子回到咸阳后，吕爷立即被封为右丞相'"}]},{"id":"char_xiao_yue_tan","name":"肖月潭","alias":[],"identity":"吕不韦门下食客","faction":"faction_lv_bu_wei_shi_li","role":"npc","archetype":"scholar","rank":"初窥门径","one_line":"吕不韦门下食客，在渡头迎接项少龙，向其介绍李斯。","personality":{"traits":["善于交际","观察敏锐","圆滑世故","好奇心重","热情"],"speech_style":"客气有礼","temperment":"热情"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":3,"dynamic":"初识"},{"target":"char_lv_bu_wei","type":"主仆","intensity":60,"bond_level":3,"dynamic":"门客效忠"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":36,"line_end":36,"text":"肖月潭和另一儒生状似军师型的青年，随图先欣然迎向项少龙"},{"chapter":57,"line_start":52,"line_end":53,"text":"肖月潭摆出老朋友的姿态，向项少龙介绍那青年道：'这位是楚国来的名士李斯先生'"}]},{"id":"char_tu_xian","name":"图先","alias":["图管家"],"identity":"吕不韦头号手下","faction":"faction_lv_bu_wei_shi_li","role":"npc","archetype":"warrior","rank":"登堂入室","one_line":"吕不韦的头号手下，体型瘦长结实，皮肤黝黑，双目有神，举止骠悍威猛，在渡头隆重迎接项少龙。","personality":{"traits":["热情豪爽","威猛慑人","精明干练","善于笼络","忠诚"],"speech_style":"热情豪迈","temperment":"豪爽"},"relationships":[{"target":"char_lv_bu_wei","type":"主仆","intensity":80,"bond_level":4,"dynamic":"首席幕僚"},{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":2,"dynamic":"初次见面"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":38,"line_end":38,"text":"他体型瘦长，年在三十岁许间，长得非常结实，皮肤黝黑，动作灵活，举止间有种骠悍威猛的慑人气势，双目有神，配上一副马脸，算不上英俊，却有股阳刚的男子气魄和魅力"},{"chapter":57,"line_start":40,"line_end":44,"text":"他大步上前，拉起项少龙双手，长笑道：'图先何幸！终于见到心仪久矣的超卓人物'"}]},{"id":"char_li_si","name":"李斯","alias":["李先生"],"identity":"楚国名士，吕不韦舍人","faction":"faction_lv_bu_wei_shi_li","role":"npc","archetype":"scholar","rank":"初窥门径","one_line":"楚国来的名士，吕不韦的舍人，少怀辅助名主一统天下大志，谦称只求一展所长。","personality":{"traits":["深藏不露","谦逊有礼","雄心壮志","谨慎低调","善于隐忍"],"speech_style":"谦恭低调","temperment":"内敛"},"relationships":[{"target":"char_lv_bu_wei","type":"主仆","intensity":50,"bond_level":3,"dynamic":"门客效忠"},{"target":"char_xiang_shao_long","type":"合作者","intensity":40,"bond_level":2,"dynamic":"初识仰慕"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":52,"line_end":53,"text":"这位是楚国来的名士李斯先生，现在是大老爷的舍人"},{"chapter":57,"line_start":58,"line_end":63,"text":"项少龙动容道：'原来是少怀辅助名主一统天下大志的李斯先生！'李斯浑身一震，垂头道：'项先生见笑了'"},{"chapter":57,"line_start":112,"line_end":112,"text":"李斯偷偷向项少龙表示明早想来探访"}]},{"id":"char_lv_bu_wei","name":"吕不韦","alias":["吕爷","吕相国"],"identity":"秦国右丞相","faction":"faction_lv_bu_wei_shi_li","role":"npc","archetype":"scholar","rank":"登堂入室","one_line":"秦国右丞相，原为富商，拥立庄襄王有功，权倾朝野，图先为其头号手下。","personality":{"traits":["精明狡诈","善于笼络","权谋深沉","野心勃勃","重利轻义"],"speech_style":"威严深沉","temperment":"深沉"},"relationships":[{"target":"char_tu_xian","type":"主仆","intensity":80,"bond_level":4,"dynamic":"首席幕僚"},{"target":"char_wu_ying_yuan","type":"合作者","intensity":60,"bond_level":3,"dynamic":"政治同盟"},{"target":"char_xiang_shao_long","type":"合作者","intensity":50,"bond_level":3,"dynamic":"笼络利用"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":74,"line_end":78,"text":"吕爷着鄙人定要清楚表达他对乌老爷子、应元少爷和少龙的感激"},{"chapter":57,"line_start":154,"line_end":155,"text":"吕爷立即被封为右丞相"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_wu_jia","name":"乌家","type":"家族","location":"咸阳","sub_divisions":[],"one_line":"原为赵国大商贾家族，乌氏倮殉死后举族迁往秦国咸阳，在吕不韦庇护下重振家业。","source_refs":[{"chapter":57,"line_start":32,"line_end":34,"text":"项少龙带着娇妻乌廷芳，领着滕翼、乌卓和过千家将叩关入秦"},{"chapter":57,"line_start":84,"line_end":86,"text":"只看乌家在咸阳以十二个三合院落组成的新宅，便知秦人对乌家隆重的礼遇"}]},{"id":"faction_lv_bu_wei_shi_li","name":"吕不韦势力","type":"帮派","location":"咸阳","sub_divisions":[],"one_line":"以吕不韦为首的外籍政团，拥有右丞相之位，与秦国本地权贵阳泉君一派对立。","source_refs":[{"chapter":57,"line_start":74,"line_end":78,"text":"吕爷着鄙人定要清楚表达他对乌老爷子、应元少爷和少龙的感激"},{"chapter":57,"line_start":154,"line_end":155,"text":"吕爷立即被封为右丞相"}]}],"locations":[{"id":"loc_xian_yang","name":"咸阳","region":"秦国","one_line":"秦国都城，位于九稷山之南、渭水之北，又名渭城，商鞅变法后成为天下霸主之都。","source_refs":[{"chapter":57,"line_start":24,"line_end":26,"text":"又把国都迁至咸阳，筑起宏伟的城阙和宫殿"},{"chapter":57,"line_start":30,"line_end":30,"text":"咸阳位于九稷山之南，渭水之北，故又名渭城"}]}],"items":[]},"entity_updates":[{"id":"char_lv_bu_wei","updates":{"one_line":"秦国右丞相，原为富商，拥立庄襄王有功，权倾朝野。","source_refs":[{"chapter":57,"line_start":154,"line_end":155,"text":"吕爷立即被封为右丞相"}]},"relationship_updates":[]},{"id":"char_xiang_shao_long","updates":{},"relationship_updates":[{"action":"add","target":"char_tu_xian","type":"合作者","intensity":50,"bond_level":2,"dynamic":"初次见面"},{"action":"add","target":"char_li_si","type":"合作者","intensity":40,"bond_level":2,"dynamic":"初识"}]}]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_tu_xian","speaker_name":"图先","listener":"char_xiang_shao_long","text":"吕爷着鄙人定要清楚表达他对乌老爷子、应元少爷和少龙的感激，若非姬王后和政太子能安返咸阳，恐怕会是另一回事。姬王后和政太子在大王和吕爷跟前对少龙推许备至，大王特地为少龙于明晚安排洗尘宴，好让少龙稍有休息的机会。以后大家就是自己人。","tone":"恳求","chapter":57,"line_start":74,"line_end":78},{"speaker":"char_wu_ting_fang","speaker_name":"乌廷芳","listener":"char_xiang_shao_long","text":"不若我们三人一起陪你吧！只怕你应付不来。","tone":"调侃","chapter":57,"line_start":130,"line_end":131},{"speaker":"char_zhao_qian","speaker_name":"赵倩","listener":"char_xiang_shao_long","text":"还有六个丫头呢！看你怎生应付？","tone":"调侃","chapter":57,"line_start":132,"line_end":133},{"speaker":"char_ting_fang_shi","speaker_name":"婷芳氏","listener":"char_xiang_shao_long","text":"忘了倩公主的翠桐和翠绿吗？","tone":"微笑","chapter":57,"line_start":136,"line_end":137},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_qian","text":"她们不是留在邯郸吗？","tone":"疑问","chapter":57,"line_start":138,"line_end":139},{"speaker":"char_zhao_qian","speaker_name":"赵倩","listener":"char_xiang_shao_long","text":"你忘了她们哩！幸好人家央求陶公派人把她们乘乱秘密接了出来，比你们还早十天到咸阳呢！","tone":"得意","chapter":57,"line_start":140,"line_end":141},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_qian","text":"还不唤她们来见我？","tone":"欣喜","chapter":57,"line_start":144,"line_end":145},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"我们乌家能有此再生机会，全赖各位协力同心，不顾生死争取回来的。","tone":"欣慰","chapter":57,"line_start":150,"line_end":152},{"speaker":"char_tao_fang","speaker_name":"陶方","listener":"char_wu_ying_yuan","text":"今天我们真的可安居乐业，王后和太子回到咸阳后，吕爷立即被封为右丞相，只要再立军功，便有望晋爵封侯，我们乌家得此大靠山，老爷在天之灵，都安乐了。","tone":"欣慰","chapter":57,"line_start":154,"line_end":155},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"这笔血账，吕相国必会为我们追讨回来，图管家私下对我说，相国已有全盘攻打赵国的计划，还希望由少龙执行。","tone":"愤怒","chapter":57,"line_start":160,"line_end":162},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_wu_ying_yuan","text":"秦王册封吕爷为丞相，难道秦国本地的权贵全无异议吗？","tone":"疑问","chapter":57,"line_start":172,"line_end":173},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"不但有异议，还反对得非常激烈。秦自卫人商鞅之后，排外的情绪相当强烈，后来为瓦解苏秦促成的'合纵'政策，免受东方六国的联攻，才勉强起用张仪，以'连横'对抗'合纵'。之后又再重用范雎，采取远交近攻的策略，应付六国联手之势，都可说是在逼不得已下，不能不借助外国的人才为己筹谋。","tone":"沉声","chapter":57,"line_start":174,"line_end":180},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"可是白起被昭襄王赐死后，秦国军方非常不满，终于逼得范雎丢官，仇外的情绪再次壮大起来。我们虽说有秦人血统，可是终被视为外人，属吕爷的系统，所以我们定要全心全力匡助吕爷，否则若他倒台，我们亦不会有好日子过。","tone":"无奈","chapter":57,"line_start":182,"line_end":184},{"speaker":"char_tao_fang","speaker_name":"陶方","listener":"char_xiang_shao_long","text":"现在吕爷的策略是要先立军功，因为秦人一向重武轻商，吕爷做生意赚钱的本事当然谁都不会有疑问，但在军事上，秦人却认为他一窍不通，所以他若能在这方面有所建树，地位即可稳若泰山，我们定要在这方面为他多做功夫。","tone":"陈述","chapter":57,"line_start":190,"line_end":192},{"speaker":"char_teng_yi","speaker_name":"滕翼","listener":"char_wu_ying_yuan","text":"秦人方面反对吕不韦的主要有什么人？","tone":"疑问","chapter":57,"line_start":194,"line_end":196},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_teng_yi","text":"最主要是以阳泉君为首的本地权贵，他们因姬王后曾是吕爷小妾，所以怀疑政太子非大王骨肉，于是抬了大王的次子成蟜出来，这批人是秦国实力派的人物，吕爷对他们非常忌惮，连大王都不敢过分违逆他们，所以虽任用吕爷为右丞相，左丞相仍只得起用阳泉君。","tone":"沉声","chapter":57,"line_start":196,"line_end":198}],"new_entities":{"characters":[{"id":"char_ting_fang_shi","name":"婷芳氏","alias":[],"identity":"项少龙的姬妾","faction":"faction_wu_jia","role":"companion","archetype":"healer","rank":"平平无奇","one_line":"项少龙的姬妾，因旅途劳顿和思念项少龙而病倒，原本冶艳化作清雅贵气的动人气质。","personality":{"traits":["深情款款","柔弱温婉","楚楚动人","痴情执着","敏感脆弱"],"speech_style":"柔声细语","temperment":"温柔"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":90,"bond_level":5,"dynamic":"深情依恋"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":120,"line_end":122,"text":"婷芳氏原来受不住旅途的艰困病倒，伊人清减不少，玉容苍白，病因却有一半是为挂念项少龙"},{"chapter":57,"line_start":236,"line_end":236,"text":"原本冶艳的风姿，化作姣丽中带着贵气的动人气质"}]},{"id":"char_chun_ying","name":"春盈","alias":[],"identity":"项少龙府中侍女","faction":"faction_wu_jia","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"项少龙府中四名贴身侍女之一，与众人欢天喜地迎接主人归来。","personality":{"traits":["活泼欢喜","忠诚体贴","善解人意","温顺","细心"],"speech_style":"轻快","temperment":"活泼"},"relationships":[{"target":"char_xiang_shao_long","type":"主仆","intensity":60,"bond_level":3,"dynamic":"侍奉主人"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":118,"line_end":118,"text":"春盈等四女拥着他与乌廷芳、赵倩到他新的隐龙居去"}]},{"id":"char_cui_tong","name":"翠桐","alias":[],"identity":"赵倩的贴身侍女","faction":"faction_wu_jia","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"赵倩的贴身侍女，被陶公派人从邯郸秘密接出，比主队早十天抵达咸阳。","personality":{"traits":["忠诚深情","感恩","柔顺","细心","温婉"],"speech_style":"轻声","temperment":"温柔"},"relationships":[{"target":"char_zhao_qian","type":"主仆","intensity":70,"bond_level":4,"dynamic":"贴身侍奉"},{"target":"char_xiang_shao_long","type":"主仆","intensity":50,"bond_level":3,"dynamic":"侍奉主人"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":146,"line_end":147,"text":"只见两个美丽的俏婢由内堂奔出，拜倒项少龙身前，忍不住痛哭起来"}]},{"id":"char_cui_lv","name":"翠绿","alias":[],"identity":"赵倩的贴身侍女","faction":"faction_wu_jia","role":"npc","archetype":"healer","rank":"平平无奇","one_line":"赵倩的贴身侍女，与翠桐一同被秘密从邯郸接出，抵达咸阳后与主人重逢痛哭。","personality":{"traits":["忠诚深情","感恩","柔顺","细心","温婉"],"speech_style":"轻声","temperment":"温柔"},"relationships":[{"target":"char_zhao_qian","type":"主仆","intensity":70,"bond_level":4,"dynamic":"贴身侍奉"},{"target":"char_xiang_shao_long","type":"主仆","intensity":50,"bond_level":3,"dynamic":"侍奉主人"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":146,"line_end":147,"text":"只见两个美丽的俏婢由内堂奔出，拜倒项少龙身前，忍不住痛哭起来"}]},{"id":"char_ji_wang_hou","name":"姬王后","alias":["朱姬"],"identity":"秦国太后","faction":"faction_qin_guo_wang_shi","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"庄襄王的王后，原为吕不韦小妾，在项少龙护送下安返咸阳，对项少龙推许备至。","personality":{"traits":["知恩图报","政治敏感","尊贵端庄","善于周旋","感恩"],"speech_style":"端庄","temperment":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"合作者","intensity":60,"bond_level":3,"dynamic":"感恩推许"},{"target":"char_lv_bu_wei","type":"合作者","intensity":50,"bond_level":3,"dynamic":"旧主新盟"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":74,"line_end":78,"text":"若非姬王后和政太子能安返咸阳，恐怕会是另一回事。姬王后和政太子在大王和吕爷跟前对少龙推许备至"}]},{"id":"char_yang_quan_jun","name":"阳泉君","alias":[],"identity":"秦国左丞相，昭襄王后之弟","faction":"faction_qin_guo_ben_tu_quan_gui","role":"villain","archetype":"scholar","rank":"略有小成","one_line":"秦国左丞相，昭襄王后之弟，本地权贵领袖，支持成蟜，与吕不韦势力对立。","personality":{"traits":["野心勃勃","居功自傲","不服外人","权欲熏心","老谋深算"],"speech_style":"威严","temperment":"深沉"},"relationships":[{"target":"char_lv_bu_wei","type":"宿敌","intensity":80,"bond_level":2,"dynamic":"权力对抗"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":196,"line_end":202,"text":"最主要是以阳泉君为首的本地权贵...阳泉君乃昭襄王王后之弟"}]},{"id":"char_wu_shi_luo","name":"乌氏倮","alias":["乌老爷子","老爷"],"identity":"乌家前任家主，已故","faction":"faction_wu_jia","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"乌家前任家主，壮烈自杀殉国，其牺牲令乌家上下悲痛不已，众人誓要追讨血债。","personality":{"traits":["刚烈不屈","忠义","宁死不屈","深明大义","壮烈"],"speech_style":"刚烈","temperment":"刚烈"},"relationships":[{"target":"char_wu_ying_yuan","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父子"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":150,"line_end":152,"text":"乌老爷子"},{"chapter":57,"line_start":158,"line_end":158,"text":"提起乌氏倮和随他一齐殉死的妻妾婢仆，众人均神色一黯"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_qin_guo_wang_shi","name":"秦国王室","type":"家族","location":"咸阳","sub_divisions":[],"one_line":"秦国嬴姓王室，庄襄王在位，吕不韦为右丞相，阳泉君为左丞相。","source_refs":[{"chapter":57,"line_start":74,"line_end":78,"text":"姬王后和政太子在大王和吕爷跟前对少龙推许备至"},{"chapter":57,"line_start":196,"line_end":198,"text":"虽任用吕爷为右丞相，左丞相仍只得起用阳泉君"}]},{"id":"faction_qin_guo_ben_tu_quan_gui","name":"秦国本土权贵","type":"帮派","location":"咸阳","sub_divisions":[],"one_line":"以阳泉君为首的秦国本地权贵集团，排外情绪强烈，与吕不韦外籍政团对立。","source_refs":[{"chapter":57,"line_start":196,"line_end":198,"text":"最主要是以阳泉君为首的本地权贵"},{"chapter":57,"line_start":182,"line_end":184,"text":"仇外的情绪再次壮大起来"}]}],"locations":[],"items":[]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":280,"dialogues":[{"speaker":"char_tao_fang","speaker_name":"陶方","listener":"char_teng_yi","text":"阳泉君乃昭襄王王后之弟，当年大王之所以能成为储君，他亦曾尽力游说乃姊，使她向昭襄王说项，所以一直以为自己功劳最大，现在竟然屈居吕爷之下，自然极不服气。","tone":"陈述","chapter":57,"line_start":200,"line_end":202},{"speaker":"char_teng_yi","speaker_name":"滕翼","listener":"char_xiang_shao_long","text":"少龙似乎对吕不韦没有多大好感，是吗？","tone":"疑问","chapter":57,"line_start":212,"line_end":214},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_teng_yi","text":"商人只重实利，这种人滕兄愿和他交朋友吗？","tone":"苦笑","chapter":57,"line_start":214,"line_end":216},{"speaker":"char_wu_zhuo","speaker_name":"乌卓","listener":"char_xiang_shao_long","text":"可是正如少爷所言，我们的命运已和他挂钩，若他坍台，我们亦完蛋。","tone":"担心","chapter":57,"line_start":216,"line_end":218},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_teng_yi","text":"这事随机应变吧！待吕不韦的权位稳定下来后，我们设法和他划清界限，否则定会给他累死。这是我的想法，切莫告诉任何人，连荆俊和陶方都不可泄露。","tone":"认真","chapter":57,"line_start":220,"line_end":225},{"speaker":"char_ting_fang_shi","speaker_name":"婷芳氏","listener":"char_xiang_shao_long","text":"夫君啊！妾身想得你很苦哩！","tone":"悲痛","chapter":57,"line_start":260,"line_end":262}],"new_entities":{"characters":[],"skills":[],"techniques":[],"factions":[],"locations":[],"items":[]},"entity_updates":[]}
