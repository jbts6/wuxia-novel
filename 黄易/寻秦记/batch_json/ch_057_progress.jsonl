"line_start":28,"line_end":33,"text":"当项少龙长途跋涉，由邯郸逃至咸阳，秦国正享受着商鞅翻天覆地的改革成果。项少龙带着娇妻乌廷芳，领着滕翼、乌卓和过千家将叩关入秦"},{"chapter":57,"line_start":46,"line_end":46,"text":"项少龙有点不知如何应付这种热情"}]},{"id":"char_wu_ting_fang","name":"乌廷芳","alias":[],"identity":"乌应元之女，项少龙之妻","faction":"faction_wu_jia","role":"companion","archetype":"warrior","rank":"略有小成","one_line":"乌家大小姐，项少龙的妻子，活泼开朗，与父亲在咸阳重逢。","personality":{"traits":["活泼开朗","热情大方","直言不讳","善解人意","重亲情"],"speech_style":"爽朗直接","temperment":"热情"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":90,"bond_level":5,"dynamic":"夫妻恩爱"},{"target":"char_wu_ying_yuan","type":"亲属","intensity":90,"bond_level":5,"dynamic":"父女情深"},{"target":"char_zhao_qian","type":"挚友","intensity":70,"bond_level":4,"dynamic":"姐妹情谊"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":34,"line_end":34,"text":"乌廷芳父女相见，既欢欣若狂，恍若隔世"},{"chapter":57,"line_start":130,"line_end":131,"text":"乌廷芳笑道：'不若我们三人一起陪你吧！只怕你应付不来。'"}]},{"id":"char_teng_yi","name":"滕翼","alias":["滕兄"],"identity":"项少龙的结义兄弟","faction":"faction_wu_jia","role":"companion","archetype":"warrior","rank":"登堂入室","one_line":"项少龙的忠实战友，沉稳可靠，以项少龙马首是瞻。","personality":{"traits":["沉稳可靠","忠诚不二","观察敏锐","寡言少语","勇猛善战"],"speech_style":"低沉稳重","temperment":"沉稳"},"relationships":[{"target":"char_xiang_shao_long","type":"挚友","intensity":85,"bond_level":5,"dynamic":"生死之交"},{"target":"char_wu_zhuo","type":"挚友","intensity":75,"bond_level":4,"dynamic":"并肩作战"}],"known_skills":[],"related_skills":[],"rag_refs":[57],"source_refs":[{"chapter":57,"line_start":32,"line_end":32,"text":"领着滕翼、乌卓和过千家将叩关入秦"},{"chapter":57,"line_start":188,"line_end":188,"text":"滕翼等人均默然不语，他们三人以项少龙马首是瞻"}]},{"id":"char_wu_zhuo","name":"乌卓","alias":[],"identity":"乌家家将，乌廷芳的族兄","faction":"faction_wu_jia","role":"companion","archetype":"warrior","rank":"略有小成","one_line":"乌家核心成员，项少龙的忠实追随者，以项少龙马首是瞻。","personality":{"traits":["忠诚可靠","务实谨慎","关心家族命运","坦率直言","沉稳"],"speech_style":"直率","temperment":"务实"},"relations