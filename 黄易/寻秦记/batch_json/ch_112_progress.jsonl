pter":112,"line_start":270,"line_end":270,"text":"葬在牧场隐龙别院附近"}]},{"id":"loc_bai_yue_feng","name":"拜月峰","region":"乌家牧场","one_line":"乌家牧场附近最高峰，突兀峥嵘","source_refs":[{"chapter":112,"line_start":318,"line_end":318,"text":"耸出云表的拜月峰，亦为此地的最高山峰"}]}],"items":[{"id":"item_he_shou_wu","name":"何首乌","type":"pill","owner":"char_xiang_shao_long","one_line":"王翦由北疆送来的上等何首乌","description":"上等何首乌，由王翦遣人从北疆送来，用于浸酒补身，是珍贵的滋补药材","effects":[{"type":"增益","description":"补身养气"}],"origin":"北疆","rarity":"上乘佳品","related_characters":["char_wang_jian","char_xiang_shao_long"],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":372,"line_end":372,"text":"四哥遣人由北疆送来一批上等的何首乌"}]}]},"entity_updates":[]}
{"segment":4,"line_start":301,"line_end":384,"dialogues":[{"speaker":"char_ji_yan_ran","speaker_name":"纪嫣然","listener":"char_xiang_shao_long","text":"有邯郸来的消息，少龙有兴趣听吗？","tone":"疑问","chapter":112,"line_start":304,"line_end":304},{"speaker":"char_ji_yan_ran","speaker_name":"纪嫣然","listener":"char_xiang_shao_long","text":"你走后，邯郸乱成一团，田单和李园均知阴谋败露，连夜匆匆逃返齐、楚。孝成王以为你们全体壮烈牺牲，非常悲痛惋惜，祭祀你的亡魂时晕倒当场，现在仍抱病不起，朝政由晶王后和郭开把持。","tone":"陈述","chapter":112,"line_start":308,"line_end":312},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_ji_yan_ran","text":"我想登上拜月峰看看，倩儿你行吗？","tone":"疑问","chapter":112,"line_start":320,"line_end":320},{"speaker":"char_zhao_qian","speaker_name":"赵倩","listener":"char_xiang_shao_long","text":"倩儿每天都和廷芳练习骑射，操练得不知多么好哩！怎会有问题呢？","tone":"欣喜","chapter":112,"line_start":324,"line_end":326},{"speaker":"char_wu_ting_fang","speaker_name":"乌廷芳","listener":"char_xiang_shao_long","text":"芳儿去找人牵马来，好省去点脚力。","tone":"欣喜","chapter":112,"line_start":328,"line_end":330},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_ji_yan_ran","text":"旦楚死了没有？","tone":"疑问","chapter":112,"line_start":340,"line_end":340},{"speaker":"char_ji_yan_ran","speaker_name":"纪嫣然","listener":"char_xiang_shao_long","text":"率兵入城的并不是他，所以执回了一条小命。听说晶王后对你的'死'非常哀痛，连续三天不肯吃东西呢！","tone":"调侃","chapter":112,"line_start":344,"line_end":348},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_ji_yan_ran","text":"有雅儿和致致的消息吗？","tone":"疑问","chapter":112,"line_start":350,"line_end":350},{"speaker":"char_ji_yan_ran","speaker_name":"纪嫣然","listener":"char_xiang_shao_long","text":"尚未有消息，但滕二哥派了人到大梁联络她们，假若我们第一站是魏国，很快可以公然与她们会面。","tone":"陈述","chapter":112,"line_start":354,"line_end":354},{"speaker":"char_ji_yan_ran","speaker_name":"纪嫣然","listener":"char_xiang_shao_long","text":"吕相遣人来请嫣然和干爹到相府小住，嫣然要陪你，当然不肯去，只好干爹一人去了。","tone":"陈述","chapter":112,"line_start":360,"line_end":362},{"speaker":"char_zhao_qian","speaker_name":"赵倩","listener":"char_xiang_shao_long","text":"最活跃是小俊，回来不久便领刘巢和蒲布他们到城里胡混，真怕他惹事生非呢！","tone":"担心","chapter":112,"line_start":364,"line_end":364},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_qian","text":"就算他们不去惹人，也会有人来惹我们，怎都避不了。","tone":"苦笑","chapter":112,"line_start":368,"line_end":370},{"speaker":"char_wu_ting_fang","speaker_name":"乌廷芳","listener":"char_xiang_shao_long","text":"四哥遣人由北疆送来一批上等的何首乌，说要给项郎浸酒补身，听爹说他最近大败匈奴，战绩彪炳哩！","tone":"欣喜","chapter":112,"line_start":372,"line_end":374}],"new_entities":{"characters":[{"id":"char_tian_dan","name":"田单","alias":[],"identity":"齐国权臣","faction":"faction_qi","role":"villain","archetype":"scholar","rank":"略有小成","one_line":"齐国权臣，阴谋败露后逃回齐国","personality":{"traits":["狡猾","野心勃勃","善谋略","残忍","贪婪"],"speech_style":"阴险","temperament":"阴沉"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":308,"line_end":308,"text":"田单和李园均知阴谋败露"}]},{"id":"char_li_yuan","name":"李园","alias":[],"identity":"楚国权臣","faction":"faction_chu","role":"villain","archetype":"scholar","rank":"略有小成","one_line":"楚国权臣，阴谋败露后逃回楚国","personality":{"traits":["狡猾","善谋略","阴险","贪婪","野心勃勃"],"speech_style":"阴险","temperament":"阴沉"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":308,"line_end":308,"text":"田单和李园均知阴谋败露"}]}],"skills":[],"techniques":[],"factions":[],"locations":[{"id":"loc_wu_jia_mu_chang","name":"乌家牧场","region":"秦国","one_line":"项少龙的家宅所在，风景如画的牧场","source_refs":[{"chapter":112,"line_start":334,"line_end":334,"text":"只见乌家牧场尽收眼底"}]},{"id":"loc_yin_long_bie_yuan","name":"隐龙别院","region":"乌家牧场","one_line":"乌家牧场内的别院，婷芳氏葬于此地附近","source_refs":[{"chapter":112,"line_start":270,"line_end":270,"text":"葬在牧场隐龙别院附近"}]},{"id":"loc_bai_yue_feng","name":"拜月峰","region":"乌家牧场","one_line":"乌家牧场附近最高峰，突兀峥嵘","source_refs":[{"chapter":112,"line_start":318,"line_end":318,"text":"耸出云表的拜月峰，亦为此地的最高山峰"}]}],"items":[]},"entity_updates":[]}
