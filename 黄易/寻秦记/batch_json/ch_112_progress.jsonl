l","owner":null,"one_line":"捆绑赵穆的刑具","description":"粗重铁链，用于束缚囚犯手脚，防止逃脱，赵穆被押解时所用","effects":[],"origin":"秦宫","rarity":"寻常凡品","related_characters":["char_zhao_mu"],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":100,"line_end":100,"text":"脚系铁链"}]},{"id":"item_jia_mian_ju","name":"假面具","type":"special","owner":"char_lv_bu_wei","one_line":"吕不韦为赵国行动特制的伪装面具","description":"共四块，由吕不韦命人特制，用于项少龙等人在赵国行动时伪装身份，避免被识破","effects":[],"origin":"秦国","rarity":"上乘佳品","related_characters":["char_lv_bu_wei","char_xiang_shao_long"],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":140,"line_end":142,"text":"使人为我们造了四块假面具"}]}]},"entity_updates":[]}
{"segment":2,"line_start":101,"line_end":200,"dialogues":[{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_zhao_mu","text":"赵侯别来无恙！","tone":"嘲讽","chapter":112,"line_start":102,"line_end":102},{"speaker":"char_zhu_ji","speaker_name":"朱姬","listener":"char_zhao_mu","text":"侯爷清减哩！","tone":"嘲讽","chapter":112,"line_start":110,"line_end":110},{"speaker":"char_zhao_mu","speaker_name":"赵穆","listener":"char_zhu_ji","text":"你这贱……","tone":"愤怒","chapter":112,"line_start":112,"line_end":112},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhao_mu","text":"竟敢辱骂王后，哼！","tone":"厉声","chapter":112,"line_start":116,"line_end":116},{"speaker":"char_zhu_ji","speaker_name":"朱姬","listener":"char_zhuang_xiang_wang","text":"大王！哀家要亲自处理这个奸贼。","tone":"恳求","chapter":112,"line_start":120,"line_end":122},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_zhu_ji","text":"就如王后所请。给我把这奸贼押下去，等待王后处置。","tone":"陈述","chapter":112,"line_start":124,"line_end":126},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_lv_bu_wei","text":"太傅先送回乐乘首级，又擒来赵穆，大大泄了寡人郁在胸口的怨气，吕相国认为寡人该怎么奖赏他呢？","tone":"欣喜","chapter":112,"line_start":136,"line_end":138},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_zhuang_xiang_wang","text":"今趟之能出师告捷，全赖吕相国奇谋妙算，使人为我们造了四块假面具，才能马到功成。吕相国方是真正立大功的人，少龙只是依命行事吧！","tone":"陈述","chapter":112,"line_start":140,"line_end":142},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_zhuang_xiang_wang","text":"大王！我大秦得少龙如此人才，实乃大王之福，不过乐乘、赵穆之事仍须保密，故不宜在此时重赏少龙，还要装模作样，责他办事不力，好掩人耳目，请大王明鉴。","tone":"得意","chapter":112,"line_start":144,"line_end":148},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_lv_bu_wei","text":"寡人虽明知事须如此，可是见到少龙，心中只有欢喜之情，怎忍责他呢？","tone":"无奈","chapter":112,"line_start":150,"line_end":152},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_zhuang_xiang_wang","text":"这事由老臣去办，大王毋须劳神。","tone":"微笑","chapter":112,"line_start":154,"line_end":154},{"speaker":"char_zhu_ji","speaker_name":"朱姬","listener":"char_xiang_shao_long","text":"项太傅回来，最高兴的是王儿，别人教他剑术、兵法，他都不屑学习，说要由项太傅指导才行呢！","tone":"欣慰","chapter":112,"line_start":158,"line_end":160},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_zhu_ji","text":"政太子恐怕要失望，项太傅稍作休息后，立即要出使六国了。","tone":"陈述","chapter":112,"line_start":164,"line_end":166},{"speaker":"char_zhuang_xiang_wang","speaker_name":"庄襄王","listener":"char_xiang_shao_long","text":"寡人也舍不得少龙，不过相国说得对，若要亡周，必须军事、外交双管齐下，才不致惹出祸事。","tone":"无奈","chapter":112,"line_start":170,"line_end":172},{"speaker":"char_zhu_ji","speaker_name":"朱姬","listener":"char_lv_bu_wei","text":"大王和相国忍心让项太傅马不停蹄地奔波劳碌吗？累坏了怎办哩？","tone":"担心","chapter":112,"line_start":174,"line_end":176},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_zhu_ji","text":"王后放心，出使的事，必须配合出兵的日期，太傅至少有一个月的时间可好好休息。","tone":"微笑","chapter":112,"line_start":178,"line_end":180},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lv_bu_wei","text":"我大秦人才济济，微臣在这方面既缺乏经验，兼之与魏、赵势成水火，可能……","tone":"疑问","chapter":112,"line_start":182,"line_end":182},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"经验是培养出来的，少龙文武兼资，足可胜任有余。至于以前的嫌隙，更属小事，少龙有我大秦在后面撑腰，谁敢不敬。现在六国给少龙巧施妙计，破坏合纵之议，正是人人自危，惟恐我们拿他们开刀，巴结都来不及哩！此事就此作实，少龙莫要谦辞了。","tone":"豪迈","chapter":112,"line_start":184,"line_end":190}],"new_entities":{"characters":[{"id":"char_le_cheng","name":"乐乘","alias":[],"identity":"赵国将领","faction":"faction_zhao","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"赵国将领，被项少龙斩杀，首级送回秦国","personality":{"traits":["勇猛","忠诚","刚烈","鲁莽","直率"],"speech_style":"武将","temperament":"刚烈"},"relationships":[{"target":"char_zhao_mu","type":"合作者","intensity":40,"bond_level":2,"dynamic":"同僚"}],"known_skills":[],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":136,"line_end":136,"text":"太傅先送回乐乘首级"}]},{"id":"char_jing_wang_hou","name":"晶王后","alias":[],"identity":"赵国王后","faction":"faction_zhao","role":"npc","archetype":"scholar","rank":"平平无奇","one_line":"赵国王后，把持朝政，对项少龙之死曾非常哀痛","personality":{"traits":["精明","有手腕","多情","善变","隐忍"],"speech_style":"威严","temperament":"深沉"},"relationships":[{"target":"char_guo_kai","type":"合作者","intensity":50,"bond_level":3,"dynamic":"共掌朝政"}],"known_skills":[],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":310,"line_end":310,"text":"朝政由晶王后和郭开把持"}]},{"id":"char_guo_kai","name":"郭开","alias":[],"identity":"赵国奸臣","faction":"faction_zhao","role":"villain","archetype":"scholar","rank":"平平无奇","one_line":"赵国奸臣，把持朝政，不能容物","personality":{"traits":["奸诈","不能容物","贪婪","阴险","嫉贤妒能"],"speech_style":"阴险","temperament":"阴沉"},"relationships":[{"target":"char_jing_wang_hou","type":"合作者","intensity":50,"bond_level":3,"dynamic":"共掌朝政"}],"known_skills":[],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":310,"line_end":310,"text":"朝政由晶王后和郭开把持"}]},{"id":"char_dan_chu","name":"旦楚","alias":[],"identity":"齐国将领","faction":"faction_qi","role":"npc","archetype":"warrior","rank":"略有小成","one_line":"齐国将领，率兵入城，侥幸逃脱","personality":{"traits":["勇猛","机敏","谨慎","果断","善战"],"speech_style":"武将","temperament":"刚烈"},"relationships":[],"known_skills":[],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":344,"line_end":344,"text":"率兵入城的并不是他，所以执回了一条小命"}]}],"skills":[],"techniques":[],"factions":[{"id":"faction_qi","name":"齐","type":"武林门派","location":null,"sub_divisions":[],"one_line":"战国七雄之一","source_refs":[{"chapter":112,"line_start":308,"line_end":308,"text":"连夜匆匆逃返齐、楚"}]},{"id":"faction_chu","name":"楚","type":"武林门派","location":null,"sub_divisions":[],"one_line":"战国七雄之一","source_refs":[{"chapter":112,"line_start":308,"line_end":308,"text":"连夜匆匆逃返齐、楚"}]},{"id":"faction_wei","name":"魏","type":"武林门派","location":"loc_da_liang","sub_divisions":[],"one_line":"战国七雄之一","source_refs":[{"chapter":112,"line_start":182,"line_end":182,"text":"与魏、赵势成水火"}]},{"id":"faction_yan","name":"燕","type":"武林门派","location":null,"sub_divisions":[],"one_line":"战国七雄之一","source_refs":[{"chapter":112,"line_start":222,"line_end":222,"text":"孤立燕人"}]}],"locations":[{"id":"loc_da_liang","name":"大梁","region":"魏国","one_line":"魏国都城","source_refs":[{"chapter":112,"line_start":354,"line_end":354,"text":"滕二哥派了人到大梁联络她们"}]}],"items":[{"id":"item_le_cheng_shou_ji","name":"乐乘首级","type":"special","owner":null,"one_line":"赵国将领乐乘的首级，被项少龙带回秦国","description":"赵国将领乐乘的首级，项少龙在赵国行动时斩杀后带回，作为向秦王的献礼，大大振奋秦廷士气","effects":[],"origin":"赵国","rarity":"寻常凡品","related_characters":["char_le_cheng","char_xiang_shao_long"],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":136,"line_end":136,"text":"太傅先送回乐乘首级"}]}]},"entity_updates":[]}
{"segment":3,"line_start":201,"line_end":300,"dialogues":[{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"少龙，不要怪我使你东奔西跑，马不停蹄。我实是一番苦心，希望能把你培植为我最得力的助手。六国均有与我互通声气的人，现既定下由你出使，我会先派人前往打点，为你铺好前路。","tone":"认真","chapter":112,"line_start":200,"line_end":206},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_lv_bu_wei","text":"相国厚爱，我项少龙纵使肝脑涂地，都报答不来。","tone":"陈述","chapter":112,"line_start":208,"line_end":210},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"现在对我来说，最紧要是争取时间，先安内，后攘外。只要有一天我在这里站稳阵脚，便可开展大业。今天少龙的出使非常重要，务使六国间加深成见，难以联手来动摇我们。天下人人贪好财货，无有例外，只要我们不惜财物，贿赂列国大臣，定可破坏他们本国的计谋。少龙明白我的意思吗？","tone":"严肃","chapter":112,"line_start":212,"line_end":218},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"对六国的策略亦各有不同，基本上是包围三晋，联结齐、楚，孤立燕人。只要三晋沦亡，其他三国不攻自破，天下便可达致大一统的局面，结束数百年来群龙无首的僵局。","tone":"豪迈","chapter":112,"line_start":222,"line_end":226},{"speaker":"char_lv_bu_wei","speaker_name":"吕不韦","listener":"char_xiang_shao_long","text":"我不陪你入府了，好好休息，明晚到相府来，让我们喝酒作乐，祝贺你今天大胜而回。","tone":"微笑","chapter":112,"line_start":236,"line_end":238},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_wu_ting_fang","text":"婷芳氏呢？","tone":"疑问","chapter":112,"line_start":244,"line_end":244},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"少龙最重要的是放宽怀抱，婷芳氏三天前病死了，唉！她竟等不到你回来。","tone":"悲伤","chapter":112,"line_start":250,"line_end":252},{"speaker":"char_wu_ying_yuan","speaker_name":"乌应元","listener":"char_xiang_shao_long","text":"自你离去，她郁郁不欢，终日苦思着你，兼之一向身体不好，没有一个月便病倒，从此时好时坏……","tone":"无奈","chapter":112,"line_start":256,"line_end":256},{"speaker":"char_teng_yi","speaker_name":"滕翼","listener":"char_xiang_shao_long","text":"不要太过悲痛，会伤身体的。","tone":"沉声","chapter":112,"line_start":266,"line_end":268},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_teng_yi","text":"我想把她葬在牧场隐龙别院附近，她最欢喜那里，同时为赵妮、舒儿和素女她们立冢……","tone":"悲伤","chapter":112,"line_start":270,"line_end":270},{"speaker":"char_ji_yan_ran","speaker_name":"纪嫣然","listener":"char_xiang_shao_long","text":"少龙！不要这么伤心，好吗？","tone":"温柔","chapter":112,"line_start":284,"line_end":284},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_ji_yan_ran","text":"黯然销魂者，惟别而已矣！生有生离，死有死别，为何人生总有这么多不如意的事，是否我的杀孽太重？","tone":"悲痛","chapter":112,"line_start":286,"line_end":290},{"speaker":"char_wu_ting_fang","speaker_name":"乌廷芳","listener":"char_xiang_shao_long","text":"项郎！不要说这些话好吗？廷芳害怕听哩！","tone":"恐惧","chapter":112,"line_start":292,"line_end":292},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_ji_yan_ran","text":"吕相国要我出使六国，推行他的外交政策……","tone":"无奈","chapter":112,"line_start":294,"line_end":294},{"speaker":"char_xiang_shao_long","speaker_name":"项少龙","listener":"char_wu_ting_fang","text":"不要担心，我怎也要把你们带在身旁，永不分离。","tone":"认真","chapter":112,"line_start":298,"line_end":300}],"new_entities":{"characters":[{"id":"char_wu_ting_fang","name":"乌廷芳","alias":["芳儿","廷芳"],"identity":"项少龙妻子","faction":null,"role":"companion","archetype":"warrior","rank":"初窥门径","one_line":"项少龙的妻子之一，活泼开朗，深爱项少龙","personality":{"traits":["活泼","深情","温柔","勇敢","善骑射"],"speech_style":"娇柔","temperament":"温柔"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":90,"bond_level":5,"dynamic":"夫妻"},{"target":"char_wu_ying_yuan","type":"亲属","intensity":80,"bond_level":5,"dynamic":"父女"}],"known_skills":[],"related_skills":[],"rag_refs":[112],"source_refs":[{"chapter":112,"line_start":242,"line_end":242,"text":"乌廷芳和赵倩两女哭着奔出府门"}]},{"id":"char_zhao_qian","name":"赵倩","alias":["倩儿","三公主"],"identity":"赵国三公主","faction":"faction_zhao","role":"companion","archetype":"scholar","rank":"初窥门径","one_line":"赵国三公主，项少龙的妻子之一，温柔贤淑","personality":{"traits":["温柔","贤淑","内敛","多愁善感","重情义"],"speech_style":"温柔","temperament":"温柔"},"relationships":[{"target":"char_xiang_shao_long","type":"恋人","intensity":85,"bond_level":5,"dynamic":"夫妻"},{"target":"cha